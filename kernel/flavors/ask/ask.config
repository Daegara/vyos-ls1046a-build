# ASK (Application Solutions Kit) kernel config fragment for Linux 6.6.x LTS
#
# This fragment is layered LAST on top of:
#   release/vyos-base/arm64/vyos_defconfig
#   release/vyos-base/*.config            (VyOS feature snippets)
#
# by apply-to-tree.sh's merge_config.sh chain. Because it is applied last,
# any value here wins over both the VyOS base and the arm64 defconfig.
#
# The purpose of this file is the LS1046A/DPAA delta:
#   - disable mainline DPAA/FMan (FSL_DPAA, FSL_FMAN, FSL_DPAA_ETH) so the
#     NXP SDK staging drivers can own the hardware instead,
#   - enable the NXP SDK DPAA/FMan/BMan/QMan stack from drivers/staging/
#     (CONFIG_FSL_SDK_DPA and friends) — these are the drivers the ASK
#     fast-path hooks into,
#   - disable ASK subsystems whose hooks are incomplete on 6.6.y and break
#     the build (CPE_FAST_PATH, IPSEC_OFFLOAD, QOSMARK xtables modules).
#
# IMPORTANT Kconfig constraint (from drivers/staging/fsl_qbman/Kconfig):
#     config FSL_SDK_DPA  depends on !FSL_DPAA
# The SDK and mainline DPAA stacks are mutually exclusive. We explicitly
# disable the mainline side below.
#
# FSL_SDK_DPA lives under drivers/staging/, so CONFIG_STAGING must be
# enabled. VyOS' vyos_defconfig leaves STAGING off by default, so we
# turn it back on here (it only enables the menu; no unwanted drivers
# are pulled in by default).

# --- Staging menu (required host for FSL_SDK_* symbols) ---
CONFIG_STAGING=y

# --- Disable mainline DPAA/FMan (mutually exclusive with SDK stack) ---
# Notes:
#   CONFIG_FSL_DPAA       — mainline QorIQ DPAA (disables FSL_SDK_DPA's
#                            `depends on !FSL_DPAA` gate)
#   CONFIG_FSL_FMAN       — mainline Frame Manager (SDK supplies its own)
#   CONFIG_FSL_DPAA_ETH   — mainline DPAA Ethernet (SDK supplies its own
#                            in drivers/net/ethernet/freescale/sdk_dpaa/)
# CONFIG_FSL_DPAA is not set
# CONFIG_FSL_FMAN is not set
# CONFIG_FSL_DPAA_ETH is not set

# --- NXP SDK DPAA/FMan/BMan/QMan (drivers/staging/fsl_*, replaces mainline) ---
CONFIG_FSL_SDK_DPA=y
CONFIG_FSL_SDK_BMAN=y
CONFIG_FSL_SDK_QMAN=y
CONFIG_FSL_SDK_FMAN=y
CONFIG_FSL_SDK_DPAA_ETH=y
CONFIG_FSL_DPAA_1588=y
CONFIG_FSL_DPAA_ETH_MAX_BUF_COUNT=640

# --- ASK Fast Path: REQUIRED for OOT modules (auto_bridge, fp_netfilter) ---
# CONFIG_CPE_FAST_PATH gates the in-kernel surface that ASK OOT modules
# plug into:
#   * register_brevent_notifier / unregister_brevent_notifier — auto_bridge
#     subscribes to bridge FDB events through this notifier chain.
#   * struct sk_buff::abm_ff field — auto_bridge tags packets it has
#     consumed so they aren't re-injected into the slow path.
#   * net/netfilter/comcerto_fp_netfilter.c — built-in netfilter hook
#     module that ARMS the fast path; without CONFIG_CPE_FAST_PATH=y
#     this never compiles and you see "[FAILED] fp_netfilter hooks
#     registered" + "[FAILED] auto_bridge.ko loaded" at boot.
#
# We tried disabling this once (ASK Boot pre-2026-04-25) — see git log
# for release/ask.config. The reasoning given was that "patch 004 hooks
# reference x->curr_time which is never added to struct xfrm_state".
# That is true, but those references are gated by CONFIG_INET_IPSEC_OFFLOAD,
# NOT by CONFIG_CPE_FAST_PATH. We can keep IPSEC_OFFLOAD off and still
# enable the bridge / fp_netfilter / abm_ff surface — they live in
# different translation units (net/bridge/br.c, net/core/skbuff.c,
# net/netfilter/comcerto_fp_netfilter.c) which compile cleanly.
CONFIG_CPE_FAST_PATH=y

# --- ASK IPsec Offload (still incomplete on 6.6.y — keep disabled) ---
# Patch 004 hooks reference x->curr_time which is never added to struct
# xfrm_state, so enabling INET_IPSEC_OFFLOAD breaks
# net/xfrm/xfrm_user.c (and net/key/af_key.c). The cdx OOT module instead
# #ifdef-guards its callers (devman.c) so it compiles cleanly without it.
# CONFIG_INET_IPSEC_OFFLOAD is not set
# CONFIG_INET6_IPSEC_OFFLOAD is not set

# --- ASK Netfilter QOS xtables (disabled — userspace tooling missing) ---
# These Xtables modules build cleanly once CONFIG_CPE_FAST_PATH=y (they
# reference skb->qosmark / nf_conn->qosconnmark which are gated by it),
# but the userspace iptables-extensions counterpart isn't currently
# packaged in vyos-ls1046a-build, so the kernel modules would have no
# user. Re-enable when the iptables QOSMARK extension lands.
# CONFIG_NETFILTER_XT_QOSMARK is not set
# CONFIG_NETFILTER_XT_QOSCONNMARK is not set

# --- Module versioning (required for out-of-tree ASK modules) ---
# Redundant with vyos_defconfig on arm64 (which already has it) but kept
# here as defence-in-depth — ASK iptables match/target modules link
# against kernel symbols by versioned hash.
CONFIG_MODVERSIONS=y

# --- LS1046A Mono hardware-specific drivers ---
# SFP: kernel-level SFP/SFP+ module management — required for the two 10G
# SFP+ cages on Mono to enumerate inserted modules, read their EEPROM,
# and toggle TX_DISABLE / read LOS via the I2C lines. Without this the
# phylink/phy layer cannot bind SFP+ modules at all.
#
# Promoted from =m to =y (ASK Boot #4, 2026-04-24): live-boot's initramfs
# calls `ipconfig` on every netdev to fetch the squashfs over HTTP. If
# SFP/PHYLINK/I2C_MUX are modules, udev in initramfs has to coldplug
# them in time or the ethernet-wait loop times out with
# "Waiting for ethernet card(s) up... maybe the ethernet card is not
# supported by the kernel 6.6.135-vyos?". Building them in guarantees
# the PHY/SFP layer is ready before fman probes MACs.
CONFIG_SFP=y
CONFIG_PHYLINK=y

# --- FMan/MAC MDIO + SFP I2C plumbing (ASK Boot #4, 2026-04-24) ---
# Without these the SDK FMan driver brings up the MACs but cannot find
# any PHY on the external MDIO bus, so every netdev stays NO-CARRIER and
# live-boot hangs in its ethernet-wait loop.
#
#   FSL_XGMAC_MDIO    — Freescale XGMAC MDIO controller (the MDIO bus
#                        inside FMan that the 1G SGMII + 10G XFI MACs
#                        use to reach external PHYs / SFP management
#                        interfaces). Upstream 6.6.135 Kconfig only
#                        `depends on OF` so no patch is needed.
#   FSL_PQ_MDIO       — PowerQUICC / QorIQ eTSEC-style MDIO; kept as a
#                        safety net for boards that expose the legacy
#                        MDIO controller aliases.
#   MDIO_I2C          — glue that lets phylink talk to SFP modules'
#                        management EEPROM/PHY over I2C (sff-8472).
#   I2C_MUX           — core I2C mux framework (promoted to =y so the
#                        PCA954x driver below can attach in initramfs).
#   I2C_MUX_PCA954x   — PCA9546/PCA9548 I2C mux used on LS1046A carriers
#                        to fan out a single I2C controller to both SFP
#                        cages + board sensors. Without it the SFP cages
#                        have no I2C path and phylink cannot bind their
#                        modules.
CONFIG_FSL_XGMAC_MDIO=y
CONFIG_FSL_PQ_MDIO=y
CONFIG_MDIO_I2C=y
CONFIG_I2C_MUX=y
CONFIG_I2C_MUX_PCA954x=y

# EMC2305: SMSC/Microchip EMC2305 PWM fan controller (I2C). Mono drives its
# chassis fans through this part. The mainline 6.6 driver (drivers/hwmon/
# emc2305.c) declares only an i2c_device_id table — it has NO of_match_table.
# Probe binding still works via the i2c-core "strip vendor prefix" fallback
# (microchip,emc2305 -> emc2305), but module auto-loading from the DT modalias
# fails: udev sees of:NTfan-controllerCT0microchip,emc2305 and emc2305.ko
# only exports i2c:emc2305, so the module is never inserted at boot. As a
# result fancontrol.service hard-fails (fancontrol-setup exits 1 when the
# emc2305 hwmon entry is missing) and the boot-complete-notify whistle
# cascades to failed via After=fancontrol.service.
# Compile in (=y) so the driver is bound at i2c probe time, before userspace,
# without depending on udev modalias resolution. Follow-up: a small upstream
# patch adding of_match_table to emc2305.c would also fix module-mode loading
# (track under release/patches/fixes/).
CONFIG_SENSORS_EMC2305=y

# --- LP5812: TI 12-channel I2C LED controller (Mono chassis status LEDs) ---
# The LP5812 drives the chassis status LEDs on the Mono Gateway DK. The
# upstream 6.6.y kernel does NOT ship a driver for this part — the driver
# source is shipped out-of-tree under
#   release/patches/kernel/sdk-sources/drivers/leds/lp5812/leds-lp5812.{c,h}
# and wired into the kbuild walk by patch fixes/095-leds-lp5812-register.patch
# (which adds drivers/leds/lp5812/Kconfig + Makefile and `source` lines in
# drivers/leds/Kconfig + drivers/leds/Makefile).
#
# CONFIG_LEDS_LP5812 is a `bool` Kconfig that `depends on LEDS_CLASS && I2C
# && OF` and `select LEDS_CLASS_MULTICOLOR`. All three dependencies are
# already satisfied by release/vyos-base/arm64/vyos_defconfig
# (CONFIG_LEDS_CLASS=y, CONFIG_I2C=y) and arm64 (CONFIG_OF=y is implicit).
# `select LEDS_CLASS_MULTICOLOR` pulls in the multicolor LED class
# automatically when this is =y.
#
# Built-in (=y) so the chassis LEDs are operable BEFORE userspace runs:
# fancontrol-setup and boot-complete-notify both expect /sys/class/leds
# entries for the LP5812-driven status indicators to exist by the time
# they fire. Otherwise the indicators stay dark for the entire boot.
#
# Without this assertion patch fixes/095 wires the Kconfig stanza into
# the kernel build system but `make olddefconfig` defaults the bool to
# `n` (nothing depends on or selects LEDS_LP5812 from the rest of the
# tree), and the kernel ships without the driver — exactly the state of
# kernel-6.6.137-ask1..ask3.
CONFIG_LEDS_LP5812=y

# --- Watchdog: LS1046A on-SoC IMX21-compatible WDT (ASK Boot #7, 2026-05-01) ---
# LS1046A's watchdog block /soc/watchdog@2ad0000 in fsl-ls1046a.dtsi declares
#     compatible = "fsl,ls1046a-wdt", "fsl,imx21-wdt";
# The driver lives in drivers/watchdog/imx2_wdt.c and is gated by
# CONFIG_IMX2_WDT. Without this symbol set, /dev/watchdog0 is never created
# and VyOS' system_watchdog.py commit-mode handler returns ERROR_COMMIT with
#     "No watchdog device found at /dev/watchdog0 and no module configured."
# The error is non-fatal (vyos-configd continues to system_option) but it's
# a lit warning on every first-boot commit — and the LS1046A SoC really does
# have a usable WDT block so we should expose it.
#
# Built-in (=y) so /dev/watchdog0 is present at the moment vyos-router does
# its first commit, before udev coldplug would have a chance to load a
# module-form driver.
CONFIG_IMX2_WDT=y

# --- Serial console: 8250 DT platform binding (ASK Boot #3, 2026-04-24) ---
# Without CONFIG_SERIAL_OF_PLATFORM=y the 8250 core prints its banner but
# never binds to the DT node serial@21c0500 on LS1046A. earlycon works
# (direct MMIO), but /dev/ttyS0 is never created, /dev/console has no
# backend, and live-boot's final `exec run-init ... < /dev/console` fails
# with "Warning: unable to open an initial console." + /init exits 1,
# producing "Kernel panic - not syncing: Attempted to kill init!
# exitcode=0x00000100" ~10 s after handoff to userspace.
#
# vyos_defconfig already sets these four, but the merge_config.sh + make
# olddefconfig chain can silently drop CONFIG_SERIAL_OF_PLATFORM if a
# dependency is missing at the moment of merge. ask.config is applied
# last, so re-asserting the full dependency chain here pins the symbol.
# Ref qdrant 2026-03-20 "VyOS LS1046A Boot Failure — unable to open
# initial console + init exit code 1".
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_FSL=y
CONFIG_SERIAL_OF_PLATFORM=y

# --- I²C controller for LS1046A (ASK Boot #5, 2026-04-25) ---
# LS1046A's on-SoC I²C blocks (i2c@2180000…21b0000) match the Vybrid
# (vf610) compatible string; the driver is `drivers/i2c/busses/i2c-imx.c`
# enabled via CONFIG_I2C_IMX. Without it ALL four I²C buses stay
# unbound, which cascades into:
#   * sfp-xfi0 / sfp-xfi1 stuck on deferred-probe-pending forever
#     (they reference an i2c-bus phandle that never registers)
#   * fsl_mac probe of 1af0000.ethernet / 1af2000.ethernet returns
#     -EINVAL → no eth3 / eth4 (10G XFI ports) ever appear
#   * EMC2305 fan controller on i2c-mux@70 child bus is invisible
#     → fancontrol no-ops
# vyos_defconfig leaves CONFIG_I2C_IMX unset; ask.config (applied last)
# pins it on. Built-in (=y) because phylink/SFP need the bus available
# during initramfs coldplug, before module loading happens.
CONFIG_I2C_IMX=y

# --- eMMC: LS1046A internal eSDHC controller (ASK Boot #5, 2026-04-25) ---
# DT node /soc/esdhc@1560000 is status=okay and uses the upstream
# `fsl,esdhc` binding handled by `drivers/mmc/host/sdhci-of-esdhc.c`.
# vyos_defconfig leaves CONFIG_MMC_SDHCI_OF_ESDHC unset, so the eSDHC
# block is unbound at runtime — no /dev/mmcblk*, no /sys/class/mmc_host.
# Promote MMC_BLOCK and the SDHCI core/platform layers to =y so eMMC is
# usable from initramfs (in case a future build wants to install to /
# on the on-board eMMC instead of USB).
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_OF_ESDHC=y

# --- QSPI / MTD: U-Boot env on LS1046A (ASK Boot #6, 2026-04-27;
#     ask45/ask46 fixes 2026-04-28) ---
# The LS1046A keeps U-Boot and its environment in QSPI NOR flash. The
# vyos-ls1046a-build installer (`bin/install-image`-equivalent) updates the
# `vyos_image=` U-Boot env var by writing to /dev/mtd2 (the U-Boot env
# partition declared in the LS1046A device-tree). Without this support the
# installer prints:
#     [SKIP] QSPI : U-Boot env NOT updated
#            reason: kernel has no MTD/SPI support -- /dev/mtd2 absent
# and the board keeps booting the previous image after `install image`.
#
# IMPORTANT Kconfig type rules (the trap that ate ask40, ask44, ask45):
#   menuconfig SPI            (drivers/spi/Kconfig)         is BOOL
#   config     SPI_MASTER     (drivers/spi/Kconfig)         is BOOL (default SPI)
#   config     SPI_MEM        (drivers/spi/Kconfig)         is BOOL
#   config     SPI_FSL_QUADSPI (drivers/spi/Kconfig)         is TRISTATE
#   menuconfig MTD            (drivers/mtd/Kconfig)         is TRISTATE
#   menuconfig MTD_SPI_NOR    (drivers/mtd/spi-nor/Kconfig) is TRISTATE
#   config     MTD_BLOCK      (drivers/mtd/Kconfig)         is TRISTATE
#   config     MTD_CMDLINE_PARTS / MTD_OF_PARTS              are TRISTATE
#                              (depend on MTD, follow MTD's tristate)
#
# Setting a BOOL symbol to `=m` makes `make olddefconfig` silently drop
# the line — which is how ask45 ended up with `# CONFIG_SPI is not set`
# in the produced vmlinuz despite ask.config saying `CONFIG_SPI=m`. With
# SPI off, the whole chain (SPI_MEM, SPI_FSL_QUADSPI, MTD_SPI_NOR) collapses
# and /dev/mtd* never appears. Bool symbols MUST be `=y`.
#
# The driver itself (SPI_FSL_QUADSPI) stays modular (=m) — that's what
# gives us late, post-userspace probing of the QSPI controller and avoids
# the ask44 fsl_qspi_probe hang (mainline driver stalls reading JEDEC ID
# over AHB because U-Boot leaves the controller in a non-vanilla state).
# By the time udev modalias-loads spi-fsl-qspi, the residual AHB mapping
# window has been retired by other initcalls / dma_remap.
#
# History of this knob:
#   ask37: enabled =y           -> initcall-order panic in fp_netfilter_init
#                                  (NULL deref in nf_ct_netns_do_get; init=0xb)
#   ask38: switched =y -> =m    -> boots fine, /dev/mtd* appear after udev
#                                  (SPI was =y back then via vyos_defconfig)
#   ask39: dropped block        -> install image SKIPped QSPI again
#   ask40: re-added but typo'd  -> CONFIG_SPI_FSL_QSPI (no such symbol; silently
#                                  dropped, driver not built, /dev/mtd* absent)
#   ask44: typo fixed to QUADSPI=y -> kernel hangs at fsl_qspi_probe on LS1046A
#                                     (board never comes back; mainline driver
#                                      stalls reading the JEDEC ID over AHB).
#                                      10+ min wedge.
#   ask45: revert chain to =m    -> CONFIG_SPI=m is INVALID (bool), olddefconfig
#                                   drops it -> # CONFIG_SPI is not set in the
#                                   produced vmlinuz -> /dev/mtd* still absent.
#                                   Verified by extract-ikconfig on the built
#                                   vmlinuz: only CONFIG_MTD=m made it through;
#                                   SPI/SPI_MEM/SPI_FSL_QUADSPI/MTD_SPI_NOR all
#                                   silently dropped.
#   ask46: bool symbols pinned =y, tristate driver stays =m -> SPI core in-kernel,
#                                   QSPI controller driver loaded by udev as
#                                   a module post-userspace (the ask38 timing).
#                                   /dev/mtd* should appear after coldplug.
CONFIG_MTD=m
CONFIG_MTD_BLOCK=m
CONFIG_MTD_CMDLINE_PARTS=m
CONFIG_MTD_OF_PARTS=m
CONFIG_MTD_SPI_NOR=m
CONFIG_SPI=y
CONFIG_SPI_MEM=y
CONFIG_SPI_FSL_QUADSPI=m

# ============================================================================
# ASK overrides for VyOS rolling kernel fragments (mainline-6.18-port)
# ============================================================================
#
# Phase 0 of the 6.18 migration re-vendored release/vyos-base/ verbatim from
# `vyos-build@HEAD`. The pre-existing ASK customizations that previously lived
# inline in those fragments are migrated here so they apply LAST via
# merge_config.sh and survive future re-vendors.
#
# 10-networking — load-bearing for ASK
#
# CONFIG_NET_KEY=y: VyOS rolling ships =m. ASK requires =y so net/key/Makefile's
#   obj-y honors patch 097's CONFIG_ASK_FCI_NLKEY entry. With =m, net/Makefile
#   descends via `obj-m += key/` and any `obj-y` line inside net/key/Makefile is
#   silently dropped — kernel image then has no NETLINK_KEY=32 registration,
#   `cmm` fails with EPROTONOSUPPORT.
CONFIG_NET_KEY=y
#
# CONFIG_ASK_FCI_NLKEY=y: registers proto-32 (NETLINK_KEY) without enabling
#   the broken-on-6.6 / partly-broken-on-6.18 IPsec offload data path. Provided
#   by release/patches/fixes/097-ask-fci-nlkey-narrow-gate.patch.
CONFIG_ASK_FCI_NLKEY=y
#
# CONFIG_NET_SCH_FQ=y: ship sch_fq built-in so net.core.default_qdisc=fq applied
#   from /etc/sysctl.d/* during early boot does not race
#   systemd-modules-load.service. Without =y, dmesg prints
#       Error -ENOENT writing to proc file to set sysctl parameter
#           'net.core.default_qdisc=fq'
#   at ~[0.987]s and the qdisc silently stays at pfifo_fast.
CONFIG_NET_SCH_FQ=y
#
# CONFIG_BRIDGE_NETFILTER=m: VyOS firewall on bridge interfaces.
CONFIG_BRIDGE_NETFILTER=m
#
# CONFIG_SMC: not used; saves built-in surface.
# CONFIG_SMC is not set
#
# 20-netfilter — ASK xtables module gating
# CONFIG_NETFILTER_XT_TARGET_NOTRACK is not set
CONFIG_NETFILTER_XT_TARGET_TRACE=m
