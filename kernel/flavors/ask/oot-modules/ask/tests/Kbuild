# ASK 2.0 - kunit test suite Kbuild (PR4 / M0.4)
#
# Built only when CONFIG_NET_ASK_KUNIT_TEST=y (or =m). Produces a
# separate ask_kunit.ko so the production ask.ko stays free of test
# code. Loading ask_kunit.ko on a kunit-enabled kernel triggers the
# registered suites; results land in dmesg as
#     KTAP version 1
#     1..N
#     ok 1 - <suite>::<test>
#     ...
# and (when the kernel is booted with kunit=enable) in
# /sys/kernel/debug/kunit/.
#
# PR4 ships exactly one trivial passing test (ask_test_dummy.c) so
# the harness itself can be validated end-to-end before the M1 PRs
# start landing real coverage on top of it.

ccflags-y += -I$(src)/../include
ccflags-y += -I$(src)/../include/uapi

obj-$(CONFIG_NET_ASK_KUNIT_TEST) += ask_kunit.o

ask_kunit-y := \
ask_test_main.o \
ask_test_dummy.o \
ask_test_hostcmd.o \
ask_test_flow.o \
ask_test_flow_offload.o
