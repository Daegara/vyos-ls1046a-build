+/*
+ * PR14z19 Path A: pre-netdev hook register / unregister / invoke.
+ *
+ * fman_pcd_register_pre_netdev_hook() - install a callback that
+ *   fman_port_init() invokes for each port BEFORE the default
+ *   keygen_port_hashing_init(). The hook can claim the port (return 0)
+ *   or decline (return -ENOENT). Single hook per FMan instance; -EBUSY
+ *   if already registered.
+ *
+ * fman_pcd_unregister_pre_netdev_hook() - remove the hook. Idempotent.
+ *
+ * fman_pcd_invoke_pre_netdev_hook() - internal helper consumed by
+ *   fman_port_init() in fman_port.c. NOT exported; sibling translation
+ *   unit only. Returns the hook's rc, or -ENOENT if no hook installed
+ *   so the caller falls through to the default keygen path.
+ */
+int fman_pcd_register_pre_netdev_hook(struct fman_pcd *pcd,
+				      fman_pcd_pre_netdev_hook_t hook,
+				      void *priv)
+{
+	if (!pcd || !hook)
+		return -EINVAL;
+
+	mutex_lock(&pcd->lock);
+	if (pcd->pre_netdev_hook) {
+		mutex_unlock(&pcd->lock);
+		return -EBUSY;
+	}
+	pcd->pre_netdev_hook = hook;
+	pcd->pre_netdev_hook_priv = priv;
+	mutex_unlock(&pcd->lock);
+
+	dev_info(fman_get_dev(pcd->fman),
+		 "fman_pcd: pre-netdev hook registered (%ps)\n", hook);
+	return 0;
+}
+EXPORT_SYMBOL_GPL(fman_pcd_register_pre_netdev_hook);
+
+void fman_pcd_unregister_pre_netdev_hook(struct fman_pcd *pcd)
+{
+	if (!pcd)
+		return;
+
+	mutex_lock(&pcd->lock);
+	pcd->pre_netdev_hook = NULL;
+	pcd->pre_netdev_hook_priv = NULL;
+	mutex_unlock(&pcd->lock);
+}
+EXPORT_SYMBOL_GPL(fman_pcd_unregister_pre_netdev_hook);
+
+int fman_pcd_invoke_pre_netdev_hook(struct fman_pcd *pcd, u8 hwport_id,
+				    u32 default_base_fqid,
+				    u32 default_hash_size)
+{
+	fman_pcd_pre_netdev_hook_t hook;
+	void *priv;
+
+	if (!pcd)
+		return -ENOENT;
+
+	mutex_lock(&pcd->lock);
+	hook = pcd->pre_netdev_hook;
+	priv = pcd->pre_netdev_hook_priv;
+	mutex_unlock(&pcd->lock);
+
+	if (!hook)
+		return -ENOENT;
+
+	return hook(pcd, hwport_id, default_base_fqid,
+		    default_hash_size, priv);
+}
+
