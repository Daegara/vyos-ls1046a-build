+/*
+ * PR14z19 Path A: pre-netdev hook.
+ *
+ * An OOT consumer (ask.ko, built-in via Kconfig bool so its
+ * module_init runs at fs_initcall, before the dpaa_eth probe) may
+ * register a single hook per FMan instance. The hook is invoked from
+ * fman_port_init() for every port that mainline would otherwise
+ * default-RSS-hash, *before* register_netdev(). The hook can:
+ *
+ *   - return 0     : "I claim this port. Skip default RSS hashing.
+ *                     The scheme has been allocated and bound by the
+ *                     hook; the netdev will come up downstream of an
+ *                     already-active PCD chain."
+ *   - return -ENOENT: "Not my port; fall through to default RSS."
+ *   - return any other negative value: fatal probe error; the port
+ *                     init fails and the netdev never registers.
+ *
+ * @pcd:                FMan PCD handle (fman_get_pcd() / fman_pcd_from_of_node()).
+ * @hwport_id:          BMI hardware port id (LS1046A: 0x01..0x31).
+ * @default_base_fqid:  Base FQID that mainline would have programmed.
+ * @default_hash_size:  Hash spread size that mainline would have used.
+ * @priv:               Cookie supplied at hook-register time.
+ */
+typedef int (*fman_pcd_pre_netdev_hook_t)(struct fman_pcd *pcd,
+					  u8 hwport_id,
+					  u32 default_base_fqid,
+					  u32 default_hash_size,
+					  void *priv);
+
+int fman_pcd_register_pre_netdev_hook(struct fman_pcd *pcd,
+				      fman_pcd_pre_netdev_hook_t hook,
+				      void *priv);
+void fman_pcd_unregister_pre_netdev_hook(struct fman_pcd *pcd);
+
