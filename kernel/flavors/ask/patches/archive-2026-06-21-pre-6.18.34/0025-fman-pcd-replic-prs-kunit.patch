diff --git a/drivers/net/ethernet/freescale/fman/tests/fman_pcd_prs_test.c b/drivers/net/ethernet/freescale/fman/tests/fman_pcd_prs_test.c
new file mode 100644
index 0000000..98096b3
--- /dev/null
+++ b/drivers/net/ethernet/freescale/fman/tests/fman_pcd_prs_test.c
@@ -0,0 +1,72 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * KUnit suite for the FMan PCD Parser (PRS) v1.0 pass-through hook
+ * landed in PR14f-body-3.
+ *
+ * This file is #include'd from fman_pcd_prs.c under
+ * CONFIG_FSL_FMAN_PCD_KUNIT_TEST so the tests reach the exported
+ * fman_pcd_prs_init() symbol in its native TU.  Coverage:
+ *
+ *   - NULL @pcd handle yields -EINVAL  (defensive contract)
+ *   - non-NULL @pcd handle yields 0    (pass-through happy path)
+ *
+ * v1.0 is a deliberate pass-through (stock FMan ucode 210.10.1 covers
+ * IPv4/IPv6/TCP/UDP/ESP/VLAN which is the entire ASK2 v1.0 flow-type
+ * set per spec sec 13.6).  These tests are the regression canary for
+ * the contract: if v1.1 adds GRE / VXLAN / MPLS HXS programming, the
+ * existing tests stay green and new tests cover the new register
+ * writes -- but the v1.0 "no register writes" property MUST remain
+ * true for the v1.0 ABI.
+ *
+ * Authoritative reference: spec sec 13.6 (FMan PCD v1.0 surface) and
+ * LS1046A RM 8.7.2 (FMan Parser HXS programming).
+ *
+ * Tests pass a non-NULL dummy pointer cast struct fman_pcd * -- the
+ * struct is opaque from this TU's vantage and the pass-through body
+ * never dereferences it.  This is intentional: v1.1 will add a real
+ * register-mocking scaffold here; v1.0 only needs the contract pinned.
+ */
+#include <kunit/test.h>
+#include <linux/kernel.h>
+#include <linux/types.h>
+
+/* ---- TEST: NULL @pcd handle returns -EINVAL ------------------------ */
+/*
+ * The contract is "non-NULL @pcd or -EINVAL".  If anyone refactors
+ * the NULL check away (it looks redundant for a pass-through return 0
+ * body) future v1.1 register writes would dereference a NULL handle
+ * and panic in atomic context.
+ */
+static void prs_init_null_pcd_test(struct kunit *test)
+{
+KUNIT_EXPECT_EQ(test, fman_pcd_prs_init(NULL), -EINVAL);
+}
+
+/* ---- TEST: valid @pcd handle returns 0 (pass-through) -------------- */
+/*
+ * The body never dereferences the pointer for v1.0, so a bogus
+ * non-NULL value is sufficient.  v1.1 will need a real PCD scaffold
+ * here -- when that lands, this test gets replaced wholesale, not
+ * augmented (the v1.0 contract is "pass-through happy path returns
+ * 0", which v1.1 will replace with "valid register writes happened").
+ */
+static void prs_init_pass_through_test(struct kunit *test)
+{
+/* Bogus non-NULL pointer -- v1.0 body never dereferences it. */
+struct fman_pcd *bogus = (struct fman_pcd *)0x1;
+
+KUNIT_EXPECT_EQ(test, fman_pcd_prs_init(bogus), 0);
+}
+
+static struct kunit_case fman_pcd_prs_test_cases[] = {
+KUNIT_CASE(prs_init_null_pcd_test),
+KUNIT_CASE(prs_init_pass_through_test),
+{}
+};
+
+static struct kunit_suite fman_pcd_prs_test_suite = {
+.name = "fman_pcd_prs",
+.test_cases = fman_pcd_prs_test_cases,
+};
+
+kunit_test_suite(fman_pcd_prs_test_suite);
\ No newline at end of file
diff --git a/drivers/net/ethernet/freescale/fman/tests/fman_pcd_replic_test.c b/drivers/net/ethernet/freescale/fman/tests/fman_pcd_replic_test.c
new file mode 100644
index 0000000..1c79f8f
--- /dev/null
+++ b/drivers/net/ethernet/freescale/fman/tests/fman_pcd_replic_test.c
@@ -0,0 +1,303 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * KUnit suite for the FMan PCD Frame Replicator (FR) layout primitives
+ * landed in PR14f-body-1/body-2/body-3.
+ *
+ * This file is #include'd from fman_pcd_replic.c under
+ * CONFIG_FSL_FMAN_PCD_KUNIT_TEST so the tests reach the static
+ * FMAN_PCD_REPLIC_* layout #defines and the struct fman_pcd_replic_group
+ * layout directly.  Coverage:
+ *
+ *   - source-TD layout offsets are byte-perfect vs RM 8.7.7 Table 8-128
+ *     (type at 0x0, frg_pointer at 0x4, opcode at 0x8, res at 0xc)
+ *   - source-TD active-OPCODE single-publication regression canary
+ *     (the type-word OPCODE byte must be the high byte at offset 0x0;
+ *     the active opcode word at 0x8 must equal SOURCE_TD_OPCODE)
+ *   - member-AD layout (FQID at offset 0x0 low 24 bits, NIA at 0x8)
+ *   - member-AD NIA encoding (FR_BIT = 0x08000000 for intermediates,
+ *     NL_BIT = 0x10000000 for the terminator, ADDR_SHIFT = 4)
+ *
+ * The byte-perfect REPLICATE-arm test against cc_encode_ad() CANNOT
+ * live here because cc_encode_ad() is static to fman_pcd_cc.c (the
+ * trailer-#include scope is per-TU).  Opaque-pointer REPLICATE tests
+ * (NULL group, zero source_td_off) live in tests/fman_pcd_cc_test.c
+ * instead.  This is the same cross-TU split that PR14d-body-4 and
+ * PR14e-body-4 used for MANIPULATE / POLICE respectively.
+ *
+ * Authoritative references: LS1046A RM 8.7.7 (Frame Replicator
+ * source-TD + member-AD layout) and RM 8.7.4.3 Table 8-119 (NIA
+ * encoding used by the AD-feeding match table).
+ *
+ * Tests build stub member arrays on the stack and program them into a
+ * kunit_kzalloc'd MURAM-scratch backing buffer cast void __iomem __force *,
+ * then call the static replic_encode_members() helper and read back
+ * via ioread32be.  Same scaffolding idiom as
+ * tests/fman_pcd_plcr_test.c (PR14e-body-4) and
+ * tests/fman_pcd_manip_test.c (PR14d-body-4).
+ */
+#include <kunit/test.h>
+#include <linux/io.h>
+#include <linux/kernel.h>
+#include <linux/types.h>
+
+/* Allocate an N-member member-AD scratch region. */
+static void __iomem *replic_member_scratch_alloc(struct kunit *test, u8 n)
+{
+	size_t sz = (size_t)n * FMAN_PCD_REPLIC_AD_SIZE;
+	void *buf = kunit_kzalloc(test, sz, GFP_KERNEL);
+
+	KUNIT_ASSERT_NOT_NULL(test, buf);
+	return (void __iomem __force *)buf;
+}
+
+/* Allocate a 16-B source-TD scratch region. */
+static void __iomem *replic_source_td_scratch_alloc(struct kunit *test)
+{
+	void *buf = kunit_kzalloc(test, FMAN_PCD_REPLIC_AD_SIZE, GFP_KERNEL);
+
+	KUNIT_ASSERT_NOT_NULL(test, buf);
+	return (void __iomem __force *)buf;
+}
+
+static u32 replic_read_be32(void __iomem *rec, unsigned int off)
+{
+	return ioread32be(rec + off);
+}
+
+/* ---- TEST: source-TD layout offsets vs RM 8.7.7 Table 8-128 -------- */
+/*
+ * RM Table 8-128 (Frame Replicator Source Type Descriptor) is silicon-
+ * fixed at 16 B:
+ *
+ *   word 0 (offset 0x0): type   - high byte = SOURCE_TD_OPCODE
+ *   word 1 (offset 0x4): frg_pointer (>> ADDR_SHIFT) to first member AD
+ *   word 2 (offset 0x8): opcode - active OPCODE word (publication point)
+ *   word 3 (offset 0xc): res    - reserved, must be 0
+ *
+ * The #defines pin those offsets.  A typo (e.g. swapping the
+ * frg_pointer and opcode offsets) would produce a build that boots
+ * fine, silently misroutes the silicon walker, and only shows up as
+ * "replicator fans nothing out" on the wire.  Pin them numerically.
+ */
+static void replic_source_td_offsets_test(struct kunit *test)
+{
+	KUNIT_EXPECT_EQ(test, FMAN_PCD_REPLIC_AD_SIZE, 16);
+	KUNIT_EXPECT_EQ(test, FMAN_PCD_REPLIC_SRC_OFF_TYPE, 0x0);
+	KUNIT_EXPECT_EQ(test, FMAN_PCD_REPLIC_SRC_OFF_FRG_POINTER, 0x4);
+	KUNIT_EXPECT_EQ(test, FMAN_PCD_REPLIC_SRC_OFF_OPCODE, 0x8);
+	KUNIT_EXPECT_EQ(test, FMAN_PCD_REPLIC_SRC_OFF_RES, 0xc);
+}
+
+/* ---- TEST: source-TD active-OPCODE single-publication property ----- */
+/*
+ * PR14f-body-2 invariant: the single act that makes a replicator group
+ * "hot" to the silicon walker is the iowrite32be(SOURCE_TD_OPCODE) into
+ * the OPCODE word at offset 0x8.  The type word at 0x0 carries the
+ * OPCODE in the HIGH byte (<<24) at construction so the silicon
+ * recognises the record as a replicator entry, but until the OPCODE
+ * word at 0x8 goes hot the walker short-circuits on a zero opcode and
+ * NO traffic can enter the chain.
+ *
+ * This test simulates the body-1 -> body-2 publication sequence:
+ *
+ *   1. Construction: zeroed source-TD + type-word HIGH byte = OPCODE.
+ *      OPCODE word at 0x8 still zero (inactive).
+ *   2. Publication: write frg_pointer at 0x4, then OPCODE word at 0x8.
+ *
+ * Regression canary: if anyone reorders the writes (publishes OPCODE
+ * before frg_pointer, or writes the OPCODE into the type-word's low
+ * byte instead of high byte), the silicon walker either fans out into
+ * a NULL chain (publication race) or never recognises the record
+ * (mis-encoded type-word).  Either failure is silent at boot.
+ */
+static void replic_source_td_publication_order_test(struct kunit *test)
+{
+	void __iomem *src = replic_source_td_scratch_alloc(test);
+	const u8 *raw = (const u8 __force *)src;
+
+	/* Step 1: type word -- OPCODE in HIGH byte at offset 0x0. */
+	iowrite32be((u32)FMAN_PCD_REPLIC_SOURCE_TD_OPCODE << 24,
+		    src + FMAN_PCD_REPLIC_SRC_OFF_TYPE);
+	KUNIT_EXPECT_EQ(test, raw[0],
+			(u8)FMAN_PCD_REPLIC_SOURCE_TD_OPCODE);
+	KUNIT_EXPECT_EQ(test, raw[1], 0u);
+	KUNIT_EXPECT_EQ(test, raw[2], 0u);
+	KUNIT_EXPECT_EQ(test, raw[3], 0u);
+	/* OPCODE word at 0x8 still zero -- record is inactive. */
+	KUNIT_EXPECT_EQ(test,
+			replic_read_be32(src,
+					 FMAN_PCD_REPLIC_SRC_OFF_OPCODE),
+			0u);
+
+	/* Step 2a: stamp frg_pointer at 0x4 (no fan-out yet). */
+	iowrite32be(0xdeadbeefu, src + FMAN_PCD_REPLIC_SRC_OFF_FRG_POINTER);
+	KUNIT_EXPECT_EQ(test, raw[4], 0xDEu);
+	KUNIT_EXPECT_EQ(test, raw[5], 0xADu);
+	KUNIT_EXPECT_EQ(test, raw[6], 0xBEu);
+	KUNIT_EXPECT_EQ(test, raw[7], 0xEFu);
+
+	/* Step 2b: publish active OPCODE word -- record goes hot. */
+	iowrite32be((u32)FMAN_PCD_REPLIC_SOURCE_TD_OPCODE,
+		    src + FMAN_PCD_REPLIC_SRC_OFF_OPCODE);
+	KUNIT_EXPECT_EQ(test,
+			replic_read_be32(src,
+					 FMAN_PCD_REPLIC_SRC_OFF_OPCODE),
+			(u32)FMAN_PCD_REPLIC_SOURCE_TD_OPCODE);
+	/* res must remain zero. */
+	KUNIT_EXPECT_EQ(test,
+			replic_read_be32(src,
+					 FMAN_PCD_REPLIC_SRC_OFF_RES),
+			0u);
+}
+
+/* ---- TEST: member-AD layout offsets + NIA encoding bits ------------ */
+/*
+ * RM 8.7.7 member-AD slot (16 B):
+ *   word 0 (offset 0x0): FQID in low 24 bits, high 8 bits reserved
+ *   word 1 (offset 0x4): reserved
+ *   word 2 (offset 0x8): NIA = FR_BIT | (next_off >> ADDR_SHIFT) for
+ *                         intermediates; NL_BIT for the terminator
+ *   word 3 (offset 0xc): reserved
+ *
+ * Pin the offsets and the bit positions.  A typo in FR_BIT / NL_BIT
+ * would silently mis-encode every member's NIA -- the silicon walker
+ * would either fan out wrong (intermediate treated as terminator) or
+ * loop forever (terminator treated as intermediate with a stale NEXT).
+ */
+static void replic_member_layout_constants_test(struct kunit *test)
+{
+	KUNIT_EXPECT_EQ(test, FMAN_PCD_REPLIC_MBR_OFF_FQID, 0x0);
+	KUNIT_EXPECT_EQ(test, FMAN_PCD_REPLIC_MBR_OFF_NIA, 0x8);
+	KUNIT_EXPECT_EQ(test, FMAN_PCD_REPLIC_FR_BIT, 0x08000000u);
+	KUNIT_EXPECT_EQ(test, FMAN_PCD_REPLIC_NL_BIT, 0x10000000u);
+	KUNIT_EXPECT_EQ(test, FMAN_PCD_REPLIC_ADDR_SHIFT, 4);
+}
+
+/* ---- TEST: replic_encode_members() byte-perfect chain -------------- */
+/*
+ * Three-member chain, byte-perfect against RM 8.7.7:
+ *
+ *   member[0] @ off+0x00 : fqid=0x123456, NIA = FR_BIT | ((off+0x10)>>4)
+ *   member[1] @ off+0x10 : fqid=0x654321, NIA = FR_BIT | ((off+0x20)>>4)
+ *   member[2] @ off+0x20 : fqid=0xABCDEF, NIA = NL_BIT
+ *
+ * This is the central byte-perfect test for body-2: it pins the NEXT
+ * pointer arithmetic AND the FR/NL terminator distinction in one shot.
+ * We pick a non-zero members_off so an off-by-(members_off>>4) bug in
+ * the next-pointer encoding cannot accidentally land on the right
+ * field value.
+ */
+static void replic_encode_members_chain_test(struct kunit *test)
+{
+	struct fman_pcd_replic_member members[3] = {
+		{ .fqid = 0x123456u },
+		{ .fqid = 0x654321u },
+		{ .fqid = 0xABCDEFu },
+	};
+	struct fman_pcd_replic_group group = {
+		.num_members  = 3,
+		.members      = replic_member_scratch_alloc(test, 3),
+		.members_off  = 0x10000u,
+	};
+	u32 nia, fqid;
+	unsigned int slot_off;
+
+	spin_lock_init(&group.lock);
+	replic_encode_members(&group, members);
+
+	/* member[0]: FQID in low 24 bits, NIA = FR | ((0x10010)>>4). */
+	slot_off = 0u * FMAN_PCD_REPLIC_AD_SIZE;
+	fqid = replic_read_be32(group.members,
+				slot_off + FMAN_PCD_REPLIC_MBR_OFF_FQID);
+	nia  = replic_read_be32(group.members,
+				slot_off + FMAN_PCD_REPLIC_MBR_OFF_NIA);
+	KUNIT_EXPECT_EQ(test, fqid, 0x00123456u);
+	KUNIT_EXPECT_EQ(test, nia,
+			FMAN_PCD_REPLIC_FR_BIT |
+			((0x10000u + 1u * FMAN_PCD_REPLIC_AD_SIZE) >>
+			 FMAN_PCD_REPLIC_ADDR_SHIFT));
+
+	/* member[1]: same shape, NEXT points to slot 2. */
+	slot_off = 1u * FMAN_PCD_REPLIC_AD_SIZE;
+	fqid = replic_read_be32(group.members,
+				slot_off + FMAN_PCD_REPLIC_MBR_OFF_FQID);
+	nia  = replic_read_be32(group.members,
+				slot_off + FMAN_PCD_REPLIC_MBR_OFF_NIA);
+	KUNIT_EXPECT_EQ(test, fqid, 0x00654321u);
+	KUNIT_EXPECT_EQ(test, nia,
+			FMAN_PCD_REPLIC_FR_BIT |
+			((0x10000u + 2u * FMAN_PCD_REPLIC_AD_SIZE) >>
+			 FMAN_PCD_REPLIC_ADDR_SHIFT));
+
+	/* member[2]: terminator -- NL_BIT only, no NEXT pointer. */
+	slot_off = 2u * FMAN_PCD_REPLIC_AD_SIZE;
+	fqid = replic_read_be32(group.members,
+				slot_off + FMAN_PCD_REPLIC_MBR_OFF_FQID);
+	nia  = replic_read_be32(group.members,
+				slot_off + FMAN_PCD_REPLIC_MBR_OFF_NIA);
+	KUNIT_EXPECT_EQ(test, fqid, 0x00ABCDEFu);
+	KUNIT_EXPECT_EQ(test, nia, FMAN_PCD_REPLIC_NL_BIT);
+}
+
+/* ---- TEST: FQID high-byte clamping ---------------------------------- */
+/*
+ * FQIDs are 24-bit on FMan v3.  The encoder MUST mask off the high 8
+ * bits before iowrite32be -- the silicon ignores them but a corrupted
+ * member-AD with garbage in the high byte would (a) make the byte-
+ * perfect test above flaky and (b) confuse anyone reading MURAM with
+ * a JTAG dump.
+ */
+static void replic_encode_members_fqid_clamp_test(struct kunit *test)
+{
+	struct fman_pcd_replic_member members[1] = {
+		{ .fqid = 0xFFAABBCCu },		/* high byte must clear */
+	};
+	struct fman_pcd_replic_group group = {
+		.num_members  = 1,
+		.members      = replic_member_scratch_alloc(test, 1),
+		.members_off  = 0u,
+	};
+
+	spin_lock_init(&group.lock);
+	replic_encode_members(&group, members);
+
+	KUNIT_EXPECT_EQ(test,
+			replic_read_be32(group.members,
+					 FMAN_PCD_REPLIC_MBR_OFF_FQID),
+			0x00AABBCCu);
+	/* Single-member chain: terminator NIA only. */
+	KUNIT_EXPECT_EQ(test,
+			replic_read_be32(group.members,
+					 FMAN_PCD_REPLIC_MBR_OFF_NIA),
+			FMAN_PCD_REPLIC_NL_BIT);
+}
+
+/* ---- TEST: source_td_off accessor NULL safety ----------------------- */
+/*
+ * The cc.c REPLICATE arm relies on the 0 sentinel returned by
+ * fman_pcd_replic_group_source_td_off(NULL) to reject uninitialised
+ * group handles with -EINVAL.  If anyone "helpfully" makes the
+ * accessor non-NULL-safe (e.g. returns a static or panics), the
+ * REPLICATE arm would dereference an arbitrary pointer.
+ */
+static void replic_group_source_td_off_null_test(struct kunit *test)
+{
+	KUNIT_EXPECT_EQ(test, fman_pcd_replic_group_source_td_off(NULL), 0UL);
+}
+
+static struct kunit_case fman_pcd_replic_test_cases[] = {
+	KUNIT_CASE(replic_source_td_offsets_test),
+	KUNIT_CASE(replic_source_td_publication_order_test),
+	KUNIT_CASE(replic_member_layout_constants_test),
+	KUNIT_CASE(replic_encode_members_chain_test),
+	KUNIT_CASE(replic_encode_members_fqid_clamp_test),
+	KUNIT_CASE(replic_group_source_td_off_null_test),
+	{}
+};
+
+static struct kunit_suite fman_pcd_replic_test_suite = {
+	.name = "fman_pcd_replic",
+	.test_cases = fman_pcd_replic_test_cases,
+};
+
+kunit_test_suite(fman_pcd_replic_test_suite);
