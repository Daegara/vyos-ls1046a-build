diff --git a/drivers/net/ethernet/freescale/fman/fman_keygen.c b/drivers/net/ethernet/freescale/fman/fman_keygen.c
index fe5710c..ffd4072 100644
--- a/drivers/net/ethernet/freescale/fman/fman_keygen.c
+++ b/drivers/net/ethernet/freescale/fman/fman_keygen.c
@@ -579,6 +579,73 @@ int keygen_scheme_setup(struct fman_keygen *keygen, u8 scheme_id,
 }
 EXPORT_SYMBOL_GPL(keygen_scheme_setup);
 
+/* keygen_scheme_set_ccbs
+ *
+ * Update only the KGSE_CCBS register of an already-programmed scheme.
+ *
+ * Used by the public ABI fman_pcd_kg_attach_cc() (fman_pcd_kg.c) to wire
+ * a previously-created KG scheme to a Coarse Classifier tree.  KGSE_CCBS
+ * carries the MURAM offset of the CC tree's group table; per RM 8.7.4 the
+ * scheme's hash output is XOR'd against this base address to index the
+ * group table, and the matching group's AD then continues the CC walk.
+ *
+ * Implementation uses the AR-mediated indirect-access window in
+ * read-modify-write mode: a READ AR loads the full scheme image into
+ * regs->fmkg_sch, we overwrite only kgse_ccbs, then a WRITE AR flushes
+ * the image back.  This preserves every other field that
+ * keygen_scheme_setup() programmed (kgse_mode/mv/fqb/...) without forcing
+ * the caller to recompute them.
+ *
+ * keygen: KeyGen handle.
+ * scheme_id: scheme id previously returned via keygen_scheme_setup().
+ * ccbs: new KGSE_CCBS value (typically tree group-table MURAM offset).
+ *
+ * Return: 0 on success or negative errno (the scheme must already be in
+ * the 'used' state -- this helper does not allocate scheme slots).
+ */
+int keygen_scheme_set_ccbs(struct fman_keygen *keygen, u8 scheme_id,
+	   u32 ccbs)
+{
+	struct fman_kg_regs __iomem *regs;
+	struct keygen_scheme *scheme;
+	u32 ar_reg;
+	int err;
+
+	if (!keygen)
+		return -EINVAL;
+	regs = keygen->keygen_regs;
+
+	scheme = get_scheme(keygen, scheme_id);
+	if (!scheme || !scheme->used)
+		return -EINVAL;
+
+	/*
+	 * READ phase: pull the current scheme image into the indirect
+	 * window.  Without this, the WRITE phase would clobber every
+	 * other KGSE_* register with stale stack contents.
+	 */
+	ar_reg = build_ar_scheme(scheme_id, false, false);
+	err = keygen_write_ar_wait(regs, ar_reg);
+	if (err) {
+		pr_err("Reading scheme %u for CCBS update failed\n", scheme_id);
+		return err;
+	}
+
+	/* Modify only kgse_ccbs in the indirect window. */
+	iowrite32be(ccbs, &regs->fmkg_sch.kgse_ccbs);
+
+	/* WRITE phase: flush the modified image back. */
+	ar_reg = build_ar_scheme(scheme_id, false, true);
+	err = keygen_write_ar_wait(regs, ar_reg);
+	if (err) {
+		pr_err("Writing kgse_ccbs for scheme %u failed\n", scheme_id);
+		return err;
+	}
+
+	return 0;
+}
+EXPORT_SYMBOL_GPL(keygen_scheme_set_ccbs);
+
 /* keygen_init
  *
  * KeyGen initialization:
diff --git a/drivers/net/ethernet/freescale/fman/fman_keygen_internal.h b/drivers/net/ethernet/freescale/fman/fman_keygen_internal.h
