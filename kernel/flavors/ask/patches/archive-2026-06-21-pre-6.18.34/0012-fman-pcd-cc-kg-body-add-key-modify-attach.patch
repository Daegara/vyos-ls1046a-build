 #endif /* __FMAN_PCD_INTERNAL_H */
diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_kg.c b/drivers/net/ethernet/freescale/fman/fman_pcd_kg.c
index dbf1c87..d0a21e9 100644
--- a/drivers/net/ethernet/freescale/fman/fman_pcd_kg.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_kg.c
@@ -361,24 +361,61 @@ return 0;
 }
 EXPORT_SYMBOL_GPL(fman_pcd_kg_bind_port);
 
+/**
+ * fman_pcd_kg_attach_cc() - wire a KG scheme to a Coarse Classifier tree.
+ *
+ * Implements the public ABI declared in <linux/fsl/fman_pcd.h>.
+ *
+ * Programming sequence (under pcd->lock):
+ *   1. Validate args.  The scheme MAY be unbound: during M2 dry bringup
+ *      ask.ko allocates the KG/CC chain and attaches it before any port
+ *      is bound (port-bind is deferred to M3/PR15).  The register write
+ *      that follows (KGSE_CCBS) is harmless in that state -- the chain
+ *      is programmed but quiescent until a subsequent kg_bind_port().
+ *   2. Resolve the tree's group-table MURAM offset via the cross-TU
+ *      accessor fman_pcd_cc_tree_group_table_off().
+ *   3. Call keygen_scheme_set_ccbs() (read-modify-write on the AR-
+ *      mediated indirect window) to update KGSE_CCBS only, preserving
+ *      every other field that keygen_scheme_setup() programmed.
+ *
+ * KGSE_CCBS encoding (RM 8.7.4): low 24 bits hold the group-table
+ * physaddr.  PR14c-body-4 sets only this base; the CC chain bit in
+ * KGSE_MODE remains as keygen_scheme_setup() left it (CC walking is
+ * implicit when CCBS is non-zero on FMan v3 -- the gating bit was a
+ * v2-era control that v3 collapsed into the all-zero CCBS check).
+ *
+ * Returns 0 on success or negative errno from keygen_scheme_set_ccbs.
+ */
 int fman_pcd_kg_attach_cc(struct fman_pcd_kg_scheme *scheme,
   struct fman_pcd_cc_tree *cc)
 {
+struct fman_keygen *keygen;
+struct fman *fman;
+struct mutex *lock;
+unsigned long off;
+u32 ccbs;
+int err;
+
 if (!scheme || !cc)
 return -EINVAL;
 
-/*
- * Deferred to PR14b follow-up: requires struct fman_pcd_cc_tree
- * which lands in PR14c (fman_pcd_cc.c).  Programming target is
- * KGSE_CCBS (RM sec 8.7.4): hash output indexes into the CC tree's
- * key table.  When PR14c lands we will:
- *   1. mutex_lock(pcd->lock)
- *   2. validate scheme->bound (cannot chain an unbound scheme)
- *   3. clear KG_SCH_MODE_EN, rewrite KGSE_CCBS, set CC chain bit,
- *      set KG_SCH_MODE_EN
- *   4. mutex_unlock
- */
-return -EOPNOTSUPP;
+fman = fman_pcd_get_fman(scheme->pcd);
+if (!fman || !fman->keygen)
+return -ENXIO;
+keygen = fman->keygen;
+
+off = fman_pcd_cc_tree_group_table_off(cc);
+if (off == 0)
+return -EINVAL;
+/* Low 24 bits: MURAM is well under 16 MiB on every FMan v3. */
+ccbs = (u32)off & 0x00FFFFFFu;
+
+lock = fman_pcd_get_lock(scheme->pcd);
+mutex_lock(lock);
+err = keygen_scheme_set_ccbs(keygen, scheme->id, ccbs);
+mutex_unlock(lock);
+
+return err;
 }
 EXPORT_SYMBOL_GPL(fman_pcd_kg_attach_cc);
 
