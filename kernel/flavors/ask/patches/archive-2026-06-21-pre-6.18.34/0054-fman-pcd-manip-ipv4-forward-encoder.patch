From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: ci <ci@local>
Date: Sun, 24 May 2026 06:58:39 +0000
Subject: [PATCH] fman-pcd-manip: add FIELD_UPDATE_IPV4_FORWARD encoder (v1.2)

---
 .../ethernet/freescale/fman/fman_pcd_manip.c  |  66 +++++++++++
 .../fman/tests/fman_pcd_manip_test.c          | 106 ++++++++++++++++++
 include/linux/fsl/fman_pcd.h                  |  46 +++++++-
 3 files changed, 212 insertions(+), 6 deletions(-)

diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
index 5c1b916..871a9f2 100644
--- a/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
@@ -528,6 +528,66 @@ manip_encode_ttl_dec(struct fman_pcd_manip *manip, u8 *out_op)
 	return hmct;
 }
 
+/* ------------------------------------------------------------------ */
+/* v1.2 (PR14i) encoder - Path A CC-key inline MANIP primitive        */
+/* ------------------------------------------------------------------ */
+
+static __must_check void __iomem *
+manip_encode_field_update_ipv4_forward(struct fman_pcd_manip *manip,
+			       const struct fman_pcd_manip_params *p,
+			       u8 *out_op)
+{
+	void __iomem *hmct = manip->hmct;
+	u32 cmd;
+	u32 payload;
+	bool emit_payload = false;
+
+	/* Validate DSCP range early - the silicon only consumes 6 bits
+	 * but the ABI exposes a u8; reject obviously-wrong values up
+	 * front so callers get -EINVAL at create-time rather than a
+	 * silently truncated DSCP at line rate.
+	 */
+	if (p->ipv4_forward.rewrite_dscp &&
+	    p->ipv4_forward.new_dscp > FMAN_PCD_IPV4_DSCP_MAX)
+		return NULL;
+
+	/* IPV4_UPDATE with the TTL bit always set (this manip's
+	 * purpose is L3 forwarding; TTL-- is mandatory).
+	 * Cross-ref SDK fm_manip.c case
+	 * e_FM_PCD_MANIP_HDR_FIELD_UPDATE_IPV4 (TTL path).
+	 */
+	cmd  = (u32)FMAN_PCD_HMCD_OP_IPV4_UPDATE
+		<< FMAN_PCD_HMCD_OC_SHIFT;
+	cmd |= FMAN_PCD_HMCD_IPV4_UPDATE_TTL;
+
+	/* The IPv4 header checksum recompute bit is intrinsically
+	 * required when TTL is decremented (the cksum-byte spans the
+	 * TTL byte).  We honour the caller's recompute_cksum hint and
+	 * additionally enforce it whenever TTL or DSCP is touched -
+	 * passing recompute_cksum=false on this manip is a
+	 * silently-wrong API misuse that drops every forwarded packet
+	 * downstream, so we set the bit unconditionally rather than
+	 * relying on the caller.
+	 */
+	cmd |= FMAN_PCD_HMCD_IP_L4_CS_CALC;
+
+	if (p->ipv4_forward.rewrite_dscp) {
+		cmd |= FMAN_PCD_HMCD_IPV4_UPDATE_DSCP;
+		emit_payload = true;
+	}
+
+	iowrite32be(cmd, hmct);
+
+	if (emit_payload) {
+		payload = ((u32)p->ipv4_forward.new_dscp)
+			<< FMAN_PCD_HMCD_IPV4_DSCP_SHIFT;
+		iowrite32be(payload, hmct + 4);
+	}
+
+	*out_op = FMAN_PCD_HMAN_OC_IP_MANIP;
+	return hmct;
+}
+
 /**
  * fman_pcd_manip_create() - program one header-manip template.
  *
@@ -591,6 +651,7 @@ fman_pcd_manip_create(struct fman_pcd *pcd,
 	case FMAN_PCD_MANIP_VLAN_PUSH:
 	case FMAN_PCD_MANIP_VLAN_POP:
 	case FMAN_PCD_MANIP_TTL_DEC:
+	case FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD:
 		break;
 	default:
 		return ERR_PTR(-EINVAL);
@@ -680,6 +741,11 @@ fman_pcd_manip_create(struct fman_pcd *pcd,
 	case FMAN_PCD_MANIP_TTL_DEC:
 		last_cmd = manip_encode_ttl_dec(manip, &op);
 		break;
+	case FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD:
+		last_cmd = manip_encode_field_update_ipv4_forward(manip,
+								  params,
+								  &op);
+		break;
 	default:
 		/* type already validated above; unreachable. */
 		last_cmd = NULL;
diff --git a/drivers/net/ethernet/freescale/fman/tests/fman_pcd_manip_test.c b/drivers/net/ethernet/freescale/fman/tests/fman_pcd_manip_test.c
index 8b27e37..7d191ce 100644
--- a/drivers/net/ethernet/freescale/fman/tests/fman_pcd_manip_test.c
+++ b/drivers/net/ethernet/freescale/fman/tests/fman_pcd_manip_test.c
@@ -292,6 +292,110 @@ static void manip_encode_nat_v4_empty_test(struct kunit *test)
 	KUNIT_EXPECT_PTR_EQ(test, last_cmd, NULL);
 }
 
+/* ---- TEST: MANIP_FIELD_UPDATE_IPV4_FORWARD (v1.2) ------------- */
+/*
+ * Path A's CC-key inline-MANIP L3-forward primitive: TTL-- with
+ * auto-cksum recompute, no DSCP rewrite.  Encoded as a single
+ * IPV4_UPDATE command word with TTL+CS_CALC bits set, no inline
+ * payload.
+ *
+ * Silicon-fact pin: the encoded word MUST equal 0x0c040001 because
+ *   (OP_IPV4_UPDATE=0x0c) << 24
+ *   | IP_L4_CS_CALC=0x00040000
+ *   | IPV4_UPDATE_TTL=0x00000001
+ * = 0x0c040001.  If the encoder ever stops setting CS_CALC on
+ * TTL-decrement the silicon will forward frames with a stale IPv4
+ * header checksum and every downstream switch will drop them - this
+ * test makes that regression a build-time failure.
+ */
+static void manip_encode_field_update_ipv4_forward_ttl_test(struct kunit *test)
+{
+	void __iomem *hmct = hmct_scratch_alloc(test);
+	struct fman_pcd_manip stub = { .hmct = hmct };
+	struct fman_pcd_manip_params p = {
+		.type = FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD,
+		.ipv4_forward = {
+			.recompute_cksum = true,
+			.rewrite_dscp = false,
+			.new_dscp = 0,
+		},
+	};
+	void __iomem *last_cmd;
+	u8 op = 0;
+
+	last_cmd = manip_encode_field_update_ipv4_forward(&stub, &p, &op);
+	KUNIT_ASSERT_NOT_NULL(test, last_cmd);
+	KUNIT_EXPECT_EQ(test, op, (u8)FMAN_PCD_HMAN_OC_IP_MANIP);
+
+	KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x00), 0x0c040001u);
+	/* No inline payload when rewrite_dscp == false. */
+	KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x04), 0u);
+
+	KUNIT_EXPECT_PTR_EQ(test, last_cmd, hmct + 0x00);
+}
+
+/* ---- TEST: MANIP_FIELD_UPDATE_IPV4_FORWARD + DSCP (v1.2) ------ */
+/*
+ * Same primitive but with the DSCP-rewrite arm exercised.  Verifies:
+ *   - the DSCP operand bit (0x04) is OR'd into the command word
+ *   - the inline payload word carries the DSCP value left-shifted
+ *     to bit position 26 (HMCD_IPV4_DSCP_SHIFT)
+ *   - the auto-cksum bit is ALSO set (TTL is touched -> cksum must
+ *     be recomputed)
+ *   - DSCP > 63 is rejected at the encoder (silicon only has 6 bits)
+ */
+static void manip_encode_field_update_ipv4_forward_dscp_test(struct kunit *test)
+{
+	void __iomem *hmct = hmct_scratch_alloc(test);
+	struct fman_pcd_manip stub = { .hmct = hmct };
+	struct fman_pcd_manip_params p_dscp_ef = {
+		.type = FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD,
+		.ipv4_forward = {
+			.recompute_cksum = true,
+			.rewrite_dscp    = true,
+			.new_dscp        = 46,  /* EF, RFC 3246 */
+		},
+	};
+	struct fman_pcd_manip_params p_dscp_bad = {
+		.type = FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD,
+		.ipv4_forward = {
+			.recompute_cksum = true,
+			.rewrite_dscp    = true,
+			.new_dscp        = 64,  /* >6 bits */
+		},
+	};
+	void __iomem *last_cmd;
+	u8 op = 0;
+	u32 expected_cmd;
+	u32 expected_payload;
+
+	last_cmd = manip_encode_field_update_ipv4_forward(&stub,
+							  &p_dscp_ef,
+							  &op);
+	KUNIT_ASSERT_NOT_NULL(test, last_cmd);
+	KUNIT_EXPECT_EQ(test, op, (u8)FMAN_PCD_HMAN_OC_IP_MANIP);
+
+	expected_cmd = ((u32)FMAN_PCD_HMCD_OP_IPV4_UPDATE
+			<< FMAN_PCD_HMCD_OC_SHIFT) |
+		       FMAN_PCD_HMCD_IP_L4_CS_CALC |
+		       FMAN_PCD_HMCD_IPV4_UPDATE_TTL |
+		       FMAN_PCD_HMCD_IPV4_UPDATE_DSCP;
+	KUNIT_EXPECT_EQ(test, expected_cmd, 0x0c040005u);
+	KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x00), expected_cmd);
+
+	expected_payload = ((u32)46u) << FMAN_PCD_HMCD_IPV4_DSCP_SHIFT;
+	KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x04), expected_payload);
+
+	KUNIT_EXPECT_PTR_EQ(test, last_cmd, hmct + 0x00);
+
+	/* Out-of-range DSCP must be rejected. */
+	KUNIT_EXPECT_PTR_EQ(test,
+			    manip_encode_field_update_ipv4_forward(&stub,
+								   &p_dscp_bad,
+								   &op),
+			    NULL);
+}
+
 /* ---- TEST: HMCD_LAST OR-in (silicon walker termination) ------- */
 /*
  * fman_pcd_manip_create() ORs HMCD_LAST=0x00800000 into the last
@@ -328,6 +432,8 @@ static struct kunit_case fman_pcd_manip_test_cases[] = {
 	KUNIT_CASE(manip_encode_vlan_pop_test),
 	KUNIT_CASE(manip_encode_ttl_dec_test),
 	KUNIT_CASE(manip_encode_nat_v4_empty_test),
+	KUNIT_CASE(manip_encode_field_update_ipv4_forward_ttl_test),
+	KUNIT_CASE(manip_encode_field_update_ipv4_forward_dscp_test),
 	KUNIT_CASE(manip_hmcd_last_or_test),
 	{}
 };
diff --git a/include/linux/fsl/fman_pcd.h b/include/linux/fsl/fman_pcd.h
index ce4a259..e3c3dde 100644
--- a/include/linux/fsl/fman_pcd.h
+++ b/include/linux/fsl/fman_pcd.h
@@ -32,8 +32,15 @@ struct fman;
 /*
  * ABI versioning macro.  Bumped when the public surface changes in an
  * incompatible way.  Consumers (ask.ko) can #if-guard against this.
+ *
+ * Version history:
+ *   1 - PR14a..g: NAT_V4/V6, VLAN_PUSH/POP, TTL_DEC manip tags.
+ *   2 - v1.2 (PR14i, Path A): adds the
+ *       MANIP_FIELD_UPDATE_IPV4_FORWARD encoder used by the
+ *       FORWARD_FQ_WITH_MANIP CC-key action atom for L3
+ *       forwarding (TTL-- + cksum + optional DSCP rewrite).
  */
-#define FMAN_PCD_API_VERSION	1
+#define FMAN_PCD_API_VERSION 2
 
 /*
  * Opaque handles.  All defined in their respective .c files.
@@ -549,11 +556,18 @@ void fman_pcd_cc_tree_destroy(struct fman_pcd_cc_tree *tree);
 
 /**
  * enum fman_pcd_manip_type - tagged-union discriminator for manip params.
- * @FMAN_PCD_MANIP_NAT_V4:     IPv4 SNAT/DNAT (rewrite SA and/or DA + L4 port)
- * @FMAN_PCD_MANIP_NAT_V6:     IPv6 SNAT/DNAT (rewrite SA and/or DA + L4 port)
- * @FMAN_PCD_MANIP_VLAN_PUSH:  prepend an 802.1Q tag
- * @FMAN_PCD_MANIP_VLAN_POP:   strip outer 802.1Q tag
- * @FMAN_PCD_MANIP_TTL_DEC:    decrement IPv4 TTL / IPv6 Hop Limit
+ * @FMAN_PCD_MANIP_NAT_V4:               IPv4 SNAT/DNAT (rewrite SA/DA + L4 port)
+ * @FMAN_PCD_MANIP_NAT_V6:               IPv6 SNAT/DNAT (rewrite SA/DA + L4 port)
+ * @FMAN_PCD_MANIP_VLAN_PUSH:            prepend an 802.1Q tag
+ * @FMAN_PCD_MANIP_VLAN_POP:             strip outer 802.1Q tag
+ * @FMAN_PCD_MANIP_TTL_DEC:              decrement IPv4 TTL / IPv6 Hop Limit
+ * @FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD:
+ *                                       TTL-decrement + IPv4 header-checksum
+ *                                       recompute (and optional DSCP rewrite)
+ *                                       bundled into a single template.
+ *                                       Consumed by Path A's CC-key
+ *                                       FORWARD_FQ_WITH_MANIP action atom.
+ *                                       v1.2.
  *
  * Hardware-supported manip kinds for ASK2 v1.0 per spec sec 13.3.
  * GRE / VXLAN encap is deferred to v1.1.  Multiple manips per flow
@@ -566,6 +580,7 @@ FMAN_PCD_MANIP_NAT_V6,
 FMAN_PCD_MANIP_VLAN_PUSH,
 FMAN_PCD_MANIP_VLAN_POP,
 FMAN_PCD_MANIP_TTL_DEC,
+FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD,
 };
 
 /**
@@ -590,6 +605,20 @@ FMAN_PCD_MANIP_TTL_DEC,
  * @vlan_push.tci:          full 16-bit TCI to push (PCP + DEI + VID)
  * @vlan_push.tpid:         EtherType for the pushed tag, normally 0x8100
  *
+ * @ipv4_forward.recompute_cksum:
+ *                          if true, set the silicon's IPv4 header-checksum
+ *                          recompute bit (HMCD_IP_L4_CS_CALC).  The encoder
+ *                          enforces this unconditionally (TTL-- always
+ *                          touches the cksum byte) regardless of the
+ *                          caller's value, but the field is retained for
+ *                          ABI clarity.
+ * @ipv4_forward.rewrite_dscp:
+ *                          if true, also rewrite the DSCP bits of the TOS
+ *                          byte to @ipv4_forward.new_dscp (only the 6 DSCP
+ *                          bits; ECN bits are preserved by silicon)
+ * @ipv4_forward.new_dscp:  new 6-bit DSCP value (0..63); unread when
+ *                          @rewrite_dscp is false
+ *
  * @vlan_pop has no payload.  @ttl_dec has no payload.
  *
  * All addresses / ports stored in host byte order for caller convenience;
@@ -622,6 +651,11 @@ struct {
 __be16 tci;
 __be16 tpid;
 } vlan_push;
+struct {
+bool recompute_cksum;
+bool rewrite_dscp;
+u8 new_dscp;
+} ipv4_forward;
 };
 };
 
