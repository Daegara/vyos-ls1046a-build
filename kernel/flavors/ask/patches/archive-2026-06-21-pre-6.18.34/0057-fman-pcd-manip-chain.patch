From: ci <ci@local>
Date: Sun, 24 May 2026 08:42:32 +0000
Subject: [PATCH] patches/0057-fman-pcd-manip-chain.patch

---
 .../ethernet/freescale/fman/fman_pcd_manip.c  | 269 ++++++++++++++++++
 include/linux/fsl/fman_pcd.h                  |  44 +++
 2 files changed, 313 insertions(+)

diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
index fe5a3a1..027f7cd 100644
--- a/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
@@ -179,6 +179,14 @@
 #define FMAN_PCD_HMCD_IPV4_UPDATE_TTL	0x00000001u
 #define FMAN_PCD_HMCD_IPV4_UPDATE_DST	0x00000020u
 #define FMAN_PCD_HMCD_IPV4_UPDATE_SRC	0x00000040u
+/* PR14i v1.2: DSCP rewrite for IPV4_FORWARD encoder (RM 8.7.5 TOS).
+ * IPv4_UPDATE opcode operand bit 0x04 selects DSCP rewrite; the new
+ * DSCP value lives in bits[31:26] of the inline payload word.  Silicon
+ * only consumes 6 bits, so values >63 are rejected at the encoder.
+ */
+#define FMAN_PCD_HMCD_IPV4_UPDATE_DSCP	0x00000004u
+#define FMAN_PCD_HMCD_IPV4_DSCP_SHIFT	26
+#define FMAN_PCD_IPV4_DSCP_MAX		63u
 
 /* IPv6 update operand bits (HMCD_IPV6_UPDATE_*) */
 #define FMAN_PCD_HMCD_IPV6_UPDATE_HL	0x00000001u
@@ -238,6 +246,14 @@
  * the v1.0 ASK2 fast-flow path; the cascade and stats fields are
  * reintroduced piecemeal in later milestones (M3+).
  */
+/* PR14x chain-primitive sizing constants.  RM 8.11.4 quotes 4 as the
+ * OH-port AD-chain limit; we adopt the same ceiling.  Worst-case chain
+ * = 4 manips * 56 B HMCT = 224 B, rounded up to 256 B (one MURAM slab
+ * at gen_pool min_alloc_order=8).
+ */
+#define FMAN_PCD_MANIP_CHAIN_MAX_MANIPS	4
+#define FMAN_PCD_HMCT_CHAIN_SIZE		256u
+
 struct fman_pcd_manip {
 	struct list_head		node;
 	struct fman_pcd		*pcd;
@@ -247,6 +263,13 @@ struct fman_pcd_manip {
 	unsigned long			hmct_off;
 	void __iomem			*hmct;
 	size_t				hmct_sz;
+	/* PR14x: bytes actually written into @hmct by the variant encoder
+	 * (or copied in by chain_create).  Always <= @hmct_sz.  Used by
+	 * fman_pcd_manip_chain_create() to memcpy just the active command
+	 * sequence of each source manip into a new chain HMCT, instead of
+	 * dragging the slack of zero-padding along with it.
+	 */
+	size_t				hmct_used;
 	spinlock_t			lock;
 };
 
@@ -859,6 +882,252 @@ unsigned long fman_pcd_manip_hmtd_off(const struct fman_pcd_manip *manip)
 	return manip->hmtd_off;
 }
 
+/* ------------------------------------------------------------------ */
+/* PR14x: chained-manip primitive                                     */
+/* ------------------------------------------------------------------ */
+
+/*
+ * Silicon facts driving fman_pcd_manip_chain_create():
+ *
+ *  - The FMan header-manip walker dispatches per-command-word, not per
+ *    HMTD.  The HMTD's opCode is the family selector that gates which
+ *    silicon micro-program runs the chain (HMAN_OC_IP_MANIP=0x34 if
+ *    any contained command is an IP/L4 mutation, HMAN_OC=0x35
+ *    otherwise).  The walker terminates at the first HMCD_LAST bit it
+ *    encounters in a command word.
+ *
+ *  - Therefore "chaining" N manips is exactly: allocate a fresh
+ *    HMTD+HMCT pair, memcpy each contained manip's active HMCT bytes
+ *    (offset 0 .. hmct_used, recorded by the per-variant encoders)
+ *    into the new HMCT consecutively, CLEAR the HMCD_LAST bit on the
+ *    first HMCD_LAST-bearing word of every contained manip except
+ *    the last, and KEEP HMCD_LAST set on the final source manip's
+ *    last word (which is now the chain's last word).  Finalise the
+ *    new HMTD with the union opCode (IP_MANIP if any source is
+ *    IP_MANIP, OC otherwise).
+ *
+ *  - The source manips are NOT mutated.  Their HMCT bytes remain
+ *    valid (a chain MEMCPIES them, it does not consume them) so the
+ *    same source manip handle may be referenced by N chains
+ *    simultaneously.
+ *
+ *  - The contained manips' lifetime is the CALLER'S responsibility.
+ *    fman_pcd_manip_chain_destroy() frees the chain's own HMTD+HMCT
+ *    but does NOT touch the source manips.
+ *
+ *  - Why no new enum / no new action arm: the existing
+ *    FMAN_PCD_ACTION_MANIPULATE union arm in struct fman_pcd_action
+ *    consumes a struct fman_pcd_manip *.  A chain handle IS a
+ *    struct fman_pcd_manip * (with a fresh HMTD+HMCT containing the
+ *    concatenated commands) so cc_encode_ad()'s existing arm picks
+ *    it up unchanged.
+ *
+ * RM 8.7.5 paragraphs 2 + 4 (HMTD + HMCT layout, identical for
+ * single and chained manips) + cross-ref SDK fm_manip.c BuildHmct()
+ * with multi-command output (same byte layout).
+ */
+struct fman_pcd_manip *
+fman_pcd_manip_chain_create(struct fman_pcd *pcd,
+				struct fman_pcd_manip * const *manips,
+				u8 n_manips)
+{
+	struct fman_pcd_manip *chain;
+	struct muram_info *muram;
+	struct mutex *pcd_lock;
+	unsigned long off;
+	unsigned long flags;
+	void __iomem *vb;
+	void __iomem *cur;
+	size_t total_bytes = 0;
+	size_t hmct_used_running;
+	u32 first_word;
+	u32 last_word;
+	u8 op = FMAN_PCD_HMAN_OC;
+	u16 cfg;
+	u8 i;
+	long err;
+
+	if (!pcd || !manips || n_manips == 0 ||
+		n_manips > FMAN_PCD_MANIP_CHAIN_MAX_MANIPS)
+		return ERR_PTR(-EINVAL);
+
+	for (i = 0; i < n_manips; i++) {
+		if (!manips[i])
+			return ERR_PTR(-EINVAL);
+		if (manips[i]->hmct_used == 0 ||
+			manips[i]->hmct_used > manips[i]->hmct_sz)
+			return ERR_PTR(-EINVAL);
+		if (manips[i]->pcd != pcd)
+			return ERR_PTR(-EINVAL);
+		total_bytes += manips[i]->hmct_used;
+	}
+	if (total_bytes > FMAN_PCD_HMCT_CHAIN_SIZE)
+		return ERR_PTR(-E2BIG);
+
+	muram = fman_get_muram(fman_pcd_get_fman(pcd));
+	if (!muram)
+		return ERR_PTR(-ENXIO);
+
+	chain = kzalloc(sizeof(*chain), GFP_KERNEL);
+	if (!chain)
+		return ERR_PTR(-ENOMEM);
+
+	INIT_LIST_HEAD(&chain->node);
+	spin_lock_init(&chain->lock);
+	chain->pcd = pcd;
+	chain->type = manips[0]->type;
+
+	off = fman_pcd_muram_alloc(pcd, FMAN_PCD_HMTD_SIZE);
+	if (IS_ERR_VALUE(off)) {
+		err = (long)off;
+		kfree(chain);
+		return ERR_PTR(err);
+	}
+	vb = (void __iomem *)fman_muram_offset_to_vbase(muram, off);
+	if (!vb) {
+		fman_pcd_muram_free(pcd, off, FMAN_PCD_HMTD_SIZE);
+		kfree(chain);
+		return ERR_PTR(-ENXIO);
+	}
+	chain->hmtd_off = off;
+	chain->hmtd = vb;
+	memset_io(vb, 0, FMAN_PCD_HMTD_SIZE);
+
+	off = fman_pcd_muram_alloc(pcd, FMAN_PCD_HMCT_CHAIN_SIZE);
+	if (IS_ERR_VALUE(off)) {
+		err = (long)off;
+		fman_pcd_muram_free(pcd, chain->hmtd_off,
+					FMAN_PCD_HMTD_SIZE);
+		kfree(chain);
+		return ERR_PTR(err);
+	}
+	vb = (void __iomem *)fman_muram_offset_to_vbase(muram, off);
+	if (!vb) {
+		fman_pcd_muram_free(pcd, off, FMAN_PCD_HMCT_CHAIN_SIZE);
+		fman_pcd_muram_free(pcd, chain->hmtd_off,
+					FMAN_PCD_HMTD_SIZE);
+		kfree(chain);
+		return ERR_PTR(-ENXIO);
+	}
+	chain->hmct_off = off;
+	chain->hmct = vb;
+	chain->hmct_sz = FMAN_PCD_HMCT_CHAIN_SIZE;
+	memset_io(vb, 0, FMAN_PCD_HMCT_CHAIN_SIZE);
+
+	spin_lock_irqsave(&chain->lock, flags);
+
+	cur = vb;
+	hmct_used_running = 0;
+	for (i = 0; i < n_manips; i++) {
+		struct fman_pcd_manip *src = manips[i];
+		size_t used = src->hmct_used;
+		unsigned int w;
+		void __iomem *seg_start = cur;
+		void __iomem *seg_last_cmd = NULL;
+		unsigned int n_words = used / 4;
+
+		/*
+		 * memcpy_fromio reads source MURAM into a kernel buffer; we
+		 * then iowrite32be the words back into the chain HMCT to
+		 * preserve byte ordering and avoid iomem-to-iomem memcpy
+		 * (not portable across arches).
+		 */
+		{
+			u32 buf[FMAN_PCD_HMCT_CHAIN_SIZE / 4];
+			unsigned int j;
+
+			memcpy_fromio(buf, src->hmct, used);
+			for (j = 0; j < n_words; j++)
+				iowrite32be(be32_to_cpu(
+					(__force __be32)buf[j]),
+					cur + (j * 4));
+		}
+
+		for (w = 0; w < n_words; w++) {
+			void __iomem *wp = seg_start + (w * 4);
+			u32 v = ioread32be(wp);
+
+			if (v & FMAN_PCD_HMCD_LAST) {
+				seg_last_cmd = wp;
+				break;
+			}
+		}
+
+		if (!seg_last_cmd) {
+			spin_unlock_irqrestore(&chain->lock, flags);
+			fman_pcd_muram_free(pcd, chain->hmct_off,
+						chain->hmct_sz);
+			fman_pcd_muram_free(pcd, chain->hmtd_off,
+						FMAN_PCD_HMTD_SIZE);
+			kfree(chain);
+			return ERR_PTR(-EINVAL);
+		}
+
+		if (i < n_manips - 1) {
+			u32 v = ioread32be(seg_last_cmd);
+
+			iowrite32be(v & ~FMAN_PCD_HMCD_LAST,
+					seg_last_cmd);
+		}
+
+		switch (manips[i]->type) {
+		case FMAN_PCD_MANIP_NAT_V4:
+		case FMAN_PCD_MANIP_NAT_V6:
+		case FMAN_PCD_MANIP_TTL_DEC:
+		case FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD:
+			op = FMAN_PCD_HMAN_OC_IP_MANIP;
+			break;
+		default:
+			break;
+		}
+
+		cur += used;
+		hmct_used_running += used;
+	}
+	chain->hmct_used = hmct_used_running;
+
+	first_word = ioread32be(vb);
+	last_word  = ioread32be(vb + hmct_used_running - 4);
+	if (first_word == 0xffffffffu || last_word == 0xffffffffu) {
+		spin_unlock_irqrestore(&chain->lock, flags);
+		fman_pcd_muram_free(pcd, chain->hmct_off,
+					chain->hmct_sz);
+		fman_pcd_muram_free(pcd, chain->hmtd_off,
+					FMAN_PCD_HMTD_SIZE);
+		kfree(chain);
+		return ERR_PTR(-ENXIO);
+	}
+
+	cfg = FMAN_PCD_HMTD_CFG_TYPE | FMAN_PCD_HMTD_CFG_EXT_HMCT;
+	iowrite16be(cfg, chain->hmtd + FMAN_PCD_HMTD_OFF_CFG);
+	iowrite32be((u32)chain->hmct_off,
+			chain->hmtd + FMAN_PCD_HMTD_OFF_HMCD_BASE);
+	iowrite8(op, chain->hmtd + FMAN_PCD_HMTD_OFF_OPCODE);
+
+	spin_unlock_irqrestore(&chain->lock, flags);
+
+	pcd_lock = fman_pcd_get_lock(pcd);
+	mutex_lock(pcd_lock);
+	list_add_tail(&chain->node, fman_pcd_get_manip_list(pcd));
+	mutex_unlock(pcd_lock);
+
+	return chain;
+}
+EXPORT_SYMBOL_GPL(fman_pcd_manip_chain_create);
+
+/**
+ * fman_pcd_manip_chain_destroy() - drop a chain handle.
+ *
+ * Equivalent to fman_pcd_manip_destroy() on the chain handle; provided
+ * as a separate symbol to make cookie-cleanup pairing self-documenting
+ * in consumer code (ask.ko per-flow remove path).
+ */
+void fman_pcd_manip_chain_destroy(struct fman_pcd_manip *chain)
+{
+	fman_pcd_manip_destroy(chain);
+}
+EXPORT_SYMBOL_GPL(fman_pcd_manip_chain_destroy);
+
 #if IS_ENABLED(CONFIG_FSL_FMAN_PCD_KUNIT_TEST)
 /*
  * KUnit suite lives in tests/fman_pcd_manip_test.c and is #include'd
diff --git a/include/linux/fsl/fman_pcd.h b/include/linux/fsl/fman_pcd.h
index 43eba33..ea0cb9d 100644
--- a/include/linux/fsl/fman_pcd.h
+++ b/include/linux/fsl/fman_pcd.h
@@ -694,6 +694,50 @@ fman_pcd_manip_create(struct fman_pcd *pcd,
  */
 void fman_pcd_manip_destroy(struct fman_pcd_manip *manip);
 
+/**
+ * fman_pcd_manip_chain_create() - bundle up to 4 manips into one HMTD/HMCT.
+ * @pcd:      parent FMan PCD context.
+ * @manips:   array of @n_manips contained-manip handles, in execution
+ *            order.  Each handle's underlying HMCT command bytes are
+ *            memcpied into the chain's fresh HMCT; the source handles
+ *            are NOT consumed and may be reused across other chains
+ *            and/or other CC keys.
+ * @n_manips: 1..4 source manips.  4 = silicon limit per RM 8.11.4.
+ *
+ * Returns a handle that is a struct fman_pcd_manip * carrying a fresh
+ * MURAM-resident HMTD + (larger) HMCT containing the concatenated
+ * command stream of all @n_manips source manips, with HMCD_LAST
+ * stamped on the final word and cleared on every intermediate source
+ * manip's last word.  The chain handle is consumable by the existing
+ * FMAN_PCD_ACTION_MANIPULATE arm of struct fman_pcd_action just like
+ * a handle from fman_pcd_manip_create() - no API additions needed
+ * elsewhere.
+ *
+ * Locking: takes pcd->lock.  May sleep (MURAM alloc).
+ *
+ * Return: chain handle on success, ERR_PTR(-EINVAL) on bad args,
+ * ERR_PTR(-E2BIG) if the concatenated HMCT would exceed the chain
+ * HMCT region (256 B), ERR_PTR(-ENOMEM)/-ENOSPC if MURAM is
+ * exhausted, ERR_PTR(-ENXIO) if MURAM mapping is degenerate.
+ */
+struct fman_pcd_manip *
+fman_pcd_manip_chain_create(struct fman_pcd *pcd,
+			    struct fman_pcd_manip * const *manips,
+			    u8 n_manips);
+
+/**
+ * fman_pcd_manip_chain_destroy() - drop a chain handle.
+ * @chain: handle from fman_pcd_manip_chain_create().  NULL-safe.
+ *
+ * Tears down the chain's OWN HMTD + HMCT MURAM regions and frees
+ * the handle.  The contained source manips are NOT touched - their
+ * lifetime is the caller's responsibility.
+ *
+ * Locking: takes pcd->lock.  May sleep.
+ */
+void fman_pcd_manip_chain_destroy(struct fman_pcd_manip *chain);
+
+
