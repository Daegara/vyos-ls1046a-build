diff --git a/drivers/net/ethernet/freescale/fman/fman.c b/drivers/net/ethernet/freescale/fman/fman.c
index 9b8956fd9..b0c6cd752 100644
--- a/drivers/net/ethernet/freescale/fman/fman.c
+++ b/drivers/net/ethernet/freescale/fman/fman.c
@@ -20,6 +20,8 @@
 
 #include "fman.h"
 #include "fman_muram.h"
+
+#include <linux/fsl/fman_pcd.h>
 #include "fman_keygen.h"
 
 /* General defines */
@@ -2509,6 +2511,47 @@ struct muram_info *fman_get_muram(struct fman *fman)
 }
 EXPORT_SYMBOL_GPL(fman_get_muram);
 
+/**
+ * fman_get_pcd
+ * @fman: A pointer to FMan device
+ *
+ * Return: A pointer to the FMan PCD subsystem handle (struct fman_pcd) or
+ *         NULL if PCD init failed at probe time. Used by ask.ko to install
+ *         exact-match flow rules into the FMan PCD pipeline. PR14a.
+ */
+struct fman_pcd *fman_get_pcd(struct fman *fman)
+{
+	return fman ? fman->pcd : NULL;
+}
+EXPORT_SYMBOL_GPL(fman_get_pcd);
+
+/**
+ * fman_get_dev
+ * @fman: A pointer to FMan device
+ *
+ * Return: The struct device that owns this FMan instance, or NULL. Used
+ *         by fman_pcd.c for dev_err/info without forcing fman_pcd to walk
+ *         dts_params directly. PR14a.
+ */
+struct device *fman_get_dev(struct fman *fman)
+{
+	return fman ? fman->dev : NULL;
+}
+EXPORT_SYMBOL_GPL(fman_get_dev);
+
+/**
+ * fman_get_id
+ * @fman: A pointer to FMan device
+ *
+ * Return: The FMan instance id (0 on LS1046A's single FMan; non-zero on
+ *         multi-FMan SoCs). Used for debugfs subdirectory naming. PR14a.
+ */
+u8 fman_get_id(struct fman *fman)
+{
+	return fman ? fman->dts_params.id : 0;
+}
+EXPORT_SYMBOL_GPL(fman_get_id);
+
 
 
 #ifdef CONFIG_DPAA_ERRATUM_A050385
@@ -2884,6 +2927,31 @@ static int fman_probe(struct platform_device *of_dev)
 
 	dev_set_drvdata(dev, fman);
 
+	/*
+	 * Initialise the PCD subsystem (PR14a). fman->muram is live at this
+	 * point (fman_config() called fman_muram_init()). On failure leave
+	 * fman->pcd as NULL; consumer (ask.ko via fman_get_pcd()) handles
+	 * gracefully. Teardown registered with devres so unbind/probe-fail
+	 * paths run fman_pcd_release() automatically.
+	 */
+	{
+		struct fman_pcd *pcd = fman_pcd_init(fman);
+
+		if (IS_ERR(pcd)) {
+			dev_warn(dev,
+				 "FMan%d: PCD subsystem init failed (err %ld) - continuing without PCD\n",
+				 fman->dts_params.id, PTR_ERR(pcd));
+		} else {
+			fman->pcd = pcd;
+			if (devm_add_action_or_reset(dev,
+				(void (*)(void *))fman_pcd_release, pcd)) {
+				dev_warn(dev, "FMan%d: cannot register PCD teardown\n",
+					 fman->dts_params.id);
+				fman->pcd = NULL;
+			}
+		}
+	}
+
 	dev_dbg(dev, "FMan%d probed\n", fman->dts_params.id);
 
 	return 0;
