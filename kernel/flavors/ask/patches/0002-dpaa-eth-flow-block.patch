From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: VyOS LS1046A maintainers <ask20@vyos-ls1046a-build>
Date: Tue, 13 May 2026 01:45:00 +0000
Subject: [PATCH 2/3] net: dpaa: register external flow-offload backend

The DPAA1 (fsl_dpa) Ethernet driver does not implement tc-flower /
nf_flow_table HW offload itself. On NXP LS1046A, the FMan 210-series
microcode running on an offline parser provides hardware flow offload
(see specs/ask2-rewrite-spec.md \10 for the broader design).

The driver lives in vmlinux (FSL_DPAA=y is mandatory on this board
because FMan must initialise before rootfs mount), while the
offload backend (ask.ko) is a module. ask.ko already depends on
FSL_DPAA via Kconfig, so the dpaa driver cannot directly call into
ask.ko symbols without creating a circular module dependency.

Introduce a single-slot RCU-protected registration API:

    int dpaa_register_flow_offload_handler(
            const struct dpaa_flow_offload_ops *ops);
    int dpaa_unregister_flow_offload_handler(
            const struct dpaa_flow_offload_ops *ops);

that the backend module calls at module init/exit. dpaa_setup_tc()
dispatches TC_SETUP_BLOCK to the registered backend under
rcu_read_lock(); MQPRIO continues to be handled inline as before.
If no backend is registered, TC_SETUP_BLOCK returns -EOPNOTSUPP and
the upper layer falls back to software flow_offload.

The ops struct carries a struct module *owner; register takes a
module reference and unregister synchronize_rcu()s before dropping
it, so dispatch never races with module removal.

No behaviour change for in-tree dpaa users: MQPRIO, ndo_setup_tc
entry surface, and all other ndo_* operations are unchanged. The
structure is one new header, two new EXPORT_SYMBOL_GPL symbols, one
new __rcu pointer slot, and a 16-line block at the top of
dpaa_setup_tc().

The ASK2 backend implements ops->setup_tc_block via the existing
ask_flow_offload_setup_tc() entry point in kernel/flavors/ask/
oot-modules/ask/ask_flow_offload.c (PR8, M1.4).

---
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c
index 3edc8d1..c564ee0 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c
@@ -36,6 +36,8 @@
 #include "fman_port.h"
 #include "mac.h"
 #include "dpaa_eth.h"
+#include <linux/fsl/dpaa_flow_offload.h>
+#include <net/flow_offload.h>
 
 /* CREATE_TRACE_POINTS only needs to be defined once. Other dpaa files
  * using trace events only need to #include <trace/events/sched.h>
@@ -367,6 +369,73 @@ static void dpaa_get_stats64(struct net_device *net_dev,
 	}
 }
 
+/* ASK2 — external flow-offload backend registration.
+ *
+ * Single-slot. The backend (ask.ko) registers at module init and
+ * unregisters at module exit. dpaa_setup_tc() RCU-derefs the slot
+ * for every TC_SETUP_BLOCK to dispatch flow_block_offload events.
+ *
+ * See include/linux/fsl/dpaa_flow_offload.h for the contract and
+ * specs/ask2-rewrite-spec.md Â§10 for the design rationale.
+ */
+static const struct dpaa_flow_offload_ops __rcu *dpaa_fo_ops_slot;
+static DEFINE_SPINLOCK(dpaa_fo_ops_lock);
+
+int dpaa_register_flow_offload_handler(const struct dpaa_flow_offload_ops *ops)
+{
+	const struct dpaa_flow_offload_ops *cur;
+
+	if (!ops || !ops->setup_tc_block)
+		return -EINVAL;
+
+	spin_lock(&dpaa_fo_ops_lock);
+	cur = rcu_dereference_protected(dpaa_fo_ops_slot,
+					lockdep_is_held(&dpaa_fo_ops_lock));
+	if (cur) {
+		spin_unlock(&dpaa_fo_ops_lock);
+		return -EBUSY;
+	}
+	if (ops->owner && !try_module_get(ops->owner)) {
+		spin_unlock(&dpaa_fo_ops_lock);
+		return -ENODEV;
+	}
+	rcu_assign_pointer(dpaa_fo_ops_slot, ops);
+	spin_unlock(&dpaa_fo_ops_lock);
+	return 0;
+}
+EXPORT_SYMBOL_GPL(dpaa_register_flow_offload_handler);
+
+int dpaa_unregister_flow_offload_handler(const struct dpaa_flow_offload_ops *ops)
+{
+	const struct dpaa_flow_offload_ops *cur;
+
+	if (!ops)
+		return -EINVAL;
+
+	spin_lock(&dpaa_fo_ops_lock);
+	cur = rcu_dereference_protected(dpaa_fo_ops_slot,
+					lockdep_is_held(&dpaa_fo_ops_lock));
+	if (cur != ops) {
+		spin_unlock(&dpaa_fo_ops_lock);
+		return -EINVAL;
+	}
+	rcu_assign_pointer(dpaa_fo_ops_slot, NULL);
+	spin_unlock(&dpaa_fo_ops_lock);
+
+	/*
+	 * Wait for any concurrent dpaa_setup_tc() readers to drop the
+	 * old pointer before letting the caller free its ops struct or
+	 * unload its module. The dispatch path runs entirely under
+	 * rcu_read_lock(), so a single grace period is sufficient.
+	 */
+	synchronize_rcu();
+
+	if (ops->owner)
+		module_put(ops->owner);
+	return 0;
+}
+EXPORT_SYMBOL_GPL(dpaa_unregister_flow_offload_handler);
+
 static int dpaa_setup_tc(struct net_device *net_dev, enum tc_setup_type type,
   void *type_data)
 {
@@ -376,6 +445,33 @@ static int dpaa_setup_tc(struct net_device *net_dev, enum tc_setup_type type,
 u8 num_tc;
 int i;
 
+/* PR14o diagnostic — fire a one-shot pr_info per (netdev, type)
+ * combination so we can verify in dmesg that the dpaa driver IS
+ * receiving the call from upper layers. Was previously invisible.
+ */
+pr_info_once("dpaa: setup_tc called dev=%s type=%u (PR14o diagnostic, once-per-boot)\n",
+     netdev_name(net_dev), (unsigned int)type);
+
+/* ASK2 — dispatch flow-block offloads to the registered
+ * backend (typically ask.ko). Returns -EOPNOTSUPP if no
+ * backend is registered, which lets the upper layer fall
+ * back to software flow_offload.
+ */
+if (type == TC_SETUP_BLOCK || type == TC_SETUP_FT) {
+const struct dpaa_flow_offload_ops *ops;
+int err;
+
+rcu_read_lock();
+ops = rcu_dereference(dpaa_fo_ops_slot);
+if (!ops) {
+rcu_read_unlock();
+return -EOPNOTSUPP;
+}
+err = ops->setup_tc_block(net_dev, type_data);
+rcu_read_unlock();
+return err;
+}
+
 if (type != TC_SETUP_QDISC_MQPRIO)
 return -EOPNOTSUPP;
 
diff --git a/include/linux/fsl/dpaa_flow_offload.h b/include/linux/fsl/dpaa_flow_offload.h
new file mode 100644
index 0000000..425110a
--- /dev/null
+++ b/include/linux/fsl/dpaa_flow_offload.h
@@ -0,0 +1,68 @@
+/* SPDX-License-Identifier: GPL-2.0-or-later */
+/*
+ * NXP DPAA1 (fsl_dpa) flow-offload registration API.
+ *
+ * The dpaa Ethernet driver does not itself implement tc-flower /
+ * nf_flow_table HW offload. Instead it exposes a single registration
+ * slot that an external offload backend can occupy at runtime.
+ *
+ * On NXP LS1046A, the backend is the ASK2 module (ask.ko) which
+ * drives the FMan 210-series microcode running on an offline parser.
+ * See specs/ask2-rewrite-spec.md for the broader design.
+ *
+ * The split exists so the dpaa driver itself does not depend on
+ * ask.ko (which would create a circular module dependency: ask.ko
+ * already depends on FSL_DPAA via Kconfig).
+ *
+ * Single-slot, single-consumer:
+ *   - dpaa_register_flow_offload_handler() returns -EBUSY if a handler
+ *     is already registered.
+ *   - dpaa_unregister_flow_offload_handler() must pass the same ops
+ *     pointer that was registered, or -EINVAL is returned.
+ *
+ * Copyright 2026 Mono Networks / VyOS LS1046A maintainers.
+ */
+
+#ifndef _LINUX_FSL_DPAA_FLOW_OFFLOAD_H
+#define _LINUX_FSL_DPAA_FLOW_OFFLOAD_H
+
+#include <linux/types.h>
+
+struct net_device;
+struct flow_block_offload;
+
+/**
+ * struct dpaa_flow_offload_ops - external flow-offload backend hooks
+ * @owner:     module owning this ops struct (set with THIS_MODULE).
+ *             A reference is taken on register and dropped on
+ *             unregister so the backend module cannot be removed
+ *             while dispatch is live.
+ * @setup_tc_block: invoked from dpaa_setup_tc() for TC_SETUP_BLOCK.
+ *             Must perform the standard FLOW_BLOCK_BIND /
+ *             FLOW_BLOCK_UNBIND dance against fbo. Returns 0 on
+ *             success or a negative errno; -EOPNOTSUPP is treated
+ *             by the upper layer as 'try software fallback'.
+ */
+struct dpaa_flow_offload_ops {
+	struct module *owner;
+	int (*setup_tc_block)(struct net_device *dev,
+			      struct flow_block_offload *fbo);
+};
+
+#if IS_ENABLED(CONFIG_FSL_DPAA)
+int dpaa_register_flow_offload_handler(const struct dpaa_flow_offload_ops *ops);
+int dpaa_unregister_flow_offload_handler(const struct dpaa_flow_offload_ops *ops);
+#else
+static inline int
+dpaa_register_flow_offload_handler(const struct dpaa_flow_offload_ops *ops)
+{
+	return -ENODEV;
+}
+static inline int
+dpaa_unregister_flow_offload_handler(const struct dpaa_flow_offload_ops *ops)
+{
+	return -ENODEV;
+}
+#endif
+
+#endif /* _LINUX_FSL_DPAA_FLOW_OFFLOAD_H */
--
2.39.5
