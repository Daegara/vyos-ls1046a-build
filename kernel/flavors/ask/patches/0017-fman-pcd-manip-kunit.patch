+
+	KUNIT_EXPECT_PTR_EQ(test, last_cmd, hmct + 0x00);
+}
+
+/* ---- TEST: empty NAT_V4 params return NULL --------------------- */
+static void manip_encode_nat_v4_empty_test(struct kunit *test)
+{
+	void __iomem *hmct = hmct_scratch_alloc(test);
+	struct fman_pcd_manip stub = { .hmct = hmct };
+	struct fman_pcd_manip_params p = {
+		.type = FMAN_PCD_MANIP_NAT_V4,
+		.nat_v4 = { 0 },  /* no rewrite flags set */
+	};
+	u8 op = 0;
+	void __iomem *last_cmd;
+
+	last_cmd = manip_encode_nat_v4(&stub, &p, &op);
+	KUNIT_EXPECT_PTR_EQ(test, last_cmd, NULL);
+}
+
+/* ---- TEST: HMCD_LAST OR-in (silicon walker termination) ------- */
+/*
+ * fman_pcd_manip_create() ORs HMCD_LAST=0x00800000 into the last
+ * command word AFTER the encoder returns.  This test simulates that
+ * step on an encoder-produced HMCT to verify the bit position is
+ * preserved against accidental drift in the FMAN_PCD_HMCD_LAST macro.
+ */
+static void manip_hmcd_last_or_test(struct kunit *test)
+{
+	void __iomem *hmct = hmct_scratch_alloc(test);
+	struct fman_pcd_manip stub = { .hmct = hmct };
+	void __iomem *last_cmd;
+	u8 op = 0;
+	u32 base, terminated;
+
+	last_cmd = manip_encode_ttl_dec(&stub, &op);
+	KUNIT_ASSERT_NOT_NULL(test, last_cmd);
+
+	base = ioread32be(last_cmd);
+	iowrite32be(base | FMAN_PCD_HMCD_LAST, last_cmd);
+	terminated = ioread32be(last_cmd);
+
+	KUNIT_EXPECT_EQ(test, terminated & FMAN_PCD_HMCD_LAST,
+			FMAN_PCD_HMCD_LAST);
+	KUNIT_EXPECT_EQ(test, terminated & ~FMAN_PCD_HMCD_LAST, base);
+	KUNIT_EXPECT_EQ(test, FMAN_PCD_HMCD_LAST, 0x00800000u);
+}
+
+static struct kunit_case fman_pcd_manip_test_cases[] = {
+	KUNIT_CASE(manip_encode_nat_v4_full_test),
+	KUNIT_CASE(manip_encode_nat_v4_snat_canary_test),
+	KUNIT_CASE(manip_encode_nat_v6_test),
+	KUNIT_CASE(manip_encode_vlan_push_test),
+	KUNIT_CASE(manip_encode_vlan_pop_test),
+	KUNIT_CASE(manip_encode_ttl_dec_test),
+	KUNIT_CASE(manip_encode_nat_v4_empty_test),
+	KUNIT_CASE(manip_hmcd_last_or_test),
+	{}
+};
+
+static struct kunit_suite fman_pcd_manip_test_suite = {
+	.name = "fman_pcd_manip",
+	.test_cases = fman_pcd_manip_test_cases,
+};
+
+kunit_test_suite(fman_pcd_manip_test_suite);
