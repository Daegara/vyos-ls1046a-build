+/**
+ * fman_pcd_cc_node_remove_key() - retire one key+AD row in a CC node.
+ * @node:      handle from fman_pcd_cc_node_create().
+ * @key_index: slot to retire, 0..num_keys-1 as returned by the
+ *             implicit add_key sequence.
+ *
+ * Tombstones the slot: re-encodes the AD to a DROP sentinel, then
+ * zeroes the mask half of the match slot so silicon never matches
+ * this row.  Slot index stays valid (num_keys is unchanged) so
+ * higher-indexed flows keep their identity across removes -- this is
+ * the slot-stability contract that ASK2 relies on for flow-id round-
+ * tripping.  Subsequent add_key() always appends to the tail; only
+ * node_destroy() reclaims slots.
+ *
+ * Returns 0 on success, -EINVAL on NULL @node or @key_index out of
+ * range, -ENOENT if the slot is already a tombstone (mask already
+ * zero -- safe to ignore on double-remove paths).
+ */
+int fman_pcd_cc_node_remove_key(struct fman_pcd_cc_node *node,
+u16 key_index);
+
 /**
  * fman_pcd_cc_node_destroy() - tear down one CC node.
  * @node: handle from fman_pcd_cc_node_create().  NULL-safe.
