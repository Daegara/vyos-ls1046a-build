diff --git a/drivers/net/ethernet/freescale/fman/fman_keygen.c b/drivers/net/ethernet/freescale/fman/fman_keygen.c
index ffd407244..9b311fd8c 100644
--- a/drivers/net/ethernet/freescale/fman/fman_keygen.c
+++ b/drivers/net/ethernet/freescale/fman/fman_keygen.c
@@ -789,3 +789,102 @@ int keygen_port_hashing_init(struct fman_keygen *keygen, u8 hw_port_id,
 	return 0;
 }
 EXPORT_SYMBOL(keygen_port_hashing_init);
+
+/* keygen_lookup_port_scheme
+ *
+ * PR14z13: discover the lowest-ID KG scheme currently bound to a given
+ * BMI hwport, so an external PCD consumer (ask.ko) can GRAFT its CC
+ * tree onto an existing kernel-owned scheme instead of creating a new
+ * scheme that loses the FMan KG dispatch race.
+ *
+ * Walks fmkg_pe.fmkg_pe_sp[hwport_id] via the AR-mediated indirect
+ * access window (SEL_PORT_ENTRY, read), then iterates the set bits
+ * in the resulting scheme partition vector to find the lowest bound
+ * scheme ID -- which is the one FMan KG actually dispatches to per
+ * packet (silicon resolves multi-scheme port-bindings by lowest
+ * scheme ID wins).
+ *
+ * Then reads that scheme's KGSE_FQB (via SCHEME_ENTRY READ AR) to
+ * extract base_fqid so the caller's CC tree can use it as the
+ * FORWARD_FQ target for miss-action, preserving the kernel's RX hash
+ * distribution to per-CPU FQs for any packet that doesn't match an
+ * ASK CC node.
+ *
+ * Encoding reminder (RM 8.7.4): keygen_bind_port_to_schemes() sets
+ * fmkg_pe_sp bit (31 - scheme_id), so bit N decodes to scheme
+ * (31 - N).
+ *
+ * keygen:     KeyGen handle.
+ * hwport_id:  BMI hardware port id (LS1046A range 0x01..0x31).
+ * scheme_id:  out, lowest scheme ID currently bound to hwport.
+ * base_fqid:  out, that scheme's KGSE_FQB base_fqid (low 24 bits).
+ *
+ * Return: 0 on success, -ENOENT if no scheme is bound to the port,
+ * negative errno on AR access failure.
+ */
+int keygen_lookup_port_scheme(struct fman_keygen *keygen, u8 hwport_id,
+	      u8 *scheme_id, u32 *base_fqid)
+{
+	struct fman_kg_regs __iomem *regs;
+	u32 ar_reg;
+	u32 sp_vec;
+	u32 fqb;
+	int err;
+	int bit;
+	u8 sid = 0;
+
+	if (!keygen || !scheme_id || !base_fqid)
+		return -EINVAL;
+	if (hwport_id == 0 || hwport_id > 0x3F)
+		return -EINVAL;
+	regs = keygen->keygen_regs;
+
+	/*
+	 * Phase 1: read fmkg_pe_sp[hwport_id] via SEL_PORT_ENTRY READ AR.
+	 * build_ar_bind_scheme(hwport_id, false) builds the read variant.
+	 */
+	ar_reg = build_ar_bind_scheme(hwport_id, false);
+	err = keygen_write_ar_wait(regs, ar_reg);
+	if (err) {
+		pr_err("keygen_lookup_port_scheme: SP read AR failed for hwport 0x%02x\n",
+		       hwport_id);
+		return err;
+	}
+	sp_vec = ioread32be(&regs->fmkg_pe.fmkg_pe_sp);
+	if (sp_vec == 0)
+		return -ENOENT;
+
+	/*
+	 * Phase 2: find the lowest scheme ID set in sp_vec.  FMan KG
+	 * dispatches lowest-ID-first, so this is the scheme that actually
+	 * processes every packet on this port.  bit N -> scheme (31 - N).
+	 * Iterate from MSB downward; first set bit gives lowest scheme ID.
+	 */
+	for (bit = 31; bit >= 0; bit--) {
+		if (sp_vec & (1u << bit)) {
+			sid = (u8)(31 - bit);
+			goto found;
+		}
+	}
+	return -ENOENT;
+found:
+	/*
+	 * Phase 3: read that scheme's KGSE_FQB via SCHEME_ENTRY READ AR
+	 * (update_counter=false, write=false).  KGSE_FQB low 24 bits =
+	 * base_fqid; upper bits are pool-channel/spread config and are
+	 * not relevant for the CC tree's FORWARD_FQ target.
+	 */
+	ar_reg = build_ar_scheme(sid, false, false);
+	err = keygen_write_ar_wait(regs, ar_reg);
+	if (err) {
+		pr_err("keygen_lookup_port_scheme: scheme %u read AR failed\n",
+		       sid);
+		return err;
+	}
+	fqb = ioread32be(&regs->fmkg_sch.kgse_fqb);
+
+	*scheme_id = sid;
+	*base_fqid = fqb & 0x00FFFFFFu;
+	return 0;
+}
+EXPORT_SYMBOL_GPL(keygen_lookup_port_scheme);
