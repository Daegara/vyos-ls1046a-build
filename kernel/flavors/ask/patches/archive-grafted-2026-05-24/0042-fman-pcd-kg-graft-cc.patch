+ */
+int fman_pcd_kg_graft_cc(struct fman_pcd *pcd, u8 scheme_id,
+			 struct fman_pcd_cc_tree *cc);
+
+/**
+ * fman_pcd_kg_ungraft_cc() - PR14z13: reverse fman_pcd_kg_graft_cc().
