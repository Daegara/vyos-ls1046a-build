+EXPORT_SYMBOL_GPL(fman_pcd_kg_scheme_destroy);
+/**
+ * fman_pcd_kg_lookup_port_scheme() - PR14z13: find the kernel-owned KG
+ *                                    scheme on a port and report its
+ *                                    base_fqid.
+ *
+ * External PCD consumers (ask.ko) need to GRAFT their CC tree onto the
+ * in-tree default KG scheme that dpaa_eth allocated at MAC bringup,
+ * instead of creating a NEW scheme that would lose the FMan KG dispatch
+ * race (lowest-ID-bound scheme wins per packet; silicon dispatches
+ * exactly one scheme per packet).
+ *
+ * Wraps keygen_lookup_port_scheme() with public-ABI argument validation
+ * and pcd->lock acquisition.
+ *
+ * @pcd:       FMan PCD handle from fman_get_pcd().
+ * @port_id:   BMI hardware port id (LS1046A 0x01..0x31).
+ * @scheme_id: out, the lowest scheme ID currently bound to @port_id
+ *             (this is the scheme FMan KG will actually dispatch).
+ * @base_fqid: out, that scheme's KGSE_FQB base_fqid -- the value the
+ *             caller should use as the FORWARD_FQ target for its CC
+ *             tree's miss-action (preserves kernel RX hash + control
+ *             plane delivery for unmatched packets).
+ *
+ * Return: 0 on success, -ENOENT if no scheme bound to @port_id,
+ * -EINVAL on bad args, -ENXIO if FMan keygen not initialised.
+ */
+int fman_pcd_kg_lookup_port_scheme(struct fman_pcd *pcd, u8 port_id,
+			   u8 *scheme_id, u32 *base_fqid)
+{
+	struct fman_keygen *keygen;
+	struct fman *fman;
+	struct mutex *lock;
+	int err;
+
+	if (!pcd || !scheme_id || !base_fqid)
+		return -EINVAL;
+	if (port_id == 0 || port_id > 0x3F)
+		return -EINVAL;
+
+	fman = fman_pcd_get_fman(pcd);
+	if (!fman || !fman->keygen)
+		return -ENXIO;
+	keygen = fman->keygen;
+	lock = fman_pcd_get_lock(pcd);
+
+	mutex_lock(lock);
+	err = keygen_lookup_port_scheme(keygen, port_id, scheme_id, base_fqid);
+	mutex_unlock(lock);
+
+	return err;
+}
+EXPORT_SYMBOL_GPL(fman_pcd_kg_lookup_port_scheme);
+
+/**
+ * fman_pcd_kg_graft_cc() - PR14z13: graft a CC tree onto an existing
+ *                          KG scheme identified by scheme_id.
+ *
+ * The architectural alternative to fman_pcd_kg_attach_cc() for the
+ * "extend kernel-owned scheme" pattern.  Where attach_cc() programs
+ * KGSE_CCBS on a scheme created by THIS module (the caller owns the
+ * scheme handle), graft_cc() programs KGSE_CCBS by scheme_id ALONE so
+ * the kernel scheme allocated by dpaa_eth -- which has no public handle
+ * -- can also be extended.
+ *
+ * The scheme MUST already be in 'used' state (this is enforced by
+ * keygen_scheme_set_ccbs()); graft_cc() does not allocate.  After
+ * graft, every packet that the kernel scheme would have hash-dispatched
+ * to a per-CPU RX FQ now walks @cc first; CC tree matches go wherever
+ * the CC key's action specifies; CC tree misses MUST be configured by
+ * the caller to fall back to FORWARD_FQ(base_fqid) so kernel control
+ * plane RX (ARP, SYN, ICMP) keeps working.
+ *
+ * Use fman_pcd_kg_lookup_port_scheme() first to discover @scheme_id +
+ * @base_fqid for the target hwport.
+ *
+ * Locking: takes pcd->lock around keygen_scheme_set_ccbs() (which
+ * does an AR-mediated indirect RMW on KGSE_CCBS only, preserving
+ * every other KGSE_* field that keygen_scheme_setup() programmed).
+ *
+ * @pcd:       FMan PCD handle.
+ * @scheme_id: scheme ID returned by fman_pcd_kg_lookup_port_scheme(),
+ *             or any other valid scheme ID in 'used' state.
+ * @cc:        CC tree handle from fman_pcd_cc_tree_create().
+ *
+ * Return: 0 on success or negative errno (the scheme must already be
+ * in 'used' state -- this helper does not allocate).
+ */
+int fman_pcd_kg_graft_cc(struct fman_pcd *pcd, u8 scheme_id,
+		 struct fman_pcd_cc_tree *cc)
+{
+	struct fman_keygen *keygen;
+	struct fman *fman;
+	struct mutex *lock;
+	unsigned long off;
+	u32 ccbs;
+	int err;
+
+	if (!pcd || !cc)
+		return -EINVAL;
+
+	fman = fman_pcd_get_fman(pcd);
+	if (!fman || !fman->keygen)
+		return -ENXIO;
+	keygen = fman->keygen;
+
+	off = fman_pcd_cc_tree_group_table_off(cc);
+	if (off == 0)
+		return -EINVAL;
+	/* Low 24 bits: MURAM is well under 16 MiB on every FMan v3. */
+	ccbs = (u32)off & 0x00FFFFFFu;
+
+	lock = fman_pcd_get_lock(pcd);
+	mutex_lock(lock);
+	err = keygen_scheme_set_ccbs(keygen, scheme_id, ccbs);
+	mutex_unlock(lock);
+
+	return err;
+}
+EXPORT_SYMBOL_GPL(fman_pcd_kg_graft_cc);
+
+/**
+ * fman_pcd_kg_ungraft_cc() - PR14z13: reverse fman_pcd_kg_graft_cc().
+ *
+ * Clears KGSE_CCBS back to 0, restoring the scheme's pre-graft
+ * "scheme dispatches directly to hash-FQ" behaviour.  Called from
+ * ask.ko on module unload so the kernel default RX hash works
+ * unchanged after ASK goes away.
+ *
+ * Idempotent: ungrafting a scheme that already has KGSE_CCBS=0 is
+ * a no-op write but returns 0 (no error reporting on this path).
+ *
+ * @pcd:       FMan PCD handle.
+ * @scheme_id: scheme ID previously passed to fman_pcd_kg_graft_cc().
+ *
+ * Return: 0 on success or negative errno.
+ */
+int fman_pcd_kg_ungraft_cc(struct fman_pcd *pcd, u8 scheme_id)
+{
+	struct fman_keygen *keygen;
+	struct fman *fman;
+	struct mutex *lock;
+	int err;
+
+	if (!pcd)
+		return -EINVAL;
+
+	fman = fman_pcd_get_fman(pcd);
+	if (!fman || !fman->keygen)
+		return -ENXIO;
+	keygen = fman->keygen;
+
+	lock = fman_pcd_get_lock(pcd);
+	mutex_lock(lock);
+	err = keygen_scheme_set_ccbs(keygen, scheme_id, 0);
+	mutex_unlock(lock);
+
+	return err;
+}
+EXPORT_SYMBOL_GPL(fman_pcd_kg_ungraft_cc);
