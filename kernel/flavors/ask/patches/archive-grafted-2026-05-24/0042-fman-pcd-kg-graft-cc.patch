+ * @scheme_id: scheme ID previously passed to fman_pcd_kg_graft_cc().
+ *
+ * Clears KGSE_CCBS back to 0.  Idempotent.  Called from ask.ko on
+ * module unload so the kernel default RX hash works unchanged
+ * after ASK goes away.
+ *
+ * Return: 0 on success or negative errno.
+ */
+int fman_pcd_kg_ungraft_cc(struct fman_pcd *pcd, u8 scheme_id);
+
 /*
  * Coarse Classifier (CC) API (PR14c).
  *
