From c163fee90a759cb7cb59e03dc584ba4d16a195ab Mon Sep 17 00:00:00 2001
From: ci <ci@local>
Date: Tue, 19 May 2026 11:28:37 +0000
Subject: [PATCH] fman-pcd-manip: RMV_ETHERNET + INSRT_GENERIC encoders (ARCHIVED v1.3)

ARCHIVE-half of the original 0033-fman-pcd-manip-v1.2-oh-port-primitives.
These two encoders (MANIP_RMV_ETHERNET and MANIP_INSRT_GENERIC) are
the OH-port AD-chain primitives that the v1.3 Path A architecture
deletes from the v1.0 forward path.  Path A's FORWARD_FQ_WITH_MANIP
CC-key action atom does not need them — it carries the new L2 header
inline on the CC-key TX FQID encoding and lets dpaa_eth's TX path
re-paint the MAC via the standard PHYLINK MAC-update primitive.

The third encoder originally bundled in 0033 — MANIP_FIELD_UPDATE_IPV4_FORWARD
— survives Path A and lives in the active patch series at
0054-fman-pcd-manip-ipv4-forward-encoder.patch (see plans/
ASK2-COURSE-CORRECTION.md §2 Phase 2 + plans/ASK2-PHASE2-PATCH-TRIAGE.md §3.1).

This patch is kept in the archive tree as a bisect anchor for one
release cycle.  It is NOT applied at build time — `bin/ci-setup-kernel.sh`
globs only the top-level `kernel/flavors/ask/patches/*.patch`, not
subdirectories.

If a future v1.1 restores OH-port for IPsec re-inject, this patch can
be re-applied alongside the OH-port driver (0032-archived) and the
matching hmct_used hunks (0037-archived).

Content (preserved as-authored on 2026-05-19):
  - L2 header macros: FMAN_PCD_L2_HDR_OFFSET, FMAN_PCD_L2_HDR_RMV_SIZE
  - manip_encode_rmv_ethernet() — GENERIC_RMV at offset 0, size 14
  - manip_encode_insrt_generic() — GENERIC_INSRT at offset 0, size 1..32
                                   with ceil(size/4) BE-32 inline words
  - FMAN_PCD_MANIP_INSRT_GENERIC_MAX_SIZE = 32u
  - 3 KUnit tests: rmv_ethernet, insrt_generic_l2, insrt_generic_reject
  - FMAN_PCD_MANIP_RMV_ETHERNET + FMAN_PCD_MANIP_INSRT_GENERIC enum members
  - insrt_generic union arm in fman_pcd_manip_params
  - dispatch arms in fman_pcd_manip_create()

Cross-reference: SDK fm_manip.c case e_FM_PCD_MANIP_HDR_RMV_ETHERNET (line 432)
and case e_FM_PCD_MANIP_HDR_INSRT_GENERIC (line 528).
---
 .../ethernet/freescale/fman/fman_pcd_manip.c  | 175 ++++++++++++++++++
 .../fman/tests/fman_pcd_manip_test.c          | 153 +++++++++++++++
 include/linux/fsl/fman_pcd.h                  |  35 ++++
 3 files changed, 363 insertions(+)

diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
index 5c1b916..c2d117b 100644
--- a/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
@@ -224,6 +224,21 @@
 #define FMAN_PCD_HMCD_IP_L4_CS_CALC 0x00040000u
 
 /* ------------------------------------------------------------------ */
+/* v1.2 (PR14i) OH-port AD-chain L2-rewrite primitives  [ARCHIVED]    */
+/* ------------------------------------------------------------------ */
+
+/*
+ * MANIP_RMV_ETHERNET / MANIP_INSRT_GENERIC silicon facts.
+ *
+ * Both use the same GENERIC_INSRT / GENERIC_RMV opcodes (0x02 / 0x01).
+ * Cross-ref SDK fm_manip.c BuildHmct() arms
+ * e_FM_PCD_MANIP_HDR_RMV_ETHERNET (line 432) and
+ * e_FM_PCD_MANIP_HDR_INSRT_GENERIC (line 528).
+ */
+#define FMAN_PCD_L2_HDR_OFFSET 0u
+#define FMAN_PCD_L2_HDR_RMV_SIZE 14u /* 6 dst + 6 src + 2 EtherType */
+
+/* ------------------------------------------------------------------ */
 /* v1.2 (PR14i) additions consumed by Path A's CC-key inline MANIP    */
 /* ------------------------------------------------------------------ */
 
@@ -570,6 +585,84 @@
 return hmct;
 }
 
+static __must_check void __iomem *
+manip_encode_rmv_ethernet(struct fman_pcd_manip *manip, u8 *out_op)
+{
+void __iomem *hmct = manip->hmct;
+u32 cmd;
+
+/* Generic remove at frame offset 0, size 14 (ETH_HLEN).
+ * Strips the outer Ethernet header in flight.  No inline payload.
+ * Cross-ref SDK fm_manip.c BuildHmct case
+ * e_FM_PCD_MANIP_HDR_RMV_ETHERNET (line 432).
+ */
+cmd  = (u32)FMAN_PCD_HMCD_OP_GENERIC_RMV
+<< FMAN_PCD_HMCD_OC_SHIFT;
+cmd |= (u32)FMAN_PCD_L2_HDR_OFFSET
+<< FMAN_PCD_HMCD_RMV_OFFSET_SHIFT;
+cmd |= (u32)FMAN_PCD_L2_HDR_RMV_SIZE
+<< FMAN_PCD_HMCD_RMV_SIZE_SHIFT;
+
+iowrite32be(cmd, hmct);
+
+*out_op = FMAN_PCD_HMAN_OC;
+return hmct;
+}
+
+static __must_check void __iomem *
+manip_encode_insrt_generic(struct fman_pcd_manip *manip,
+   const struct fman_pcd_manip_params *p,
+   u8 *out_op)
+{
+void __iomem *hmct = manip->hmct;
+void __iomem *cur;
+u32 cmd;
+unsigned int n_words;
+unsigned int i;
+u8 size = p->insrt_generic.size;
+
+if (size == 0 || size > FMAN_PCD_MANIP_INSRT_GENERIC_MAX_SIZE)
+return NULL;
+
+/* Generic insert at frame offset 0, size N bytes carrying
+ * inline payload p->insrt_generic.hdr[0..N-1].  Cross-ref SDK
+ * fm_manip.c BuildHmct case e_FM_PCD_MANIP_HDR_INSRT_GENERIC
+ * (line 528).
+ */
+cmd  = (u32)FMAN_PCD_HMCD_OP_GENERIC_INSRT
+<< FMAN_PCD_HMCD_OC_SHIFT;
+cmd |= (u32)FMAN_PCD_L2_HDR_OFFSET
+<< FMAN_PCD_HMCD_INSRT_OFFSET_SHIFT;
+cmd |= (u32)size
+<< FMAN_PCD_HMCD_INSRT_SIZE_SHIFT;
+
+iowrite32be(cmd, hmct);
+
+/* Inline payload: ceil(size/4) BE-32 words. */
+n_words = (size + 3) / 4;
+cur = hmct + 4;
+for (i = 0; i < n_words; i++) {
+unsigned int base = i * 4;
+u32 word = 0;
+unsigned int b;
+
+for (b = 0; b < 4; b++) {
+unsigned int idx = base + b;
+u8 byte = (idx < size) ? p->insrt_generic.hdr[idx]
+       : 0u;
+
+word |= ((u32)byte) << ((3 - b) * 8);
+}
+iowrite32be(word, cur);
+cur += 4;
+}
+
+*out_op = FMAN_PCD_HMAN_OC;
+return hmct;
+}
+
 /* ------------------------------------------------------------------ */
 /* v1.2 (PR14i) encoder — Path A CC-key inline MANIP primitive        */
 /* ------------------------------------------------------------------ */
