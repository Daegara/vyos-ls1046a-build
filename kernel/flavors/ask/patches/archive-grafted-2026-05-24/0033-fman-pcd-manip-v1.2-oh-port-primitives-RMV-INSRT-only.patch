+break;
 case FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD:
 last_cmd = manip_encode_field_update_ipv4_forward(manip,
   params,
diff --git a/drivers/net/ethernet/freescale/fman/tests/fman_pcd_manip_test.c b/drivers/net/ethernet/freescale/fman/tests/fman_pcd_manip_test.c
index 8b27e37..081fcea 100644
--- a/drivers/net/ethernet/freescale/fman/tests/fman_pcd_manip_test.c
+++ b/drivers/net/ethernet/freescale/fman/tests/fman_pcd_manip_test.c
@@ -292,6 +292,135 @@ static void manip_encode_nat_v4_empty_test(struct kunit *test)
 KUNIT_EXPECT_PTR_EQ(test, last_cmd, NULL);
 }
 
+/* ---- TEST: MANIP_RMV_ETHERNET (v1.2) ----------- [ARCHIVED] ---- */
+/*
+ * 14-byte L2 strip at frame offset 0 — the OH-port chain's stage-1
+ * primitive.  Encoded as a single GENERIC_RMV command word with no
+ * inline payload.
+ */
+static void manip_encode_rmv_ethernet_test(struct kunit *test)
+{
+void __iomem *hmct = hmct_scratch_alloc(test);
+struct fman_pcd_manip stub = { .hmct = hmct };
+void __iomem *last_cmd;
+u8 op = 0;
+u32 expected_cmd;
+
+last_cmd = manip_encode_rmv_ethernet(&stub, &op);
+KUNIT_ASSERT_NOT_NULL(test, last_cmd);
+KUNIT_EXPECT_EQ(test, op, (u8)FMAN_PCD_HMAN_OC);
+
+expected_cmd = ((u32)FMAN_PCD_HMCD_OP_GENERIC_RMV
+<< FMAN_PCD_HMCD_OC_SHIFT) |
+       ((u32)FMAN_PCD_L2_HDR_OFFSET
+<< FMAN_PCD_HMCD_RMV_OFFSET_SHIFT) |
+       ((u32)FMAN_PCD_L2_HDR_RMV_SIZE
+<< FMAN_PCD_HMCD_RMV_SIZE_SHIFT);
+
+/* Silicon-fact pin: GENERIC_RMV(op=0x01) at offset 0, size 14
+ * encodes as exactly 0x01000E00.
+ */
+KUNIT_EXPECT_EQ(test, expected_cmd, 0x01000e00u);
+KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x00), expected_cmd);
+KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x04), 0u);
+
+KUNIT_EXPECT_PTR_EQ(test, last_cmd, hmct + 0x00);
+}
+
+/* ---- TEST: MANIP_INSRT_GENERIC 14-byte L2 (v1.2) [ARCHIVED] ---- */
+static void manip_encode_insrt_generic_l2_test(struct kunit *test)
+{
+void __iomem *hmct = hmct_scratch_alloc(test);
+struct fman_pcd_manip stub = { .hmct = hmct };
+struct fman_pcd_manip_params p = {
+.type = FMAN_PCD_MANIP_INSRT_GENERIC,
+.insrt_generic = {
+.size = 14,
+.hdr = {
+0xaa, 0xbb, 0xcc, 0xdd, 0xee, 0xff,
+0x11, 0x22, 0x33, 0x44, 0x55, 0x66,
+0x08, 0x00,
+},
+},
+};
+void __iomem *last_cmd;
+u8 op = 0;
+u32 expected_cmd;
+
+last_cmd = manip_encode_insrt_generic(&stub, &p, &op);
+KUNIT_ASSERT_NOT_NULL(test, last_cmd);
+KUNIT_EXPECT_EQ(test, op, (u8)FMAN_PCD_HMAN_OC);
+
+expected_cmd = ((u32)FMAN_PCD_HMCD_OP_GENERIC_INSRT
+<< FMAN_PCD_HMCD_OC_SHIFT) |
+       ((u32)FMAN_PCD_L2_HDR_OFFSET
+<< FMAN_PCD_HMCD_INSRT_OFFSET_SHIFT) |
+       ((u32)14u
+<< FMAN_PCD_HMCD_INSRT_SIZE_SHIFT);
+
+KUNIT_EXPECT_EQ(test, expected_cmd, 0x02000e00u);
+KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x00), expected_cmd);
+
+KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x04), 0xaabbccddu);
+KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x08), 0xeeff1122u);
+KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x0c), 0x33445566u);
+KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x10), 0x08000000u);
+KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x14), 0u);
+
+KUNIT_EXPECT_PTR_EQ(test, last_cmd, hmct + 0x00);
+}
+
+/* ---- TEST: MANIP_INSRT_GENERIC reject (v1.2) -- [ARCHIVED] ----- */
+static void manip_encode_insrt_generic_reject_test(struct kunit *test)
+{
+void __iomem *hmct = hmct_scratch_alloc(test);
+struct fman_pcd_manip stub = { .hmct = hmct };
+struct fman_pcd_manip_params p_zero = {
+.type = FMAN_PCD_MANIP_INSRT_GENERIC,
+.insrt_generic = { .size = 0, .hdr = { 0 } },
+};
+struct fman_pcd_manip_params p_over = {
+.type = FMAN_PCD_MANIP_INSRT_GENERIC,
+.insrt_generic = { .size = 33, .hdr = { 0 } },
+};
+u8 op = 0;
+
+KUNIT_EXPECT_PTR_EQ(test,
+    manip_encode_insrt_generic(&stub, &p_zero, &op),
+    NULL);
+KUNIT_EXPECT_PTR_EQ(test,
+    manip_encode_insrt_generic(&stub, &p_over, &op),
+    NULL);
+}
+
 /* ---- TEST: HMCD_LAST OR-in (silicon walker termination) ------- */
@@ -419,6 +548,9 @@
 KUNIT_CASE(manip_encode_vlan_pop_test),
 KUNIT_CASE(manip_encode_ttl_dec_test),
 KUNIT_CASE(manip_encode_nat_v4_empty_test),
+KUNIT_CASE(manip_encode_rmv_ethernet_test),
+KUNIT_CASE(manip_encode_insrt_generic_l2_test),
+KUNIT_CASE(manip_encode_insrt_generic_reject_test),
 KUNIT_CASE(manip_encode_field_update_ipv4_forward_ttl_test),
 KUNIT_CASE(manip_encode_field_update_ipv4_forward_dscp_test),
 KUNIT_CASE(manip_hmcd_last_or_test),
diff --git a/include/linux/fsl/fman_pcd.h b/include/linux/fsl/fman_pcd.h
index a5e2c91..89230bc 100644
--- a/include/linux/fsl/fman_pcd.h
+++ b/include/linux/fsl/fman_pcd.h
@@ -509,6 +509,16 @@
  * @FMAN_PCD_MANIP_VLAN_PUSH:            prepend an 802.1Q tag
  * @FMAN_PCD_MANIP_VLAN_POP:             strip outer 802.1Q tag
  * @FMAN_PCD_MANIP_TTL_DEC:              decrement IPv4 TTL / IPv6 Hop Limit
+ * @FMAN_PCD_MANIP_RMV_ETHERNET:         strip the outer Ethernet/802.3 header
+ *                                       (14 bytes, no payload).  v1.2.
+ *                                       [ARCHIVED — OH-port chain only]
+ * @FMAN_PCD_MANIP_INSRT_GENERIC:        push an operator-supplied byte array
+ *                                       at frame offset 0 (typical use:
+ *                                       insert a new L2 header after
+ *                                       RMV_ETHERNET).  Carries
+ *                                       @insrt_generic.size and
+ *                                       @insrt_generic.hdr[].  v1.2.
+ *                                       [ARCHIVED — OH-port chain only]
  * @FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD:
  *                                       TTL-decrement + IPv4 header-checksum
  *                                       recompute (and optional DSCP rewrite)
@@ -525,9 +535,21 @@
 FMAN_PCD_MANIP_VLAN_PUSH,
 FMAN_PCD_MANIP_VLAN_POP,
 FMAN_PCD_MANIP_TTL_DEC,
+FMAN_PCD_MANIP_RMV_ETHERNET,
+FMAN_PCD_MANIP_INSRT_GENERIC,
 FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD,
 };
 
+/*
+ * Maximum byte count for the inline header carried by
+ * FMAN_PCD_MANIP_INSRT_GENERIC.  The silicon GENERIC_INSRT command
+ * supports an inline payload of up to 32 bytes per RM 8.7.5 + the
+ * SDK cross-reference (fm_manip.h::HMCD_INSRT_GENERIC_MAX_SIZE).
+ */
+#define FMAN_PCD_MANIP_INSRT_GENERIC_MAX_SIZE 32u
+
 /**
  * struct fman_pcd_manip_params - configuration for one manip template.
  * @type:                   discriminator selecting the union arm
@@ -596,6 +618,10 @@
 __be16 tci;
 __be16 tpid;
 } vlan_push;
+struct {
+u8 size;
+u8 hdr[FMAN_PCD_MANIP_INSRT_GENERIC_MAX_SIZE];
+} insrt_generic;
 struct {
 bool recompute_cksum;
 bool rewrite_dscp;
