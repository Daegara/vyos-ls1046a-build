+case FMAN_PCD_MANIP_INSRT_GENERIC:
 case FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD:
 break;
 default:
@@ -779,6 +874,12 @@
 case FMAN_PCD_MANIP_TTL_DEC:
 last_cmd = manip_encode_ttl_dec(manip, &op);
 break;
+case FMAN_PCD_MANIP_RMV_ETHERNET:
+last_cmd = manip_encode_rmv_ethernet(manip, &op);
+break;
+case FMAN_PCD_MANIP_INSRT_GENERIC:
