From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: ask2 PR14z19 <ask2@local>
Date: Sat, 23 May 2026 05:40:00 +0000
Subject: fman_pcd: add debugfs regdump surface (kg_schemes, port_sp)

PR14z19 Path A inspection surface. Two non-destructive forensic views
exposed under /sys/kernel/debug/fman_pcd/<id>/ :

  kg_schemes - one line per used KG scheme with its KGSE_* register
               block (MODE/EKFC/FQB/HC/PPC/SPC/CCBS/MV).
               update_counter=false so KGSE_SPC is NOT cleared by
               the dump.

  port_sp    - one line per BMI hwport (1..0x3F) with its raw
               fmkg_pe_sp vector and decoded scheme-ID list.

Both reads go through the AR-mediated indirect-access window via two
new helpers in fman_keygen.c (keygen_dump_scheme_regs and
keygen_dump_port_sp), with prototypes in fman_keygen_internal.h.

These are the inspection points needed to diagnose silicon residue from
graft/ungraft cycles (PR14z13/z15/z18), and to verify that the Path A
pre-netdev hook in 0044 actually wires KGSE_MODE.NIA=FM_CTL and
KGSE_CCBS=cc_tree at scheme-create time without subsequent rewrites.

Read-only; no writes; safe to cat at any time including under load.

Signed-off-by: ask2 PR14z19 <ask2@local>
---
diff --git a/drivers/net/ethernet/freescale/fman/fman_keygen.c b/drivers/net/ethernet/freescale/fman/fman_keygen.c
index f0d3e0b..9dd68d7 100644
--- a/drivers/net/ethernet/freescale/fman/fman_keygen.c
+++ b/drivers/net/ethernet/freescale/fman/fman_keygen.c
@@ -914,3 +914,91 @@ found:
 	return 0;
 }
 EXPORT_SYMBOL_GPL(keygen_lookup_port_scheme);
+
+/* keygen_dump_scheme_regs
+ *
+ * PR14z19 / patch 0046: forensic register snapshot of one KG scheme via
+ * the AR-mediated SCHEME_ENTRY READ window. Used by the new
+ * /sys/kernel/debug/fman_pcd/<id>/kg_schemes debugfs file to support
+ * post-hoc diagnosis of silicon mutation events (graft/ungraft residue,
+ * BMI/parser leak detection, etc).
+ *
+ * Reading a scheme via AR uses the same indirect-access pattern as
+ * keygen_scheme_setup() in WRITE mode but with the RW bit clear. After
+ * the AR latches into the fmkg_sch shadow block, every KGSE_* slot is
+ * memory-mappable as a plain ioread32be(). update_counter MUST be false
+ * here so the read does not clear KGSE_SPC -- forensic dumps must be
+ * non-destructive.
+ *
+ * @keygen:    KeyGen handle (NULL-safe; returns -EINVAL).
+ * @scheme_id: 0..31 (FM_KG_MAX_NUM_OF_SCHEMES-1).
+ * @out:       caller-owned buffer; 8 u32 slots filled in this order:
+ *             [0]=KGSE_MODE [1]=KGSE_EKFC [2]=KGSE_FQB [3]=KGSE_HC
+ *             [4]=KGSE_PPC  [5]=KGSE_SPC  [6]=KGSE_CCBS [7]=KGSE_MV
+ *
+ * Return: 0 on success, -EINVAL on bad args, -EIO on AR timeout/error.
+ */
+int keygen_dump_scheme_regs(struct fman_keygen *keygen, u8 scheme_id,
+			    u32 *out)
+{
+	struct fman_kg_regs __iomem *regs;
+	u32 ar_reg;
+	int err;
+
+	if (!keygen || !out || scheme_id >= FM_KG_MAX_NUM_OF_SCHEMES)
+		return -EINVAL;
+	regs = keygen->keygen_regs;
+
+	ar_reg = build_ar_scheme(scheme_id, false, false);
+	err = keygen_write_ar_wait(regs, ar_reg);
+	if (err)
+		return err;
+
+	out[0] = ioread32be(&regs->fmkg_sch.kgse_mode);
+	out[1] = ioread32be(&regs->fmkg_sch.kgse_ekfc);
+	out[2] = ioread32be(&regs->fmkg_sch.kgse_fqb);
+	out[3] = ioread32be(&regs->fmkg_sch.kgse_hc);
+	out[4] = ioread32be(&regs->fmkg_sch.kgse_ppc);
+	out[5] = ioread32be(&regs->fmkg_sch.kgse_spc);
+	out[6] = ioread32be(&regs->fmkg_sch.kgse_ccbs);
+	out[7] = ioread32be(&regs->fmkg_sch.kgse_mv);
+
+	return 0;
+}
+EXPORT_SYMBOL_GPL(keygen_dump_scheme_regs);
+
+/* keygen_dump_port_sp
+ *
+ * PR14z19 / patch 0046: read the fmkg_pe_sp port-to-scheme partition
+ * vector for a given BMI hwport via SEL_PORT_ENTRY READ AR. The decoded
+ * scheme list is left to the caller (bit N set -> scheme (31 - N) per
+ * keygen_bind_port_to_schemes()).
+ *
+ * @keygen:    KeyGen handle (NULL-safe).
+ * @hwport_id: BMI hwport (1..0x3F valid on LS1046A; 0 invalid).
+ * @sp_out:    caller-owned u32; raw fmkg_pe_sp vector on success.
+ *
+ * Return: 0 on success, -EINVAL on bad args, -EIO on AR error.
+ */
+int keygen_dump_port_sp(struct fman_keygen *keygen, u8 hwport_id,
+			u32 *sp_out)
+{
+	struct fman_kg_regs __iomem *regs;
+	u32 ar_reg;
+	int err;
+
+	if (!keygen || !sp_out)
+		return -EINVAL;
+	if (hwport_id == 0 || hwport_id > 0x3F)
+		return -EINVAL;
+	regs = keygen->keygen_regs;
+
+	ar_reg = build_ar_bind_scheme(hwport_id, false);
+	err = keygen_write_ar_wait(regs, ar_reg);
+	if (err)
+		return err;
+
+	*sp_out = ioread32be(&regs->fmkg_pe.fmkg_pe_sp);
+	return 0;
+}
+EXPORT_SYMBOL_GPL(keygen_dump_port_sp);
diff --git a/drivers/net/ethernet/freescale/fman/fman_keygen_internal.h b/drivers/net/ethernet/freescale/fman/fman_keygen_internal.h
