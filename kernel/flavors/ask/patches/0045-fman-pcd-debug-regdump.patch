@@ -126,4 +126,21 @@ bool bind);
 int keygen_lookup_port_scheme(struct fman_keygen *keygen, u8 hwport_id,
       u8 *scheme_id, u32 *base_fqid);
 
+
+/* keygen_dump_scheme_regs / keygen_dump_port_sp:
+ *   PR14z19 patch 0046 — non-destructive forensic readers used by the
+ *   fman_pcd debugfs regdump surface.  The scheme reader returns 8 u32
+ *   slots in this fixed order:
+ *     [0]=KGSE_MODE [1]=KGSE_EKFC [2]=KGSE_FQB [3]=KGSE_HC
+ *     [4]=KGSE_PPC  [5]=KGSE_SPC  [6]=KGSE_CCBS [7]=KGSE_MV
+ *   The port reader returns the raw fmkg_pe_sp vector for hwport
+ *   (decoding is the caller's responsibility: set bit N -> scheme
+ *   31 - N).  Both use the AR indirect-access window with
+ *   update_counter=false so the read does NOT clear KGSE_SPC.
+ */
+int keygen_dump_scheme_regs(struct fman_keygen *keygen, u8 scheme_id,
+    u32 *out);
+int keygen_dump_port_sp(struct fman_keygen *keygen, u8 hwport_id,
+u32 *sp_out);
+
 #endif /* __FMAN_KEYGEN_INTERNAL_H */
