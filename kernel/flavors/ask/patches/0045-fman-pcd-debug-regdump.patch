 #include "fman_muram.h"
 
 /*
@@ -180,6 +181,94 @@ static int fman_pcd_muram_budget_show(struct seq_file *s, void *unused)
 }
 DEFINE_SHOW_ATTRIBUTE(fman_pcd_muram_budget);
 
+/*
+ * PR14z19 patch 0046 — debugfs regdump surface.
+ *
+ * Two non-destructive forensic views exposed under
+ * /sys/kernel/debug/fman_pcd/<id>/ :
+ *
+ *   kg_schemes — one line per used KG scheme with its KGSE_*
+ *                register block (MODE/EKFC/FQB/HC/PPC/SPC/CCBS/MV).
+ *                update_counter=false on the AR read so KGSE_SPC is
+ *                NOT cleared by the dump.
+ *
+ *   port_sp    — one line per BMI hwport (1..0x3F) with its raw
+ *                fmkg_pe_sp vector and decoded scheme-ID list.
+ *
+ * These are the inspection points the operator asked for to diagnose
+ * graft/ungraft residue. Read-only; no writes; safe to cat at any
+ * time including under load.
+ */
+static int fman_pcd_kg_schemes_show(struct seq_file *m, void *unused)
+{
+	struct fman_pcd *pcd = m->private;
+	struct fman_keygen *keygen;
+	u32 regs[8];
+	u8 sid;
+	int err;
+
+	if (!pcd || !pcd->fman || !pcd->fman->keygen) {
+		seq_puts(m, "# keygen not initialised\n");
+		return 0;
+	}
+	keygen = pcd->fman->keygen;
+
+	seq_puts(m, "# scheme MODE     EKFC     FQB      HC       PPC      SPC      CCBS     MV\n");
+	mutex_lock(&pcd->lock);
+	for (sid = 0; sid < FM_KG_MAX_NUM_OF_SCHEMES; sid++) {
+		if (!keygen->schemes[sid].used)
+			continue;
+		err = keygen_dump_scheme_regs(keygen, sid, regs);
+		if (err) {
+			seq_printf(m, "%3u err=%d\n", sid, err);
+			continue;
+		}
+		seq_printf(m,
+			   "%3u %08x %08x %08x %08x %08x %08x %08x %08x\n",
+			   sid, regs[0], regs[1], regs[2], regs[3],
+			   regs[4], regs[5], regs[6], regs[7]);
+	}
+	mutex_unlock(&pcd->lock);
+	return 0;
+}
+DEFINE_SHOW_ATTRIBUTE(fman_pcd_kg_schemes);
+
+static int fman_pcd_port_sp_show(struct seq_file *m, void *unused)
+{
+	struct fman_pcd *pcd = m->private;
+	struct fman_keygen *keygen;
+	u32 sp_vec;
+	u8 hwport;
+	int err;
+	int bit;
+
+	if (!pcd || !pcd->fman || !pcd->fman->keygen) {
+		seq_puts(m, "# keygen not initialised\n");
+		return 0;
+	}
+	keygen = pcd->fman->keygen;
+
+	seq_puts(m, "# hwport fmkg_pe_sp  schemes\n");
+	mutex_lock(&pcd->lock);
+	for (hwport = 1; hwport <= 0x3F; hwport++) {
+		err = keygen_dump_port_sp(keygen, hwport, &sp_vec);
+		if (err)
+			continue;
+		if (sp_vec == 0)
+			continue;
+		seq_printf(m, "  0x%02x  0x%08x ", hwport, sp_vec);
+		for (bit = 31; bit >= 0; bit--) {
+			if (sp_vec & (1u << bit))
+				seq_printf(m, "%u ", 31 - bit);
+		}
+		seq_putc(m, '\n');
+	}
+	mutex_unlock(&pcd->lock);
+	return 0;
+}
+DEFINE_SHOW_ATTRIBUTE(fman_pcd_port_sp);
+
