+static __must_check void __iomem *
+manip_encode_insrt_generic(struct fman_pcd_manip *manip,
+   const struct fman_pcd_manip_params *p,
+   u8 *out_op)
+{
+void __iomem *hmct = manip->hmct;
+void __iomem *cur;
+u32 cmd;
+unsigned int n_words;
+unsigned int i;
+u8 size = p->insrt_generic.size;
+
+/* Validate payload size against the silicon's GENERIC_INSRT
+ * upper bound (32 bytes) - cross-ref SDK
+ * HMCD_INSRT_GENERIC_MAX_SIZE.  Zero-byte insert carries no
+ * action and is rejected as an encoder-invariant violation.
+ */
+if (size == 0 || size > FMAN_PCD_MANIP_INSRT_GENERIC_MAX_SIZE)
+return NULL;
+
+/* Generic insert at frame offset 0 (start-of-frame), size N
+ * bytes carrying inline payload p->insrt_generic.hdr[0..N-1].
+ * Used by the OH-port chain to push a fresh L2 header after
+ * MANIP_RMV_ETHERNET strips the old one.  Cross-ref SDK
+ * fm_manip.c BuildHmct case e_FM_PCD_MANIP_HDR_INSRT_GENERIC
+ * (line 528).
+ */
+cmd  = (u32)FMAN_PCD_HMCD_OP_GENERIC_INSRT
+<< FMAN_PCD_HMCD_OC_SHIFT;
+cmd |= (u32)FMAN_PCD_L2_HDR_OFFSET
+<< FMAN_PCD_HMCD_INSRT_OFFSET_SHIFT;
+cmd |= (u32)size
+<< FMAN_PCD_HMCD_INSRT_SIZE_SHIFT;
+
+iowrite32be(cmd, hmct);
+
+/* Inline payload: ceil(size/4) BE-32 words, written big-endian
+ * so the on-wire byte order matches hdr[0], hdr[1], ... .
+ * Trailing bytes in the last word are zero-padded (no silicon
+ * impact - the size field in the cmd word constrains the
+ * engine to exactly @size bytes of insertion).
+ */
+n_words = (size + 3) / 4;
+cur = hmct + 4;
+for (i = 0; i < n_words; i++) {
+unsigned int base = i * 4;
+u32 word = 0;
+unsigned int b;
+
+for (b = 0; b < 4; b++) {
+unsigned int idx = base + b;
+u8 byte = (idx < size) ? p->insrt_generic.hdr[idx]
+       : 0u;
+
+word |= ((u32)byte) << ((3 - b) * 8);
+}
+iowrite32be(word, cur);
+cur += 4;
+}
