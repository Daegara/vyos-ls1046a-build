+expected_cmd = ((u32)FMAN_PCD_HMCD_OP_IPV4_UPDATE
+<< FMAN_PCD_HMCD_OC_SHIFT) |
+       FMAN_PCD_HMCD_IP_L4_CS_CALC |
+       FMAN_PCD_HMCD_IPV4_UPDATE_TTL |
+       FMAN_PCD_HMCD_IPV4_UPDATE_DSCP;
+KUNIT_EXPECT_EQ(test, expected_cmd, 0x0c040005u);
+KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x00), expected_cmd);
+
+expected_payload = ((u32)46u) << FMAN_PCD_HMCD_IPV4_DSCP_SHIFT;
+KUNIT_EXPECT_EQ(test, hmct_read_be32(hmct, 0x04), expected_payload);
+
+KUNIT_EXPECT_PTR_EQ(test, last_cmd, hmct + 0x00);
+
+/* Out-of-range DSCP must be rejected. */
+KUNIT_EXPECT_PTR_EQ(test,
+    manip_encode_field_update_ipv4_forward(&stub,
+   &p_dscp_bad,
+   &op),
+    NULL);
