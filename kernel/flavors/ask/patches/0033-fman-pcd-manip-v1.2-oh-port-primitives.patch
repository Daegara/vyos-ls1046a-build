+void __iomem *hmct = hmct_scratch_alloc(test);
+struct fman_pcd_manip stub = { .hmct = hmct };
+struct fman_pcd_manip_params p_dscp_ef = {
+.type = FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD,
+.ipv4_forward = {
+.recompute_cksum = true,
+.rewrite_dscp    = true,
+.new_dscp        = 46,  /* EF, RFC 3246 */
+},
+};
+struct fman_pcd_manip_params p_dscp_bad = {
+.type = FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD,
+.ipv4_forward = {
+.recompute_cksum = true,
+.rewrite_dscp    = true,
+.new_dscp        = 64,  /* >6 bits */
+},
+};
+void __iomem *last_cmd;
+u8 op = 0;
+u32 expected_cmd;
+u32 expected_payload;
