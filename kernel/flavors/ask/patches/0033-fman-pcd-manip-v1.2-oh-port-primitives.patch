+  &p_dscp_ef,
+  &op);
+KUNIT_ASSERT_NOT_NULL(test, last_cmd);
+KUNIT_EXPECT_EQ(test, op, (u8)FMAN_PCD_HMAN_OC_IP_MANIP);
