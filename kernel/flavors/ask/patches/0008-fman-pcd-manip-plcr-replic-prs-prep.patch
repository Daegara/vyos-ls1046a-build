--- /dev/null
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
@@ -0,0 +1,89 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * FMan PCD Header Manipulation - public API stubs.
+ *
+ * PR14d-prep of the ASK2 v1.0 PR14 series.  Declares the on-disk
+ * translation unit for the header-manip layer and provides
+ * -EOPNOTSUPP stubs for every public entry point declared in
+ * <linux/fsl/fman_pcd.h>.  PR14d-body replaces these stubs with the
+ * real silicon-programming code per LS1046A RM 8.7.5 (header
+ * modification table format) and 8.7.5.4 (incremental checksum
+ * recompute hardware support).
+ *
+ * Authoritative reference
+ * -----------------------
+ * - LS1046A Reference Manual sec 8.7.5 (Header modification table).
+ * - LS1046A Reference Manual sec 8.7.5.4 (Auto checksum recompute).
+ *
+ * Provenance (v1.1)
+ * ---------------------
+ * Mainline drivers/net/ethernet/freescale/fman/ has zero manip code;
+ * this file is authored from the RM only.  The legacy NXP SDK
+ * fm_manip.c (~6000 LOC under drivers/net/ethernet/freescale/sdk_fman/
+ * Peripherals/FM/Pcd/ in the archived mihakralj/kernel-ls1046a-build
+ * repo at HEAD 464df181) is a read-only silicon-fact cross-reference
+ * only - no code or struct layouts are copied from it.  See spec
+ * specs/ask2-rewrite-spec.md sec 16 (provenance discipline risk #12).
+ *
+ * What this file delivers at PR14d-prep
+ * -------------------------------------
+ * Two public entry points, both returning ERR_PTR(-EOPNOTSUPP) /
+ * no-op.  No struct fman_pcd_manip definition yet - it stays forward-
+ * declared in <linux/fsl/fman_pcd.h>.  No MURAM allocation, no register
+ * writes.  The point of this PR is to lock down the public ABI surface
+ * (struct fman_pcd_manip_params tagged union with five MANIP_* variants)
+ * and the Makefile integration so that PR14d-body is a pure
+ * implementation drop.
+ */
+
+#include <linux/err.h>
+#include <linux/errno.h>
+#include <linux/export.h>
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/types.h>
+
+#include <linux/fsl/fman_pcd.h>
+#include "fman_pcd_internal.h"
+
+/**
+ * fman_pcd_manip_create() - program one header-manip template.
+ *
+ * PR14d-prep stub.  See <linux/fsl/fman_pcd.h> for the full contract.
+ * Returns ERR_PTR(-EOPNOTSUPP) until PR14d-body lands.
+ */
+struct fman_pcd_manip *
+fman_pcd_manip_create(struct fman_pcd *pcd,
+		      const struct fman_pcd_manip_params *params)
+{
+	if (!pcd || !params)
+		return ERR_PTR(-EINVAL);
+
+	switch (params->type) {
+	case FMAN_PCD_MANIP_NAT_V4:
+	case FMAN_PCD_MANIP_NAT_V6:
+	case FMAN_PCD_MANIP_VLAN_PUSH:
+	case FMAN_PCD_MANIP_VLAN_POP:
+	case FMAN_PCD_MANIP_TTL_DEC:
+		break;
+	default:
+		return ERR_PTR(-EINVAL);
+	}
+
+	return ERR_PTR(-EOPNOTSUPP);
+}
+EXPORT_SYMBOL_GPL(fman_pcd_manip_create);
+
+/**
+ * fman_pcd_manip_destroy() - tear down one header-manip template.
+ *
+ * PR14d-prep stub.  See <linux/fsl/fman_pcd.h> for the full contract.
+ * NULL-safe no-op until PR14d-body lands.
+ */
+void fman_pcd_manip_destroy(struct fman_pcd_manip *manip)
+{
+	if (!manip)
+		return;
+	/* PR14d-body: detach from CC keys, free MURAM template, free handle. */
+}
+EXPORT_SYMBOL_GPL(fman_pcd_manip_destroy);
