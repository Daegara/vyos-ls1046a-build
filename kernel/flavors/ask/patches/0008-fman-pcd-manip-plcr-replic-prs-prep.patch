diff --git a/include/linux/fsl/fman_pcd.h b/include/linux/fsl/fman_pcd.h
index 256349533..9b5a069fd 100644
--- a/include/linux/fsl/fman_pcd.h
+++ b/include/linux/fsl/fman_pcd.h
@@ -422,4 +422,304 @@ void fman_pcd_cc_node_destroy(struct fman_pcd_cc_node *node);
  */
 void fman_pcd_cc_tree_destroy(struct fman_pcd_cc_tree *tree);
 
+/* ----------------------------------------------------------------------
+ * Header manipulation (fman_pcd_manip.c, PR14d)
+ *
+ * The header-manipulation engine sits between the CC walker and the
+ * QMan enqueue step.  When a CC key match produces an
+ * FMAN_PCD_ACTION_MANIPULATE action, the silicon walks the manip
+ * chain pointed to by @manipulate.manip before enqueueing the frame
+ * to @manipulate.next_fqid.
+ *
+ * Each manip handle programs one MURAM-resident rewrite template per
+ * LS1046A RM sec 8.7.5.  Templates are stateless; the same handle
+ * may be referenced by N CC keys.  IPv4 / IPv6 / TCP / UDP checksum
+ * incremental recompute is hardware-automatic per RM sec 8.7.5.4 and
+ * does not require a separate manip kind.
+ * ---------------------------------------------------------------------- */
+
+/**
+ * enum fman_pcd_manip_type - tagged-union discriminator for manip params.
+ * @FMAN_PCD_MANIP_NAT_V4:     IPv4 SNAT/DNAT (rewrite SA and/or DA + L4 port)
+ * @FMAN_PCD_MANIP_NAT_V6:     IPv6 SNAT/DNAT (rewrite SA and/or DA + L4 port)
+ * @FMAN_PCD_MANIP_VLAN_PUSH:  prepend an 802.1Q tag
+ * @FMAN_PCD_MANIP_VLAN_POP:   strip outer 802.1Q tag
+ * @FMAN_PCD_MANIP_TTL_DEC:    decrement IPv4 TTL / IPv6 Hop Limit
+ *
+ * Hardware-supported manip kinds for ASK2 v1.0 per spec sec 13.3.
+ * GRE / VXLAN encap is deferred to v1.1.  Multiple manips per flow
+ * are chained via repeated FMAN_PCD_ACTION_MANIPULATE actions across
+ * a multi-node CC tree path.
+ */
+enum fman_pcd_manip_type {
+FMAN_PCD_MANIP_NAT_V4 = 0,
+FMAN_PCD_MANIP_NAT_V6,
+FMAN_PCD_MANIP_VLAN_PUSH,
+FMAN_PCD_MANIP_VLAN_POP,
+FMAN_PCD_MANIP_TTL_DEC,
+};
+
+/**
+ * struct fman_pcd_manip_params - configuration for one manip template.
+ * @type:                   discriminator selecting the union arm
+ * @nat_v4.rewrite_sa:      if true, rewrite source IPv4 address
+ * @nat_v4.new_sa:          new source address (host byte order)
+ * @nat_v4.rewrite_da:      if true, rewrite destination IPv4 address
+ * @nat_v4.new_da:          new destination address (host byte order)
+ * @nat_v4.rewrite_sport:   if true, rewrite L4 source port (TCP/UDP only)
+ * @nat_v4.new_sport:       new source port (host byte order)
+ * @nat_v4.rewrite_dport:   if true, rewrite L4 destination port
+ * @nat_v4.new_dport:       new destination port (host byte order)
+ * @nat_v6.rewrite_sa:      if true, rewrite source IPv6 address
+ * @nat_v6.new_sa:          new source address, 16 bytes network order
+ * @nat_v6.rewrite_da:      if true, rewrite destination IPv6 address
+ * @nat_v6.new_da:          new destination address, 16 bytes network order
+ * @nat_v6.rewrite_sport:   if true, rewrite L4 source port
+ * @nat_v6.new_sport:       new source port (host byte order)
+ * @nat_v6.rewrite_dport:   if true, rewrite L4 destination port
+ * @nat_v6.new_dport:       new destination port (host byte order)
+ * @vlan_push.tci:          full 16-bit TCI to push (PCP + DEI + VID)
+ * @vlan_push.tpid:         EtherType for the pushed tag, normally 0x8100
+ *
+ * @vlan_pop has no payload.  @ttl_dec has no payload.
+ *
+ * All addresses / ports stored in host byte order for caller convenience;
+ * the manip-template encoder swaps to network order before MURAM write.
+ */
+struct fman_pcd_manip_params {
+enum fman_pcd_manip_type type;
+union {
+struct {
+bool rewrite_sa;
+__be32 new_sa;
+bool rewrite_da;
+__be32 new_da;
+bool rewrite_sport;
+__be16 new_sport;
+bool rewrite_dport;
+__be16 new_dport;
+} nat_v4;
+struct {
+bool rewrite_sa;
+u8 new_sa[16];
+bool rewrite_da;
+u8 new_da[16];
+bool rewrite_sport;
+__be16 new_sport;
+bool rewrite_dport;
+__be16 new_dport;
+} nat_v6;
+struct {
+__be16 tci;
+__be16 tpid;
+} vlan_push;
+};
+};
+
+/**
+ * fman_pcd_manip_create() - program one header-manip template.
+ * @pcd:    parent FMan PCD context.
+ * @params: manip parameters; @params->type selects the union arm.
+ *
+ * Allocates a MURAM-resident manip template, encodes it per RM sec 8.7.5,
+ * registers the handle on the PCD context.  IPv4/UDP/TCP checksum
+ * incremental recompute is enabled automatically for all NAT variants
+ * per RM sec 8.7.5.4 - no explicit knob.
+ *
+ * Returns ERR_PTR(-EOPNOTSUPP) at PR14d-prep; PR14d-body programs the
+ * real silicon templates.
+ *
+ * Locking: takes pcd->lock.  May sleep (MURAM alloc).
+ *
+ * Return: handle on success, ERR_PTR(-EINVAL) on bad args, ERR_PTR(-ENOMEM)
+ * if MURAM exhausted, ERR_PTR(-EOPNOTSUPP) until PR14d-body lands.
+ */
+struct fman_pcd_manip *
+fman_pcd_manip_create(struct fman_pcd *pcd,
+      const struct fman_pcd_manip_params *params);
+
+/**
+ * fman_pcd_manip_destroy() - tear down one manip template.
+ * @manip: handle from fman_pcd_manip_create().  NULL-safe.
+ *
+ * Frees the MURAM-resident template and the handle.  WARN if any CC
+ * key still references this manip via FMAN_PCD_ACTION_MANIPULATE
+ * (caller leaked a manip).
+ *
+ * Locking: takes pcd->lock.  May sleep.
+ */
+void fman_pcd_manip_destroy(struct fman_pcd_manip *manip);
+
+/* ----------------------------------------------------------------------
+ * Policer profiles (fman_pcd_plcr.c, PR14e)
+ *
+ * Policer profiles are orthogonal to the CC walk: every CC action may
+ * carry a policer-profile id (programmed into the action template at
+ * CC-node-create time) that meters the frame BEFORE the action is
+ * executed.  A profile implements an RFC 4115 trTCM with
+ * configurable CIR / CBS / EIR / EBS per RM sec 8.7.6.
+ *
+ * Token-bucket rates are passed in bps; the encoder converts to
+ * silicon clock-cycle counts using the FMan reference clock.
+ * ---------------------------------------------------------------------- */
+
+/**
+ * enum fman_pcd_plcr_color_mode - trTCM color awareness.
+ * @FMAN_PCD_PLCR_COLOR_BLIND: ignore ingress color, treat as green
+ * @FMAN_PCD_PLCR_COLOR_AWARE: respect ingress color from upstream policer
+ *
+ * Per RFC 4115 sec 2.  ASK2 v1.0 uses BLIND mode exclusively;
+ * AWARE is reserved for chained policers in v1.1.
+ */
+enum fman_pcd_plcr_color_mode {
+FMAN_PCD_PLCR_COLOR_BLIND = 0,
+FMAN_PCD_PLCR_COLOR_AWARE,
+};
+
+/**
+ * struct fman_pcd_plcr_params - one policer-profile configuration.
+ * @color_mode: BLIND or AWARE per RFC 4115
+ * @cir_bps:    committed information rate, bits per second
+ * @cbs_bytes:  committed burst size in bytes (token-bucket depth)
+ * @eir_bps:    excess information rate, bits per second
+ * @ebs_bytes:  excess burst size in bytes
+ *
+ * RFC 4115 trTCM:  if frame_size <= committed_tokens  -> green
+ *                  else if frame_size <= excess_tokens -> yellow
+ *                  else                                -> red (drop).
+ *
+ * The action template attached to a CC key carries a 16-bit profile id
+ * that selects the meter; per-profile colour counters live in MURAM and
+ * are read via fman_pcd_plcr_profile_query_stats() (PR14e-body).
+ */
+struct fman_pcd_plcr_params {
+enum fman_pcd_plcr_color_mode color_mode;
+u64 cir_bps;
+u32 cbs_bytes;
+u64 eir_bps;
+u32 ebs_bytes;
+};
+
+/**
+ * fman_pcd_plcr_profile_create() - allocate and program one policer profile.
+ * @pcd:    parent FMan PCD context.
+ * @params: rate / burst / color configuration.
+ *
+ * Allocates a free profile slot (LS1046A FMan has 256 slots per RM
+ * sec 8.7.6), writes the trTCM record, returns the handle.  Profile id
+ * is queryable via fman_pcd_plcr_profile_get_id().
+ *
+ * Locking: takes pcd->lock.  May sleep (MURAM alloc).
+ *
+ * Return: handle on success, ERR_PTR(-EINVAL) on bad args, ERR_PTR(-ENOSPC)
+ * if all profile slots are in use, ERR_PTR(-EOPNOTSUPP) until PR14e-body.
+ */
+struct fman_pcd_plcr_profile *
+fman_pcd_plcr_profile_create(struct fman_pcd *pcd,
+     const struct fman_pcd_plcr_params *params);
+
+/**
+ * fman_pcd_plcr_profile_set_rates() - runtime rate update.
+ * @prof:   handle from fman_pcd_plcr_profile_create().
+ * @params: new rate / burst configuration.  @params->color_mode is honoured.
+ *
+ * Re-writes the trTCM rate fields in MURAM atomically from the silicon
+ * side (single 128-bit write).  Token counters are NOT reset - the
+ * profile keeps its current burst credit.  Used by ask.ko for runtime
+ * QoS changes without re-creating the profile (which would lose the
+ * id and force every CC key to be re-modified).
+ *
+ * Locking: takes pcd->lock.  May sleep.
+ *
+ * Return: 0 on success, -EINVAL on bad args, -EOPNOTSUPP at PR14e-prep.
+ */
+int fman_pcd_plcr_profile_set_rates(struct fman_pcd_plcr_profile *prof,
+    const struct fman_pcd_plcr_params *params);
+
+/**
+ * fman_pcd_plcr_profile_destroy() - free one policer profile.
+ * @prof: handle from fman_pcd_plcr_profile_create().  NULL-safe.
+ *
+ * Frees the profile slot and the handle.  WARN if any CC action
+ * template still references this profile id (caller leaked).
+ *
+ * Locking: takes pcd->lock.  May sleep.
+ */
+void fman_pcd_plcr_profile_destroy(struct fman_pcd_plcr_profile *prof);
+
+/* ----------------------------------------------------------------------
+ * Replicator groups + Parser (fman_pcd_replic.c, fman_pcd_prs.c, PR14f)
+ *
+ * Replicator groups fan one ingress frame out to N egress FQIDs for
+ * multicast forwarding per RM sec 8.7.7.  A CC action of type
+ * FMAN_PCD_ACTION_REPLICATE points at a replicator-group handle.
+ *
+ * The parser layer is configured pass-through for ASK2 v1.0 (the stock
+ * IPv4/IPv6/TCP/UDP/ESP/VLAN HXSes shipped with FMan ucode 210.10.1
+ * cover every v1.0 flow type).  GRE / VXLAN / MPLS HXS is reserved
+ * for v1.1.  fman_pcd_prs_init() is the only entry point.
+ * ---------------------------------------------------------------------- */
+
+/**
+ * struct fman_pcd_replic_member - one egress FQID in a replicator group.
+ * @fqid: destination FQID for this copy of the frame
+ *
+ * The silicon replicator stamps one frame descriptor per member; the
+ * DPAA TX path then enqueues each copy to its FQID independently.
+ * Per RM sec 8.7.7, a single group may hold up to 64 members.
+ */
+struct fman_pcd_replic_member {
+u32 fqid;
+};
+
+/**
+ * fman_pcd_replic_group_create() - allocate a replicator group.
+ * @pcd:        parent FMan PCD context.
+ * @members:    array of egress FQIDs, length @num_members.
+ * @num_members: number of egress copies; 1..64 per RM sec 8.7.7.
+ *
+ * Programs the MURAM-resident replicator-group table.  Returns the
+ * handle to feed into an FMAN_PCD_ACTION_REPLICATE action.
+ *
+ * Locking: takes pcd->lock.  May sleep (MURAM alloc).
+ *
+ * Return: handle on success, ERR_PTR(-EINVAL) if @num_members is 0 or > 64,
+ * ERR_PTR(-ENOMEM) if MURAM exhausted, ERR_PTR(-EOPNOTSUPP) until
+ * PR14f-body lands.
+ */
+struct fman_pcd_replic_group *
+fman_pcd_replic_group_create(struct fman_pcd *pcd,
+     const struct fman_pcd_replic_member *members,
+     u8 num_members);
+
+/**
+ * fman_pcd_replic_group_destroy() - free one replicator group.
+ * @group: handle from fman_pcd_replic_group_create().  NULL-safe.
+ *
+ * Frees the MURAM-resident table and the handle.  WARN if any CC key
+ * still references this group via FMAN_PCD_ACTION_REPLICATE.
+ *
+ * Locking: takes pcd->lock.  May sleep.
+ */
+void fman_pcd_replic_group_destroy(struct fman_pcd_replic_group *group);
+
+/**
+ * fman_pcd_prs_init() - configure FMan parser for ASK2 v1.0.
+ * @pcd: parent FMan PCD context.
+ *
+ * Pass-through configuration: the stock IPv4/IPv6/TCP/UDP/ESP/VLAN
+ * HXSes loaded by FMan ucode 210.10.1 cover every ASK2 v1.0 flow
+ * type, so this entry point currently just validates that the parser
+ * is in a known-good state and registers a debugfs dump of the active
+ * HXS table.  GRE / VXLAN / MPLS HXS programming lands in v1.1.
+ *
+ * Idempotent - safe to call from fman_pcd_init() and again from each
+ * fman_port_pcd_attach() call.
+ *
+ * Locking: takes pcd->lock.  May sleep.
+ *
+ * Return: 0 on success, -EOPNOTSUPP at PR14f-prep.
+ */
+int fman_pcd_prs_init(struct fman_pcd *pcd);
+
 #endif /* __LINUX_FSL_FMAN_PCD_H */
