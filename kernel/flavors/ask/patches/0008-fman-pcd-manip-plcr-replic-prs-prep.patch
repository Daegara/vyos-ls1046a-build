+// SPDX-License-Identifier: GPL-2.0
+/*
+ * FMan PCD Parser - public API stubs.
+ *
+ * PR14f-prep of the ASK2 v1.0 PR14 series (parser half).  Declares
+ * the on-disk translation unit for the soft-parser configuration layer
+ * and provides a -EOPNOTSUPP stub for the single public entry point
+ * declared in <linux/fsl/fman_pcd.h>.  PR14f-body replaces the stub
+ * with the real silicon-programming code per LS1046A RM 8.7.2
+ * (Header eXamination Sequence - HXS - table format).
+ *
+ * Authoritative reference
+ * -----------------------
+ * - LS1046A Reference Manual sec 8.7.2 (FMan parser HXS table).
+ *
+ * Provenance (v1.1)
+ * ---------------------
+ * Mainline drivers/net/ethernet/freescale/fman/ has zero parser-config
+ * code; this file is authored from the RM only.  The legacy NXP SDK
+ * fm_prs.c / fman_prs.c (~500 LOC combined under
+ * drivers/net/ethernet/freescale/sdk_fman/Peripherals/FM/Pcd/ in the
+ * archived mihakralj/kernel-ls1046a-build repo at HEAD 464df181) is a
+ * read-only silicon-fact cross-reference only - no code or struct
+ * layouts are copied from it.  See spec specs/ask2-rewrite-spec.md
+ * sec 16 (provenance discipline risk #12).
+ *
+ * What this file delivers at PR14f-prep
+ * -------------------------------------
+ * One public entry point: fman_pcd_prs_init(), returning -EOPNOTSUPP.
+ * No HXS table writes, no register writes.  PR14f-body adds a
+ * pass-through configuration plus a debugfs dump - the stock IPv4 /
+ * IPv6 / TCP / UDP / ESP / VLAN HXSes loaded by FMan ucode 210.10.1
+ * cover every ASK2 v1.0 flow type, so the parser change in v1.0 is
+ * minimal.  GRE / VXLAN / MPLS HXS programming is deferred to v1.1.
+ */
+
+#include <linux/err.h>
+#include <linux/errno.h>
+#include <linux/export.h>
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/types.h>
+
+#include <linux/fsl/fman_pcd.h>
+#include "fman_pcd_internal.h"
+
+/**
+ * fman_pcd_prs_init() - configure FMan parser for ASK2 v1.0.
+ *
+ * PR14f-prep stub.  See <linux/fsl/fman_pcd.h> for the full contract.
+ * Returns -EOPNOTSUPP until PR14f-body lands.
+ */
+int fman_pcd_prs_init(struct fman_pcd *pcd)
+{
+if (!pcd)
+return -EINVAL;
+
+return -EOPNOTSUPP;
+}
+EXPORT_SYMBOL_GPL(fman_pcd_prs_init);
