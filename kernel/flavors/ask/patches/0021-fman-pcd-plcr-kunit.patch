+/* ---- TEST: POLICE arm rejects NULL profile -------------------- */
+/*
+ * The struct fman_pcd_plcr_profile is opaque from the cc TU, so the
+ * happy-path byte-perfect POLICE encode lives in tests/fman_pcd_plcr_test.c.
+ * Here we only verify the two failure modes that are reachable without
+ * needing the struct's internals: NULL profile (the 0xffff sentinel
+ * comes back from fman_pcd_plcr_profile_id_internal()) and zero post-
+ * meter fqid.  Both must yield -EINVAL.
+ */
+static void cc_encode_ad_police_null_profile_test(struct kunit *test)
+{
+	void __iomem *ad = ad_scratch_alloc(test);
+	struct fman_pcd_action act = {
+		.type = FMAN_PCD_ACTION_POLICE,
+		.police = { .profile = NULL, .next_fqid = 1 },
+	};
+
+	KUNIT_EXPECT_EQ(test, cc_encode_ad(&act, ad), -EINVAL);
+}
+
+/* ---- TEST: POLICE arm rejects zero next_fqid ------------------ */
+static void cc_encode_ad_police_zero_fqid_test(struct kunit *test)
+{
+	void __iomem *ad = ad_scratch_alloc(test);
+	/*
+	 * We cannot reach into struct fman_pcd_plcr_profile from here, but
+	 * we CAN exercise the zero-next_fqid early reject because that
+	 * check fires before the profile pointer is dereferenced.  Use a
+	 * non-NULL bogus pointer that the validator never touches.
+	 */
+	struct fman_pcd_plcr_profile *bogus =
+		(struct fman_pcd_plcr_profile *)0x1;
+	struct fman_pcd_action act = {
+		.type = FMAN_PCD_ACTION_POLICE,
+		.police = { .profile = bogus, .next_fqid = 0 },
+	};
+
+	KUNIT_EXPECT_EQ(test, cc_encode_ad(&act, ad), -EINVAL);
+}
+
