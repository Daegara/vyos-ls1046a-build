From d82896703bd9b103ee75fd3fad74949483434611 Mon Sep 17 00:00:00 2001
From: ci <ci@local>
Date: Tue, 19 May 2026 11:28:38 +0000
Subject: [PATCH] patches/0037-fman-pcd-manip-hmct-used-v12-encoders.patch

---
 drivers/net/ethernet/freescale/fman/fman_pcd_manip.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
index 06f64b7..62c9eea 100644
--- a/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
@@ -602,6 +602,7 @@ cmd |= FMAN_PCD_HMCD_IPV4_UPDATE_TTL;
 
 iowrite32be(cmd, hmct);
 
+manip->hmct_used = 4; /* PR14z: cmd word, no payload */
 *out_op = FMAN_PCD_HMAN_OC_IP_MANIP;
 return hmct;
 }
@@ -637,6 +638,7 @@ cmd |= (u32)FMAN_PCD_L2_HDR_RMV_SIZE
 
 iowrite32be(cmd, hmct);
 
+manip->hmct_used = 4; /* PR14z: cmd word, no payload */
 *out_op = FMAN_PCD_HMAN_OC;
 return hmct;
 }
@@ -701,6 +703,7 @@ iowrite32be(word, cur);
 cur += 4;
 }
 
+manip->hmct_used = 4 + (n_words * 4); /* PR14z: cmd word + payload words */
 *out_op = FMAN_PCD_HMAN_OC;
 return hmct;
 }
@@ -763,6 +766,7 @@ payload = ((u32)p->ipv4_forward.new_dscp)
 iowrite32be(payload, hmct + 4);
 }
 
+manip->hmct_used = emit_payload ? 8 : 4; /* PR14z: cmd + optional DSCP word */
 *out_op = FMAN_PCD_HMAN_OC_IP_MANIP;
 return hmct;
 }
