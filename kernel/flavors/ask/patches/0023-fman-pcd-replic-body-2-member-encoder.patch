Subject: patches/0023-fman-pcd-replic-body-2-member-encoder.patch

---
 .../ethernet/freescale/fman/fman_pcd_replic.c | 130 +++++++++++++++---
 1 file changed, 111 insertions(+), 19 deletions(-)

diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_replic.c b/drivers/net/ethernet/freescale/fman/fman_pcd_replic.c
index 9d46bef..7a5a068 100644
--- a/drivers/net/ethernet/freescale/fman/fman_pcd_replic.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_replic.c
@@ -1,6 +1,6 @@
 // SPDX-License-Identifier: GPL-2.0
 /*
- * FMan PCD Frame Replicator - real MURAM bodies (PR14f-body-1).
+ * FMan PCD Frame Replicator - real MURAM bodies (PR14f-body-1+2).
  *
  * Replaces the PR14f-prep ERR_PTR(-EOPNOTSUPP) stubs in
  * fman_pcd_replic_group_create() / _destroy() with real silicon-resident
@@ -24,7 +24,7 @@
  * copied.  See spec specs/ask2-rewrite-spec.md sec 16 (provenance
  * discipline risk #12).
  *
- * Body-1 scope
+ * Body-1+2 scope
  * ------------
  * - struct fman_pcd_replic_group (private to TU): list anchor on
  *   pcd->replic_groups, pcd back-pointer, cached num_members, source-TD
@@ -42,14 +42,15 @@
  * - Real destroy() is the exact reverse: list_del under pcd->lock,
  *   free members array, free source-TD, kfree handle.
  *
- * Body-2 will add the member-AD encoder (FQID into each 16-B member
+ * Body-2 lands the member-AD encoder (FQID into each 16-B member
  * slot, NEXT pointer chaining via FRM_REPLIC_ADDR_SHIFT, NL_BIT on the
- * last member, FR_BIT to enable per-member fan-out) and stamp them in
- * one pass under group->lock so silicon never sees a partial chain.
- * Body-3 wires cc_encode_ad() FMAN_PCD_ACTION_REPLICATE to point AD.res
- * at group->source_td_off.  Body-4 lands the KUnit suite covering the
- * source-TD layout byte-perfect against RM 8.7.7 and the member-AD
- * chaining math.
+ * last member, FR_BIT to enable per-member fan-out) in one pass under
+ * group->lock so silicon never sees a partial chain, then publishes
+ * source-TD frg_pointer + active OPCODE as the single publication
+ * point.  Body-3 wires cc_encode_ad() FMAN_PCD_ACTION_REPLICATE to
+ * point AD.res at group->source_td_off.  Body-4 lands the KUnit suite
+ * covering the source-TD layout byte-perfect against RM 8.7.7 and the
+ * member-AD chaining math.
  */
 
 #include <linux/err.h>
@@ -113,6 +114,14 @@
 #define FMAN_PCD_REPLIC_SRC_OFF_OPCODE		0x8
 #define FMAN_PCD_REPLIC_SRC_OFF_RES		0xc
 
+/* Member-AD record offsets (RM sec 8.7.7).  Per-member layout is
+ * FQID at 0x0 and NIA at 0x8; the NIA word carries the NEXT pointer
+ * (next member MURAM offset >> ADDR_SHIFT) ORed with FR_BIT, and on
+ * the LAST member also NL_BIT to terminate the chain.
+ */
+#define FMAN_PCD_REPLIC_MBR_OFF_FQID		0x0
+#define FMAN_PCD_REPLIC_MBR_OFF_NIA		0x8
+
 /**
  * struct fman_pcd_replic_group - one MURAM-resident replicator group.
  * @node: anchor on pcd->replic_groups
@@ -142,6 +151,72 @@ struct fman_pcd_replic_group {
 	spinlock_t		lock;
 };
 
+/*
+ * replic_encode_members() - stamp FQID + NEXT/FR/NL bits into all
+ * member-AD slots in one atomic pass under group->lock.
+ *
+ * Per RM sec 8.7.7 Table 8-128 + ¶ on NIA chain encoding:
+ *
+ *   - Each member is a 16-B AD; FQID at offset 0x0, NIA at 0x8.
+ *   - The NIA of member[i] for i in [0, num-2] holds:
+ *       FR_BIT | (next_member_off >> ADDR_SHIFT)
+ *     where next_member_off = members_off + (i+1) * 16.
+ *   - The NIA of the LAST member additionally has NL_BIT set and
+ *     a zero NEXT pointer - silicon walker exits at NL_BIT.
+ *
+ * Body-2 deliberately does NOT touch the source-TD record - that
+ * happens in fman_pcd_replic_group_create() after this helper
+ * returns, so the encoder failure path (which today cannot fail
+ * because args are pre-validated) leaves source-TD type at the
+ * body-1 inactive value and the silicon walker still short-
+ * circuits.
+ *
+ * Locking: caller MUST hold group->lock (spinlock); writes are
+ * iowrite32be (host->BE swap) so MURAM contents are seen by the
+ * silicon walker in big-endian as the RM requires.
+ */
+static void replic_encode_members(struct fman_pcd_replic_group *group,
+			  const struct fman_pcd_replic_member *members)
+{
+	void __iomem *slot;
+	unsigned long next_off;
+	u32 nia;
+	u8 i;
+
+	for (i = 0; i < group->num_members; i++) {
+		slot = group->members + (size_t)i * FMAN_PCD_REPLIC_AD_SIZE;
+
+		/* FQID lives in the low 24 bits of word 0; high 8 bits are
+		 * reserved/zero per RM Table 8-128.  iowrite32be will swap
+		 * host->BE so MURAM holds the FQID in big-endian.
+		 */
+		iowrite32be(members[i].fqid & 0x00ffffffu,
+			    slot + FMAN_PCD_REPLIC_MBR_OFF_FQID);
+
+		if (i + 1 < group->num_members) {
+			/* Intermediate member: FR_BIT + NEXT pointer to the
+			 * subsequent slot.  NEXT is the MURAM byte offset of
+			 * member[i+1] right-shifted by ADDR_SHIFT (16-B
+			 * alignment is guaranteed by the gen_pool order-8
+			 * allocator + the array-contiguous layout).
+			 */
+			next_off = group->members_off +
+				   (unsigned long)(i + 1) *
+				   FMAN_PCD_REPLIC_AD_SIZE;
+			nia = FMAN_PCD_REPLIC_FR_BIT |
+			      (u32)(next_off >>
+				    FMAN_PCD_REPLIC_ADDR_SHIFT);
+		} else {
+			/* Last member: NL_BIT terminates the chain; NEXT must
+			 * be zero per RM ¶ on chain termination (silicon
+			 * walker checks NL_BIT before dereferencing NEXT).
+			 */
+			nia = FMAN_PCD_REPLIC_NL_BIT;
+		}
+		iowrite32be(nia, slot + FMAN_PCD_REPLIC_MBR_OFF_NIA);
+	}
+}
+
 /**
  * fman_pcd_replic_group_create() - allocate a replicator group.
  *
@@ -245,20 +320,37 @@ fman_pcd_replic_group_create(struct fman_pcd *pcd,
 		kfree(group);
 		return ERR_PTR(-EINVAL);
 	}
+	/* Body-2: stamp the member chain under group->lock before
+	 * publishing source-TD.  At this point the silicon walker still
+	 * sees an inactive source-TD (type = OPCODE<<24, frg_pointer = 0,
+	 * opcode word = 0) so no traffic can enter the chain yet.
+	 */
+	{
+		unsigned long flags;
+
+		spin_lock_irqsave(&group->lock, flags);
+		replic_encode_members(group, members);
+		spin_unlock_irqrestore(&group->lock, flags);
+	}
+
+	/* Publish source-TD pointer + active OPCODE as the SINGLE
+	 * publication point.  Order matters: write frg_pointer first
+	 * (so when the active OPCODE goes hot the walker has a valid
+	 * member-chain to follow), then the active opcode word last.
+	 * Members chain is already fully stamped above.
+	 */
+	iowrite32be((u32)(group->members_off >>
+			    FMAN_PCD_REPLIC_ADDR_SHIFT),
+		    group->source_td +
+		    FMAN_PCD_REPLIC_SRC_OFF_FRG_POINTER);
+	iowrite32be(FMAN_PCD_REPLIC_SOURCE_TD_OPCODE,
+		    group->source_td +
+		    FMAN_PCD_REPLIC_SRC_OFF_OPCODE);
+
 	mutex_lock(pcd_lock);
 	list_add_tail(&group->node, list);
 	mutex_unlock(pcd_lock);
 
-	/* members[] is consumed by body-2 - body-1 stores the requested
-	 * FQIDs nowhere yet, on the principle that body-1 can land
-	 * independently of body-2 without leaving a partially-programmed
-	 * silicon state.  Pinning the FQIDs into the all-zero MURAM region
-	 * would defeat the inactive-state invariant.  Body-2's signature
-	 * will take (group, members[], num) and re-validate against
-	 * group->num_members.
-	 */
-	(void)members;
-
 	return group;
 }
 EXPORT_SYMBOL_GPL(fman_pcd_replic_group_create);
