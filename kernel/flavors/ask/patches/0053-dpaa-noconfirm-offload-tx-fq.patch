From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: ci <ci@local>
Date: Sat, 24 May 2026 03:45:00 +0000
Subject: [PATCH] fsl/dpaa: silicon-HIT TX-confirm fast-path + no-confirm offload TX FQ

PR14z23.3 — silicon-level suppression of per-frame TX-confirm work
on the FMan PCD HIT path.  See plans/PR14z23-DESIGN.md for the full
architectural rationale.  This patch supersedes the v1 (0x1e -> 0x1c
context_a) approach, which was based on a misreading of the B0V
bitfield (B0V controls context_b ASPID validity, NOT confirm-FD
generation — confirm enqueue is driven by the FMan TX port's
fmbm_tcfqid BMI register per RM 8.7.6, programmed by
dpaa_eth_init_tx_port() with cfg->dflt_fqid).

Architecture of the actual fix:

  1. FMan CC engine builds silicon-HIT FDs WITHOUT FM_FD_CMD_FCO,
     so FMan TX falls back to the port-default fmbm_tcfqid and
     enqueues a confirm-FD per frame regardless of which TX FQ the
     CC action targeted.  That confirm-FD lands in the kernel's
     conf_dflt_dqrr -> dpaa_tx_conf path which does heavyweight
     skb cleanup work that is wholly inappropriate for silicon-HIT
     frames (the kernel never allocated an skb for them).

  2. Silicon-HIT FDs are distinguishable from kernel-driven TX FDs
     by fd->bpid: dpaa_xmit() always sets fd->bpid = FSL_DPAA_BPID_INV
     (0xff) at dpaa_eth.c:2244 and :2373 before enqueue, while
     silicon-HIT FDs retain the ingress BMan pool's bpid (typically
     a single-digit value from the per-port BP allocation).  This
     gives us a 1-bit branch in the TX-confirm dequeue path.

  3. New fast-path at the top of dpaa_tx_conf(): if fd->bpid is a
     real BMan pool id (not _INV), the FD is silicon-HIT — release
     the buffer directly to BMan via bman_release(), skip DMA-unmap
     (no kernel mapping ever existed for this buffer; ingress
     mapped/unmapped via the RX BMan-managed DMA), skip the bogus
     swbp->skb / swbp->xdpf dereference, increment the tx_confirm
     counter for visibility, and return.

  4. Existing kernel-driven path is unchanged: fd->bpid == 0xff
     short-circuits the bman_release branch and runs the original
     dpaa_cleanup_tx_fd() + consume_skb() flow.

Adds (legacy v1 carry-over, retained for FQ-side hygiene):
  - FQ_TYPE_TX_NO_CONFIRM enum value in dpaa_eth.h
  - dpaa_alloc_offload_tx_fq() exported helper in dpaa_eth.c so
    ask_hw_resolve_oif_tx_fqid() (OOT, kernel/flavors/ask/oot-modules/
    ask/ask_hw.c) keeps a dedicated FQ per OIF.  The FQ itself is
    not the perf knob (the fast-path is) but having distinct TX FQs
    for silicon-HIT traffic keeps qman_p_poll_dqrr() accounting
    clean and gives operators a way to dump silicon-HIT TX state
    via debugfs without sifting through kernel-TX FDs.
  - Public declaration + !FLOW_OFFLOAD stub in dpaa_flow_offload.h.

Adds (the actual perf fix):
  - bpid-aware fast-path at the top of dpaa_tx_conf() in dpaa_eth.c.

Signed-off-by: ASK2 build bot <ask2-build@kralj.dev>
---
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c
index aae93601d..4c0bb5db2 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.c
@@ -1360,7 +1360,8 @@ static int dpaa_fq_init(struct dpaa_fq *dpaa_fq, bool td_enable)
 		 */
 		if (dpaa_fq->fq_type == FQ_TYPE_TX ||
 		    dpaa_fq->fq_type == FQ_TYPE_TX_CONFIRM ||
-		    dpaa_fq->fq_type == FQ_TYPE_TX_CONF_MQ) {
+		    dpaa_fq->fq_type == FQ_TYPE_TX_CONF_MQ ||
+		    dpaa_fq->fq_type == FQ_TYPE_TX_NO_CONFIRM) {
 			initfq.we_mask |= cpu_to_be16(QM_INITFQ_WE_CGID);
 			initfq.fqd.fq_ctrl |= cpu_to_be16(QM_FQCTRL_CGE);
 			initfq.fqd.cgid = (u8)priv->cgr_data.cgr.cgrid;
@@ -1406,6 +1407,20 @@ static int dpaa_fq_init(struct dpaa_fq *dpaa_fq, bool td_enable)
 			}
 		}
 
+		/* PR14z23.3: silicon-suppressed TX confirmation.  Same
+		 * context_a layout as FQ_TYPE_TX (OVOM|A2V|A0V|B0V|EBD)
+		 * so the FQ programming is benign for kernel-driven TX
+		 * fallback paths.  The actual confirm suppression happens
+		 * in dpaa_tx_conf() via the bpid-aware fast-path; this
+		 * branch only differentiates the FQ type so future debugfs
+		 * dumps can identify silicon-HIT TX FQs at a glance.
+		 */
+		if (dpaa_fq->fq_type == FQ_TYPE_TX_NO_CONFIRM) {
+			initfq.we_mask |= cpu_to_be16(QM_INITFQ_WE_CONTEXTA);
+			qm_fqd_context_a_set64(&initfq.fqd,
+					       0x1e00000080000000ULL);
+		}
+
 		/* Put all the ingress queues in our "ingress CGR". */
 		if (priv->use_ingress_cgr &&
 		    (dpaa_fq->fq_type == FQ_TYPE_RX_DEFAULT ||
@@ -1471,6 +1486,55 @@ static int dpaa_fq_init(struct dpaa_fq *dpaa_fq, bool td_enable)
 	return 0;
 }
 
+/**
+ * dpaa_alloc_offload_tx_fq() - allocate a TX FQ tagged for silicon-HIT
+ * offload paths.  The actual TX-confirm suppression is performed by
+ * the bpid-aware fast-path in dpaa_tx_conf() below - this allocator
+ * exists so the offload TX FQ can be identified at debugfs-dump time
+ * and is enrolled in the same egress CGR as the stock per-CPU TX FQs.
+ *
+ * See <linux/fsl/dpaa_flow_offload.h> for the full contract.  PR14z23.
+ */
+int dpaa_alloc_offload_tx_fq(struct net_device *dev, u32 *fqid)
+{
+	struct dpaa_priv *priv;
+	struct dpaa_fq *dpaa_fq;
+	struct device *parent;
+	int err;
+
+	if (!dev || !fqid)
+		return -EINVAL;
+
+	if (dev->netdev_ops != &dpaa_ops)
+		return -ENODEV;
+
+	priv = netdev_priv(dev);
+	parent = dev->dev.parent;
+
+	dpaa_fq = devm_kzalloc(parent, sizeof(*dpaa_fq), GFP_KERNEL);
+	if (!dpaa_fq)
+		return -ENOMEM;
+
+	dpaa_fq->fq_type = FQ_TYPE_TX_NO_CONFIRM;
+	dpaa_fq->net_dev = dev;
+	dpaa_fq->channel = priv->channel;
+	dpaa_fq->wq = 6;
+	dpaa_fq->fqid = 0;
+	dpaa_fq->flags = QMAN_FQ_FLAG_TO_DCPORTAL;
+	INIT_LIST_HEAD(&dpaa_fq->list);
+	list_add_tail(&dpaa_fq->list, &priv->dpaa_fq_list);
+
+	err = dpaa_fq_init(dpaa_fq, false);
+	if (err) {
+		list_del(&dpaa_fq->list);
+		return err;
+	}
+
+	*fqid = dpaa_fq->fqid;
+	return 0;
+}
+EXPORT_SYMBOL_GPL(dpaa_alloc_offload_tx_fq);
+
 static int dpaa_fq_free_entry(struct device *dev, struct qman_fq *fq)
 {
 	const struct dpaa_priv  *priv;
@@ -2743,6 +2807,40 @@ static void dpaa_tx_conf(struct net_device *net_dev,
 {
 	struct sk_buff	*skb;
 
+	/*
+	 * PR14z23.3 silicon-HIT TX-confirm fast-path.
+	 *
+	 * Silicon-HIT FDs are constructed by the FMan CC engine
+	 * (without FM_FD_CMD_FCO), so FMan TX falls back to the
+	 * port-default fmbm_tcfqid (RM 8.7.6) and enqueues a
+	 * confirm-FD per transmitted frame regardless of which TX
+	 * FQ supplied it.  Those confirm-FDs land here in the
+	 * kernel's conf_dflt_dqrr -> dpaa_tx_conf path, but the
+	 * default cleanup is wholly inappropriate for them: the
+	 * kernel never allocated an skb (swbp->skb is uninitialised
+	 * garbage from a BMan buffer's prefix area), and the buffer
+	 * was DMA-mapped by ingress, not by dpaa_xmit().
+	 *
+	 * Distinguish via fd->bpid: dpaa_xmit() always stamps
+	 * fd->bpid = FSL_DPAA_BPID_INV (0xff) before enqueue, so
+	 * any other bpid means "silicon-HIT, release the buffer to
+	 * BMan and bail".  This removes per-frame dma_unmap_single()
+	 * + xdp_return_frame() work that pinned NET_KERNEL_CPU at
+	 * ~21% on M2 at 7 Gbps under PR14z23.2.
+	 */
+	if (fd->bpid != FSL_DPAA_BPID_INV) {
+		struct dpaa_bp *dpaa_bp = dpaa_bpid2pool(fd->bpid);
+		struct bm_buffer bmb;
+
+		percpu_priv->tx_confirm++;
+		if (likely(dpaa_bp)) {
+			bm_buffer_set64(&bmb, qm_fd_addr(fd));
+			while (bman_release(dpaa_bp->pool, &bmb, 1) == -EBUSY)
+				cpu_relax();
+		}
+		return;
+	}
+
 	if (unlikely(be32_to_cpu(fd->status) & FM_FD_STAT_TX_ERRORS)) {
 		if (net_ratelimit())
 			netif_warn(priv, hw, net_dev, "FD status = 0x%08x\n",
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h
index 7ed659eb0..f2e3e15be 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h
@@ -28,6 +28,7 @@ enum dpaa_fq_type {
 	FQ_TYPE_TX_CONFIRM,	/* Tx default Conf FQ (actually an Rx FQ) */
 	FQ_TYPE_TX_CONF_MQ,	/* Tx conf FQs (one for each Tx FQ) */
 	FQ_TYPE_TX_ERROR,	/* Tx Error FQs (these are actually Rx FQs) */
+	FQ_TYPE_TX_NO_CONFIRM,	/* PR14z23: HW-offload TX FQ (no confirm) */
 };
 
 struct dpaa_fq {
diff --git a/include/linux/fsl/dpaa_flow_offload.h b/include/linux/fsl/dpaa_flow_offload.h
index d3e1ab749..2f6ffca00 100644
--- a/include/linux/fsl/dpaa_flow_offload.h
+++ b/include/linux/fsl/dpaa_flow_offload.h
@@ -125,6 +125,19 @@ int dpaa_get_fman_port_id(struct net_device *dev, u8 *port_id);
  */
 int dpaa_get_tx_fqid(struct net_device *dev, u32 queue, u32 *fqid);
 
+/**
+ * dpaa_alloc_offload_tx_fq() - allocate a TX FQ tagged for silicon-HIT
+ * offload paths.
+ * @dev:   any net_device; -ENODEV if not a dpaa port.
+ * @fqid:  out-param; receives the FQID on success.
+ *
+ * Allocates a fresh dynamic-FQID dpaa_fq tagged FQ_TYPE_TX_NO_CONFIRM.
+ * Per-frame TX-confirm suppression is performed by the bpid-aware
+ * fast-path in dpaa_tx_conf() in dpaa_eth.c, not by this allocator;
+ * the tag exists so debugfs dumps can identify offload TX FQs.
+ */
+int dpaa_alloc_offload_tx_fq(struct net_device *dev, u32 *fqid);
+
 /**
  * dpaa_get_rx_fman_port() - resolve the RX FMan port handle for a netdev.
  * @dev: dpaa netdev (e.g. eth3) to query.
@@ -182,6 +195,11 @@ dpaa_get_tx_fqid(struct net_device *dev, u32 queue, u32 *fqid)
 {
 return -ENODEV;
 }
+static inline int
+dpaa_alloc_offload_tx_fq(struct net_device *dev, u32 *fqid)
+{
+return -ENODEV;
+}
 struct fman_port;
 static inline struct fman_port *
 dpaa_get_rx_fman_port(struct net_device *dev)
-- 
2.39.5
