+/**
+ * fman_pcd_cc_node_remove_key() - retire a single key+AD row.
+ *
+ * Implements the public ABI declared in <linux/fsl/fman_pcd.h>.
+ *
+ * The CC walker compares the extract bytes against (match_table[i].key
+ * & match_table[i].mask) for i in [0, num_keys); the miss-slot at
+ * index num_keys catches no-match.  To safely retire a row without
+ * teardown-then-rebuild churn we cannot simply shift higher slots
+ * down -- the walker reads MURAM directly and a mid-write shift
+ * would temporarily duplicate or lose entries.  Instead we:
+ *
+ *   1. Re-encode the AD slot to a "drop" (FQID=0 control-flow,
+ *      which traps as invalid-FQ in DPAA1 -- same posture as a
+ *      freshly-allocated node).  This is one cc_encode_ad() call
+ *      against a known-typed action; identical guarantee as
+ *      modify_next_action() above re: torn-AD safety.
+ *   2. Overwrite the mask half of the match slot with all-zero
+ *      bytes.  A zero mask means no byte position can match, so
+ *      the walker will skip this row for every possible extract
+ *      value, but the row still exists and num_keys is unchanged.
+ *      This is the same "tombstone" idiom the SDK used in the
+ *      legacy fm_pcd_cc.c DeleteKey path.
+ *   3. Clear the in-memory mirror entry (key+mask zeroed, action
+ *      replaced with the same drop sentinel).
+ *
+ * num_keys is left untouched: shrinking it would let a subsequent
+ * add_key() reuse the tombstoned slot, which would be safe but
+ * loses the slot-index stability that ASK2 relies on for flow-id
+ * round-tripping (PR14z19 design §3.5).  Use add_key() to grow,
+ * remove_key() to retire; only node_destroy() reclaims slots.
+ *
+ * Locking: same spin_lock_bh() as add_key/modify_next_action.
+ *
+ * Returns 0 on success, -EINVAL on NULL @node or out-of-range
+ * @key_index, -ENOENT if the slot is already a tombstone (mask
+ * already zero).  The -ENOENT path is informational; callers can
+ * treat it as success if they don't care about double-removes.
+ */
+int fman_pcd_cc_node_remove_key(struct fman_pcd_cc_node *node,
+u16 key_index)
+{
+struct fman_pcd_action drop = {
+.type = FMAN_PCD_ACTION_DROP,
+};
+void __iomem *match_slot, *ad_slot;
+size_t key_stride;
+int err;
+u8 zero_mask[56];
+u8 i;
+bool already_tombstoned;
+
+if (!node)
+return -EINVAL;
+if (node->extract.size == 0 || node->extract.size > 56)
+return -EINVAL;
+
+key_stride = 2u * (size_t)node->extract.size;
+memset(zero_mask, 0, sizeof(zero_mask));
+
+spin_lock_bh(&node->lock);
+
+if (key_index >= node->num_keys) {
+err = -EINVAL;
+goto out;
+}
+
+/* Detect double-remove: if every byte of the mirror's mask is
+ * already zero the slot is already a tombstone.  Cheap pre-check
+ * before the iowrite traffic.
+ */
+already_tombstoned = true;
+for (i = 0; i < node->extract.size; i++) {
+if (node->keys[key_index].mask[i] != 0) {
+already_tombstoned = false;
+break;
+}
+}
+if (already_tombstoned) {
+err = -ENOENT;
+goto out;
+}
+
+ad_slot = node->ad_table + (size_t)key_index *
+  FMAN_PCD_CC_AD_ENTRY_SIZE;
+match_slot = node->match_table + (size_t)key_index * key_stride;
+
+/* Re-encode AD to drop FIRST.  cc_encode_ad on FMAN_PCD_ACTION_DROP
+ * cannot fail (no operand validation needed for the drop arm),
+ * but check anyway -- if it ever did fail we would leak a live
+ * row, which is worse than aborting with the slot still live.
+ */
+err = cc_encode_ad(&drop, ad_slot);
+if (err)
+goto out;
+
+/* Tombstone the mask half of the match slot. */
+memcpy_toio(match_slot + node->extract.size, zero_mask,
+    node->extract.size);
+
+/* Mirror: zero mask + record the drop sentinel.  Leave key bytes
+ * intact so debugfs cc_nodes can still show what USED to be here
+ * (useful for forensic dumps after a flow eviction storm).
+ */
+memset(node->keys[key_index].mask, 0,
+       sizeof(node->keys[key_index].mask));
+node->keys[key_index].action = drop;
+err = 0;
+
+out:
+spin_unlock_bh(&node->lock);
+return err;
+}
+EXPORT_SYMBOL_GPL(fman_pcd_cc_node_remove_key);
+
