diff --git a/drivers/net/ethernet/freescale/fman/fman_host_cmd.c b/drivers/net/ethernet/freescale/fman/fman_host_cmd.c
new file mode 100644
index 000000000..1d1a96109
--- /dev/null
+++ b/drivers/net/ethernet/freescale/fman/fman_host_cmd.c
@@ -0,0 +1,325 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * NXP FMan host-command transport.
+ *
+ * Generic synchronous request/response transport between the kernel
+ * and a microcode running inside the FMan policer/parser/keygen
+ * complex. The opcode space and payload encoding are
+ * microcode-specific (see specs/ask2-rewrite-spec.md §12 for the ASK2
+ * 210-microcode opcode map); only the transport — command/response
+ * MURAM slots, doorbell ringing, IRQ-driven completion, mutex
+ * serialisation — lives here.
+ *
+ * Per-FMan state is created lazily on the first fmd_host_cmd() call.
+ * A hidden registry list (fmd_host_cmd_state_list) keys per-FMan state
+ * structs by their owning struct fman *.
+ *
+ * Hardware-probe gap (see specs/ask2-rewrite-spec.md §12.7):
+ *   - The FMan FPM doorbell register offset for host-command
+ *     submission and the IRQ-status bit asserted on response are
+ *     microcode-specific and not documented in the public FMan TRM.
+ *     The two helpers fmd_host_cmd_ring_doorbell() and
+ *     fmd_host_cmd_arm_irq() return -ENXIO until the hardware-probe
+ *     PR (see plans/ASK2-IMPLEMENTATION.md PR13) fills in the
+ *     microcode-specific MMIO bring-up.
+ *   - Until then, any caller of fmd_host_cmd() receives -ENXIO
+ *     immediately after the wire-format header is composed in MURAM
+ *     (which is observable by reading the MURAM region from
+ *     userspace via /dev/mem on a debug kernel).
+ *
+ * Copyright 2026 Mono Networks / VyOS LS1046A maintainers.
+ */
+
+#include <linux/completion.h>
+#include <linux/device.h>
+#include <linux/errno.h>
+#include <linux/io.h>
+#include <linux/jiffies.h>
+#include <linux/list.h>
+#include <linux/module.h>
+#include <linux/mutex.h>
+#include <linux/slab.h>
+#include <linux/spinlock.h>
+#include <linux/string.h>
+#include <linux/types.h>
+#include <linux/fsl/fman_host_cmd.h>
+
+#include "fman.h"
+#include "fman_muram.h"
+
+/* MURAM slot sizes. The 4-byte header is included in the slot. */
+#define FMD_HOST_CMD_HDR_LEN		4
+#define FMD_HOST_CMD_REQ_SLOT_SIZE	1024
+#define FMD_HOST_CMD_RESP_SLOT_SIZE	1024
+#define FMD_HOST_CMD_MAX_PAYLOAD	(FMD_HOST_CMD_REQ_SLOT_SIZE - \
+					 FMD_HOST_CMD_HDR_LEN)
+#define FMD_HOST_CMD_TIMEOUT_MS		100
+
+/* Per-FMan host-command state. */
+struct fmd_host_cmd_state {
+	struct list_head	link;
+	struct fman		*fman;
+
+	/* MURAM offsets and CPU-side virtual base for the request/response
+	 * slots. Allocated once on the first fmd_host_cmd() call against
+	 * @fman; freed only at module unload (we never know when the last
+	 * caller is finished). Each MURAM call returns an unsigned long
+	 * offset; fman_muram_offset_to_vbase() converts to a CPU pointer.
+	 */
+	unsigned long		req_offset;
+	unsigned long		resp_offset;
+	void __iomem		*req_vbase;
+	void __iomem		*resp_vbase;
+
+	/* Serialises in-flight commands per FMan. */
+	struct mutex		lock;
+
+	/* Signalled from fmd_host_cmd_complete() when the microcode has
+	 * written a response into resp_vbase.
+	 */
+	struct completion	done;
+};
+
+/* Hidden registry of per-FMan state. Protected by fmd_host_cmd_reg_lock.
+ * Two-FMan SoCs (LS1043A et al.) need two slots; LS1046A is single-FMan.
+ */
+static LIST_HEAD(fmd_host_cmd_state_list);
+static DEFINE_MUTEX(fmd_host_cmd_reg_lock);
+
+/* ---------- Microcode-specific MMIO hooks (PR13 hardware probe) ---------- *
+ *
+ * These two helpers are the only place where microcode-specific MMIO
+ * happens. They return -ENXIO until the hardware-probe PR fills in the
+ * doorbell register offset and the IRQ binding.
+ *
+ * fmd_host_cmd_ring_doorbell() — write the request-ready notification
+ *   to a microcode-specific FMan FPM register so the microcode picks
+ *   up the request from req_vbase.
+ *
+ * fmd_host_cmd_arm_irq() — ensure the IRQ-status bit that
+ *   fmd_host_cmd_complete() relies on is unmasked.
+ */
+static int fmd_host_cmd_ring_doorbell(struct fmd_host_cmd_state *st)
+{
+	/* TODO(PR13): write microcode-specific doorbell register.
+	 * For ASK2 210 microcode, expected location is in FMan FPM CCSR;
+	 * exact offset to be confirmed by hardware probe per
+	 * specs/ask2-rewrite-spec.md §12.7.
+	 */
+	return -ENXIO;
+}
+
+static int fmd_host_cmd_arm_irq(struct fmd_host_cmd_state *st)
+{
+	/* TODO(PR13): unmask microcode-specific IRQ status bit.
+	 * Likely a status bit on the existing FMan err_irq line; the
+	 * exact mask is microcode-specific.
+	 */
+	return -ENXIO;
+}
+
+/* ------------------------------------------------------------------ */
+
+static struct fmd_host_cmd_state *fmd_host_cmd_lookup(struct fman *fman)
+{
+	struct fmd_host_cmd_state *st;
+
+	list_for_each_entry(st, &fmd_host_cmd_state_list, link)
+		if (st->fman == fman)
+			return st;
+	return NULL;
+}
+
+static struct fmd_host_cmd_state *
+fmd_host_cmd_get_or_create(struct fman *fman)
+{
+	struct fmd_host_cmd_state *st;
+	struct muram_info *muram;
+	unsigned long req_off, resp_off;
+	void __iomem *req_vb, *resp_vb;
+
+	mutex_lock(&fmd_host_cmd_reg_lock);
+	st = fmd_host_cmd_lookup(fman);
+	if (st) {
+		mutex_unlock(&fmd_host_cmd_reg_lock);
+		return st;
+	}
+
+	muram = fman_get_muram(fman);
+	if (!muram) {
+		mutex_unlock(&fmd_host_cmd_reg_lock);
+		return ERR_PTR(-ENODEV);
+	}
+
+	req_off = fman_muram_alloc(muram, FMD_HOST_CMD_REQ_SLOT_SIZE);
+	if (IS_ERR_VALUE(req_off)) {
+		mutex_unlock(&fmd_host_cmd_reg_lock);
+		return ERR_PTR(-ENOSPC);
+	}
+
+	resp_off = fman_muram_alloc(muram, FMD_HOST_CMD_RESP_SLOT_SIZE);
+	if (IS_ERR_VALUE(resp_off)) {
+		fman_muram_free_mem(muram, req_off, FMD_HOST_CMD_REQ_SLOT_SIZE);
+		mutex_unlock(&fmd_host_cmd_reg_lock);
+		return ERR_PTR(-ENOSPC);
+	}
+
+	req_vb = (void __iomem *)fman_muram_offset_to_vbase(muram, req_off);
+	resp_vb = (void __iomem *)fman_muram_offset_to_vbase(muram, resp_off);
+
+	st = kzalloc(sizeof(*st), GFP_KERNEL);
+	if (!st) {
+		fman_muram_free_mem(muram, req_off, FMD_HOST_CMD_REQ_SLOT_SIZE);
+		fman_muram_free_mem(muram, resp_off,
+				    FMD_HOST_CMD_RESP_SLOT_SIZE);
+		mutex_unlock(&fmd_host_cmd_reg_lock);
+		return ERR_PTR(-ENOMEM);
+	}
+
+	st->fman = fman;
+	st->req_offset = req_off;
+	st->resp_offset = resp_off;
+	st->req_vbase = req_vb;
+	st->resp_vbase = resp_vb;
+	mutex_init(&st->lock);
+	init_completion(&st->done);
+
+	list_add(&st->link, &fmd_host_cmd_state_list);
+
+	mutex_unlock(&fmd_host_cmd_reg_lock);
+	return st;
+}
+
+/*
+ * Compose the 4-byte header at the start of the request slot:
+ *   byte 0: opcode
+ *   byte 1: reserved (0)
+ *   bytes 2-3: payload length, big-endian
+ * Then memcpy_toio the payload immediately after.
+ */
+static void fmd_host_cmd_compose(struct fmd_host_cmd_state *st, u8 opcode,
+				 const void *req, size_t req_len)
+{
+	u8 hdr[FMD_HOST_CMD_HDR_LEN];
+
+	hdr[0] = opcode;
+	hdr[1] = 0;
+	hdr[2] = (req_len >> 8) & 0xff;
+	hdr[3] = req_len & 0xff;
+
+	memcpy_toio(st->req_vbase, hdr, FMD_HOST_CMD_HDR_LEN);
+	if (req_len)
+		memcpy_toio(st->req_vbase + FMD_HOST_CMD_HDR_LEN,
+			    req, req_len);
+}
+
+/*
+ * Parse the 4-byte response header out of the response slot. Returns
+ * the payload length on success or a negative errno on framing error.
+ */
+static int fmd_host_cmd_parse_resp_hdr(struct fmd_host_cmd_state *st,
+				       u8 expected_opcode)
+{
+	u8 hdr[FMD_HOST_CMD_HDR_LEN];
+	u16 plen;
+
+	memcpy_fromio(hdr, st->resp_vbase, FMD_HOST_CMD_HDR_LEN);
+
+	if (hdr[0] != expected_opcode)
+		return -EIO;
+
+	plen = ((u16)hdr[2] << 8) | hdr[3];
+	if (plen > FMD_HOST_CMD_MAX_PAYLOAD)
+		return -EIO;
+
+	return plen;
+}
+
+int fmd_host_cmd(struct fman *fman,
+		 u8 opcode,
+		 const void *req, size_t req_len,
+		 void *resp, size_t resp_buf_len,
+		 size_t *resp_len_out)
+{
+	struct fmd_host_cmd_state *st;
+	unsigned long timeout;
+	int ret, plen;
+
+	if (!fman || req_len > FMD_HOST_CMD_MAX_PAYLOAD ||
+	    (req_len && !req) || (resp_buf_len && !resp))
+		return -EINVAL;
+
+	st = fmd_host_cmd_get_or_create(fman);
+	if (IS_ERR(st))
+		return PTR_ERR(st);
+
+	mutex_lock(&st->lock);
+
+	reinit_completion(&st->done);
+	fmd_host_cmd_compose(st, opcode, req, req_len);
+
+	ret = fmd_host_cmd_arm_irq(st);
+	if (ret) {
+		/*
+		 * Hardware-probe gap: the IRQ wiring lives in the
+		 * microcode-specific bring-up patch (see PR13). Fail fast
+		 * with -ENXIO so the caller can surface a clean error
+		 * rather than block forever on a doorbell that no one
+		 * will ever ring.
+		 */
+		goto out_unlock;
+	}
+
+	ret = fmd_host_cmd_ring_doorbell(st);
+	if (ret)
+		goto out_unlock;
+
+	timeout = msecs_to_jiffies(FMD_HOST_CMD_TIMEOUT_MS);
+	if (!wait_for_completion_timeout(&st->done, timeout)) {
+		ret = -ETIMEDOUT;
+		goto out_unlock;
+	}
+
+	plen = fmd_host_cmd_parse_resp_hdr(st, opcode);
+	if (plen < 0) {
+		ret = plen;
+		goto out_unlock;
+	}
+
+	if (resp && resp_buf_len) {
+		size_t copy = min_t(size_t, (size_t)plen, resp_buf_len);
+
+		memcpy_fromio(resp, st->resp_vbase + FMD_HOST_CMD_HDR_LEN,
+			      copy);
+	}
+
+	if (resp_len_out)
+		*resp_len_out = (size_t)plen;
+
+	ret = 0;
+
+out_unlock:
+	mutex_unlock(&st->lock);
+	return ret;
+}
+EXPORT_SYMBOL_GPL(fmd_host_cmd);
+
+void fmd_host_cmd_complete(struct fman *fman)
+{
+	struct fmd_host_cmd_state *st;
+
+	/*
+	 * IRQ context — must not sleep. fmd_host_cmd_lookup() is a list
+	 * walk under fmd_host_cmd_reg_lock; on the LS1046A there is one
+	 * FMan so this is a single deref + ptr compare. For dual-FMan
+	 * SoCs the spinlock_irqsave variant would be needed; left as a
+	 * follow-up if/when this lands on LS1043A.
+	 */
+	mutex_lock(&fmd_host_cmd_reg_lock);
+	st = fmd_host_cmd_lookup(fman);
+	mutex_unlock(&fmd_host_cmd_reg_lock);
+
+	if (st)
+		complete(&st->done);
+}
+EXPORT_SYMBOL_GPL(fmd_host_cmd_complete);
diff --git a/include/linux/fsl/fman_host_cmd.h b/include/linux/fsl/fman_host_cmd.h
new file mode 100644
index 000000000..6e4b66263
--- /dev/null
+++ b/include/linux/fsl/fman_host_cmd.h
@@ -0,0 +1,84 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * NXP FMan host-command transport API.
+ *
+ * Synchronous request/response interface to a microcode loaded into
+ * the FMan policer/parser/keygen complex (e.g. NXP's proprietary 210
+ * fast-path microcode used by ASK2 — see
+ * specs/ask2-rewrite-spec.md).
+ *
+ * The generic framing wired by this header (4-byte command header +
+ * payload, MURAM-resident command/response slots, doorbell + IRQ
+ * completion) is microcode-agnostic: any future FMan microcode that
+ * implements the same MURAM doorbell convention can use this API.
+ * Opcode-specific encoding lives in the consumer (ask_hostcmd.c).
+ *
+ * Single-consumer per FMan device. Per-call mutex serialises in-flight
+ * commands. Synchronous: returns when the response has been written
+ * back to MURAM by the microcode (or after a 100 ms timeout).
+ *
+ * Copyright 2026 Mono Networks / VyOS LS1046A maintainers.
+ */
+
+#ifndef _LINUX_FSL_FMAN_HOST_CMD_H
+#define _LINUX_FSL_FMAN_HOST_CMD_H
+
+#include <linux/types.h>
+
+struct fman;
+
+/**
+ * fmd_host_cmd - send a host command to FMan microcode and await reply
+ * @fman:           FMan device handle (from fman_bind() or DT lookup)
+ * @opcode:         microcode opcode byte; meaning is microcode-specific.
+ *                  ASK2 opcodes are documented in
+ *                  specs/ask2-rewrite-spec.md §12.2.
+ * @req:            request payload (may be NULL when @req_len == 0).
+ *                  Maximum @req_len is 1020 bytes (1024-byte MURAM
+ *                  command slot minus the 4-byte header).
+ * @req_len:        length of @req in bytes.
+ * @resp:           response buffer (may be NULL when @resp_buf_len == 0).
+ * @resp_buf_len:   size of @resp in bytes; the function writes at most
+ *                  this many bytes back to the caller.
+ * @resp_len_out:   on success, set to the number of bytes the microcode
+ *                  actually returned (may be less than @resp_buf_len).
+ *                  May be NULL if the caller does not need it.
+ *
+ * Return:
+ *   0           on success (response written to @resp, length in @resp_len_out)
+ *   -EINVAL     bad arguments (NULL fman, @req_len > 1020, etc.)
+ *   -ENOMEM     could not allocate per-fman state on first call
+ *   -ENOSPC     MURAM region claim failed (insufficient MURAM)
+ *   -ENXIO      microcode-specific doorbell/IRQ wiring not yet
+ *               provisioned (see specs/ask2-rewrite-spec.md §12.7;
+ *               filled in by the hardware-probe PR)
+ *   -ETIMEDOUT  microcode did not respond within 100 ms
+ *   -EIO        microcode returned a malformed response
+ *   -EBUSY      a concurrent caller already holds the host-command
+ *               mutex (only returned in non-blocking mode, currently
+ *               unused — the synchronous API blocks instead)
+ *
+ * Context: may sleep (mutex_lock + wait_for_completion_timeout).
+ */
+int fmd_host_cmd(struct fman *fman,
+		 u8 opcode,
+		 const void *req, size_t req_len,
+		 void *resp, size_t resp_buf_len,
+		 size_t *resp_len_out);
+
+/**
+ * fmd_host_cmd_complete - signal that the microcode has written a response
+ * @fman: FMan device whose host-command IRQ fired.
+ *
+ * Called from the IRQ status path that is installed by the
+ * microcode-specific bring-up code (added in a follow-up patch — see
+ * specs/ask2-rewrite-spec.md §12.7 "Event channel binding"). Wakes any
+ * caller currently sleeping inside fmd_host_cmd().
+ *
+ * Safe to call from hard-IRQ context. No-op if no per-fman state has
+ * been allocated yet (i.e. fmd_host_cmd() has never been called for
+ * this FMan).
+ */
+void fmd_host_cmd_complete(struct fman *fman);
+
+#endif /* _LINUX_FSL_FMAN_HOST_CMD_H */
-- 
