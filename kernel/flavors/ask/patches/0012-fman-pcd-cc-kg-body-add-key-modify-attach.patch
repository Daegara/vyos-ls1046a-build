 .../freescale/fman/fman_keygen_internal.h     |  12 ++
 .../net/ethernet/freescale/fman/fman_pcd_cc.c | 145 ++++++++++++++++--
 .../freescale/fman/fman_pcd_internal.h        |  11 ++
 .../net/ethernet/freescale/fman/fman_pcd_kg.c |  68 ++++++--
