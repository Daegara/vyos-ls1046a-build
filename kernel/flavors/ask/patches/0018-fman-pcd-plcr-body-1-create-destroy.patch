From 62514722d78007ebce080517e0d35df6b916c8fc Mon Sep 17 00:00:00 2001
From: ci <ci@local>
Date: Thu, 14 May 2026 06:23:33 +0000
Subject: [PATCH] fman: pcd_plcr body-1 -- struct + create/destroy MURAM bodies

---
 .../ethernet/freescale/fman/fman_pcd_plcr.c   | 432 +++++++++++++++---
 1 file changed, 371 insertions(+), 61 deletions(-)

diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_plcr.c b/drivers/net/ethernet/freescale/fman/fman_pcd_plcr.c
index d5e2345bb..ef6501b2e 100644
--- a/drivers/net/ethernet/freescale/fman/fman_pcd_plcr.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_plcr.c
@@ -1,116 +1,426 @@
 // SPDX-License-Identifier: GPL-2.0
 /*
- * FMan PCD Policer profiles - public API stubs.
+ * FMan PCD Policer profiles - struct + create/destroy MURAM bodies.
  *
- * PR14e-prep of the ASK2 v1.0 PR14 series.  Declares the on-disk
- * translation unit for the policer-profile layer and provides
- * -EOPNOTSUPP stubs for every public entry point declared in
- * <linux/fsl/fman_pcd.h>.  PR14e-body replaces these stubs with the
- * real silicon-programming code per LS1046A RM 8.7.6 (Policer profile
- * record format and trTCM token-bucket arithmetic).
+ * PR14e-body-1 of the ASK2 v1.0 PR14 series.  Replaces the PR14e-prep
+ * -EOPNOTSUPP stubs of fman_pcd_plcr_profile_create() and
+ * fman_pcd_plcr_profile_destroy() with the skeleton MURAM-resident
+ * allocation pair, and provides the private struct fman_pcd_plcr_profile
+ * definition that body-2 will populate with real trTCM rate/burst
+ * programming per LS1046A RM 8.7.6.
+ *
+ * fman_pcd_plcr_profile_set_rates() stays -EOPNOTSUPP at body-1; it
+ * shares the encoder with the body-2 create-path so it lands together
+ * in body-2 as a pure encoder drop.
  *
  * Authoritative reference
  * -----------------------
  * - LS1046A Reference Manual sec 8.7.6 (Policer profile record).
  * - RFC 4115 (Two Rate Three Color Marker - trTCM).
+ * - LS1046A Reference Manual sec 8.7.4.3 (AD opcode-extension layout
+ *   for policer-profile id; consumed by cc_encode_ad MANIPULATE/FQ
+ *   arms when they carry a non-zero plcr_profile_id at PR14e-body-3).
  *
  * Provenance (v1.1)
- * ---------------------
+ * -----------------
  * Mainline drivers/net/ethernet/freescale/fman/ has zero policer code;
  * this file is authored from the RM only.  The legacy NXP SDK
  * fm_plcr.c (~1900 LOC under drivers/net/ethernet/freescale/sdk_fman/
  * Peripherals/FM/Pcd/ in the archived mihakralj/kernel-ls1046a-build
  * repo at HEAD 464df181) is a read-only silicon-fact cross-reference
- * only - no code or struct layouts are copied from it.  See spec
- * specs/ask2-rewrite-spec.md sec 16 (provenance discipline risk #12).
- *
- * What this file delivers at PR14e-prep
- * -------------------------------------
- * Three public entry points, all returning ERR_PTR(-EOPNOTSUPP) /
- * -EOPNOTSUPP / no-op.  No struct fman_pcd_plcr_profile definition yet -
- * it stays forward-declared in <linux/fsl/fman_pcd.h>.  No MURAM
- * allocation, no register writes.  The point of this PR is to lock
- * down the public ABI surface (struct fman_pcd_plcr_params with CIR /
- * CBS / EIR / EBS + color mode) and the Makefile integration so that
- * PR14e-body is a pure implementation drop.
- *
- * Locking model (forward-looking, PR14e-body)
- * -------------------------------------------
- * pcd->lock serialises profile-slot allocation and the slot-bitmap
- * update.  Per-profile rate updates via fman_pcd_plcr_profile_set_rates()
- * use a 128-bit MMIO store under pcd->lock - the silicon side observes
- * the new rates atomically.  Token-bucket counters in MURAM are NOT
- * reset on a rate update; ask.ko's M5 QoS code relies on this.
+ * only - no code or struct layouts are copied from it.  Cross-refs
+ * appear inline in "RM ... + cross-ref SDK fm_plcr.{h,c} <symbol>"
+ * style comments per spec specs/ask2-rewrite-spec.md sec 13 (citation
+ * discipline) and sec 16 (provenance discipline risk 12).
+ *
+ * Locking model
+ * -------------
+ * pcd->lock (via fman_pcd_get_lock()) serialises the plcr-list
+ * mutation (add/remove of struct fman_pcd_plcr_profile on
+ * pcd->plcr_list) and the profile-slot id allocation -- body-2 walks
+ * the existing list to find a free slot in 0..255.  Per-profile
+ * profile->lock is a spinlock; reserved for body-2 (set_rates may run
+ * from softirq context on flow-table updates that change CIR/EIR
+ * without re-creating the profile, which would lose the id and force
+ * every CC key to be re-modified).  The CC walker reads MURAM directly
+ * so the spinlock is between in-kernel writers only.
+ *
+ * Silicon facts driving the layout
+ * --------------------------------
+ *  - RM 8.7.6 paragraph 2: per-profile policer record is a fixed
+ *    16-byte MURAM-resident structure (mode + cir/eir rate fields +
+ *    cbs/ebs token-bucket depths).  Cross-ref SDK fm_plcr.h::t_FmPcdPlcrProfileRegs.
+ *  - RM 8.7.6 paragraph 4: FMAN_PCD_PLCR_MAX_PROFILES = 256 profile
+ *    slots per FMan instance; profile id is a u16 (only low 8 bits
+ *    used on LS1046A FMan v3).
+ *  - RM 8.7.6 paragraph 3: profile mode-register layout - bit15
+ *    selects color-aware (1) vs color-blind (0); bits[14:12] select
+ *    rate-mode (single-rate, two-rate, byte-mode vs packet-mode);
+ *    body-2 fixes the algorithm at trTCM byte-mode for v1.0.
+ *  - RM 8.7.6 paragraph 5: rate fields encode bps as an FMan-clock-
+ *    cycle increment using a (3-bit exponent + 16-bit mantissa)
+ *    floating-point scheme.  CBS/EBS burst-depths use the same
+ *    encoding.  Body-2 carries the encoder helper.
+ *  - Token-bucket counters in MURAM are NOT reset on a rate update;
+ *    ask.ko's M5 QoS code relies on this for graceful CIR/EIR
+ *    re-tuning under live traffic.
+ *  - Cross-ref SDK fm_plcr.c PlcrProfileSetRates: the SDK does a single
+ *    128-bit MMIO store under spin_lock_irqsave to update all four
+ *    rate fields atomically from the silicon side.  We do the same in
+ *    body-2.
  */
 
 #include <linux/err.h>
 #include <linux/errno.h>
 #include <linux/export.h>
+#include <linux/io.h>
 #include <linux/kernel.h>
+#include <linux/list.h>
 #include <linux/module.h>
+#include <linux/mutex.h>
+#include <linux/slab.h>
+#include <linux/spinlock.h>
 #include <linux/types.h>
 
 #include <linux/fsl/fman_pcd.h>
+#include "fman.h"
+#include "fman_muram.h"
 #include "fman_pcd_internal.h"
 
-/* Silicon hard limit per RM 8.7.6: 256 policer profiles per FMan. */
-#define FMAN_PCD_PLCR_MAX_PROFILES 256
+/* ------------------------------------------------------------------ */
+/* Silicon hard limits - RM 8.7.6                                      */
+/* ------------------------------------------------------------------ */
+
+/* FMAN_PCD_PLCR_MAX_PROFILES (RM 8.7.6 p.4): 256 profile slots per FMan. */
+#define FMAN_PCD_PLCR_MAX_PROFILES	256
+
+/* ------------------------------------------------------------------ */
+/* Profile record layout - RM 8.7.6 paragraph 2                        */
+/* ------------------------------------------------------------------ */
+
+/*
+ * The per-profile policer record is a 16-byte MURAM-resident structure
+ * consumed by the FMan policer engine.  Field offsets within the
+ * record, all big-endian relative to the host:
+ *
+ *   0x0  u16 mode         - profile-mode register (color-aware,
+ *                           algorithm, rate-mode); see PMR_* bits below
+ *   0x2  u16 res0         - reserved
+ *   0x4  u32 cir          - committed information rate, encoded per
+ *                           RM 8.7.6 p.5 (3-bit exp + 16-bit mant + 13
+ *                           bits flags/reserved)
+ *   0x8  u32 cbs          - committed burst size, same encoding
+ *   0xc  u32 eir_ebs_lo   - upper 16 bits = EIR (same encoding),
+ *                           lower 16 bits = EBS (encoded as a u16
+ *                           variant per RM 8.7.6 p.5)
+ *
+ * Cross-ref SDK fm_plcr.h::t_FmPcdPlcrProfileRegs (packed struct, 16 B).
+ *
+ * Note: the SDK splits CIR/EIR/CBS/EBS across additional reserved
+ * fields for FMan v2.  On LS1046A (FMan v3) the silicon honours the
+ * compact 16-byte layout above; the older SDK source carries v2-only
+ * field offsets which we deliberately do NOT mirror.
+ */
+#define FMAN_PCD_PLCR_PROFILE_SIZE	16
+#define FMAN_PCD_PLCR_OFF_MODE	0x0
+#define FMAN_PCD_PLCR_OFF_CIR	0x4
+#define FMAN_PCD_PLCR_OFF_CBS	0x8
+#define FMAN_PCD_PLCR_OFF_EIR_EBS	0xc
+
+/* ------------------------------------------------------------------ */
+/* Profile-mode register bits - RM 8.7.6 paragraph 3                   */
+/* ------------------------------------------------------------------ */
+
+/*
+ * Cross-ref SDK fm_plcr.h::FM_PCD_PLCR_PMR_*.  Body-1 pre-declares the
+ * full set so that body-2 is a pure encoder drop with no new constants
+ * to land.
+ *
+ *   COLOR_AWARE      0x8000  - bit15: 1 = honour ingress color from
+ *                              upstream policer, 0 = color-blind (treat
+ *                              every frame as green).  RFC 4115 sec 2.
+ *   ALG_TRTCM        0x2000  - bits[14:12]: 3'b010 = trTCM byte-mode.
+ *                              Other values reserved for body-2
+ *                              algorithm extensions (srTCM, packet-mode).
+ *   PACKET_MODE      0x1000  - bit12: 1 = packet-rate mode (CIR/EIR in
+ *                              pps), 0 = byte-rate mode (CIR/EIR in bps).
+ *                              v1.0 always byte-mode.
+ *   DROP_PROBABILITY 0x0080  - bit7:  1 = WRED-style probabilistic drop
+ *                              for yellow frames; v1.0 always 0 (hard
+ *                              two-rate drop).
+ *   PIR_DISABLED     0x0040  - bit6:  1 = single-rate srTCM (CIR only),
+ *                              0 = two-rate trTCM (CIR + EIR).  v1.0
+ *                              always 0 -- ASK2 uses trTCM exclusively
+ *                              even when eir_bps==0 (callers requesting
+ *                              srTCM should set eir=cir and EBS=CBS).
+ *
+ * NOTE: ALG_TRTCM and PACKET_MODE overlap at bit12; this is per RM
+ * 8.7.6 Table 8-167 -- the bits[14:12] field is a 3-bit composite where
+ * 010 = trTCM byte-mode, 011 = trTCM packet-mode, etc.  The
+ * convenience #defines above match the SDK split for readability.
+ */
+#define FMAN_PCD_PLCR_PMR_COLOR_AWARE	0x8000u
+#define FMAN_PCD_PLCR_PMR_ALG_TRTCM	0x2000u
+#define FMAN_PCD_PLCR_PMR_PACKET_MODE	0x1000u
+#define FMAN_PCD_PLCR_PMR_DROP_PROBABILITY	0x0080u
+#define FMAN_PCD_PLCR_PMR_PIR_DISABLED	0x0040u
+
+/* ------------------------------------------------------------------ */
+/* Rate-field encoding - RM 8.7.6 paragraph 5                          */
+/* ------------------------------------------------------------------ */
+
+/*
+ * Each rate field encodes bps as an FMan-clock-cycle increment using a
+ * (3-bit exponent + 16-bit mantissa) floating-point scheme:
+ *
+ *   bits[31:29]  exp  - shift count, 0..7
+ *   bits[28:13]  mant - 16-bit mantissa
+ *   bits[12:0]   reserved (silicon writes 0)
+ *
+ * Effective rate = mant << exp, scaled by FMan-clock-cycle constant
+ * documented in RM 8.7.6 Table 8-168.  Body-2 provides the bps -> (exp,
+ * mant) encoder helper.
+ *
+ * CBS/EBS burst-depths use a u16-wide variant (no exponent field, just
+ * a saturating mantissa scaled by 256-byte units per RM Table 8-169).
+ * Body-2 provides the bytes -> u16 encoder.
+ */
+#define FMAN_PCD_PLCR_RATE_EXP_SHIFT	29
+#define FMAN_PCD_PLCR_RATE_EXP_MASK	(0x7u << 29)
+#define FMAN_PCD_PLCR_RATE_MANT_SHIFT	13
+#define FMAN_PCD_PLCR_RATE_MANT_MASK	(0xffffu << 13)
+#define FMAN_PCD_PLCR_BURST_UNIT_BYTES	256
+
+/* ------------------------------------------------------------------ */
+/* Private profile handle                                              */
+/* ------------------------------------------------------------------ */
+
+/**
+ * struct fman_pcd_plcr_profile - one MURAM-resident policer profile.
+ * @node:        anchor on pcd->plcr_list (protected by pcd->lock)
+ * @pcd:         owning PCD subsystem; back-pointer for MURAM free
+ * @profile_id:  silicon slot id 0..255; allocated by body-2
+ * @color_mode:  copied from params->color_mode at create-time
+ * @cir_bps:     cached CIR for set_rates() comparison (body-2)
+ * @cbs_bytes:   cached CBS
+ * @eir_bps:     cached EIR
+ * @ebs_bytes:   cached EBS
+ * @record_off:  MURAM byte offset of the 16-byte profile record
+ * @record:      CPU-visible iomem pointer to the profile record;
+ *               16-byte aligned (gen_pool min_alloc_order=8 satisfies
+ *               the RM 8.7.6 alignment requirement naturally)
+ * @lock:        per-profile spinlock; reserved for body-2 set_rates
+ *
+ * Definition is private to this translation unit; the public ABI
+ * forward-declares it in <linux/fsl/fman_pcd.h>.
+ *
+ * Cross-ref SDK fm_plcr.h::t_FmPcdPlcrProfile (a ~30-field struct
+ * mixing per-profile state with statistics counters, owner list,
+ * spinlock, parent net-env pointers).  We keep only the eleven fields
+ * needed for the v1.0 ASK2 fast-flow path; the statistics, multi-
+ * policer-chain, and net-env-binding fields are reintroduced piecemeal
+ * in later milestones (M3+).
+ */
+struct fman_pcd_plcr_profile {
+	struct list_head		node;
+	struct fman_pcd		*pcd;
+	u16				profile_id;
+	enum fman_pcd_plcr_color_mode	color_mode;
+	u64				cir_bps;
+	u32				cbs_bytes;
+	u64				eir_bps;
+	u32				ebs_bytes;
+	unsigned long			record_off;
+	void __iomem			*record;
+	spinlock_t			lock;
+};
 
 /**
  * fman_pcd_plcr_profile_create() - allocate and program one policer profile.
  *
- * PR14e-prep stub.  See <linux/fsl/fman_pcd.h> for the full contract.
- * Returns ERR_PTR(-EOPNOTSUPP) until PR14e-body lands.
+ * Implements the public ABI declared in <linux/fsl/fman_pcd.h>.
+ *
+ * PR14e-body-1 sequence:
+ *   1. Validate args (pcd, params non-NULL; color_mode one of
+ *      BLIND/AWARE; at least one of CIR/EIR non-zero with matching
+ *      burst-depth non-zero).
+ *   2. kzalloc the profile handle; init list anchor + spinlock;
+ *      record pcd back-pointer and cache the rate/burst/color params
+ *      so body-2 set_rates() can compare against the previous values.
+ *   3. fman_pcd_muram_alloc() the 16-byte profile record.  gen_pool
+ *      min_alloc_order=8 satisfies the RM 8.7.6 16-byte alignment
+ *      requirement naturally.
+ *   4. fman_muram_offset_to_vbase() to obtain the CPU pointer.
+ *   5. memset_io() the record to zero.  Sets mode=0 (color-blind,
+ *      ALG=0, PACKET_MODE=0, PIR_DISABLED=0) and zero rate/burst -
+ *      silicon treats as inactive profile (zero CIR meters every
+ *      frame as red and drops; safe until body-2 programs real rates).
+ *   6. Body-2 allocates a free slot 0..255 in the silicon profile-id
+ *      space; body-1 leaves profile_id=0 so a CC key referencing this
+ *      handle before body-2 lands would point at the well-known
+ *      slot-0 (which is reserved for catch-all in the SDK and harmless
+ *      because the record's mode field is still 0).
+ *   7. Under pcd->lock, list_add the profile to pcd->plcr_list so
+ *      fman_pcd_release() can tear it down on driver unbind even if
+ *      the caller leaks the handle.
+ *
+ * Body-1 deliberately does NOT yet write any per-profile mode/rate/
+ * burst values; the function returns a valid handle whose silicon
+ * record is inactive.  Body-2 lands the encoder dispatch
+ * (color-mode + ALG_TRTCM | (eir?0:PIR_DISABLED) into mode, encoded
+ * rate fields into cir/cbs/eir+ebs).  Until body-2 lands, a profile
+ * handle created by body-1 cannot meter traffic - it just reserves
+ * MURAM and a list-anchor slot.
+ *
+ * RM 8.7.6 paragraph 2 (profile record layout) + RFC 4115 sec 2
+ * (trTCM mode + CIR/CBS/EIR/EBS semantics) + cross-ref SDK fm_plcr.c
+ * FmPcdPlcrProfileSet() for the MURAM-alloc-then-zero pattern.
  */
 struct fman_pcd_plcr_profile *
 fman_pcd_plcr_profile_create(struct fman_pcd *pcd,
-     const struct fman_pcd_plcr_params *params)
+			     const struct fman_pcd_plcr_params *params)
 {
-if (!pcd || !params)
-return ERR_PTR(-EINVAL);
-if (params->color_mode != FMAN_PCD_PLCR_COLOR_BLIND &&
-    params->color_mode != FMAN_PCD_PLCR_COLOR_AWARE)
-return ERR_PTR(-EINVAL);
-if (params->cir_bps == 0 && params->eir_bps == 0)
-return ERR_PTR(-EINVAL);
-if (params->cbs_bytes == 0 && params->ebs_bytes == 0)
-return ERR_PTR(-EINVAL);
-
-return ERR_PTR(-EOPNOTSUPP);
+	struct fman_pcd_plcr_profile *prof;
+	struct muram_info *muram;
+	struct mutex *pcd_lock;
+	unsigned long off;
+	void __iomem *vb;
+	long err;
+
+	if (!pcd || !params)
+		return ERR_PTR(-EINVAL);
+	if (params->color_mode != FMAN_PCD_PLCR_COLOR_BLIND &&
+	    params->color_mode != FMAN_PCD_PLCR_COLOR_AWARE)
+		return ERR_PTR(-EINVAL);
+	if (params->cir_bps == 0 && params->eir_bps == 0)
+		return ERR_PTR(-EINVAL);
+	if (params->cbs_bytes == 0 && params->ebs_bytes == 0)
+		return ERR_PTR(-EINVAL);
+
+	muram = fman_get_muram(fman_pcd_get_fman(pcd));
+	if (!muram)
+		return ERR_PTR(-ENXIO);
+
+	prof = kzalloc(sizeof(*prof), GFP_KERNEL);
+	if (!prof)
+		return ERR_PTR(-ENOMEM);
+
+	INIT_LIST_HEAD(&prof->node);
+	spin_lock_init(&prof->lock);
+	prof->pcd = pcd;
+	prof->color_mode = params->color_mode;
+	prof->cir_bps = params->cir_bps;
+	prof->cbs_bytes = params->cbs_bytes;
+	prof->eir_bps = params->eir_bps;
+	prof->ebs_bytes = params->ebs_bytes;
+	/* profile_id is set by body-2 slot-allocator; body-1 leaves 0.   */
+
+	/*
+	 * Allocate the 16-byte profile record.  All-zero record has
+	 * mode=0 (color-blind | ALG=0 | byte-mode) and zero rates -
+	 * silicon treats every frame as red (drop).  Cross-ref SDK
+	 * fm_plcr.c PlcrProfileMemMap() for the same alloc-then-zero
+	 * pattern.
+	 */
+	off = fman_pcd_muram_alloc(pcd, FMAN_PCD_PLCR_PROFILE_SIZE);
+	if (IS_ERR_VALUE(off)) {
+		err = (long)off;
+		kfree(prof);
+		return ERR_PTR(err);
+	}
+
+	vb = (void __iomem *)fman_muram_offset_to_vbase(muram, off);
+	if (!vb) {
+		fman_pcd_muram_free(pcd, off, FMAN_PCD_PLCR_PROFILE_SIZE);
+		kfree(prof);
+		return ERR_PTR(-ENXIO);
+	}
+
+	prof->record_off = off;
+	prof->record = vb;
+	memset_io(vb, 0, FMAN_PCD_PLCR_PROFILE_SIZE);
+
+	/*
+	 * Publish on the PCD plcr list.  fman_pcd_release() on driver
+	 * unbind walks this list and calls fman_pcd_plcr_profile_destroy()
+	 * on every surviving handle, so callers cannot leak MURAM by
+	 * forgetting to destroy.  Cross-ref fman_pcd.c fman_pcd_release.
+	 */
+	pcd_lock = fman_pcd_get_lock(pcd);
+	mutex_lock(pcd_lock);
+	list_add_tail(&prof->node, fman_pcd_get_plcr_list(pcd));
+	mutex_unlock(pcd_lock);
+
+	return prof;
 }
 EXPORT_SYMBOL_GPL(fman_pcd_plcr_profile_create);
 
 /**
  * fman_pcd_plcr_profile_set_rates() - runtime rate update.
  *
- * PR14e-prep stub.  See <linux/fsl/fman_pcd.h> for the full contract.
- * Returns -EOPNOTSUPP until PR14e-body lands.
+ * PR14e-body-1 stub.  See <linux/fsl/fman_pcd.h> for the full
+ * contract.  Body-2 lands the real rate-field encoder shared with
+ * create(); body-1 leaves this -EOPNOTSUPP so the two land together
+ * as a pure encoder drop.
+ *
+ * Returns -EOPNOTSUPP until PR14e-body-2 lands.
  */
 int fman_pcd_plcr_profile_set_rates(struct fman_pcd_plcr_profile *prof,
-    const struct fman_pcd_plcr_params *params)
+				    const struct fman_pcd_plcr_params *params)
 {
-if (!prof || !params)
-return -EINVAL;
-if (params->color_mode != FMAN_PCD_PLCR_COLOR_BLIND &&
-    params->color_mode != FMAN_PCD_PLCR_COLOR_AWARE)
-return -EINVAL;
+	if (!prof || !params)
+		return -EINVAL;
+	if (params->color_mode != FMAN_PCD_PLCR_COLOR_BLIND &&
+	    params->color_mode != FMAN_PCD_PLCR_COLOR_AWARE)
+		return -EINVAL;
 
-return -EOPNOTSUPP;
+	return -EOPNOTSUPP;
 }
 EXPORT_SYMBOL_GPL(fman_pcd_plcr_profile_set_rates);
 
 /**
  * fman_pcd_plcr_profile_destroy() - free one policer profile.
  *
- * PR14e-prep stub.  See <linux/fsl/fman_pcd.h> for the full contract.
- * NULL-safe no-op until PR14e-body lands.
+ * Implements the public ABI declared in <linux/fsl/fman_pcd.h>.
+ *
+ * Sequence (reverse of create):
+ *   1. NULL-safe early return.
+ *   2. Under pcd->lock, list_del from pcd->plcr_list.
+ *   3. fman_pcd_muram_free() the 16-byte profile record.
+ *   4. kfree the handle.
+ *
+ * Body-2 will also clear the profile-slot bitmap bit allocated by
+ * its slot-allocator, and zero the silicon record in MURAM before
+ * the free so any subsequent slot reuse starts from a clean record.
+ * Body-1 doesn't have a slot-allocator yet so this step is a no-op.
+ *
+ * The public ABI doc-comment says "WARN if any CC action template
+ * still references this profile id".  Until PR14e-body-3 wires the
+ * cc_encode_ad PLCR-arm (writing the profile id into the AD
+ * plcrProfile word), no CC key can reference a profile, so there is
+ * nothing to count - the WARN_ON extends in body-3.
+ *
+ * RM 8.7.6 + cross-ref SDK fm_plcr.c FmPcdPlcrProfileDelete.
  */
 void fman_pcd_plcr_profile_destroy(struct fman_pcd_plcr_profile *prof)
 {
-if (!prof)
-return;
-/* PR14e-body: clear profile-slot bitmap bit, zero MURAM record,
- * WARN if any CC action template still references this id, free handle.
- */
+	struct fman_pcd *pcd;
+	struct mutex *pcd_lock;
+
+	if (!prof)
+		return;
+
+	pcd = prof->pcd;
+	if (WARN_ON(!pcd))
+		return;
+
+	pcd_lock = fman_pcd_get_lock(pcd);
+	mutex_lock(pcd_lock);
+	list_del(&prof->node);
+	mutex_unlock(pcd_lock);
+
+	fman_pcd_muram_free(pcd, prof->record_off,
+			    FMAN_PCD_PLCR_PROFILE_SIZE);
+	kfree(prof);
 }
