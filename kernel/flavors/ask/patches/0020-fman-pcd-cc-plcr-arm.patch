diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_cc.c b/drivers/net/ethernet/freescale/fman/fman_pcd_cc.c
index 5a7951ce4..6d444142a 100644
--- a/drivers/net/ethernet/freescale/fman/fman_pcd_cc.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_cc.c
@@ -292,9 +292,9 @@ struct fman_pcd_cc_node {
  * PR14c-body-4 wires fman_pcd_cc_node_add_key().
  *
  * Returns 0 on success, -EINVAL for an unknown action->type, and
- * -EOPNOTSUPP for REPLICATE/MANIPULATE which require helper objects
- * not yet plumbed (REPLICATE waits on PR14f-body integration; the
- * MANIPULATE arm landed in PR14d-body-3 and is now functional).
+ * -EOPNOTSUPP only for REPLICATE which waits on PR14f-body
+ * integration.  MANIPULATE landed in PR14d-body-3; POLICE landed
+ * in PR14e-body-3.
  *
  * Empty-table FQ-0-trap safety property (carried over from body-2):
  * an all-zero AD slot decodes as RESULT_CONTRL_FLOW with fqid=0, which
@@ -391,6 +391,50 @@ cc_encode_ad(const struct fman_pcd_action *action, void __iomem *ad)
 		break;
 	}
 
+	case FMAN_PCD_ACTION_POLICE: {
+		/*
+		 * Police-AD encoding per RM 8.7.4.3 Table 8-119 cross-ref
+		 * SDK fm_cc.c BuildAdForProfile() (RESULT_CF + plcr-arm).
+		 * The match-table AD encodes a control-flow result that
+		 * is metered by the named policer profile BEFORE the
+		 * frame is enqueued to next_fqid:
+		 *
+		 *   fqid = police.next_fqid    (post-meter FQID)
+		 *   plcr = profile_id          (silicon slot 0..255 as
+		 *                               programmed by PR14e
+		 *                               body-1/2 into MURAM)
+		 *   nia  = RESULT_CF           (PLCR_DIS clear -- the
+		 *                               whole point is to run
+		 *                               the policer pass)
+		 *   res  = 0                   (no chained next-AD)
+		 *
+		 * Silicon ordering: AD -> PLCR meter -> trTCM color
+		 * decision -> (green|yellow) enqueue to AD.fqid, (red)
+		 * drop or downgrade per the profile's mode word.  The
+		 * profile's record was written under prof->lock by
+		 * plcr_program_record() in body-2.
+		 *
+		 * Validation: non-NULL profile handle, non-zero post-
+		 * meter fqid, and a profile_id in the silicon-legal
+		 * 0..255 range (the accessor returns 0xffff for NULL).
+		 */
+		u16 pid;
+
+		if (!action->police.profile)
+			return -EINVAL;
+		if (action->police.next_fqid == 0)
+			return -EINVAL;
+		pid = fman_pcd_plcr_profile_id_internal(action->police.profile);
+		if (pid == 0xffffu)
+			return -EINVAL;
+		if (pid > 0xffu)
+			return -ERANGE;
+		nia = FMAN_PCD_AD_NIA_TYPE_RESULT_CF;
+		fqid = action->police.next_fqid;
+		plcr = pid;
+		break;
+	}
+
 	default:
 		return -EINVAL;
 	}
diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_internal.h b/drivers/net/ethernet/freescale/fman/fman_pcd_internal.h
index 3e79617ad..f009828ca 100644
