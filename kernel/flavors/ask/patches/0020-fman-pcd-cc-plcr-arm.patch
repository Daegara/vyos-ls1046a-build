+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_internal.h
@@ -67,4 +67,17 @@ unsigned long fman_pcd_cc_tree_group_table_off(
  */
 unsigned long fman_pcd_manip_hmtd_off(const struct fman_pcd_manip *manip);
 
+/* fman_pcd_plcr_profile_id_internal:
+ *   Cross-TU accessor exposing struct fman_pcd_plcr_profile::profile_id
+ *   to fman_pcd_cc.c, which needs it to encode the
+ *   FMAN_PCD_ACTION_POLICE arm in cc_encode_ad().  Mirrors the
+ *   public fman_pcd_plcr_profile_get_id() one-to-one; declared in
+ *   the internal header so the CC TU does not have to pull in
+ *   <linux/fsl/fman_pcd.h>'s public-ABI sentinel surface for a
+ *   single accessor.  Returns 0xffff for NULL @prof to match the
+ *   sibling-TU defensive idiom.
+ */
+u16 fman_pcd_plcr_profile_id_internal(
+	const struct fman_pcd_plcr_profile *prof);
+
 #endif /* __FMAN_PCD_INTERNAL_H */
diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_plcr.c b/drivers/net/ethernet/freescale/fman/fman_pcd_plcr.c
index 5c100ce8b..40a7f473d 100644
--- a/drivers/net/ethernet/freescale/fman/fman_pcd_plcr.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_plcr.c
@@ -725,3 +725,38 @@ void fman_pcd_plcr_profile_destroy(struct fman_pcd_plcr_profile *prof)
 	kfree(prof);
 }
 EXPORT_SYMBOL_GPL(fman_pcd_plcr_profile_destroy);
+
+/**
+ * fman_pcd_plcr_profile_get_id() - read the silicon slot id of @prof.
+ *
+ * Public-ABI accessor matching the declaration in
+ * <linux/fsl/fman_pcd.h>.  Cross-TU consumers inside the driver
+ * (currently fman_pcd_cc.c via the FMAN_PCD_ACTION_POLICE arm in
+ * cc_encode_ad()) reach this through the internal accessor
+ * fman_pcd_plcr_profile_id_internal() declared in
+ * fman_pcd_internal.h, which is just a thin alias of this one.
+ * Returns 0xffff for a NULL @prof so callers can distinguish from
+ * the well-known catch-all silicon id 0; the body-1 slot
+ * allocator never hands out 0xffff (max legal id is 0xff).
+ */
+u16 fman_pcd_plcr_profile_get_id(const struct fman_pcd_plcr_profile *prof)
+{
+	if (!prof)
+		return 0xffffu;
+	return prof->profile_id;
+}
+EXPORT_SYMBOL_GPL(fman_pcd_plcr_profile_get_id);
+
+/*
+ * fman_pcd_plcr_profile_id_internal: thin in-driver alias of the
+ * public helper above.  Kept separate so the CC TU does not have
+ * to pull <linux/fsl/fman_pcd.h> into its dependency closure just
+ * for one accessor; matches the
+ * fman_pcd_cc_tree_group_table_off / fman_pcd_manip_hmtd_off
+ * idiom from PR14c/PR14d.  Not EXPORT_SYMBOL'd -- internal use only.
+ */
+u16 fman_pcd_plcr_profile_id_internal(
+	const struct fman_pcd_plcr_profile *prof)
+{
+	return fman_pcd_plcr_profile_get_id(prof);
+}
