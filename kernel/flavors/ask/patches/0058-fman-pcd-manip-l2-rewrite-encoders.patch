From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: ci <ci@local>
Date: Sun, 24 May 2026 21:20:00 +0000
Subject: [PATCH] fman-pcd-manip: RMV_ETHERNET + INSRT_GENERIC encoders

Phase 4.1 / v1.3 restoration of the L2-rewrite primitives needed by
ASK2 Path A per-flow MANIP chain (plan §4.2):

  flow MANIP chain = [ RMV_ETHERNET, INSRT_GENERIC(14B new L2),
                       FIELD_UPDATE_IPV4_FORWARD ]
  → fman_pcd_manip_chain_create() → CC-key action MANIPULATE{chain, tx_fqid}

Adds:
  - L2 helper macros FMAN_PCD_L2_HDR_OFFSET / FMAN_PCD_L2_HDR_RMV_SIZE
  - manip_encode_rmv_ethernet()       — GENERIC_RMV  offset 0, size 14
  - manip_encode_insrt_generic()      — GENERIC_INSRT offset 0, size 1..32
                                        with ceil(size/4) BE-32 inline words
  - hmct_used bookkeeping in both encoders (folds in former patch 0059)
  - FMAN_PCD_MANIP_RMV_ETHERNET + FMAN_PCD_MANIP_INSRT_GENERIC enum members
  - FMAN_PCD_MANIP_INSRT_GENERIC_MAX_SIZE = 32u
  - insrt_generic{size, hdr[]} union arm in fman_pcd_manip_params
  - validator + dispatcher case arms in fman_pcd_manip_create()

Patch authored on 2026-05-24 as a fresh regeneration against the
post-0057 staged kernel tree, replacing the corrupt archived 0033
hunk arithmetic that didn't apply on top of patches 0050+0054+0055+0057.
The L2-rewrite encoders are silicon-fact identical to the archived
0033 version (cross-ref SDK fm_manip.c lines 432 and 528).
---
diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
index 027f7cd..7165c98 100644
--- a/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
@@ -224,6 +224,17 @@
 /* Auto checksum recompute (RM 8.7.5.4 + SDK HMCD_IP_L4_CS_CALC) */
 #define FMAN_PCD_HMCD_IP_L4_CS_CALC	0x00040000u
 
+/* v1.2 (PR14i) OH-port AD-chain L2-rewrite primitives.
+ *
+ * MANIP_RMV_ETHERNET / MANIP_INSRT_GENERIC silicon facts:
+ * use the GENERIC_RMV (0x01) / GENERIC_INSRT (0x02) opcodes.
+ * Cross-ref SDK fm_manip.c BuildHmct() arms
+ * e_FM_PCD_MANIP_HDR_RMV_ETHERNET (line 432) and
+ * e_FM_PCD_MANIP_HDR_INSRT_GENERIC (line 528).
+ */
+#define FMAN_PCD_L2_HDR_OFFSET		0u
+#define FMAN_PCD_L2_HDR_RMV_SIZE	14u	/* 6 dst + 6 src + 2 EtherType */
+
 /**
  * struct fman_pcd_manip - one MURAM-resident header-manip template.
  * @node:        anchor on pcd->manip_list (protected by pcd->lock)
@@ -552,6 +563,88 @@ manip_encode_ttl_dec(struct fman_pcd_manip *manip, u8 *out_op)
 	return hmct;
 }
 
+/* ------------------------------------------------------------------ */
+/* v1.2 (PR14i) OH-port AD-chain L2-rewrite encoders                  */
+/* ------------------------------------------------------------------ */
+
+static __must_check void __iomem *
+manip_encode_rmv_ethernet(struct fman_pcd_manip *manip, u8 *out_op)
+{
+	void __iomem *hmct = manip->hmct;
+	u32 cmd;
+
+	/* Generic remove at frame offset 0, size 14 (ETH_HLEN).
+	 * Strips the outer Ethernet header in flight.  No inline payload.
+	 * Cross-ref SDK fm_manip.c BuildHmct case
+	 * e_FM_PCD_MANIP_HDR_RMV_ETHERNET (line 432).
+	 */
+	cmd  = (u32)FMAN_PCD_HMCD_OP_GENERIC_RMV
+		<< FMAN_PCD_HMCD_OC_SHIFT;
+	cmd |= (u32)FMAN_PCD_L2_HDR_OFFSET
+		<< FMAN_PCD_HMCD_RMV_OFFSET_SHIFT;
+	cmd |= (u32)FMAN_PCD_L2_HDR_RMV_SIZE
+		<< FMAN_PCD_HMCD_RMV_SIZE_SHIFT;
+
+	iowrite32be(cmd, hmct);
+
+	manip->hmct_used = 4;
+	*out_op = FMAN_PCD_HMAN_OC;
+	return hmct;
+}
+
+static __must_check void __iomem *
+manip_encode_insrt_generic(struct fman_pcd_manip *manip,
+			   const struct fman_pcd_manip_params *p,
+			   u8 *out_op)
+{
+	void __iomem *hmct = manip->hmct;
+	void __iomem *cur;
+	u32 cmd;
+	unsigned int n_words;
+	unsigned int i;
+	u8 size = p->insrt_generic.size;
+
+	if (size == 0 || size > FMAN_PCD_MANIP_INSRT_GENERIC_MAX_SIZE)
+		return NULL;
+
+	/* Generic insert at frame offset 0, size N bytes carrying
+	 * inline payload p->insrt_generic.hdr[0..N-1].  Cross-ref SDK
+	 * fm_manip.c BuildHmct case e_FM_PCD_MANIP_HDR_INSRT_GENERIC
+	 * (line 528).
+	 */
+	cmd  = (u32)FMAN_PCD_HMCD_OP_GENERIC_INSRT
+		<< FMAN_PCD_HMCD_OC_SHIFT;
+	cmd |= (u32)FMAN_PCD_L2_HDR_OFFSET
+		<< FMAN_PCD_HMCD_INSRT_OFFSET_SHIFT;
+	cmd |= (u32)size
+		<< FMAN_PCD_HMCD_INSRT_SIZE_SHIFT;
+
+	iowrite32be(cmd, hmct);
+
+	/* Inline payload: ceil(size/4) BE-32 words. */
+	n_words = (size + 3) / 4;
+	cur = hmct + 4;
+	for (i = 0; i < n_words; i++) {
+		unsigned int base = i * 4;
+		u32 word = 0;
+		unsigned int b;
+
+		for (b = 0; b < 4; b++) {
+			unsigned int idx = base + b;
+			u8 byte = (idx < size) ? p->insrt_generic.hdr[idx]
+					       : 0u;
+
+			word |= ((u32)byte) << ((3 - b) * 8);
+		}
+		iowrite32be(word, cur);
+		cur += 4;
+	}
+
+	manip->hmct_used = 4 + (n_words * 4);
+	*out_op = FMAN_PCD_HMAN_OC;
+	return hmct;
+}
+
 /* ------------------------------------------------------------------ */
 /* v1.2 (PR14i) encoder - Path A CC-key inline MANIP primitive        */
 /* ------------------------------------------------------------------ */
@@ -676,6 +769,8 @@ fman_pcd_manip_create(struct fman_pcd *pcd,
 	case FMAN_PCD_MANIP_VLAN_PUSH:
 	case FMAN_PCD_MANIP_VLAN_POP:
 	case FMAN_PCD_MANIP_TTL_DEC:
+	case FMAN_PCD_MANIP_RMV_ETHERNET:
+	case FMAN_PCD_MANIP_INSRT_GENERIC:
 	case FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD:
 		break;
 	default:
@@ -766,6 +861,12 @@ fman_pcd_manip_create(struct fman_pcd *pcd,
 	case FMAN_PCD_MANIP_TTL_DEC:
 		last_cmd = manip_encode_ttl_dec(manip, &op);
 		break;
+	case FMAN_PCD_MANIP_RMV_ETHERNET:
+		last_cmd = manip_encode_rmv_ethernet(manip, &op);
+		break;
+	case FMAN_PCD_MANIP_INSRT_GENERIC:
+		last_cmd = manip_encode_insrt_generic(manip, params, &op);
+		break;
 	case FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD:
 		last_cmd = manip_encode_field_update_ipv4_forward(manip,
 								  params,
diff --git a/include/linux/fsl/fman_pcd.h b/include/linux/fsl/fman_pcd.h
index ea0cb9d..d0f1161 100644
--- a/include/linux/fsl/fman_pcd.h
+++ b/include/linux/fsl/fman_pcd.h
@@ -581,9 +581,20 @@ FMAN_PCD_MANIP_NAT_V6,
 FMAN_PCD_MANIP_VLAN_PUSH,
 FMAN_PCD_MANIP_VLAN_POP,
 FMAN_PCD_MANIP_TTL_DEC,
+FMAN_PCD_MANIP_RMV_ETHERNET,
+FMAN_PCD_MANIP_INSRT_GENERIC,
 FMAN_PCD_MANIP_FIELD_UPDATE_IPV4_FORWARD,
 };
 
+/*
+ * Maximum byte count for the inline header carried by
+ * FMAN_PCD_MANIP_INSRT_GENERIC.  The silicon GENERIC_INSRT command
+ * supports an inline payload of up to 32 bytes per RM 8.7.5 + the
+ * SDK cross-reference (fm_manip.h::HMCD_INSRT_GENERIC_MAX_SIZE).
+ */
+#define FMAN_PCD_MANIP_INSRT_GENERIC_MAX_SIZE 32u
+
+
 /**
  * struct fman_pcd_manip_params - configuration for one manip template.
  * @type:                   discriminator selecting the union arm
@@ -653,6 +664,10 @@ __be16 tci;
 __be16 tpid;
 } vlan_push;
 struct {
+u8 size;
+u8 hdr[FMAN_PCD_MANIP_INSRT_GENERIC_MAX_SIZE];
+} insrt_generic;
+struct {
 bool recompute_cksum;
 bool rewrite_dscp;
 u8 new_dscp;
-- 
