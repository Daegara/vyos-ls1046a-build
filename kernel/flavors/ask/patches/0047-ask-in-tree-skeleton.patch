--- /dev/null
+++ b/drivers/net/ethernet/freescale/dpaa/ask/Makefile
@@ -0,0 +1,24 @@
+# SPDX-License-Identifier: GPL-2.0
+#
+# Makefile for the FSL DPAA1 ASK2 hardware offload driver — PR14z19
+# Path A stage 1 skeleton.  Stage 2 will append the real
+# ask_main.o + ask_hw.o + ask_flow.o + ask_flow_offload.o +
+# ask_genl.o + ask_hostcmd.o + ask_bridge.o + ask_neigh.o +
+# ask_caam.o + ask_op.o + ask_stats.o + ask_xfrm.o + ask_debugfs.o
+# + ask_genl_attr.o sources once they have been migrated in-tree from
+# the legacy kernel/flavors/ask/oot-modules/ask/ pipeline.
+
+# Include FMan + dpaa headers so the upcoming ask_hw.c can reach
+# struct fman_pcd, fman_pcd_register_pre_netdev_hook(), and dpaa_eth.h.
+FMAN        = $(srctree)/drivers/net/ethernet/freescale/fman
+DPAA        = $(srctree)/drivers/net/ethernet/freescale/dpaa
+ccflags-y += -I$(FMAN)
+ccflags-y += -I$(DPAA)
+
+obj-$(CONFIG_FSL_DPAA_ASK) += ask.o
+
+# Stage 1: skeleton only — ask_main.o prints a single fs_initcall
+# banner and provides MODULE_* stubs so the in-tree Kbuild plumbing
+# can be verified before the real source is migrated.  Stage 2 will
+# rewrite this objects list.
+ask-objs := ask_main.o
\ No newline at end of file
diff --git a/drivers/net/ethernet/freescale/dpaa/ask/ask_main.c b/drivers/net/ethernet/freescale/dpaa/ask/ask_main.c
new file mode 100644
index 0000000..87cd958
--- /dev/null
+++ b/drivers/net/ethernet/freescale/dpaa/ask/ask_main.c
@@ -0,0 +1,59 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * ASK2 (NXP LS1046A Mono Gateway hardware offload) — in-tree skeleton.
+ *
+ * PR14z19 Path A stage 1 of the in-tree migration plan
+ * (plans/PR14z19-PATH-A-DESIGN.md and the stages 1–6 plan in the
+ * agent session log).  This is intentionally a one-line fs_initcall
+ * scaffold that proves the in-tree Kbuild plumbing
+ * (CONFIG_FSL_DPAA_ASK=y → drivers/net/ethernet/freescale/dpaa/ask/
+ * compiles and links into vmlinux) works on its own, BEFORE we move
+ * the ~5600 LOC of real ASK source from the legacy out-of-tree
+ * kernel/flavors/ask/oot-modules/ask/ pipeline into this directory
+ * (stage 2).
+ *
+ * Why fs_initcall and not module_init: the ASK pre-netdev hook
+ * (registered via fman_pcd_register_pre_netdev_hook() from PR14z19
+ * patch 0044) MUST be installed before dpaa_eth_probe runs.
+ * dpaa_eth is itself a module_init driver, but its probe pass for
+ * each MAC node fires very early during boot — earlier than any
+ * loadable module's module_init can run.  fs_initcall puts us
+ * *before* device_initcall, which is what eventually triggers
+ * dpaa_eth's probe loop.  This is exactly why ASK must be built-in
+ * (Kconfig bool, not tristate).
+ *
+ * At stage 1 the fs_initcall does nothing except print a banner so
+ * "did the in-tree object get linked in" is visible in dmesg.  At
+ * stage 3 this same fs_initcall will gain the actual
+ * fman_pcd_register_pre_netdev_hook() call site.
+ */
+
+#include <linux/init.h>
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/printk.h>
+
+#define ASK_DRV_VERSION_STR "2.0.0-stage1-skeleton"
+
+static int __init ask_init(void)
+{
+pr_info("ask: in-tree skeleton present (version %s, fs_initcall)\n",
+ASK_DRV_VERSION_STR);
+return 0;
+}
+fs_initcall(ask_init);
+
+/*
+ * No module_exit is wired up — a fs_initcall built-in driver does
+ * not unload at runtime.  This is correct: the pre-netdev hook is a
+ * boot-time-only contract.  If a future stage needs teardown
+ * semantics (e.g. shutdown notifier for clean MURAM release on
+ * `reboot` / `kexec`), wire it via register_reboot_notifier(); do
+ * NOT add module_exit() because that would make the driver
+ * unloadable, which contradicts the Kconfig bool gate.
+ */
+
+MODULE_AUTHOR("VyOS LS1046A maintainers");
+MODULE_DESCRIPTION("FSL DPAA1 ASK2 hardware offload (LS1046A Mono Gateway)");
+MODULE_LICENSE("GPL");
+MODULE_VERSION(ASK_DRV_VERSION_STR);
\ No newline at end of file
