diff --git a/drivers/net/ethernet/freescale/dpaa/ask/Kconfig b/drivers/net/ethernet/freescale/dpaa/ask/Kconfig
new file mode 100644
index 0000000..7176983
--- /dev/null
+++ b/drivers/net/ethernet/freescale/dpaa/ask/Kconfig
@@ -0,0 +1,37 @@
+# SPDX-License-Identifier: GPL-2.0-only
+#
+# ASK2 (NXP LS1046A Mono Gateway hardware offload) — in-tree migration
+# scaffold per PR14z19 Path A stage 1 (plans/PR14z19-PATH-A-DESIGN.md
+# §3.2 + the stages 1–6 plan).  Built-in is mandatory: ASK's
+# pre-netdev hook (registered via fman_pcd_register_pre_netdev_hook())
+# MUST be installed before dpaa_eth_probe runs, which means ASK's
+# fs_initcall has to land before the dpaa_eth driver's probe pass.
+# An out-of-tree module loaded post-boot is structurally too late.
+#
+# Stage 1 ships only the skeleton: a one-line fs_initcall that proves
+# the in-tree Kbuild plumbing works.  Stage 2 (a separate patch) copies
+# the real ~5600 LOC of ASK source from the legacy
+# kernel/flavors/ask/oot-modules/ask/ tree into this directory.
+
+config FSL_DPAA_ASK
+bool "DPAA1 ASK2 hardware offload (LS1046A Mono Gateway)"
+depends on FSL_DPAA_ETH
+depends on FSL_FMAN_PCD
+default n
+help
+  ASK2 (Accelerated SoftKernel 2) provides FMan PCD-backed
+  hardware offload of stateful flow forwarding for the NXP
+  LS1046A SoC, used in the Mono Gateway Development Kit.
+
+  When enabled, ASK installs a pre-netdev hook into fman_pcd so
+  every BMI port wires its KGSE_CCBS to an ASK-owned CC tree
+  BEFORE the dpaa_eth driver creates the netdev.  Unmatched
+  frames fall back to the kernel default RX FQ via the CC
+  miss-action (preserving ARP/SYN/ICMP control plane).
+
+  This option is force-built-in (bool, not tristate) because
+  the pre-netdev hook must be registered before dpaa_eth_probe
+  runs.  It is only meaningful on LS1046A hardware; on other
+  QorIQ SoCs the hook never finds a matching port and is inert.
+
+  If unsure, say N.  This is FLAVOR=ask territory.
\ No newline at end of file
diff --git a/drivers/net/ethernet/freescale/dpaa/ask/Makefile b/drivers/net/ethernet/freescale/dpaa/ask/Makefile
