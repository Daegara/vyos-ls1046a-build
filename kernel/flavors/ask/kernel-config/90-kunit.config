# ASK flavor: KUnit infrastructure + FMan PCD encoder test suites.
#
# Built-in (=y) so the suites run during boot before userspace starts,
# emitting KTAP results on the serial console.  Output appears in dmesg
# between the FMan probe and the rootfs mount.
#
# Suites registered (trailer-#include in fman_pcd_*.c):
#   - fman_pcd_cc_test_suite       (8.7.4.3 Table 8-119 AD encoder)
#   - fman_pcd_replic_test_suite   (8.7.7 source-TD + member-AD chain)
#   - fman_pcd_prs_test_suite      (8.7.2 parser pass-through wire-up)
#
# KUNIT itself is built-in (not =m) so suite registration runs at
# late_initcall on built-in subsystems.  Production ISO releases can
# revisit this trade-off once PR14g (M2 acceptance) lands.
CONFIG_KUNIT=y
CONFIG_KUNIT_DEBUGFS=y
CONFIG_FSL_FMAN_PCD_KUNIT_TEST=y