# Pstore / ramoops persistent crash store (diagnostic).
#
# Captures panic backtraces and full console output into a fixed DRAM
# region (ramoops node in mono-gateway-dk.dts @ 0xb0000000, 1 MB) that
# survives the panic=60 -> reboot cycle, so crash dumps can be retrieved
# from /sys/fs/pstore on the next boot. On this U-Boot board the panic
# backtrace otherwise only reaches the serial console (efi_pstore does
# not persist; no ramoops reserved-memory existed before).
#
# CONFIG_PSTORE=y is already provided by the VyOS base config.
CONFIG_PSTORE=y
CONFIG_PSTORE_RAM=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_PMSG=y
