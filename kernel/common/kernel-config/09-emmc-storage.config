# === LS1046A eMMC / SD storage — MUST be built-in ===
#
# The LS1046A eMMC controller is the NXP eSDHC at 0x1560000 (compatible
# "fsl,ls1046a-esdhc", "fsl,esdhc"). The mainline driver is
# MMC_SDHCI_OF_ESDHC. The board's installed VyOS lives on
# /dev/mmcblk0p3 (ext4) and live-boot mounts /boot/<image>/<image>.squashfs
# from inside that ext4 partition via a loop device.
#
# For a TFTP dev loop (kernel + DTB + initrd over TFTP, squashfs from eMMC),
# the kernel must be able to access mmcblk0 BEFORE the initrd starts
# loading modules — otherwise live-boot's find_live_media() polls
# /sys/block forever (no entries) and the boot stalls.
#
# Even for normal eMMC boot (run vyos), having these as modules
# requires the initrd to be perfectly tracked against this exact kernel,
# which is fragile for dev iteration. Built-in is the right answer.
#
# Verified live on board, 2026-05-15: with MMC_SDHCI_OF_ESDHC not set,
# zero /sys/block entries, live-boot loops on "cat: can't open
# /sys/block/*/removable: No such file or directory" forever.

# Core MMC stack
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_OF_ESDHC=y

# Generic block device support for storage discovery
CONFIG_BLK_DEV_SD=y

# EXT4 must be built-in too — live-boot's bind/mount of
# /boot/<image>/<image>.squashfs from mmcblk0p3 happens in the
# initramfs phase, before any modules are loaded. (Loop and squashfs
# already built-in via kernel/common/vyos-base/00-filesystems.config.)
CONFIG_EXT4_FS=y
CONFIG_JBD2=y
CONFIG_FS_MBCACHE=y