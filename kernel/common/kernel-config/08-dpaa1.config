# === LS1046A / NXP Layerscape DPAA1 + common board config (Mono Gateway DK) ===
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_FSL_FMAN=y
CONFIG_FSL_DPAA=y
CONFIG_FSL_DPAA_ETH=y
# DPAA AF_XDP zero-copy flavor pool must be BUILT-IN (=y), not =m.
# Rationale: dpaa_eth.ko is built-in (CONFIG_FSL_DPAA_ETH=y) and its
# late_initcall(dpaa_load) probes every FMan platform device early at
# boot. dpaa_eth_probe() publishes net_dev->xdp_features BEFORE
# register_netdev(); if af_xdp_pool is =m it loads later via modprobe
# (after rootfs), so qmgmt_ops is NULL at the moment xdp_features is
# published and NETDEV_XDP_ACT_XSK_ZEROCOPY is omitted. Subsequent
# bind(XDP_ZEROCOPY) then fails with -EOPNOTSUPP at the XSK core layer
# before any DPAA code runs. With =y, af_xdp_pool_init() runs at
# late_initcall before dpaa_eth_probe()'s register_netdev() and
# qmgmt_ops is non-NULL on first publish — no retro-attach needed.
# MODULE_SOFTDEP("pre: af_xdp_pool") (patch 0078) is unreachable under
# this posture (modprobe never loads either of them) and has been
# intentionally dropped from the patch stack.
CONFIG_DPAA_AF_XDP_POOL=y
CONFIG_FSL_XGMAC_MDIO=y
CONFIG_PHY_FSL_LYNX_28G=y
CONFIG_FSL_BMAN=y
CONFIG_FSL_QMAN=y
# QMan CEETM hierarchical egress shaper (patch 0111) + dpaa HTB-offload
# consumer (patch 0112). bool symbols, default n/y -- force both on.
CONFIG_FSL_QMAN_CEETM=y
CONFIG_DPAA_HW_CEETM=y
CONFIG_FSL_PAMU=y
CONFIG_HWMON=y
CONFIG_MAXLINEAR_GPHY=y
CONFIG_MMC_SDHCI_OF_ESDHC=y
CONFIG_FSL_EDMA=y
CONFIG_SERIAL_OF_PLATFORM=y
CONFIG_MTD=y
CONFIG_MTD_SPI_NOR=y
CONFIG_SPI=y
CONFIG_SPI_FSL_DSPI=y
CONFIG_SPI_FSL_QUADSPI=y
CONFIG_CDX_BUS=y
# CONFIG_DEBUG_PREEMPT is not set
CONFIG_QORIQ_CPUFREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
# CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL is not set
