+/*
+ * FM_CTL control-parameters page, SDK t_FmPcdCtrlParamsPage
+ * (sdk fm_common.h:182-197; port-open programming fm_port.c:2813-2846).
+ *
+ * 0116: the FM_CTL PRE_BMI_ENQ_FRAME ucode (result-AD NIA AC 0x28, the
+ * mandatory CC exit path on A006675/SW006 silicon) consumes a per-port
+ * 256-byte MURAM page named by FMBM_RGPR: misc (+0x40) must carry
+ * ALWAYS_ON, errorsDiscardMask (+0x44) must mirror FMBM_RFSDM|RFSEM so
+ * the SW006 error-VSP fixup can discard errored frames.  Mainline never
+ * allocates this page (FMBM_RGPR stays 0 = ucode would read MURAM offset
+ * 0 garbage), so every CC attach must ensure it first.  Allocated once
+ * per port and kept for the port's lifetime (SDK never frees it either);
+ * idempotent via the port-side cached offset.
+ */
+#define CC_CTRL_PARAMS_PAGE_SZ	256
+
+int fman_pcd_port_ensure_params_page(struct fman_pcd *pcd,
+				     struct fman_port *port)
+{
+	struct muram_info *muram;
+	void __iomem *page;
+	unsigned long off;
+	int err;
+
+	if (!pcd || !port)
+		return -EINVAL;
+
+	if (fman_port_get_params_page(port))
+		return 0;
+
+	muram = fman_get_muram(fman_pcd_get_fman(pcd));
+	if (!muram)
+		return -ENXIO;
+
+	off = fman_pcd_muram_alloc(pcd, CC_CTRL_PARAMS_PAGE_SZ);
+	if (IS_ERR_VALUE(off))
+		return (int)off;
+
+	page = (void __iomem *)fman_muram_offset_to_vbase(muram, off);
+	memset_io(page, 0, CC_CTRL_PARAMS_PAGE_SZ);
+
+	err = fman_port_set_params_page(port, (u32)off, page);
+	if (err)
+		fman_pcd_muram_free(pcd, off, CC_CTRL_PARAMS_PAGE_SZ);
+	return err;
+}
+EXPORT_SYMBOL_GPL(fman_pcd_port_ensure_params_page);
