+/* FM_CTL ctrl-params page field offsets (SDK t_FmPcdCtrlParamsPage) */
+#define FMAN_PP_MISC_OFF	0x40
+#define FMAN_PP_ERRDISC_OFF	0x44
+#define FMAN_PP_MISC_ALWAYS_ON	0x00000100
+
+/**
+ * fman_port_get_params_page() - cached FM_CTL params-page MURAM offset
+ * @port: the FMan RX port
+ *
+ * Returns the MURAM byte offset programmed by a prior
+ * fman_port_set_params_page(), or 0 if the page was never set up
+ * (0 is never a valid page offset - MURAM base hosts the CC trees).
+ */
+u32 fman_port_get_params_page(struct fman_port *port)
+{
+	return port ? port->ctrl_params_page : 0;
+}
+EXPORT_SYMBOL_GPL(fman_port_get_params_page);
+
+/**
+ * fman_port_set_params_page() - program the FM_CTL ctrl-params page (0116)
+ * @port:      the FMan RX port
+ * @muram_off: MURAM byte offset of the zeroed 256-byte page
+ * @page:      ioremapped virtual address of that page
+ *
+ * SDK port-open equivalent (fm_port.c:2813-2846 on DPAA v1.1):
+ * misc = ALWAYS_ON, errorsDiscardMask = FMBM_RFSDM | FMBM_RFSEM, then
+ * FMBM_RGPR = page offset.  Required by the FM_CTL AC 0x28
+ * PRE_BMI_ENQ_FRAME ucode that every CC result AD exits through on
+ * A006675/SW006 silicon.  Caller zeroes the page.
+ */
+int fman_port_set_params_page(struct fman_port *port, u32 muram_off,
+			      void __iomem *page)
+{
+	u32 sdm, sem;
+
+	if (!port || !page || port->port_type != FMAN_PORT_TYPE_RX)
+		return -EINVAL;
+
+	sdm = ioread32be(&port->bmi_regs->rx.fmbm_rfsdm);
+	sem = ioread32be(&port->bmi_regs->rx.fmbm_rfsem);
+	iowrite32be(FMAN_PP_MISC_ALWAYS_ON,
+		    (u32 __iomem *)((u8 __iomem *)page + FMAN_PP_MISC_OFF));
+	iowrite32be(sdm | sem,
+		    (u32 __iomem *)((u8 __iomem *)page + FMAN_PP_ERRDISC_OFF));
+	iowrite32be(muram_off, &port->bmi_regs->rx.fmbm_rgpr);
+	port->ctrl_params_page = muram_off;
+
+	dev_info(port->dev,
+		 "fman_port: FM_CTL params page at MURAM off 0x%x (errdisc 0x%08x)\n",
+		 muram_off, sdm | sem);
+	return 0;
+}
+EXPORT_SYMBOL_GPL(fman_port_set_params_page);
