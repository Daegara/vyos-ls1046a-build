+/* Ingress rate-limit policer offload (spec sec 5.6, board patch 0104).
+ *
+ * Bridges a single 'tc filter ... matchall action police' (or the
+ * equivalent nftables ingress rate-limit) onto the dormant FMan PCD
+ * Policer install body (fman_policer_install/destroy, board patch 0100).
+ * One profile slot per netdev (slot 0); the matchall classifier is the
+ * userspace surface the install body was missing.
+ *
+ * struct fman * and the FMan port id are resolved exactly as the HM
+ * VLAN-strip bridge (patch 0101) does: fman_bind(mac_dev->fman_dev) and
+ * fman_port_get_qman_channel_id(mac_dev->port[RX]).
+ *
+ * Fail-soft: gated on fman_policer_caps_supported() so a board whose
+ * ucode lacks POLICER_TRTCM rejects the offload with -EOPNOTSUPP and an
+ * extack message instead of a silent no-op; tc then leaves the filter in
+ * software.
+ */
+#define DPAA_POLICE_PROFILE_ID 0
+
+static int dpaa_setup_tc_matchall_replace(struct net_device *net_dev,
+					  struct tc_cls_matchall_offload *f)
+{
+	struct dpaa_priv *priv = netdev_priv(net_dev);
+	struct netlink_ext_ack *extack = f->common.extack;
+	struct fman_policer_profile prof = {};
+	const struct flow_action_entry *act;
+	struct fman_pcd *pcd;
+	struct fman *fm;
+	u8 port_id;
+	int err;
+
+	if (!fman_policer_caps_supported()) {
+		NL_SET_ERR_MSG_MOD(extack,
+				   "hardware policer not available on this ucode");
+		return -EOPNOTSUPP;
+	}
+
+	if (priv->ingress_police_installed) {
+		NL_SET_ERR_MSG_MOD(extack,
+				   "only one ingress policer per interface is supported");
+		return -EOPNOTSUPP;
+	}
+
+	if (!flow_offload_has_one_action(&f->rule->action)) {
+		NL_SET_ERR_MSG_MOD(extack,
+				   "matchall offload supports exactly one action");
+		return -EOPNOTSUPP;
+	}
+
+	if (!flow_action_basic_hw_stats_check(&f->rule->action, extack))
+		return -EOPNOTSUPP;
+
+	act = &f->rule->action.entries[0];
+	if (act->id != FLOW_ACTION_POLICE) {
+		NL_SET_ERR_MSG_MOD(extack,
+				   "matchall offload supports only the police action");
+		return -EOPNOTSUPP;
+	}
+
+	if (act->police.rate_pkt_ps) {
+		NL_SET_ERR_MSG_MOD(extack,
+				   "packet-per-second policing is not supported");
+		return -EOPNOTSUPP;
+	}
+
+	if (act->police.exceed.act_id != FLOW_ACTION_DROP) {
+		NL_SET_ERR_MSG_MOD(extack,
+				   "exceed action must be drop");
+		return -EOPNOTSUPP;
+	}
+
+	if (act->police.notexceed.act_id != FLOW_ACTION_ACCEPT &&
+	    act->police.notexceed.act_id != FLOW_ACTION_PIPE &&
+	    act->police.notexceed.act_id != FLOW_ACTION_CONTINUE) {
+		NL_SET_ERR_MSG_MOD(extack,
+				   "conform action must be accept/pipe/continue");
+		return -EOPNOTSUPP;
+	}
+
+	if (!priv->mac_dev)
+		return -ENODEV;
+
+	fm = fman_bind(priv->mac_dev->fman_dev);
+	if (!fm)
+		return -ENODEV;
+	port_id = fman_port_get_id(priv->mac_dev->port[RX]);
+
+	/* tc police rates are bytes/s, FMan profiles are bits/s; bursts are
+	 * bytes on both sides. peakrate present => trTCM (RFC 2698), else
+	 * srTCM (RFC 2697). Colour-blind: we do not honour an upstream colour.
+	 */
+	prof.color_mode = FMAN_POLICER_COLOR_BLIND;
+	prof.cir_bps    = act->police.rate_bytes_ps * 8;
+	prof.cbs_bytes  = act->police.burst;
+
+	if (act->police.peakrate_bytes_ps) {
+		prof.mode      = FMAN_POLICER_MODE_TRTCM;
+		prof.pir_bps   = act->police.peakrate_bytes_ps * 8;
+		prof.pbs_bytes = act->police.burst;
+	} else {
+		/* Single-rate (no peakrate): silicon lacks srTCM, so 0100 maps
+		 * this to RFC2698 with PIR==CIR/PBS==CBS; leaving them 0 would
+		 * red-mark and drop ALL frames. Mirror CIR/CBS to police, not drop. */
+		prof.mode      = FMAN_POLICER_MODE_SRTCM;
+		prof.pir_bps   = prof.cir_bps;
+		prof.pbs_bytes = prof.cbs_bytes;
+	}
+
+	err = fman_policer_install(fm, port_id, DPAA_POLICE_PROFILE_ID, &prof);
+	if (err) {
+		NL_SET_ERR_MSG_MOD(extack, "policer install failed");
+		netif_err(priv, drv, net_dev,
+			  "ingress policer install failed: %d\n", err);
+		return err;
+	}
+
+	/* The profile is now programmed but unbound: nothing routes frames
+	 * into it yet. The RX port already has an RSS-hashing KeyGen scheme
+	 * (created at port init by keygen_port_hashing_init()) that every
+	 * ingress frame is dispatched to - that is why un-policed traffic
+	 * flows through KeyGen at all. Reprogram THAT existing scheme's
+	 * next-engine in place to the policer profile, preserving its hash
+	 * spreading and FQID base, so conforming (green/yellow) frames
+	 * continue to the same hashed RX FQs while the policer meters and
+	 * drops the excess. Creating a *separate* catch-all scheme does not
+	 * work: the silicon's scheme-select picks the lowest-id scheme bound
+	 * to the port, so the pre-existing hash scheme always wins selection
+	 * and a higher-id policer scheme is never consulted (confirmed on
+	 * hardware 2026-06-09: traffic stayed uncapped at line rate).
+	 */
+	pcd = fman_get_pcd(fm);
+	if (!pcd) {
+		NL_SET_ERR_MSG_MOD(extack, "FMan PCD subsystem unavailable");
+		err = -ENODEV;
+		goto err_policer;
+	}
+
+	err = fman_pcd_kg_port_attach_policer(pcd, port_id,
+					      DPAA_POLICE_PROFILE_ID);
+	if (err) {
+		NL_SET_ERR_MSG_MOD(extack, "policer KeyGen attach failed");
+		netif_err(priv, drv, net_dev,
+			  "policer KeyGen attach failed: %d\n", err);
+		goto err_policer;
+	}
+
+	priv->ingress_police_installed = true;
+	return 0;
+
+err_policer:
+	fman_policer_destroy(fm, port_id, DPAA_POLICE_PROFILE_ID);
+	return err;
+}
+
+static int dpaa_setup_tc_matchall_destroy(struct net_device *net_dev)
+{
+	struct dpaa_priv *priv = netdev_priv(net_dev);
+	struct fman *fm;
+	u8 port_id;
+
+	if (!priv->ingress_police_installed)
+		return 0;
+
+	if (priv->mac_dev) {
+		/* Reverse of _replace: restore the RX port's existing RSS hash
+		 * scheme to plain BMI-enqueue next-engine, then remove the
+		 * policer profile. The scheme itself is NOT destroyed - it is
+		 * the port's permanent RSS-hashing scheme (created at port
+		 * init); _replace only flipped its next-engine to the policer.
+		 */
+		fm = fman_bind(priv->mac_dev->fman_dev);
+		if (fm) {
+			struct fman_pcd *pcd = fman_get_pcd(fm);
+
+			port_id = fman_port_get_id(priv->mac_dev->port[RX]);
+			if (pcd)
+				fman_pcd_kg_port_detach_policer(pcd, port_id);
+			fman_policer_destroy(fm, port_id,
+					     DPAA_POLICE_PROFILE_ID);
+		}
+	}
+
+	priv->ingress_police_installed = false;
+	return 0;
+}
+
+static int dpaa_setup_tc_block_cb(enum tc_setup_type type, void *type_data,
+				  void *cb_priv)
+{
+	struct net_device *net_dev = cb_priv;
+	struct tc_cls_matchall_offload *f = type_data;
+
+	if (type != TC_SETUP_CLSMATCHALL)
+		return -EOPNOTSUPP;
+
+	if (!tc_cls_can_offload_and_chain0(net_dev, type_data))
+		return -EOPNOTSUPP;
+
+	switch (f->command) {
+	case TC_CLSMATCHALL_REPLACE:
+		return dpaa_setup_tc_matchall_replace(net_dev, f);
+	case TC_CLSMATCHALL_DESTROY:
+		return dpaa_setup_tc_matchall_destroy(net_dev);
+	default:
+		return -EOPNOTSUPP;
+	}
+}
+
+static LIST_HEAD(dpaa_block_cb_list);
+
+/* Block-unbind self-heal (BUG 3b).
+ *
+ * The ingress qdisc/block can be torn down WITHOUT the matchall filter's
+ * TC_CLSMATCHALL_DESTROY ever reaching this driver: net/sched/cls_api.c's
+ * __tcf_block_put() runs tcf_block_offload_unbind() (which removes our
+ * block-cb) BEFORE tcf_block_flush_all_chains() destroys the filter, so
+ * mall_destroy_hw_filter() -> tc_setup_cb_destroy() iterates over zero
+ * registered cbs and dpaa_setup_tc_matchall_destroy() is never called.
+ * VyOS hits exactly this path: ingress-policer update() runs
+ * super().update() -> set_mirror_redirect(), which deletes the whole
+ * ingress qdisc first. Without a revert here the FMan RX KeyGen scheme
+ * stays stuck in next-engine=PLCR and the port stays dead.
+ *
+ * flow_block_cb_alloc()'s release callback IS invoked on block-unbind
+ * (tcf_block_unbind() -> flow_block_cb_free() -> block_cb->release()),
+ * so reverting the policer scheme here guarantees recovery on every
+ * teardown path. dpaa_setup_tc_matchall_destroy() is idempotent
+ * (guards on priv->ingress_police_installed), so the normal
+ * TC_CLSMATCHALL_DESTROY path co-existing with this one is harmless.
+ *
+ * Do NOT take rtnl here: block-unbind runs from the qdisc teardown path
+ * which already holds rtnl, and the revert only touches FMan PCD
+ * registers (internally locked) plus the idempotent installed flag.
+ */
+static void dpaa_tc_block_release(void *cb_priv)
+{
+	struct net_device *net_dev = cb_priv;
+
+	dpaa_setup_tc_matchall_destroy(net_dev);
+}
+
+static int dpaa_setup_tc_block(struct net_device *net_dev,
+			       struct flow_block_offload *f)
+{
+	struct flow_block_cb *block_cb;
+
+	if (f->binder_type != FLOW_BLOCK_BINDER_TYPE_CLSACT_INGRESS)
+		return -EOPNOTSUPP;
+
+	f->driver_block_list = &dpaa_block_cb_list;
+
+	switch (f->command) {
+	case FLOW_BLOCK_BIND:
+		if (flow_block_cb_is_busy(dpaa_setup_tc_block_cb, net_dev,
+					  &dpaa_block_cb_list))
+			return -EBUSY;
+
+		block_cb = flow_block_cb_alloc(dpaa_setup_tc_block_cb,
+					       net_dev, net_dev,
+					       dpaa_tc_block_release);
+		if (IS_ERR(block_cb))
+			return PTR_ERR(block_cb);
+
+		flow_block_cb_add(block_cb, f);
+		list_add_tail(&block_cb->driver_list, &dpaa_block_cb_list);
+		return 0;
+	case FLOW_BLOCK_UNBIND:
+		block_cb = flow_block_cb_lookup(f->block,
+						dpaa_setup_tc_block_cb,
+						net_dev);
+		if (!block_cb)
+			return -ENOENT;
+
+		flow_block_cb_remove(block_cb, f);
+		list_del(&block_cb->driver_list);
+		return 0;
+	default:
+		return -EOPNOTSUPP;
+	}
+}
+
+static int dpaa_setup_tc(struct net_device *net_dev, enum tc_setup_type type,
+			 void *type_data)
+{
+	switch (type) {
+	case TC_SETUP_QDISC_MQPRIO:
+		return dpaa_setup_tc_mqprio(net_dev, type_data);
+	case TC_SETUP_BLOCK:
+		return dpaa_setup_tc_block(net_dev, type_data);
+	default:
+		return -EOPNOTSUPP;
+	}
+}
