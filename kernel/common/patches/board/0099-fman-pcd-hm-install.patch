+/*
+ * Header-Manipulation (HM) install surface (spec sec 5.5).
+ *
+ * The dpaa1 HM steering API exported from the dpaa driver
+ * (fman_hm_node_install() in dpaa_fman_caps.c) consumes a host-endian
+ * ordered-op-list (struct fman_hm_spec) that is module-private to
+ * fsl_dpa.ko. To program the FMan HMTD/HMCT silicon (which lives in
+ * fsl_dpaa_fman.ko alongside the MURAM allocator) without a circular
+ * include, dpaa_fman_caps.c normalises its host-endian struct fman_hm_spec
+ * into the neutral, big-endian-ready descriptor below and hands it to the
+ * fman-side installer.  Multi-byte fields here carry host values that the
+ * silicon-programming layer assembles and writes big-endian via
+ * iowrite32be (see fman_pcd_manip.c).
+ */
+
+#define FMAN_PCD_HM_HW_MAX_OPS	8
+
+/**
+ * enum fman_pcd_hm_hw_op_type - one ordered header-manip operation kind.
+ * @FMAN_PCD_HM_HW_OP_VLAN_STRIP:  remove one VLAN tag at L2 offset 12
+ * @FMAN_PCD_HM_HW_OP_VLAN_INSERT: insert one VLAN tag at L2 offset 12
+ * @FMAN_PCD_HM_HW_OP_MPLS_PUSH:   push one MPLS label entry at offset 14
+ * @FMAN_PCD_HM_HW_OP_MPLS_POP:    pop  one MPLS label entry at offset 14
+ *
+ * Values mirror enum fman_hm_op_type in dpaa_fman_caps.h (kept in sync by
+ * review; the dpaa-side translator maps one-to-one).
+ */
+enum fman_pcd_hm_hw_op_type {
+	FMAN_PCD_HM_HW_OP_VLAN_STRIP	= 0,
+	FMAN_PCD_HM_HW_OP_VLAN_INSERT	= 1,
+	FMAN_PCD_HM_HW_OP_MPLS_PUSH	= 2,
+	FMAN_PCD_HM_HW_OP_MPLS_POP	= 3,
+};
+
+/**
+ * struct fman_pcd_hm_hw_op - one normalised HM operation (host values).
+ * @type:        which operation (enum fman_pcd_hm_hw_op_type)
+ * @vlan_insert: VLAN-insert params (valid iff type == VLAN_INSERT)
+ * @mpls_push:   MPLS-push  params (valid iff type == MPLS_PUSH)
+ *
+ * VLAN_STRIP / MPLS_POP carry no params (fixed offset/size).  The encoder
+ * in fman_pcd_manip.c assembles the inline payload words from these host
+ * fields and writes them big-endian into the HMCT.
+ */
+struct fman_pcd_hm_hw_op {
+	enum fman_pcd_hm_hw_op_type type;
+	union {
+		struct {
+			u16 tpid_be;	/* host TPID, e.g. 0x8100 */
+			u16 vid;	/* 12-bit VLAN id */
+			u8  pcp;	/* 3-bit priority */
+		} vlan_insert;
+		struct {
+			u32 label;	/* 20-bit MPLS label */
+			u8  tc;	/* 3-bit traffic class */
+			u8  s;	/* bottom-of-stack bit */
+			u8  ttl;	/* time-to-live */
+		} mpls_push;
+	};
+};
+
+/**
+ * struct fman_pcd_hm_hw_spec - a complete ordered HM op list.
+ * @num_ops: number of valid entries in @ops (1..FMAN_PCD_HM_HW_MAX_OPS)
+ * @ops:     applied in array order at runtime
+ */
+struct fman_pcd_hm_hw_spec {
+	u8 num_ops;
+	struct fman_pcd_hm_hw_op ops[FMAN_PCD_HM_HW_MAX_OPS];
+};
+
+/**
+ * fman_pcd_hm_install() - program one ordered-op-list HM node into MURAM.
+ * @pcd:     PCD subsystem handle (fman_get_pcd(fm))
+ * @port_id: FMan port id this node is installed for
+ * @spec:    neutral, big-endian-ready op list
+ * @handle:  on success, receives the HMTD MURAM byte offset (the opaque
+ *           handle for fman_pcd_hm_destroy() and a CC action's hm_handle)
+ *
+ * Return: 0 on success (writes @handle); negative errno on failure.
+ */
+int fman_pcd_hm_install(struct fman_pcd *pcd, u8 port_id,
+			const struct fman_pcd_hm_hw_spec *spec, u32 *handle);
+
+/**
+ * fman_pcd_hm_destroy() - tear down one HM node by handle.
+ * @pcd:     PCD subsystem handle
+ * @port_id: FMan port id (matched against the node for safety)
+ * @handle:  the HMTD MURAM offset returned by fman_pcd_hm_install()
+ *
+ * Idempotent: a handle matching no live node is a no-op returning 0.
+ *
+ * Return: 0 always.
+ */
+int fman_pcd_hm_destroy(struct fman_pcd *pcd, u8 port_id, u32 handle);
+
 #endif /* __LINUX_FSL_FMAN_PCD_H */
