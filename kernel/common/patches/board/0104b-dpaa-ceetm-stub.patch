index cfc3dd1..3b935ec 100644
--- a/drivers/net/ethernet/freescale/dpaa/Kconfig
+++ b/drivers/net/ethernet/freescale/dpaa/Kconfig
@@ -80,4 +80,33 @@ config DPAA_HW_POLICER_OFFLOAD
 	  now so downstream consumers can wire calls today.
 	  Safe to leave on: zero runtime cost without FMAN_CAP_POLICER_TRTCM.
 
+config DPAA_HW_CEETM
+	bool "DPAA: QMan CEETM egress-shaper scaffold (M3-3e)"
+	depends on DPAA_HW_CC_STEERING
+	default y
+	help
+	  Compile in the QMan CEETM egress-shaper scaffold API
+	  (dpaa_ceetm_qdisc_install / dpaa_ceetm_qdisc_destroy /
+	  dpaa_ceetm_supported) per
+	  specs/dpaa1-afxdp-modernization-spec.md sec 5.7.
+
+	  CEETM is QMan's hierarchical egress traffic manager: a class
+	  queue channel tree with strict-priority + weighted-fair
+	  sub-queues and per-channel/per-CQ CR/ER token-bucket shaping,
+	  optionally with colour-aware CGR tail-drop. It backs the VyOS
+	  `tc qdisc` CEETM offload (HTB / strict-priority -> hardware).
+
+	  Unlike the FMan PCD stubs, CEETM lives in QMan silicon and is
+	  NOT ucode-gated -- it works on any FMan microcode. This symbol
+	  controls only the scaffold: dpaa_ceetm_supported() returns
+	  false and install() returns -ENOTSUPP until the productive
+	  QMan CEETM core + ndo_setup_tc forward-port lands. The API is
+	  pinned now so the VyOS CLI consumer can compile against a
+	  stable contract. Safe to leave on: zero runtime cost.
+
+	  Depends on DPAA_HW_CC_STEERING because the scaffold object
+	  (dpaa_fman_caps.o) is gated by CONFIG_DPAA_HW_CC_STEERING in
+	  the Makefile; selecting CEETM without it would leave the
+	  exported symbols undefined at link time.
+
 source "drivers/net/ethernet/freescale/dpaa/af_xdp_pool/Kconfig"
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.c b/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.c
index 3bb03bb..063d3be 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.c
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.c
@@ -549,5 +549,39 @@ return (dpaa_fman_get_caps() & FMAN_CAP_POLICER_TRTCM) != 0;
 }
 EXPORT_SYMBOL_GPL(fman_policer_caps_supported);
 
+/*
+ * CEETM (Customer Edge Egress Traffic Management) -- M3-3e scaffold.
+ *
+ * Stub entry points for the QMan egress hierarchical shaper. CEETM is
+ * ucode-independent QMan silicon, so unlike the FMan PCD stubs above
+ * these do NOT consult dpaa_fman_get_caps(); they gate purely on
+ * whether the productive datapath has been compiled in. Until the
+ * QMan CEETM core + dpaa_eth ndo_setup_tc forward-port lands,
+ * dpaa_ceetm_supported() reports false and install() returns -ENOTSUPP,
+ * so the VyOS CLI consumer cleanly degrades to software qdiscs.
+ *
+ * Spec sec 5.7: CEETM API.
+ */
+int dpaa_ceetm_qdisc_install(struct net_device *dev,
+			     const struct dpaa_ceetm_config *cfg)
+{
+if (!dev || !cfg)
+return -EINVAL;
+return -ENOTSUPP;
+}
+EXPORT_SYMBOL_GPL(dpaa_ceetm_qdisc_install);
+
+void dpaa_ceetm_qdisc_destroy(struct net_device *dev)
+{
+/* No productive hierarchy to release in the scaffold; no-op. */
+}
+EXPORT_SYMBOL_GPL(dpaa_ceetm_qdisc_destroy);
+
+bool dpaa_ceetm_supported(void)
+{
+return false;
+}
+EXPORT_SYMBOL_GPL(dpaa_ceetm_supported);
+
 MODULE_LICENSE("Dual BSD/GPL");
 MODULE_DESCRIPTION("DPAA1 FMan PCD capability detection + HW-offload stubs");
