@@ -37,6 +37,7 @@ struct device;
 struct fman;
 struct fman_cc_static_tree;
 struct fman_cc_key;
+struct net_device;
 
 /* Spec sec 3.5: FMan PCD capability bitmask.  Each bit indicates that
  * the loaded FMan microcode supports the corresponding PCD primitive.
@@ -452,5 +453,75 @@ void fman_policer_destroy(struct fman *fm, u8 port_id, u8 profile_id);
  */
 bool fman_policer_caps_supported(void);
 
+/*
+ * CEETM (Customer Edge Egress Traffic Management) -- M3-3e scaffold.
+ *
+ * CEETM is QMan's egress hierarchical shaper: a class queue (CQ)
+ * channel hierarchy with strict-priority + weighted-fair sub-queues
+ * and per-channel/per-CQ shaping (CR/ER token buckets), plus optional
+ * colour-aware CGR tail-drop. It backs the VyOS `tc qdisc` CEETM
+ * offload contract (HTB/strict-priority -> hardware) per
+ * specs/dpaa1-afxdp-modernization-spec.md sec 5.7.
+ *
+ * Unlike the FMan PCD stubs above, CEETM lives in QMan silicon and is
+ * NOT gated on an FMan ucode capability bit -- it works on any ucode.
+ * The productive datapath (QMan CEETM core + dpaa_eth ndo_setup_tc
+ * binding) is a large LSDK forward-port that lands in follow-up
+ * patches; this scaffold fixes the API + Kconfig symbol now so the
+ * VyOS CLI consumer can be wired against a stable contract.
+ */
+
+/**
+ * struct dpaa_ceetm_config - opaque CEETM channel/CQ shaping request
+ * @reserved: placeholder; the productive forward-port replaces this
+ *            with the channel hierarchy, per-CQ weights, CR/ER token
+ *            bucket rates and CGR thresholds.
+ *
+ * Kept opaque on purpose: the scaffold pins the symbol and the
+ * by-pointer ABI so downstream consumers compile today without
+ * committing to the productive layout.
+ */
+struct dpaa_ceetm_config {
+	u32 reserved;
+};
+
+/**
+ * dpaa_ceetm_qdisc_install - attach a CEETM shaping hierarchy to a port
+ * @dev: the dpaa_eth net_device whose egress is to be shaped
+ * @cfg: requested channel/CQ shaping parameters
+ *
+ * Scaffold: returns -ENOTSUPP. The productive implementation claims a
+ * QMan CEETM logical network interface (LNI) for @dev's TX FQs, builds
+ * the class-queue channel hierarchy and programs CR/ER shapers.
+ *
+ * Spec sec 5.7: CEETM API.
+ */
+int dpaa_ceetm_qdisc_install(struct net_device *dev,
+			     const struct dpaa_ceetm_config *cfg);
+
+/**
+ * dpaa_ceetm_qdisc_destroy - tear down a port's CEETM hierarchy
+ * @dev: the dpaa_eth net_device to revert to its default TX FQs
+ *
+ * Scaffold: no-op. Idempotent -- destroying a port that never had a
+ * CEETM hierarchy installed is safe. The productive implementation
+ * releases the LNI, channels and CQs and restores the default 1:1
+ * TX FQ mapping.
+ *
+ * Spec sec 5.7: CEETM API.
+ */
+void dpaa_ceetm_qdisc_destroy(struct net_device *dev);
+
+/**
+ * dpaa_ceetm_supported - true when the CEETM offload datapath is present
+ *
+ * Scaffold: returns false unconditionally (the productive QMan CEETM
+ * core is not forward-ported yet). This is deliberately NOT an FMan
+ * capability check -- CEETM is QMan silicon and ucode-independent;
+ * the gate here is purely "is the productive code compiled in".
+ * Consumers MUST early-skip CEETM config when this returns false.
+ */
+bool dpaa_ceetm_supported(void);
+
 
 #endif /* __DPAA_FMAN_CAPS_H */
