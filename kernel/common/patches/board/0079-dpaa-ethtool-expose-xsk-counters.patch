From: VyOS LS1046A maintainers <ls1046a@vyos.local>
Date: 2026-05-27
Subject: [PATCH] dpaa_ethtool: expose AF_XDP zero-copy counters via ETH_SS_STATS

Spec section 5.3 (dpaa1-afxdp-modernization-spec.md v4.4) lists 12 u64
counters added to struct dpaa_priv by patches 0071 / 0075a / 0075b:

  xsk_pool_attach_ok       xsk_pool_attach_fail
  xsk_pool_detach_ok       xsk_pool_detach_timeout
  xsk_bman_seed_short      xsk_bman_starve         (Phase 3)
  xsk_tx_backpressure      (Phase 3)
  xsk_dma_map_fail         xsk_align_reject
  xsk_headroom_reject      xsk_mtu_reject
  xsk_pamu_window_fail

The fields are bumped on every attach/detach/seed/dma path in
af_xdp_pool.ko but there is currently NO way for an operator to read
them.  /sys/kernel/debug/dpaa/* is not exposed, and the natural place
ethtool uses for driver-private u64 stats - ETH_SS_STATS - does not
yet include them.  This patch wires the 12 counters into ETH_SS_STATS
so that

    ethtool -S eth4 | grep xsk_

prints all 12 values, and so the M2-stage-1 / -stage-2 DUT verification
gate can confirm which arm of af_xdp_pool_attach() ran (attach_ok vs
attach_fail vs align/headroom/mtu/pamu reject) without dmesg parsing or
ftrace.

Mechanics
---------

dpaa_ethtool.c already has the standard "global" stats pattern:

  - dpaa_stats_global[][ETH_GSTRING_LEN]   - string table
  - DPAA_STATS_GLOBAL_LEN macro            - array length
  - dpaa_get_sset_count() adds it to total
  - dpaa_get_ethtool_stats() copies the raw u64s into data[]
  - dpaa_get_strings() emits the strings

We add a SIBLING table dpaa_stats_xsk[] alongside dpaa_stats_global[]
and DPAA_STATS_XSK_LEN alongside DPAA_STATS_GLOBAL_LEN, then extend
all three handlers identically.  Counter values are read straight from
the contiguous u64 block at &priv->xsk_pool_attach_ok (verified
contiguous in dpaa_eth.h after 0071 + 0075a + 0075b).

The string order MUST match the in-memory u64 order in struct dpaa_priv.
Both are kept in spec-section-5.3 order.  If a future patch reorders or
inserts a counter in dpaa_eth.h, this patch must be updated in lockstep.

Effect after this patch
-----------------------

  $ ethtool -S eth4 | grep xsk_
       xsk_pool_attach_ok: 1
       xsk_pool_attach_fail: 0
       xsk_pool_detach_ok: 0
       xsk_pool_detach_timeout: 0
       xsk_bman_seed_short: 0
       xsk_bman_starve: 0
       xsk_tx_backpressure: 0
       xsk_dma_map_fail: 0
       xsk_align_reject: 0
       xsk_headroom_reject: 0
       xsk_mtu_reject: 0
       xsk_pamu_window_fail: 0

Verification on the next ISO build (M2-stage-1 closure):

  1. ethtool -S eth4 | wc -l on a freshly booted system must show
     12 more lines than the pre-0079 v4.4 ISO did.
  2. bin/dpaa1-xsk-bind-probe.py eth4 0 4096 returns rc=0, AND
     ethtool -S eth4 | grep xsk_pool_attach_ok shows the counter
     having incremented by exactly 1 (from 0 to 1, or N to N+1).
  3. A deliberately-broken bind() (e.g. queue_id=99) must increment
     xsk_pool_attach_fail without incrementing xsk_pool_attach_ok.

Backwards compatibility: zero behaviour change when no AF_XDP socket
ever binds - all 12 counters stay at 0 and ethtool -S just emits 12
extra zero lines.  No effect on existing dpaa_stats_percpu[] /
dpaa_stats_global[] ordering - those keep their offsets, the new block
is appended.  Out-of-tree consumers that parsed `ethtool -S` by name
(not by offset) are unaffected.

Signed-off-by: VyOS LS1046A maintainers <ls1046a@vyos.local>
---
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_ethtool.c b/drivers/net/ethernet/freescale/dpaa/dpaa_ethtool.c
index d09e456f1..5d34aab67 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_ethtool.c
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_ethtool.c
@@ -50,8 +50,28 @@ static char dpaa_stats_global[][ETH_GSTRING_LEN] = {
 	"congested (0/1)"
 };
 
+/* AF_XDP zero-copy counters (Phase 2 + 3). Order MUST match the u64
+ * block at &priv->xsk_pool_attach_ok in struct dpaa_priv (dpaa_eth.h).
+ * Spec: specs/dpaa1-afxdp-modernization-spec.md sec 5.3.
+ */
+static char dpaa_stats_xsk[][ETH_GSTRING_LEN] = {
+	"xsk_pool_attach_ok",
+	"xsk_pool_attach_fail",
+	"xsk_pool_detach_ok",
+	"xsk_pool_detach_timeout",
+	"xsk_bman_seed_short",
+	"xsk_bman_starve",
+	"xsk_tx_backpressure",
+	"xsk_dma_map_fail",
+	"xsk_align_reject",
+	"xsk_headroom_reject",
+	"xsk_mtu_reject",
+	"xsk_pamu_window_fail",
+};
+
 #define DPAA_STATS_PERCPU_LEN ARRAY_SIZE(dpaa_stats_percpu)
 #define DPAA_STATS_GLOBAL_LEN ARRAY_SIZE(dpaa_stats_global)
+#define DPAA_STATS_XSK_LEN    ARRAY_SIZE(dpaa_stats_xsk)
 
 static int dpaa_get_link_ksettings(struct net_device *net_dev,
 				   struct ethtool_link_ksettings *cmd)
@@ -123,7 +143,7 @@ static int dpaa_get_sset_count(struct net_device *net_dev, int type)
 
 	num_stats   = num_online_cpus() + 1;
 	total_stats = num_stats * (DPAA_STATS_PERCPU_LEN + 1) +
-			DPAA_STATS_GLOBAL_LEN;
+			DPAA_STATS_GLOBAL_LEN + DPAA_STATS_XSK_LEN;
 
 	switch (type) {
 	case ETH_SS_STATS:
@@ -238,6 +258,15 @@ static void dpaa_get_ethtool_stats(struct net_device *net_dev,
 	data[offset++] = cg_time;
 	data[offset++] = cg_num;
 	data[offset++] = cg_status;
+
+	/* AF_XDP zero-copy counters - contiguous u64 block in dpaa_priv,
+	 * order matches dpaa_stats_xsk[] above.  Spec sec 5.3.
+	 */
+	{
+		const u64 *xsk_src = &priv->xsk_pool_attach_ok;
+		for (i = 0; i < DPAA_STATS_XSK_LEN; i++)
+			data[offset++] = xsk_src[i];
+	}
 }
 
 static void dpaa_get_strings(struct net_device *net_dev, u32 stringset,
@@ -261,6 +290,8 @@ static void dpaa_get_strings(struct net_device *net_dev, u32 stringset,
 
 	for (i = 0; i < DPAA_STATS_GLOBAL_LEN; i++)
 		ethtool_puts(&data, dpaa_stats_global[i]);
+	for (i = 0; i < DPAA_STATS_XSK_LEN; i++)
+		ethtool_puts(&data, dpaa_stats_xsk[i]);
 }
 
 static int dpaa_get_rxfh_fields(struct net_device *dev,
-- 
