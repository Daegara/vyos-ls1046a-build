diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
--- a/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_manip.c
@@ -161,5 +161,21 @@
 #define FMAN_PCD_MPLS_S_SHIFT	8
 #define FMAN_PCD_MPLS_LABEL_MASK	0x000fffffu
+
+/* L3-forward op encodings.  Cross-ref NXP SDK fm_manip.h:
+ * HMCD_OPCODE_IPV4_UPDATE = 0x0c, HMCD_IP_L4_CS_CALC = 0x00040000,
+ * HMCD_IPV4_UPDATE_TTL = 0x01.  The IPv4 field-update is one more command
+ * word in the generic HMAN_OC (0x35) chain (SDK BuildHmct IPv4
+ * field-update), NOT a separate IP-manip HMTD opcode.
+ */
+#define FMAN_PCD_HMCD_OP_IPV4_UPDATE	0x0cu
+#define FMAN_PCD_HMCD_IP_L4_CS_CALC	0x00040000u
+#define FMAN_PCD_HMCD_IPV4_UPDATE_TTL	0x00000001u
+
+/* A whole-frame egress L2 (Ethernet) header is inserted at / removed from
+ * frame offset 0; ETH_HLEN (14) bytes for the remove.
+ */
+#define FMAN_PCD_L2_HDR_OFFSET	0u
+#define FMAN_PCD_ETH_HDR_SIZE	14u
 
 /**
  * struct fman_pcd_hm_node - one MURAM-resident header-manip template.
@@ -306,5 +322,88 @@
 	return cur;
 }
 
+static void __iomem *
+hm_encode_rmv_ethernet(void __iomem *cur, void __iomem **last_cmd)
+{
+	u32 cmd;
+
+	/* Generic remove at frame offset 0, ETH_HLEN (14) bytes: strip the
+	 * inbound L2 header before the egress L2 is inserted.  SDK fm_manip.c
+	 * BuildHmct e_FM_PCD_MANIP_RMV_GENERIC.
+	 */
+	cmd  = (u32)FMAN_PCD_HMCD_OP_GENERIC_RMV << FMAN_PCD_HMCD_OC_SHIFT;
+	cmd |= (u32)FMAN_PCD_L2_HDR_OFFSET << FMAN_PCD_HMCD_RMV_OFFSET_SHIFT;
+	cmd |= (u32)FMAN_PCD_ETH_HDR_SIZE << FMAN_PCD_HMCD_RMV_SIZE_SHIFT;
+
+	iowrite32be(cmd, cur);
+	*last_cmd = cur;
+	cur += 4;
+
+	return cur;
+}
+
+static void __iomem *
+hm_encode_insrt_generic(const struct fman_pcd_hm_hw_op *op,
+			void __iomem *cur, void __iomem **last_cmd)
+{
+	u32 cmd;
+	u32 word;
+	u8  size = op->insrt_generic.size;
+	u8  i;
+
+	/* Generic insert at frame offset 0 of @size bytes (the new egress L2
+	 * header) carried as inline payload.  SDK fm_manip.c BuildHmct
+	 * e_FM_PCD_MANIP_INSRT_GENERIC + inline-payload copy.
+	 */
+	cmd  = (u32)FMAN_PCD_HMCD_OP_GENERIC_INSRT << FMAN_PCD_HMCD_OC_SHIFT;
+	cmd |= (u32)FMAN_PCD_L2_HDR_OFFSET << FMAN_PCD_HMCD_INSRT_OFFSET_SHIFT;
+	cmd |= (u32)size << FMAN_PCD_HMCD_INSRT_SIZE_SHIFT;
+
+	iowrite32be(cmd, cur);
+	*last_cmd = cur;
+	cur += 4;
+
+	/* Inline payload: @size header bytes rounded up to a 4-byte boundary,
+	 * assembled big-endian (byte 0 in bits[31:24]).
+	 */
+	for (i = 0; i < size; i += 4) {
+		word = (u32)op->insrt_generic.hdr[i] << 24;
+		if (i + 1 < size)
+			word |= (u32)op->insrt_generic.hdr[i + 1] << 16;
+		if (i + 2 < size)
+			word |= (u32)op->insrt_generic.hdr[i + 2] << 8;
+		if (i + 3 < size)
+			word |= (u32)op->insrt_generic.hdr[i + 3];
+		iowrite32be(word, cur);
+		cur += 4;
+	}
+
+	return cur;
+}
+
+static void __iomem *
+hm_encode_ipv4_forward(const struct fman_pcd_hm_hw_op *op,
+			void __iomem *cur, void __iomem **last_cmd)
+{
+	u32 cmd;
+
+	/* IPv4 field-update command word inside the generic HMAN_OC chain (NOT
+	 * a separate IP-manip HMTD opcode): optional TTL-decrement + optional
+	 * L3/L4 checksum recompute.  SDK fm_manip.c BuildHmct IPv4
+	 * field-update; 0x0c040001 when both TTL and checksum are requested.
+	 */
+	cmd = (u32)FMAN_PCD_HMCD_OP_IPV4_UPDATE << FMAN_PCD_HMCD_OC_SHIFT;
+	if (op->ipv4_forward.l4_csum)
+		cmd |= FMAN_PCD_HMCD_IP_L4_CS_CALC;
+	if (op->ipv4_forward.dec_ttl)
+		cmd |= FMAN_PCD_HMCD_IPV4_UPDATE_TTL;
+
+	iowrite32be(cmd, cur);
+	*last_cmd = cur;
+	cur += 4;
+
+	return cur;
+}
+
 /**
  * fman_pcd_hm_install() - program one ordered-op-list HM node.
@@ -407,10 +506,17 @@
 	for (i = 0; i < spec->num_ops; i++) {
 		const struct fman_pcd_hm_hw_op *op = &spec->ops[i];
+		size_t need;
 
-		/* Worst-case op is INSRT command word + 4-byte payload = 8
-		 * bytes; bounds-check before dispatch.
-		 */
-		if (cur + 8 > end) {
+		/* Worst-case bytes this op writes: one 4-byte command word plus,
+		 * for a generic insert, its 4-byte-aligned inline payload (up to
+		 * FMAN_PCD_HM_INSRT_GENERIC_MAX bytes).
+		 */
+		if (op->type == FMAN_PCD_HM_HW_OP_INSRT_GENERIC)
+			need = 4 + ALIGN(op->insrt_generic.size, 4);
+		else
+			need = 8;
+
+		if (cur + need > end) {
 			spin_unlock_irqrestore(&hm->lock, flags);
 			goto err_free_hmct;
 		}
@@ -428,4 +534,13 @@
 		case FMAN_PCD_HM_HW_OP_MPLS_POP:
 			cur = hm_encode_mpls_pop(cur, &last_cmd);
 			break;
+		case FMAN_PCD_HM_HW_OP_RMV_ETHERNET:
+			cur = hm_encode_rmv_ethernet(cur, &last_cmd);
+			break;
+		case FMAN_PCD_HM_HW_OP_INSRT_GENERIC:
+			cur = hm_encode_insrt_generic(op, cur, &last_cmd);
+			break;
+		case FMAN_PCD_HM_HW_OP_IPV4_FORWARD:
+			cur = hm_encode_ipv4_forward(op, cur, &last_cmd);
+			break;
 		default:
