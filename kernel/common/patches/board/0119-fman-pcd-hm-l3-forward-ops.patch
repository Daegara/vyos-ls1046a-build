From: vyos-ls1046a-build CI <ci@local>
Date: Sun, 14 Jun 2026 00:00:00 +0000
Subject: [PATCH] dpaa: FMan PCD HM L3-forward op-set (RMV_ETHERNET +
 INSRT_GENERIC + IPV4_FORWARD)

Extends the dpaa1 Header-Manipulation op-set (board patches 0090a/0099)
with the three primitives an L3 router next-hop rewrite needs, re-grounded
on the authoritative NXP SDK fm_manip.{c,h} BuildHmct() encodings:

  - FMAN_HM_OP_RMV_ETHERNET   strip the 14-byte inbound L2 header
  - FMAN_HM_OP_INSRT_GENERIC  insert a new egress L2 header (<=32 bytes)
  - FMAN_HM_OP_IPV4_FORWARD   decrement IPv4 TTL + recompute L3/L4 cksum

All three emit command words into the SAME generic HMCT, so a combined
remove+insert+IPv4-update node keeps the generic HMAN_OC=0x35 HMTD opcode
(SDK single-HMTD multi-op model); the IPv4 edit is a HMCT command WORD
(0x0c<<24 | L4_CS_CALC | TTL -> 0x0c040001), NOT a separate IP-manip HMTD
opcode.  The install-loop bounds check is widened from a fixed 8 bytes/op
to the true per-op footprint (a generic insert is one command word plus
its 4-byte-aligned inline payload, up to FMAN_PCD_HM_INSRT_GENERIC_MAX).

Additive across all four HM layers (host op set, host->neutral translator,
neutral op set, silicon encoders/dispatch); no existing VLAN/MPLS encoder,
constant, or opcode is touched.  Next-hop dedup and the ask.ko CC consumer
re-point are deferred to a follow-on patch.

Spec: specs/ask2-rewrite-spec.md sec 13.4/13.5.

Signed-off-by: vyos-ls1046a-build CI <ci@local>
---
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.h b/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.h
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.h
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.h
@@ -237,4 +237,8 @@
 	FMAN_HM_OP_VLAN_INSERT	= 1,
 	FMAN_HM_OP_MPLS_PUSH	= 2,
 	FMAN_HM_OP_MPLS_POP	= 3,
+	/* L3-forward op-set extension (board patch 0119). */
+	FMAN_HM_OP_RMV_ETHERNET	= 4,
+	FMAN_HM_OP_INSRT_GENERIC = 5,
+	FMAN_HM_OP_IPV4_FORWARD	= 6,
 };
@@ -253,6 +257,21 @@
 	u8  s;/* bottom-of-stack bit */
 	u8  ttl;/* MPLS TTL */
 };
 
+/* Parameters for FMAN_HM_OP_INSRT_GENERIC: @size header bytes inserted at
+ * frame offset 0 (a new outer L2 header).  @size in 1..32.
+ */
+#define FMAN_HM_INSRT_GENERIC_MAX	32
+struct fman_hm_insrt_generic {
+	u8 size;/* header bytes to insert (1..32) */
+	u8 hdr[FMAN_HM_INSRT_GENERIC_MAX];/* the header image */
+};
+
+/* Parameters for FMAN_HM_OP_IPV4_FORWARD: routed-frame IPv4 edits. */
+struct fman_hm_ipv4_forward {
+	u8 dec_ttl;/* nonzero: decrement the IPv4 TTL */
+	u8 l4_csum;/* nonzero: recompute L3+L4 checksums in silicon */
+};
+
 /**
  * struct fman_hm_op - one entry in an HM node's op list
@@ -268,5 +287,7 @@
 	union {
 		struct fman_hm_vlan_insert vlan_insert;
 		struct fman_hm_mpls_push   mpls_push;
+		struct fman_hm_insrt_generic insrt_generic;
+		struct fman_hm_ipv4_forward  ipv4_forward;
 	};
 };
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.c b/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.c
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.c
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.c
@@ -373,4 +373,18 @@
 		case FMAN_HM_OP_MPLS_POP:
 			dst->type = FMAN_PCD_HM_HW_OP_MPLS_POP;
 			break;
+		case FMAN_HM_OP_RMV_ETHERNET:
+			dst->type = FMAN_PCD_HM_HW_OP_RMV_ETHERNET;
+			break;
+		case FMAN_HM_OP_INSRT_GENERIC:
+			dst->type = FMAN_PCD_HM_HW_OP_INSRT_GENERIC;
+			dst->insrt_generic.size = src->insrt_generic.size;
+			memcpy(dst->insrt_generic.hdr, src->insrt_generic.hdr,
+			       sizeof(dst->insrt_generic.hdr));
+			break;
+		case FMAN_HM_OP_IPV4_FORWARD:
+			dst->type = FMAN_PCD_HM_HW_OP_IPV4_FORWARD;
+			dst->ipv4_forward.dec_ttl = src->ipv4_forward.dec_ttl;
+			dst->ipv4_forward.l4_csum = src->ipv4_forward.l4_csum;
+			break;
 		}
diff --git a/include/linux/fsl/fman_pcd.h b/include/linux/fsl/fman_pcd.h
--- a/include/linux/fsl/fman_pcd.h
+++ b/include/linux/fsl/fman_pcd.h
@@ -354,2 +354,3 @@
 #define FMAN_PCD_HM_HW_MAX_OPS	8
+#define FMAN_PCD_HM_INSRT_GENERIC_MAX	32
 
@@ -368,4 +369,7 @@
 	FMAN_PCD_HM_HW_OP_VLAN_INSERT	= 1,
 	FMAN_PCD_HM_HW_OP_MPLS_PUSH	= 2,
 	FMAN_PCD_HM_HW_OP_MPLS_POP	= 3,
+	FMAN_PCD_HM_HW_OP_RMV_ETHERNET	= 4,
+	FMAN_PCD_HM_HW_OP_INSRT_GENERIC	= 5,
