index 7ed659e..5e9cc55 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_eth.h
@@ -127,6 +127,9 @@ struct dpaa_eth_swbp {
 	struct xdp_frame *xdpf;
 };
 
+struct dpaa_pcd_ops;
