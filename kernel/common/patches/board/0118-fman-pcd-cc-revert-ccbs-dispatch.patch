--- a/drivers/net/ethernet/freescale/fman/fman_keygen.c
+++ b/drivers/net/ethernet/freescale/fman/fman_keygen.c
@@ -109,32 +109,19 @@
  */
 #define KG_SCH_MODE_NIA_PLCR		0x40000000
 
+/* Coarse Classification (CC) chaining - HW-PROVEN recipe (LS1046A FMan v3,
+ * silicon captures 2026-05-23/25): the KGSE_MODE NIA must STAY at the BMI
+ * direct-enqueue default (EN | NIA_ENG_BMI | NIA_BMI_AC_ENQ_FRAME =
+ * 0x80500002).  The CC walk is dispatched IMPLICITLY whenever KGSE_CCBS is
+ * non-zero: CCBS carries the MURAM byte offset of the CC root group table,
+ * and the optional CCOBASE field (KGSE_MODE bits 30:24, SDK fm_kg.c)
+ * selects the group index within it (0 for the single-group static tree of
+ * board patch 0098).  The alternative theory - flipping the NIA engine
+ * bits to FM_CTL|AC_CC (mode 0x80000006/0x80000000) - was DISPROVEN on
+ * hardware: it stalled dispatch at a few hundred frames, while the
+ * CCBS-only graft carried 24M+ frames through CC match -> silicon forward.
+ * The USDPAA SDK concurs: it keeps NIA = BMI|ENQ_FRAME when grafting and
+ * only ORs in CCOBASE.
-/*
- * Next-engine = Coarse Classification NIA (SDK sdk_fm_common.h): engine
- * FM_CTL (0x00000000) + action-code CC (0x6).  The FMan controller
- * microcode walks the CC root named by the port's FMBM_RCCB.
- */
-#define NIA_ENG_FM_CTL			0x00000000
-#define NIA_FM_CTL_AC_CC		0x00000006
-
-/* Coarse Classification (CC) chaining - SDK-convergent model (0115).
- *
- * sdk_fm_kg.c FmPcdKgBuildScheme() (lines 1097-1113, 1206-1212): when a
- * scheme's next engine is CC the KGSE_MODE NIA is ENG_FM_CTL | AC_CC (the
- * FMan controller runs the CC walker), CCOBASE (KGSE_MODE bits 30:24)
- * carries the root group BASE ENTRY index, and KGSE_CCBS carries the
- * group-bits select mask (grpBits) - NOT a pointer.  The CC root MURAM
- * offset is named per-port in FMBM_RCCB (fman_port_set_cc_base()).
- *
- * HISTORY: the pre-0115 model ("NIA stays BMI direct-enqueue, KGSE_CCBS
- * carries the root MURAM offset, CC fires implicitly") was retired by the
- * 2026-06-11 SDK init-delta analysis: on the mainline driver it produced
- * the M3-3b FPM port-stall, and the ask20 silicon captures credited to it
- * ran on the SDK kernel whose own FM_PCD bring-up had already programmed
- * FMBM_RCCB and SDK-format root ADs.  The lone FM_CTL|AC_CC experiment
- * that "stalled dispatch" ran without FMBM_RCCB and with a non-SDK root
- * AD, so the walker chased a garbage root - it disproves nothing about
- * the SDK encoding when all three pieces change together.
  */
 #define KG_SCH_MODE_CCOBASE_SHIFT	24
 
@@ -566,16 +553,17 @@ int keygen_scheme_setup(struct fman_keygen *keygen, u8 scheme_id,
 			tmp_reg |= KG_SCH_MODE_NIA_PLCR | NIA_ENG_PLCR;
 			scheme_regs.kgse_ppc = scheme->policer_profile_id;
 		} else if (scheme->next_engine == 2) {
+			/* Next engine = Coarse Classification.  HW-proven
+			 * recipe (see the CC chaining comment above): keep
+			 * the BMI direct-enqueue NIA - the CC walk fires
+			 * implicitly because KGSE_CCBS (set below) is
+			 * non-zero - and OR in the CCOBASE group index
+			 * (0 for the single-group static tree).  Flipping
+			 * the NIA to FM_CTL|AC_CC stalls dispatch.
-			/* Next engine = Coarse Classification: SDK-convergent
-			 * encoding (sdk_fm_kg.c:1206-1212): NIA = ENG_FM_CTL |
-			 * AC_CC so the FMan controller walks the CC root named
-			 * by the port's FMBM_RCCB; CCOBASE carries the root
-			 * group BASE ENTRY index (0 for the single-group
-			 * static tree).  See the CC chaining comment above.
 			 */
+			tmp_reg |= ENQUEUE_KG_DFLT_NIA |
+				(scheme->cc_base_offset <<
+				 KG_SCH_MODE_CCOBASE_SHIFT);
-			tmp_reg |= NIA_ENG_FM_CTL | NIA_FM_CTL_AC_CC |
-				   (scheme->cc_base_offset <<
-				    KG_SCH_MODE_CCOBASE_SHIFT);
 		} else {
 			/* Enqueue frame NIA */
 			tmp_reg |= ENQUEUE_KG_DFLT_NIA;
@@ -594,10 +582,10 @@ int keygen_scheme_setup(struct fman_keygen *keygen, u8 scheme_id,
 	 * policer-attach (see BUG 3a above). For the non-policer paths PPC stays 0
 	 * from the memset above.
 	 */
+	/* KGSE_CCBS: MURAM byte offset of the CC root group table.  A
+	 * non-zero CCBS is what dispatches the frame through the CC engine
+	 * on FMan v3 (HW-proven; the NIA stays BMI direct-enqueue).  Zero
+	 * (from the memset above) on every non-CC path.
-	/* KGSE_CCBS: CC group-bits select mask (SDK kgse_ccbs = grpBits,
-	 * sdk_fm_kg.c:1206-1212) - NOT a pointer.  0 for the single-group
-	 * static tree (numOfDistinctionUnits = 0).  The CC root MURAM offset
-	 * lives in the port's FMBM_RCCB (fman_port_set_cc_base()).
 	 */
 	if (enable && scheme->next_engine == 2)
 		scheme_regs.kgse_ccbs = scheme->cc_bits_sel;
