+static u32 dpaa_xsk_chunk_head_index(struct xsk_buff_pool *pool,
+     struct xdp_buff *xdp)
+{
+struct xdp_buff_xsk *xskb =
+container_of(xdp, struct xdp_buff_xsk, xdp);
+
+return (u32)(xskb - pool->heads);
