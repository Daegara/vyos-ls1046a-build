+/* FM_CTL ctrl-params page FE fields (SDK t_FmPcdCtrlParamsPage). */
+#define FMAN_PP_FE_MGMT_IDX_OFF	0x54
+#define FMAN_PP_FE_DEPL_CNT_OFF	0x58
+/* BMI FIFO unit; FE internal-buffer pool size unit and alignment. */
+#define FMAN_PCD_BMI_FIFO_UNITS	0x100
+
+/*
+ * Per-port FE (frame-engine) internal-buffer support - see
+ * arch/fman-fe-ehash.md section 4 (FmPortSetFESupport).  Each engaged RX
+ * port gets an FE internal-buffer pool in MURAM (total_tnums *
+ * BMI_FIFO_UNITS * 2 bytes, 256-byte aligned) plus a management free-list
+ * (5 + total_tnums bytes) whose MURAM offset is written to the port's
+ * FM_CTL ctrl-params page at +0x54, with the depletion counter (+0x58)
+ * cleared.  Allocate-only scaffold: ships dormant, proves a clean MURAM
+ * lifecycle (pcd-snapshot gen_pool "used" returns to baseline on del).
+ * fe_lock is held across set/del; the muram wrappers take pcd->lock
+ * inside (order fe_lock -> pcd->lock, matching fe_pool).
+ */
+struct fman_pcd_fe_port {
+	struct list_head node;
+	u8 port_id;
+	unsigned long pool_raw_off;	/* unaligned off handed to free() */
+	size_t pool_raw_size;
+	unsigned long mgmt_off;
+	size_t mgmt_size;
+};
+
+static struct fman_pcd_fe_port *
+fman_pcd_fe_port_find(struct fman_pcd *pcd, u8 port_id)
+{
+	struct fman_pcd_fe_port *fp;
+
+	list_for_each_entry(fp, &pcd->fe_ports, node)
+		if (fp->port_id == port_id)
+			return fp;
+	return NULL;
+}
+
+static int fman_pcd_fe_port_set(struct fman_pcd *pcd, u8 port_id)
+{
+	struct fman *fman = fman_pcd_get_fman(pcd);
+	struct muram_info *muram = fman_get_muram(pcd->fman);
+	struct fman_pcd_fe_port *fp;
+	struct fman_port *port;
+	unsigned long pool_raw_off, aligned_off, mgmt_off;
+	size_t pool_size, pool_raw_size, mgmt_size;
+	void __iomem *pool_v, *mgmt_v, *page_v;
+	u32 params_off;
+	u8 total_tnums, i;
+	int err;
+
+	if (!muram)
+		return -ENXIO;
+	if (fman_pcd_fe_port_find(pcd, port_id))
+		return -EEXIST;
+
+	port = fman_port_lookup_rx(fman, port_id);
+	if (!port)
+		return -ENODEV;
+
+	/*
+	 * The FM_CTL ctrl-params page is created once per port by a prior
+	 * CC install (fman_pcd_port_ensure_params_page, 0116) and kept for
+	 * the port lifetime.  FE support REQUIRES it - do NOT allocate it
+	 * here (that would leak +256 B that del() never returns, breaking
+	 * the pcd-snapshot reversibility gate).
+	 */
+	params_off = fman_port_get_params_page(port);
+	if (!params_off)
+		return -ENXIO;
+
+	total_tnums = fman_port_get_total_tnums(port);
+	if (!total_tnums)
+		return -EINVAL;
+
+	fp = kzalloc(sizeof(*fp), GFP_KERNEL);
+	if (!fp)
+		return -ENOMEM;
+
+	/*
+	 * (a) FE internal-buffer pool: total_tnums * BMI_FIFO_UNITS * 2
+	 * bytes, 256-byte aligned.  The muram gen_pool only guarantees
+	 * 64-byte alignment, so over-allocate by one BMI_FIFO_UNITS and
+	 * round the offset up; the gap (0/64/128/192 < 256) leaves room.
+	 * free() uses the raw offset/size so muram_used stays symmetric.
+	 */
+	pool_size = (size_t)total_tnums * FMAN_PCD_BMI_FIFO_UNITS * 2;
+	pool_raw_size = pool_size + FMAN_PCD_BMI_FIFO_UNITS;
+	pool_raw_off = fman_pcd_muram_alloc(pcd, pool_raw_size);
+	if (IS_ERR_VALUE(pool_raw_off)) {
+		err = (int)pool_raw_off;
+		goto err_fp;
+	}
+	aligned_off = (pool_raw_off + (FMAN_PCD_BMI_FIFO_UNITS - 1)) &
+		      ~(unsigned long)(FMAN_PCD_BMI_FIFO_UNITS - 1);
+	pool_v = (void __iomem *)fman_muram_offset_to_vbase(muram, aligned_off);
+	memset_io(pool_v, 0, pool_size);
+
+	/*
+	 * (b) management free-list: a 4-byte big-endian pool MURAM offset
+	 * whose MSB byte is then overwritten with the read index (4),
+	 * total_tnums tnum-slot bytes (0..N-1), and a 0xFF terminator.
+	 * This byte layout is the FE silicon ABI - keep it verbatim
+	 * (arch/fman-fe-ehash.md section 4).
+	 */
+	mgmt_size = 5 + total_tnums;
+	mgmt_off = fman_pcd_muram_alloc(pcd, mgmt_size);
+	if (IS_ERR_VALUE(mgmt_off)) {
+		err = (int)mgmt_off;
+		goto err_pool;
+	}
+	mgmt_v = (void __iomem *)fman_muram_offset_to_vbase(muram, mgmt_off);
+	iowrite32be((u32)aligned_off, mgmt_v);		/* [0..3] pool off (BE) */
+	iowrite8(4, mgmt_v);				/* [0] read index = 4 */
+	for (i = 0; i < total_tnums; i++)
+		iowrite8(i, (u8 __iomem *)mgmt_v + 4 + i);
+	iowrite8(0xFF, (u8 __iomem *)mgmt_v + 4 + total_tnums);
+
+	/*
+	 * (c) ctrl-params page: clear the depletion counter (+0x58), then
+	 * publish the management free-list MURAM offset (+0x54).  gen_pool
+	 * offsets are MURAM-relative already (no XX_VirtToPhys like the
+	 * SDK), so the raw mgmt_off is what the FE ucode expects.
+	 */
+	page_v = (void __iomem *)fman_muram_offset_to_vbase(muram, params_off);
+	iowrite32be(0, (u8 __iomem *)page_v + FMAN_PP_FE_DEPL_CNT_OFF);
+	iowrite32be((u32)mgmt_off, (u8 __iomem *)page_v + FMAN_PP_FE_MGMT_IDX_OFF);
+
+	fp->port_id = port_id;
+	fp->pool_raw_off = pool_raw_off;
+	fp->pool_raw_size = pool_raw_size;
+	fp->mgmt_off = mgmt_off;
+	fp->mgmt_size = mgmt_size;
+	list_add_tail(&fp->node, &pcd->fe_ports);
+
+	dev_info(fman_get_dev(pcd->fman),
+		 "fman_pcd: FE support on port 0x%x (tnums %u, pool 0x%lx/%zu B, mgmt 0x%lx/%zu B)\n",
+		 port_id, total_tnums, aligned_off, pool_size,
+		 mgmt_off, mgmt_size);
+	return 0;
+
+err_pool:
+	fman_pcd_muram_free(pcd, pool_raw_off, pool_raw_size);
+err_fp:
+	kfree(fp);
+	return err;
+}
+
+static int fman_pcd_fe_port_del(struct fman_pcd *pcd, u8 port_id)
+{
+	struct muram_info *muram = fman_get_muram(pcd->fman);
+	struct fman *fman = fman_pcd_get_fman(pcd);
+	struct fman_pcd_fe_port *fp;
+	struct fman_port *port;
+	u32 params_off;
+
+	fp = fman_pcd_fe_port_find(pcd, port_id);
+	if (!fp)
+		return -ENOENT;
+
+	/*
+	 * Inverse of set(): unhook the ctrl-params page management index
+	 * (+0x54 = 0) FIRST so the FE stops dereferencing the free-list,
+	 * then free mgmt, then the pool.  Never free silicon-referenced
+	 * MURAM before unpublishing it from the page.
+	 */
+	port = fman_port_lookup_rx(fman, port_id);
+	if (port) {
+		params_off = fman_port_get_params_page(port);
+		if (params_off && muram) {
+			void __iomem *page_v = (void __iomem *)
+				fman_muram_offset_to_vbase(muram, params_off);
+
+			iowrite32be(0, (u8 __iomem *)page_v + FMAN_PP_FE_MGMT_IDX_OFF);
+			iowrite32be(0, (u8 __iomem *)page_v + FMAN_PP_FE_DEPL_CNT_OFF);
+		}
+	}
+
+	fman_pcd_muram_free(pcd, fp->mgmt_off, fp->mgmt_size);
+	fman_pcd_muram_free(pcd, fp->pool_raw_off, fp->pool_raw_size);
+	list_del(&fp->node);
+	dev_info(fman_get_dev(pcd->fman),
+		 "fman_pcd: FE support removed on port 0x%x\n", port_id);
+	kfree(fp);
+	return 0;
+}
+
+static void fman_pcd_fe_port_drain(struct fman_pcd *pcd)
+{
+	struct fman_pcd_fe_port *fp, *tmp;
+
+	list_for_each_entry_safe(fp, tmp, &pcd->fe_ports, node) {
+		fman_pcd_muram_free(pcd, fp->mgmt_off, fp->mgmt_size);
+		fman_pcd_muram_free(pcd, fp->pool_raw_off, fp->pool_raw_size);
+		list_del(&fp->node);
+		kfree(fp);
+	}
+}
+
+static int fman_pcd_fe_port_show(struct seq_file *s, void *unused)
+{
+	struct fman_pcd *pcd = s->private;
+	struct fman_pcd_fe_port *fp;
+
+	mutex_lock(&pcd->fe_lock);
+	if (list_empty(&pcd->fe_ports)) {
+		seq_puts(s, "no FE-support ports\n");
+	} else {
+		list_for_each_entry(fp, &pcd->fe_ports, node)
+			seq_printf(s,
+				   "port 0x%02x pool 0x%lx/%zu B mgmt 0x%lx/%zu B\n",
+				   fp->port_id, fp->pool_raw_off,
+				   fp->pool_raw_size, fp->mgmt_off,
+				   fp->mgmt_size);
+	}
+	mutex_unlock(&pcd->fe_lock);
+	return 0;
+}
+
+static int fman_pcd_fe_port_open(struct inode *inode, struct file *file)
+{
+	return single_open(file, fman_pcd_fe_port_show, inode->i_private);
+}
+
+static ssize_t fman_pcd_fe_port_write(struct file *file,
+				      const char __user *ubuf,
+				      size_t count, loff_t *ppos)
+{
+	struct seq_file *s = file->private_data;
+	struct fman_pcd *pcd = s->private;
+	char buf[32];
+	u8 port_id;
+	int err;
+
+	if (count >= sizeof(buf))
+		return -EINVAL;
+	if (copy_from_user(buf, ubuf, count))
+		return -EFAULT;
+	buf[count] = '\0';
+
+	mutex_lock(&pcd->fe_lock);
+	if (sscanf(buf, "set %hhi", &port_id) == 1)
+		err = fman_pcd_fe_port_set(pcd, port_id);
+	else if (sscanf(buf, "del %hhi", &port_id) == 1)
+		err = fman_pcd_fe_port_del(pcd, port_id);
+	else
+		err = -EINVAL;
+	mutex_unlock(&pcd->fe_lock);
+
+	return err ? err : count;
+}
+
+static const struct file_operations fman_pcd_fe_port_fops = {
+	.owner		= THIS_MODULE,
+	.open		= fman_pcd_fe_port_open,
+	.read		= seq_read,
+	.write		= fman_pcd_fe_port_write,
+	.llseek		= seq_lseek,
+	.release	= single_release,
+};
