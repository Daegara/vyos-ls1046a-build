+/**
+ * fman_port_get_total_tnums() - committed + extra task (tnum) count
+ * @port: the FMan RX port
+ *
+ * Used to size the FE internal-buffer pool and management free-list
+ * (arch/fman-fe-ehash.md section 4).  Returns 0 for a NULL port.
+ */
+u8 fman_port_get_total_tnums(struct fman_port *port)
+{
+	return port ? (u8)(port->tasks.num + port->tasks.extra) : 0;
+}
