From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: VyOS LS1046A maintainers <dpaa1@vyos-ls1046a-build>
Date: Fri, 29 May 2026 00:00:00 +0000
Subject: [PATCH] fman: add Parse/Classify/Distribute (PCD) orchestration
 subsystem (common, all flavors)

Forward-port of the FMan PCD orchestration skeleton from the ask20
branch into the COMMON board patch stack so it is built-in for the
default/vpp/ask flavors alike (FSL_FMAN_PCD default y). This unblocks
the dpaa1 M3-3b/M3-3c/M3-3d milestones (CC steering, HM offload,
Policer) whose entry points currently return -ENOTSUPP.

The subsystem introduces struct fman_pcd (per-FMan PCD state with a
96 KiB MURAM budget and six per-engine list-heads), the lifecycle
fman_pcd_init/release wired into fman_probe via
devm_add_action_or_reset, the public accessors fman_get_pcd /
fman_get_dev / fman_get_id, a MURAM-budget accessor, seven internal
intra-module helpers, and a debugfs muram_budget node.

The minimal prerequisite fman_get_muram() accessor (an additive
EXPORT_SYMBOL_GPL wrapper returning fman->muram) is included here. The
ASK2-only fman_host_cmd.c microcode-doorbell transport from the ask20
0003 patch is intentionally NOT forward-ported: the PCD subsystem
writes MURAM tables directly via fman_muram_alloc() and never calls
the host-command path.

No FMan hardware register is touched by this skeleton. No KeyGen/
Classifier scheme is programmed. fman_pcd_muram_alloc() forwards to
fman_muram_alloc() inside the reserved budget; the per-engine bodies
(landed in follow-up patches) actually call it.

Signed-off-by: VyOS LS1046A maintainers <dpaa1@vyos-ls1046a-build>
---
diff --git a/drivers/net/ethernet/freescale/fman/Kconfig b/drivers/net/ethernet/freescale/fman/Kconfig
index a55542c..5d204b7 100644
--- a/drivers/net/ethernet/freescale/fman/Kconfig
+++ b/drivers/net/ethernet/freescale/fman/Kconfig
@@ -38,3 +38,15 @@ config DPAA_ERRATUM_A050385
 		With any one of the above three conditions present, there is
 		likelihood of stalled FMAN packet processing, especially under
 		stress with multiple ports injecting line-rate traffic.
+
+config FSL_FMAN_PCD
+	bool "FMan Parse/Classify/Distribute (PCD) subsystem"
+	depends on FSL_FMAN
+	default y
+	help
+	  Enables the FMan PCD hardware-programming layer that lets
+	  external consumers install exact-match flow rules into the
+	  FMan KeyGen/Classifier/Manipulator/Policer pipeline at line
+	  rate. This skeleton delivers the orchestration scaffold; the
+	  per-engine APIs land in follow-up patches.
+	  If unsure, say Y.
diff --git a/drivers/net/ethernet/freescale/fman/Makefile b/drivers/net/ethernet/freescale/fman/Makefile
index b618091..cc0ba7e 100644
--- a/drivers/net/ethernet/freescale/fman/Makefile
+++ b/drivers/net/ethernet/freescale/fman/Makefile
@@ -6,5 +6,6 @@ obj-$(CONFIG_FSL_FMAN) += fsl_dpaa_fman_port.o
 obj-$(CONFIG_FSL_FMAN) += fsl_dpaa_mac.o
 
 fsl_dpaa_fman-objs	:= fman_muram.o fman.o fman_sp.o fman_keygen.o
+fsl_dpaa_fman-$(CONFIG_FSL_FMAN_PCD) += fman_pcd.o
 fsl_dpaa_fman_port-objs := fman_port.o
 fsl_dpaa_mac-objs:= mac.o fman_dtsec.o fman_memac.o fman_tgec.o
diff --git a/drivers/net/ethernet/freescale/fman/fman.c b/drivers/net/ethernet/freescale/fman/fman.c
index 1188745..f763664 100644
--- a/drivers/net/ethernet/freescale/fman/fman.c
+++ b/drivers/net/ethernet/freescale/fman/fman.c
@@ -20,6 +20,8 @@
 
 #include "fman.h"
 #include "fman_muram.h"
+
+#include <linux/fsl/fman_pcd.h>
 #include "fman_keygen.h"
 
 /* General defines */
@@ -2495,6 +2497,73 @@ struct fman *fman_bind(struct device *fm_dev)
 }
 EXPORT_SYMBOL(fman_bind);
 
+/**
+ * fman_get_muram
+ * @fman: A pointer to FMan device
+ *
+ * Return: A pointer to the FMan MURAM allocator handle, suitable for use
+ *         with fman_muram_alloc()/free_mem(). Used by in-kernel users
+ *         that need to claim a MURAM region (e.g. fman_pcd.c).
+ */
+struct muram_info *fman_get_muram(struct fman *fman)
+{
+	return fman ? fman->muram : NULL;
+}
+EXPORT_SYMBOL_GPL(fman_get_muram);
+
+/**
+ * fman_get_pcd
+ * @fman: A pointer to FMan device
+ *
+ * Return: A pointer to the FMan PCD subsystem handle (struct fman_pcd) or
+ *         NULL if PCD init failed at probe time. Used by consumers to
+ *         install exact-match flow rules into the FMan PCD pipeline.
+ */
+struct fman_pcd *fman_get_pcd(struct fman *fman)
+{
+	return fman ? fman->pcd : NULL;
+}
+EXPORT_SYMBOL_GPL(fman_get_pcd);
+
+/**
+ * fman_get_dev
+ * @fman: A pointer to FMan device
+ *
+ * Return: The struct device that owns this FMan instance, or NULL. Used
+ *         by fman_pcd.c for dev_err/info without forcing fman_pcd to walk
+ *         dts_params directly.
+ */
+struct device *fman_get_dev(struct fman *fman)
+{
+	return fman ? fman->dev : NULL;
+}
+EXPORT_SYMBOL_GPL(fman_get_dev);
+
+/**
+ * fman_get_id
+ * @fman: A pointer to FMan device
+ *
+ * Return: The FMan instance id (0 on LS1046A's single FMan; non-zero on
+ *         multi-FMan SoCs). Used for debugfs subdirectory naming.
+ */
+u8 fman_get_id(struct fman *fman)
+{
+	return fman ? fman->dts_params.id : 0;
+}
+EXPORT_SYMBOL_GPL(fman_get_id);
+
+/**
+ * fman_pcd_release_action
+ * @arg: the struct fman_pcd * to release (devres trampoline)
+ *
+ * devm_add_action_or_reset() callback wrapper so the release runs at
+ * the right point in the unwind even if probe later fails.
+ */
+static void fman_pcd_release_action(void *arg)
+{
+	fman_pcd_release((struct fman_pcd *)arg);
+}
+
 #ifdef CONFIG_DPAA_ERRATUM_A050385
 bool fman_has_errata_a050385(void)
 {
@@ -2868,6 +2937,31 @@ static int fman_probe(struct platform_device *of_dev)
 
 	dev_set_drvdata(dev, fman);
 
+	/*
+	 * Initialise the PCD subsystem. fman->muram is live at this point
+	 * (fman_config() called fman_muram_init()). On failure leave
+	 * fman->pcd as NULL; consumers (via fman_get_pcd()) handle that
+	 * gracefully. Teardown registered with devres so unbind/probe-fail
+	 * paths run fman_pcd_release() automatically.
+	 */
+	{
+		struct fman_pcd *pcd = fman_pcd_init(fman);
+
+		if (IS_ERR(pcd)) {
+			dev_warn(dev,
+				 "FMan%d: PCD subsystem init failed (err %ld) - continuing without PCD\n",
+				 fman->dts_params.id, PTR_ERR(pcd));
+		} else {
+			fman->pcd = pcd;
+			if (devm_add_action_or_reset(dev,
+						     fman_pcd_release_action, pcd)) {
+				dev_warn(dev, "FMan%d: cannot register PCD teardown\n",
+					 fman->dts_params.id);
+				fman->pcd = NULL;
+			}
+		}
+	}
+
 	dev_dbg(dev, "FMan%d probed\n", fman->dts_params.id);
 
 	return 0;
