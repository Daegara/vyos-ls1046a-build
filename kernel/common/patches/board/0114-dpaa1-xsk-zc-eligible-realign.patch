-				 */
-				if (priv->xsk_zc_rx_armed &&
-				    !priv->xsk_fill_guard_block)
-					priv->xsk_zc_rx_recovered++;
-			}
+			/* The 0093/0096 recognition + Recover oracles that lived here
+ * were relocated by 0114 into af_xdp_pool_rx_hook(): the 0103f/0110
+ * dispatch above consumes ZC frames before this probe runs, so the
+ * increments were dead.  xsk_rx_branch (0083) remains as the
+ * band-has-bound-pool diagnostic for frames the hook declined.
+ */
 		}
 		rcu_read_unlock();
 	}
