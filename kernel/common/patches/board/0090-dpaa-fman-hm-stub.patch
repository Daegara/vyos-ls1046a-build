diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.h b/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.h
index aa97658..3093bd8 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.h
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.h
@@ -185,4 +185,72 @@ struct fman_cc_static_tree {
 	struct fman_cc_key keys[FMAN_CC_MAX_STATIC_KEYS];
 };
 
+/* ------------------------------------------------------------------ *
+ * M3-3c STUB API  (spec sec 5.5 Header Manipulation)
+ *
+ * Header Manipulation (HM) nodes program the FMan PCD HM block to
+ * mutate L2/L3 headers (VLAN push/pop, MAC rewrite, IPv4/IPv6 NAT,
+ * TTL decrement, DSCP rewrite) entirely in silicon after CC matching
+ * and before QMan enqueue. Per spec sec 5.4 chain ordering:
+ *
+ *   Parser \u2192 CC \u2192 HM \u2192 QMan
+ *
+ * Gated on FMAN_CAP_HM_NODES which lights up automatically on ucode
+ * 210+ silicon (verified on Mono Gateway DK 2026-05-28 — "Microcode
+ * version 210.10.1 for LS1043 r1.0" advertises HM_NODES per the
+ * dpaa_fman_caps_from_id() string parser).
+ *
+ * All three helpers below are unconditional -ENOTSUPP stubs in this
+ * patch; the productive implementation lands in a follow-up patch
+ * per spec sec 5.5. The API contract is fixed now so consumers
+ * (af_xdp_pool egress rewrite, ASK2 flowtable bridge, vyos-1x NAT
+ * offload CLI) can wire calls today and gracefully degrade on
+ * ucode-106 silicon.
+ * ------------------------------------------------------------------ */
+
+/* Opaque type referenced by the HM stub signatures; the concrete
+ * layout (per-op TLV array) lands with the productive implementation.
+ */
+struct fman_hm_spec {
+	u32 reserved;		/* productive layout TBD per spec sec 5.5 */
+};
+
+/**
+ * fman_hm_node_install - allocate and program a HM node for @port_id
+ *
+ * On success the returned @handle is opaque and must be passed back to
+ * fman_hm_node_destroy() for cleanup. The handle is also the value a
+ * matching CC action's HM-pointer field must carry per spec sec 5.4
+ * chain encoding (Parser \u2192 CC \u2192 HM \u2192 QMan).
+ *
+ * Returns 0 on success and writes @handle; -ENOTSUPP on stub build /
+ * unsupported silicon (will bump priv->hw_offload_unavailable on the
+ * caller side, mirroring the CC steering convention).
+ *
+ * Spec sec 5.5: HM API.
+ */
+int  fman_hm_node_install(struct fman *fm, u8 port_id,
+			  const struct fman_hm_spec *spec, u32 *handle);
+
+/**
+ * fman_hm_node_destroy - release a HM node previously installed
+ *
+ * Idempotent — destroying an already-released or never-installed handle
+ * is a no-op and returns 0. Detaches the node from any CC actions that
+ * still reference it (their AD records are rewritten to bypass HM).
+ *
+ * Spec sec 5.5: HM API.
+ */
+int  fman_hm_node_destroy(struct fman *fm, u8 port_id, u32 handle);
+
+/**
+ * fman_hm_caps_supported - returns true when ucode advertises HM
+ *
+ * Cheap wrapper around (dpaa_fman_get_caps() & FMAN_CAP_HM_NODES).
+ * Provided so consumers can early-skip building HM specs they can't
+ * install anyway.
+ */
+bool fman_hm_caps_supported(void);
+
+
 #endif /* __DPAA_FMAN_CAPS_H */
\ No newline at end of file
diff --git a/drivers/net/ethernet/freescale/dpaa/Kconfig b/drivers/net/ethernet/freescale/dpaa/Kconfig
index 0e52cda..3c19f41 100644
--- a/drivers/net/ethernet/freescale/dpaa/Kconfig
+++ b/drivers/net/ethernet/freescale/dpaa/Kconfig
@@ -35,4 +35,26 @@ help
   now so downstream consumers can wire calls today.
   Safe to leave on: zero runtime cost without ucode 210.
 
+
+config DPAA_HW_HM_OFFLOAD
+	bool "DPAA: FMan PCD Header Manipulation stubs (M3-3c)"
+	depends on DPAA_HW_CC_STEERING
+	default y
+	help
+	  Compile in the FMan PCD Header Manipulation (HM) stub API
+	  (fman_hm_node_install / fman_hm_node_destroy /
+	  fman_hm_caps_supported) per
+	  specs/dpaa1-afxdp-modernization-spec.md sec 5.5.
+
+	  HM nodes mutate L2/L3 headers (VLAN push/pop, MAC rewrite,
+	  IPv4/IPv6 NAT, TTL decrement, DSCP rewrite) entirely in
+	  silicon after CC matching and before QMan enqueue, per the
+	  spec sec 5.4 chain ordering (Parser -> CC -> HM -> QMan).
+
+	  All stubs return -ENOTSUPP on builds without ucode 210 and
+	  bump the hw_offload_unavailable ethtool counter. Productive
+	  implementations land in follow-up patches; the API is fixed
+	  now so downstream consumers can wire calls today.
+	  Safe to leave on: zero runtime cost without FMAN_CAP_HM_NODES.
+
 source "drivers/net/ethernet/freescale/dpaa/af_xdp_pool/Kconfig"
diff --git a/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.c b/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.c
index da5223d..2c468e7 100644
--- a/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.c
+++ b/drivers/net/ethernet/freescale/dpaa/dpaa_fman_caps.c
@@ -212,5 +212,38 @@ void fman_cc_tree_destroy(struct fman *fm, u8 port_id)
 }
 EXPORT_SYMBOL_GPL(fman_cc_tree_destroy);
 
+
+/* ------------------------------------------------------------------ *
+ * M3-3c stub: HM (Header Manipulation) API.
+ *
+ * Productive implementation replaces these bodies in a follow-up patch
+ * per spec sec 5.5. Until then both entry-points return -ENOTSUPP and
+ * bump the dpaa_priv hw_offload_unavailable counter via the
+ * downstream caller. Spec sec 5.5.
+ * ------------------------------------------------------------------ */
+
+int fman_hm_node_install(struct fman *fm, u8 port_id,
+			 const struct fman_hm_spec *spec, u32 *handle)
+{
+	if (!handle)
+		return -EINVAL;
+	*handle = 0;
+	return -ENOTSUPP;
+}
+EXPORT_SYMBOL_GPL(fman_hm_node_install);
+
+int fman_hm_node_destroy(struct fman *fm, u8 port_id, u32 handle)
+{
+	/* idempotent no-op on stub; productive impl will validate handle */
+	return 0;
+}
+EXPORT_SYMBOL_GPL(fman_hm_node_destroy);
+
+bool fman_hm_caps_supported(void)
+{
+	return (dpaa_fman_get_caps() & FMAN_CAP_HM_NODES) != 0;
+}
+EXPORT_SYMBOL_GPL(fman_hm_caps_supported);
+
 MODULE_LICENSE("Dual BSD/GPL");
 MODULE_DESCRIPTION("DPAA1 FMan PCD capability detection + HW-offload stubs");
