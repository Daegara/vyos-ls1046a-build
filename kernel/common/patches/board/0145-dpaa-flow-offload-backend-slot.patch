+/* External flow-offload backend registration (ASK2). */
+static const struct dpaa_flow_offload_ops __rcu *dpaa_fo_ops_slot;
+static DEFINE_SPINLOCK(dpaa_fo_ops_lock);
+
+int dpaa_register_flow_offload_handler(const struct dpaa_flow_offload_ops *ops)
+{
+	const struct dpaa_flow_offload_ops *cur;
+
+	if (!ops || !ops->setup_tc_block)
+		return -EINVAL;
+
+	spin_lock(&dpaa_fo_ops_lock);
+	cur = rcu_dereference_protected(dpaa_fo_ops_slot,
+					lockdep_is_held(&dpaa_fo_ops_lock));
+	if (cur) {
+		spin_unlock(&dpaa_fo_ops_lock);
+		return -EBUSY;
+	}
+	if (ops->owner && !try_module_get(ops->owner)) {
+		spin_unlock(&dpaa_fo_ops_lock);
+		return -ENODEV;
+	}
+
+	rcu_assign_pointer(dpaa_fo_ops_slot, ops);
+	spin_unlock(&dpaa_fo_ops_lock);
+	return 0;
+}
+EXPORT_SYMBOL_GPL(dpaa_register_flow_offload_handler);
+
+int dpaa_unregister_flow_offload_handler(const struct dpaa_flow_offload_ops *ops)
+{
+	const struct dpaa_flow_offload_ops *cur;
+
+	if (!ops)
+		return -EINVAL;
+
+	spin_lock(&dpaa_fo_ops_lock);
+	cur = rcu_dereference_protected(dpaa_fo_ops_slot,
+					lockdep_is_held(&dpaa_fo_ops_lock));
+	if (cur != ops) {
+		spin_unlock(&dpaa_fo_ops_lock);
+		return -EINVAL;
+	}
+
+	rcu_assign_pointer(dpaa_fo_ops_slot, NULL);
+	spin_unlock(&dpaa_fo_ops_lock);
+	synchronize_rcu();
+
+	if (ops->owner)
+		module_put(ops->owner);
+
+	return 0;
+}
+EXPORT_SYMBOL_GPL(dpaa_unregister_flow_offload_handler);
+
+static int dpaa_setup_tc_flow_block(struct net_device *net_dev,
+				struct flow_block_offload *f)
+{
+	const struct dpaa_flow_offload_ops *ops;
+	int err;
+
+	rcu_read_lock();
+	ops = rcu_dereference(dpaa_fo_ops_slot);
+	if (!ops) {
+		rcu_read_unlock();
+		return -EOPNOTSUPP;
+	}
+
+	err = ops->setup_tc_block(net_dev, f);
+	rcu_read_unlock();
+
+	return err;
+}
