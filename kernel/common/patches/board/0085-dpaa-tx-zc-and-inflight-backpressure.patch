+/* M3-3 step 5 (patch 0085): NAPI-hooked TX ZC submission and
+ * tx-need-wakeup arming. Same RCU read-section, reuses the
+ * local `ops`. napi_tx_zc drains the XSK Tx ring into the
+ * DPAA1 egress FQs (xsk_tx_peek_release_desc_batch ->
+ * qman_enqueue) honouring the software xsk_tx_inflight budget.
+ * xsk_set_tx_need_wakeup arms tx-need-wakeup when the budget
+ * is exhausted OR the Tx ring drained. Spec sec 6.1.4.
+ */
+if (ops && ops->napi_tx_zc)
+ops->napi_tx_zc(priv);
+if (ops && ops->xsk_set_tx_need_wakeup)
+ops->xsk_set_tx_need_wakeup(priv, np);
+
 rcu_read_unlock();
 
 		qman_p_irqsource_add(np->p, QM_PIRQ_DQRI);
@@ -2539,6 +2552,31 @@ static void dpaa_tx_conf(struct net_device *net_dev,
 {
 	struct sk_buff	*skb;
 
+	/* M3-3 step 5 (patch 0085): give the flavor module first crack
+	 * at the TxConf FD. If it returns true, the FD belonged to an
+	 * XSK qband (bpid matched priv->xsk_bpid[q]); the flavor has
+	 * called xsk_tx_completed() and atomic_dec'd xsk_tx_inflight;
+	 * we MUST NOT run dpaa_cleanup_tx_fd() on it (no skb backing
+	 * -- the FD's DMA address is an XSK UMEM chunk still owned by
+	 * the pool). Strictly NAPI-context. With no flavor module
+	 * loaded (default flavor) ops is NULL and the fast path falls
+	 * through to the existing skb cleanup verbatim. Spec sec 6.1.4
+	 * round-trip closure.
+	 */
+	{
+		const struct dpaa_qmgmt_ops *ops;
+
+		rcu_read_lock();
+		ops = rcu_dereference(priv->qmgmt_ops);
+		if (ops && ops->tx_conf_zc &&
+		    ops->tx_conf_zc((struct dpaa_priv *)priv, fd)) {
+			rcu_read_unlock();
+			percpu_priv->tx_confirm++;
