@@ -55,4 +55,10 @@ void fman_pcd_cc_seq_dump(struct fman_pcd *pcd, struct seq_file *m);
 void fman_pcd_cc_test_debugfs_init(struct dentry *parent,
 				   struct fman_pcd *pcd);
 
+/* FE-VM arm debugfs (patch 0132). */
+struct dentry;
+struct fman_pcd;
+void fman_pcd_fe_arm_debugfs_init(struct dentry *parent,
+				  struct fman_pcd *pcd);
+
 #endif /* __FMAN_PCD_INTERNAL_H */
