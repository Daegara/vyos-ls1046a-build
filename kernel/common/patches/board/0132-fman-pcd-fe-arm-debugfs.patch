diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_fe_arm.c b/drivers/net/ethernet/freescale/fman/fman_pcd_fe_arm.c
new file mode 100644
index 0000000..5e1a9b0
--- /dev/null
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_fe_arm.c
@@ -0,0 +1,162 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * FMan PCD Frame-Engine arm debugfs node (Fork B Phase 1 D9-B).
+ * Copyright 2026 Mono Networks / VyOS LS1046A maintainers.
+ */
+
+#include <linux/debugfs.h>
+#include <linux/fsl/fman_pcd.h>
+#include <linux/seq_file.h>
+#include <linux/string.h>
+#include <linux/uaccess.h>
+
+#include "fman.h"
+#include "fman_pcd_internal.h"
+
+/*
+ * Write interface:
+ *   engage <hw_port_id_hex> <fe_enter_off_hex>
+ *   disengage <hw_port_id_hex>
+ */
+static int fe_arm_engage(struct fman_pcd *pcd, const char *args)
+{
+	unsigned int port_id;
+	unsigned long fe_enter_off;
+	u8 saved_engine;
+	int err;
+
+	if (sscanf(args, "engage %x %lx", &port_id, &fe_enter_off) != 2)
+		return -EINVAL;
+	if (port_id < 0x08 || port_id >= 0x28 || fe_enter_off == 0)
+		return -EINVAL;
+
+	if (pcd->fe_refcount == 0)
+		return -EINVAL;
+	if (pcd->fe_root_ad_off != fe_enter_off)
+		return -EINVAL;
+
+	err = fman_pcd_kg_port_arm_fe(pcd, (u8)port_id,
+				      (u32)fe_enter_off, &saved_engine);
+	if (err)
+		return err;
+
+	pr_info("fman_pcd fe_arm: port 0x%02x ENGAGED (FE_ENTER=0x%lx)\n",
+		port_id, fe_enter_off);
+	return 0;
+}
+
+static int fe_arm_disengage(struct fman_pcd *pcd, const char *args)
+{
+	unsigned int port_id;
+
+	if (sscanf(args, "disengage %x", &port_id) != 1)
+		return -EINVAL;
+	if (port_id < 0x08 || port_id >= 0x28)
+		return -EINVAL;
+
+	fman_pcd_kg_port_disarm_fe(pcd, (u8)port_id, 0);
+
+	pr_info("fman_pcd fe_arm: port 0x%02x DISENGAGED\n", port_id);
+	return 0;
+}
+
+static int fe_arm_show(struct seq_file *s, void *unused)
+{
+	struct fman_pcd *pcd = s->private;
+
+	seq_printf(s, "fe_pool engaged:  %s\n",
+		   pcd->fe_refcount ? "YES" : "NO");
+	seq_printf(s, "FE_ENTER root AD: 0x%lx\n", pcd->fe_root_ad_off);
+	seq_printf(s, "verbs: engage <port_hex> <fe_enter_off_hex> | "
+		   "disengage <port_hex>\n");
+	return 0;
+}
+
+static int fe_arm_open(struct inode *inode, struct file *file)
+{
+	return single_open(file, fe_arm_show, inode->i_private);
+}
+
+static ssize_t fe_arm_write(struct file *file, const char __user *buf,
+			    size_t count, loff_t *ppos)
+{
+	struct seq_file *m = file->private_data;
+	struct fman_pcd *pcd = m->private;
+	char *kbuf;
+	int ret;
+
+	if (!pcd || count == 0 || count > 128)
+		return -EINVAL;
+
+	kbuf = memdup_user_nul(buf, count);
+	if (IS_ERR(kbuf))
+		return PTR_ERR(kbuf);
+
+	kbuf[strcspn(kbuf, "\n")] = 0;
+
+	if (strncmp(kbuf, "engage ", 7) == 0) {
+		ret = fe_arm_engage(pcd, kbuf);
+		if (ret == 0)
+			ret = count;
+	} else if (strncmp(kbuf, "disengage ", 10) == 0) {
+		ret = fe_arm_disengage(pcd, kbuf);
+		if (ret == 0)
+			ret = count;
+	} else {
+		ret = -EINVAL;
+	}
+
+	kfree(kbuf);
+	return ret;
+}
+
+static const struct file_operations fman_pcd_fe_arm_fops = {
+	.owner   = THIS_MODULE,
+	.open    = fe_arm_open,
+	.read    = seq_read,
+	.write   = fe_arm_write,
+	.llseek  = seq_lseek,
+	.release = single_release,
+};
+
+void fman_pcd_fe_arm_debugfs_init(struct dentry *parent,
+				  struct fman_pcd *pcd)
+{
+	if (IS_ERR_OR_NULL(parent) || !pcd)
+		return;
+	debugfs_create_file("fe_arm", 0600, parent, pcd,
+			    &fman_pcd_fe_arm_fops);
+}
