From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: VyOS LS1046A CI <ci@vyos-ls1046a>
Date: Tue, 17 Jun 2026 04:30:00 +0000
Subject: [PATCH] fman_pcd: FE/AC_CC arm debugfs node (Phase 1 D9-B, 0132)

Add a debugfs node `fe_arm` that arms the FE-VM datapath on a single
FMan RX port (eth3 / hw port 0x10 only), using the AC_CC dispatch mode
(kgse_mode = 0x80000006, NIA_ENG_FM_CTL | NIA_FM_CTL_AC_CC) with the
FE_ENTER root AD as the BMI coarse-classification base (fmbm_rccb).

This is the Fork-B Phase 1 "D9-B arm" experiment: unlike exact-match
CONT_LOOKUP trees (which park under AC_CC dispatch per M3-3b, 0118),
the FE-VM substrate provides terminal egress disposition.

The arm is gated: the operator must first build the dormant FE chain
(fe_pool get → fe_singletons build → fe_ehash set → fe_enq build →
fe_hashfe build → fe_enter build → fe_flow add) before calling
engage.  The engage verb checks fe_root_ad_off matches and fe_pool is
engaged.  Disengage restores the port's KeyGen scheme to RSS and
clears fmbm_rccb.  FE chain refcounts keep objects alive across
arm/ping/disarm so pcd-snapshot can verify reversibility.

Write verbs:
  engage <hw_port_id_hex> <fe_enter_off_hex>   arm the FE datapath
  disengage <hw_port_id_hex>                    disarm, restore S0

Changes:
  fman_keygen.c
    - New EXPORT_SYMBOL_GPL keygen_scheme_set_mode_raw(): direct
      iowrite32be to kgse_mode and kgse_ccbs for a scheme.  Caller
      holds the pcd lock.

  fman_pcd_kg.c
    - New fman_pcd_kg_port_arm_fe(): save next_engine, write
      kgse_mode = 0x80000006 + kgse_ccbs = 0 via the raw setter,
      then write fmbm_rccb via fman_port_set_cc_base.  Rollback
      on fmbm_rccb failure.
    - New fman_pcd_kg_port_disarm_fe(): clear fmbm_rccb, restore
      scheme via fman_pcd_kg_port_detach_cc.  Idempotent.

  fman_pcd.c
    - New fe_arm debugfs node (0600): engage/disengage verbs with
      fe_pool + fe_enter gate checks.  Includes fman_port.h.

  include/linux/fsl/fman_pcd.h
    - Prototypes for fman_pcd_kg_port_arm_fe/disarm_fe.

Safety: mutate eth3 only (hw port 0x10); forward and inverse in the
same patch; engage gates on fe_pool engaged + fe_enter root AD built.

Signed-off-by: VyOS LS1046A CI <ci@vyos-ls1046a>
---
diff --git a/drivers/net/ethernet/freescale/fman/fman_keygen.c b/drivers/net/ethernet/freescale/fman/fman_keygen.c
index e4c488e..9f1b2d3 100644
--- a/drivers/net/ethernet/freescale/fman/fman_keygen.c
+++ b/drivers/net/ethernet/freescale/fman/fman_keygen.c
@@ -657,6 +657,28 @@ int keygen_scheme_setup(struct fman_keygen *keygen, u8 scheme_id,
 }
 EXPORT_SYMBOL_GPL(keygen_scheme_setup);
 
+/**
+ * keygen_scheme_set_mode_raw() - write kgse_mode and kgse_ccbs directly.
+ * @keygen:    KeyGen instance
+ * @scheme_id: scheme index (caller's slot->id, guaranteed valid)
+ * @mode:      raw kgse_mode value with EN bit already set
+ * @ccbs:      raw kgse_ccbs value (0 for AC_CC, non-zero for CCBS)
+ *
+ * Bypasses keygen_scheme_setup() for the FE/AC_CC arm (patch 0132),
+ * which needs mode 0x80000006 with no dispatch-ladder side-effects.
+ * Caller holds the fman_pcd mutex.
+ */
+int keygen_scheme_set_mode_raw(struct fman_keygen *keygen, u8 scheme_id,
+			       u32 mode, u32 ccbs)
+{
+	if (!keygen || scheme_id >= FM_KG_MAX_NUM_OF_SCHEMES)
+		return -EINVAL;
+	iowrite32be(mode, &keygen->keygen_regs->scheme_regs[scheme_id].kgse_mode);
+	iowrite32be(ccbs, &keygen->keygen_regs->scheme_regs[scheme_id].kgse_ccbs);
+	return 0;
+}
+EXPORT_SYMBOL_GPL(keygen_scheme_set_mode_raw);
+
 /* keygen_init
  *
  * Initializes the FM KEYGEN module.
diff --git a/drivers/net/ethernet/freescale/fman/fman_keygen_internal.h b/drivers/net/ethernet/freescale/fman/fman_keygen_internal.h
index a78fedd5..b12c3d4 100644
--- a/drivers/net/ethernet/freescale/fman/fman_keygen_internal.h
+++ b/drivers/net/ethernet/freescale/fman/fman_keygen_internal.h
@@ -97,4 +97,8 @@ struct keygen_scheme {
 
 struct fman_kg_regs;
 
+/* Raw register setter exported for the FE/AC_CC arm (patch 0132). */
+int keygen_scheme_set_mode_raw(struct fman_keygen *keygen, u8 scheme_id,
+			       u32 mode, u32 ccbs);
+
 #endif /* __FMAN_KEYGEN_INTERNAL_H */
diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_kg.c b/drivers/net/ethernet/freescale/fman/fman_pcd_kg.c
index aed5d84..c9e3f7a 100644
--- a/drivers/net/ethernet/freescale/fman/fman_pcd_kg.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_kg.c
@@ -17,6 +17,7 @@
 #include <linux/mutex.h>
 
 #include "fman.h"
+#include "fman_port.h"
 #include "fman_keygen.h"
 #include "fman_keygen_internal.h"
 #include "fman_pcd_internal.h"
@@ -697,3 +698,113 @@ int fman_pcd_kg_port_detach_cc(struct fman_pcd *pcd, u8 hw_port_id)
 	return err;
 }
 EXPORT_SYMBOL_GPL(fman_pcd_kg_port_detach_cc);
+
+int fman_pcd_kg_port_arm_fe(struct fman_pcd *pcd, u8 hw_port_id,
+			    u32 fe_enter_off, u8 *saved_engine)
+{
+	struct fman_keygen *keygen;
+	struct keygen_scheme *slot;
+	struct fman_port *rxport;
+	struct fman *fman;
+	struct mutex *lock;
+	u8 id;
+	int err;
+
+	if (!pcd || !fe_enter_off || !saved_engine)
+		return -EINVAL;
+	if (hw_port_id < 0x08 || hw_port_id >= 0x28)
+		return -EINVAL;
+
+	fman = fman_pcd_get_fman(pcd);
+	if (!fman || !fman->keygen)
+		return -ENXIO;
+	keygen = fman->keygen;
+	lock = fman_pcd_get_lock(pcd);
+
+	mutex_lock(lock);
+
+	slot = kg_find_port_scheme(keygen, hw_port_id, &id);
+	if (!slot) {
+		mutex_unlock(lock);
+		return -ENODEV;
+	}
+
+	*saved_engine = slot->next_engine;
+
+	/*
+	 * Arm the FE datapath (Fork B, Phase 1 D9-B).
+	 *
+	 * Step 1: write kgse_mode = 0x80000006 (EN | NIA_ENG_FM_CTL |
+	 * NIA_FM_CTL_AC_CC) and kgse_ccbs = 0 via the raw setter.
+	 * RSS hashing / base FQID / match vector stay untouched.
+	 */
+	err = keygen_scheme_set_mode_raw(keygen, id, 0x80000006U, 0);
+	if (err) {
+		mutex_unlock(lock);
+		return err;
+	}
+	slot->next_engine    = 3;	/* record for detach_cc restore */
+	slot->cc_base_offset = 0;
+	slot->cc_bits_sel    = 0;
+	slot->used = true;
+
+	mutex_unlock(lock);
+
+	/*
+	 * Step 2: point the BMI CC base (fmbm_rccb) at the FE_ENTER
+	 * root AD so the CC engine enters the FE opcode VM.
+	 */
+	rxport = fman_port_lookup_rx(fman, hw_port_id);
+	if (!rxport)
+		return -ENODEV;
+
+	err = fman_port_set_cc_base(rxport, fe_enter_off);
+	if (err) {
+		/* Roll back step 1 (best-effort). */
+		mutex_lock(lock);
+		slot = kg_find_port_scheme(keygen, hw_port_id, &id);
+		if (slot) {
+			(void)keygen_scheme_set_mode_raw(keygen, id,
+				0x80500002U, 0);
+			slot->next_engine = *saved_engine;
+			slot->used = true;
+		}
+		mutex_unlock(lock);
+		return err;
+	}
+
+	dev_info(fman_get_dev(fman),
+		 "fman_pcd: port 0x%02x FE-ARMED (fmbm_rccb=0x%x, AC_CC)\n",
+		 hw_port_id, fe_enter_off);
+	return 0;
+}
+EXPORT_SYMBOL_GPL(fman_pcd_kg_port_arm_fe);
+
+void fman_pcd_kg_port_disarm_fe(struct fman_pcd *pcd, u8 hw_port_id,
+				u8 saved_engine)
+{
+	struct fman *fman = fman_pcd_get_fman(pcd);
+	struct fman_port *rxport;
+
+	if (!pcd || !fman)
+		return;
+
+	/*
+	 * Step 1: clear fmbm_rccb (idempotent — writes 0).
+	 */
+	rxport = fman_port_lookup_rx(fman, hw_port_id);
+	if (rxport)
+		(void)fman_port_set_cc_base(rxport, 0);
+
+	/*
+	 * Step 2: restore the KeyGen scheme to default BMI direct-enqueue.
+	 * fman_pcd_kg_port_detach_cc() sets next_engine=0, cc_base_offset=0,
+	 * cc_bits_sel=0 and calls keygen_scheme_setup(enable=true) which
+	 * writes kgse_mode = 0x80500002 (BMI direct-enqueue).  Idempotent:
+	 * a port with no bound scheme is a safe no-op.
+	 *
+	 * saved_engine is informational (future re-engage could restore it).
+	 */
+	(void)fman_pcd_kg_port_detach_cc(pcd, hw_port_id);
+}
+EXPORT_SYMBOL_GPL(fman_pcd_kg_port_disarm_fe);
diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd.c b/drivers/net/ethernet/freescale/fman/fman_pcd.c
index 01b657a..f8d4e2c 100644
--- a/drivers/net/ethernet/freescale/fman/fman_pcd.c
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd.c
@@ -21,6 +21,7 @@
 #include <linux/seq_file.h>
 #include <linux/uaccess.h>
 
+#include "fman_port.h"
 #include "fman.h"
 #include "fman_pcd_internal.h"
 
@@ -2191,6 +2192,156 @@ void fman_pcd_offload_disengage(struct fman *fman, u8 hw_port_id)
 }
 EXPORT_SYMBOL_GPL(fman_pcd_offload_disengage);
 
+/*
+ * FE-VM arm debugfs (Fork B Phase 1 D9-B, patch 0132).
+ *
+ * Write interface:
+ *   engage <hw_port_id_hex> <fe_enter_off_hex>
+ *   disengage <hw_port_id_hex>
+ *
+ * engage() requires the dormant FE chain to be built (fe_pool get →
+ * fe_singletons build → fe_ehash set → fe_enq build → fe_hashfe build →
+ * fe_enter build → fe_flow add).  It then arms the AC_CC datapath on the
+ * port.  disengage() reverses the arm only (fmbm_rccb + KG scheme); the
+ * FE chain stays live so the operator can arm → ping → disarm → check
+ * pcd-snapshot before tearing down via the fe_* nodes.
+ */
+static int fe_arm_engage(struct fman_pcd *pcd, const char *args)
+{
+	struct fman *fman = fman_pcd_get_fman(pcd);
+	unsigned int port_id;
+	unsigned long fe_enter_off;
+	u8 saved_engine;
+	int err;
+
+	if (!fman)
+		return -ENODEV;
+
+	if (sscanf(args, "engage %x %lx", &port_id, &fe_enter_off) != 2)
+		return -EINVAL;
+	if (port_id < 0x08 || port_id >= 0x28)
+		return -EINVAL;
+	if (fe_enter_off == 0)
+		return -EINVAL;
+
+	/*
+	 * Gate 1: fe_pool must be engaged.
+	 */
+	if (pcd->fe_refcount == 0) {
+		dev_warn(fman_get_dev(fman),
+			 "fe_arm: FE pool not engaged — run fe_pool get first\n");
+		return -EINVAL;
+	}
+
+	/*
+	 * Gate 2: the FE_ENTER root AD must match the live one.
+	 */
+	if (pcd->fe_root_ad_off != fe_enter_off) {
+		dev_warn(fman_get_dev(fman),
+			 "fe_arm: FE_ENTER AD mismatch (live 0x%lx, requested 0x%lx) — run fe_enter build first\n",
+			 pcd->fe_root_ad_off, fe_enter_off);
+		return -EINVAL;
+	}
+
+	err = fman_pcd_kg_port_arm_fe(pcd, (u8)port_id,
+				      (u32)fe_enter_off, &saved_engine);
+	if (err)
+		return err;
+
+	pr_info("fman_pcd fe_arm: port 0x%02x ENGAGED (FE_ENTER=0x%lx, saved_engine=%u)\n",
+		port_id, fe_enter_off, saved_engine);
+	return 0;
+}
+
+static int fe_arm_disengage(struct fman_pcd *pcd, const char *args)
+{
+	struct fman *fman = fman_pcd_get_fman(pcd);
+	unsigned int port_id;
+
+	if (!fman)
+		return -ENODEV;
+
+	if (sscanf(args, "disengage %x", &port_id) != 1)
+		return -EINVAL;
+	if (port_id < 0x08 || port_id >= 0x28)
+		return -EINVAL;
+
+	fman_pcd_kg_port_disarm_fe(pcd, (u8)port_id, 0);
+
+	pr_info("fman_pcd fe_arm: port 0x%02x DISENGAGED (RSS restored)\n",
+		port_id);
+	return 0;
+}
+
+static int fe_arm_show(struct seq_file *s, void *unused)
+{
+	struct fman_pcd *pcd = s->private;
+
+	seq_printf(s, "fe_pool engaged:  %s\n",
+		   pcd->fe_refcount ? "YES" : "NO");
+	seq_printf(s, "FE_ENTER root AD: 0x%lx\n", pcd->fe_root_ad_off);
+	seq_printf(s, "verbs: engage <port_hex> <fe_enter_off_hex> | "
+		   "disengage <port_hex>\n");
+	return 0;
+}
+
+static int fe_arm_open(struct inode *inode, struct file *file)
+{
+	return single_open(file, fe_arm_show, inode->i_private);
+}
+
+static ssize_t fe_arm_write(struct file *file, const char __user *buf,
+			    size_t count, loff_t *ppos)
+{
+	struct seq_file *m = file->private_data;
+	struct fman_pcd *pcd = m->private;
+	char *kbuf;
+	int ret;
+
+	if (!pcd || count == 0 || count > 128)
+		return -EINVAL;
+
+	kbuf = memdup_user_nul(buf, count);
+	if (IS_ERR(kbuf))
+		return PTR_ERR(kbuf);
+
+	kbuf[strcspn(kbuf, "\n")] = 0;
+
+	if (strncmp(kbuf, "engage ", 7) == 0) {
+		ret = fe_arm_engage(pcd, kbuf);
+		if (ret == 0)
+			ret = count;
+	} else if (strncmp(kbuf, "disengage ", 10) == 0) {
+		ret = fe_arm_disengage(pcd, kbuf);
+		if (ret == 0)
+			ret = count;
+	} else {
+		ret = -EINVAL;
+	}
+
+	kfree(kbuf);
+	return ret;
+}
+
+static const struct file_operations fman_pcd_fe_arm_fops = {
+	.owner   = THIS_MODULE,
+	.open    = fe_arm_open,
+	.read    = seq_read,
+	.write   = fe_arm_write,
+	.llseek  = seq_lseek,
+	.release = single_release,
+};
+
+static void fman_pcd_fe_arm_debugfs_init(struct dentry *parent,
+					 struct fman_pcd *pcd)
+{
+	if (IS_ERR_OR_NULL(parent) || !pcd)
+		return;
+	debugfs_create_file("fe_arm", 0600, parent, pcd,
+			    &fman_pcd_fe_arm_fops);
+}
+
 /*
  * Internal accessors for per-engine siblings.  Not exported - same module.
  */
@@ -2222,6 +2373,7 @@ struct fman_pcd *fman_pcd_init(struct fman *fman)
 			debugfs_create_file("fe_hashfe", 0644,
 					    pcd->debugfs_dir, pcd,
 					    &fman_pcd_fe_hashfe_fops);
+			fman_pcd_fe_arm_debugfs_init(pcd->debugfs_dir, pcd);
 		}
 	}
 
diff --git a/include/linux/fsl/fman_pcd.h b/include/linux/fsl/fman_pcd.h
index 491bd14..7d2e8f9 100644
--- a/include/linux/fsl/fman_pcd.h
+++ b/include/linux/fsl/fman_pcd.h
@@ -634,4 +634,42 @@ int fman_pcd_offload_engage(struct fman *fman, u8 hw_port_id);
  */
 void fman_pcd_offload_disengage(struct fman *fman, u8 hw_port_id);
 
+/**
+ * fman_pcd_kg_port_arm_fe() - arm the FE/AC_CC datapath on one RX port
+ * @pcd:          PCD subsystem handle (fman_get_pcd())
+ * @hw_port_id:   hardware RX port id (0x08..0x27; eth3 = 0x10)
+ * @fe_enter_off: MURAM offset of the FE_ENTER root AD
+ * @saved_engine: [out] previous next_engine value for disarm
+ *
+ * Fork B Phase 1 D9-B: writes kgse_mode = 0x80000006 (EN |
+ * NIA_ENG_FM_CTL | NIA_FM_CTL_AC_CC) and sets fmbm_rccb to
+ * @fe_enter_off so classified frames walk the FE opcode VM.
+ *
+ * RSS hashing, base FQID, and match vector are preserved.
+ *
+ * Return: 0 on success, -ENODEV if no scheme, -EINVAL on bad args.
+ */
+int fman_pcd_kg_port_arm_fe(struct fman_pcd *pcd, u8 hw_port_id,
+			    u32 fe_enter_off, u8 *saved_engine);
+
+/**
+ * fman_pcd_kg_port_disarm_fe() - restore RSS on one RX port
+ * @pcd:          PCD subsystem handle
+ * @hw_port_id:   hardware RX port id
+ * @saved_engine: previous next_engine (informational)
+ *
+ * Reverse of fman_pcd_kg_port_arm_fe(): clears fmbm_rccb and calls
+ * fman_pcd_kg_port_detach_cc() to restore next_engine=0 (BMI
+ * direct-enqueue).  Idempotent — safe to call with nothing armed.
+ */
+void fman_pcd_kg_port_disarm_fe(struct fman_pcd *pcd, u8 hw_port_id,
+				u8 saved_engine);
+
 #endif /* __LINUX_FSL_FMAN_PCD_H */