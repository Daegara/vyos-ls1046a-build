 struct fman_pcd_muram_budget fman_pcd_get_muram_budget(struct fman_pcd *pcd);
 
+/*
+ * KeyGen (KG) API.
+ *
+ * The KeyGen engine extracts a configurable byte-mask out of every
+ * incoming frame and feeds it to a hash that selects one of N
+ * Classifier-Continue (CC) targets, a direct frame queue, or a default
+ * policer profile.  The hardware programming lives in fman_pcd_kg.c.
+ *
+ * Reference: LS1046A RM 8.7.4 (KeyGen scheme registers), 8.7.5 (KG
+ * extract record format).  All extract offsets are in bytes from the
+ * start of the parse result described in RM 8.7.3.
+ */
+
+/**
+ * enum fman_pcd_kg_extract_from - source for one extract slot.
+ * @FMAN_PCD_KG_EXTRACT_FROM_FRAME:        raw byte at fixed frame offset
+ * @FMAN_PCD_KG_EXTRACT_FROM_PARSE_RESULT: byte at offset inside parse result
+ * @FMAN_PCD_KG_EXTRACT_FROM_DEFAULT:      use the per-port default value
+ *
+ * Mirrors the KGSE_EKDV (KeyGen Scheme Extract Definition - Value) field
+ * documented in RM 8.7.5 Table 8-105.
+ */
+enum fman_pcd_kg_extract_from {
+	FMAN_PCD_KG_EXTRACT_FROM_FRAME = 0,
+	FMAN_PCD_KG_EXTRACT_FROM_PARSE_RESULT,
+	FMAN_PCD_KG_EXTRACT_FROM_DEFAULT,
+};
+
+/**
+ * struct fman_pcd_kg_extract_spec - one extract slot inside a scheme.
+ * @src:    where the byte run comes from (frame / parse result / default)
+ * @offset: starting byte offset (0..63 for parse result, 0..127 for frame)
+ * @size:   number of bytes to extract (1..16); total across all slots must
+ *          not exceed the FMan KG generic extract buffer of 36 bytes
+ * @mask:   per-byte AND-mask applied before hashing (0xff = no mask)
+ *
+ * Used to build the IPv4/IPv6 5-tuple key (typical flow: SIP, DIP, proto,
+ * SPORT, DPORT - all sourced from FMAN_PCD_KG_EXTRACT_FROM_PARSE_RESULT
+ * with the standard FMan parser offsets).
+ */
+struct fman_pcd_kg_extract_spec {
+	enum fman_pcd_kg_extract_from src;
+	u8 offset;
+	u8 size;
+	u8 mask;
+};
+
+/**
+ * struct fman_pcd_kg_scheme_params - immutable scheme description.
+ * @id:         requested scheme id (0..31 on FMan v3); -1 = first free
+ * @num_extracts:  count of populated entries in @extracts (1..8)
+ * @extracts:   per-slot extract specs
+ * @default_fqid: fallback FQID when CC chaining is not used
+ * @use_hash:   true = hash extracts and select target via CC; false = direct
+ *              FQID via @default_fqid only
+ *
+ * Mainline LS1046A FMan v3 silicon has 32 KG schemes (8 per netcfg
+ * partition).  Each scheme is single-attach to a port.
+ */
+struct fman_pcd_kg_scheme_params {
+	int id;
+	u8 num_extracts;
+	struct fman_pcd_kg_extract_spec extracts[8];
+	u32 default_fqid;
+	bool use_hash;
+};
+
+/**
+ * fman_pcd_kg_scheme_create() - allocate and program a new KG scheme.
+ * @pcd:    PCD subsystem handle from fman_pcd_init()
+ * @params: scheme parameters; not retained after the call returns
+ *
+ * Programs the FMan KGSE_* registers for the chosen scheme id, attaches
+ * the scheme to @pcd->kg_schemes, and returns a handle that can be passed
+ * to fman_pcd_kg_bind_port() / fman_pcd_kg_attach_cc().
+ *
+ * Return: handle on success, ERR_PTR(-EBUSY) if @params->id is already in
+ * use, ERR_PTR(-EOPNOTSUPP) for an unsupported extract shape.
+ */
+struct fman_pcd_kg_scheme *
+fman_pcd_kg_scheme_create(struct fman_pcd *pcd,
+			  const struct fman_pcd_kg_scheme_params *params);
+
+/**
+ * fman_pcd_kg_bind_port() - bind a scheme to an FMan ingress port.
+ * @scheme:  handle from fman_pcd_kg_scheme_create()
+ * @port_id: FMan port id (1..8 for 1G, 9..10 for 10G on LS1046A)
+ *
+ * Writes the scheme's match-vector bit for @port_id and updates the
+ * port's PCD configuration so that frames classified to this scheme
+ * enter the KG hash pipeline.
+ *
+ * Return: 0 on success, -EINVAL on bad args, -EBUSY if already bound.
+ */
+int fman_pcd_kg_bind_port(struct fman_pcd_kg_scheme *scheme, u8 port_id);
+
+/**
+ * fman_pcd_kg_attach_cc() - chain a scheme to a Classifier-Continue tree.
+ * @scheme: handle from fman_pcd_kg_scheme_create()
+ * @cc:     classifier tree from fman_pcd_cc_tree_create()
+ *
+ * Wires the KGSE_CCBS (CC Base Scheme) register so that the scheme's
+ * hash output indexes into the CC tree's key table.
+ *
+ * Return: 0 on success, -EOPNOTSUPP until the CC subsystem lands,
+ * -EINVAL on bad args.
+ */
+int fman_pcd_kg_attach_cc(struct fman_pcd_kg_scheme *scheme,
+			  struct fman_pcd_cc_tree *cc);
+
+/**
+ * fman_pcd_kg_scheme_destroy() - tear down a previously created scheme.
+ * @scheme: handle from fman_pcd_kg_scheme_create().  NULL-safe.
+ *
+ * Detaches all port bindings, clears the KGSE_* registers, removes the
+ * scheme from @pcd->kg_schemes, and frees the handle.
+ */
+void fman_pcd_kg_scheme_destroy(struct fman_pcd_kg_scheme *scheme);
+
 #endif /* __LINUX_FSL_FMAN_PCD_H */
