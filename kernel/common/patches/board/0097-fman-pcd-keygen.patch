index 442c49d..13bc9d6 100644
--- a/include/linux/fsl/fman_pcd.h
+++ b/include/linux/fsl/fman_pcd.h
@@ -74,4 +74,123 @@ struct fman_pcd *fman_pcd_init(struct fman *fman);
