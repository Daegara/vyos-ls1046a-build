 					    pcd->debugfs_dir, pcd,
 					    &fman_pcd_ehash_fops);
+			debugfs_create_file("fe_enq", 0644,
+					    pcd->debugfs_dir, pcd,
+					    &fman_pcd_fe_enq_fops);
+			debugfs_create_file("fe_enter", 0644,
