+/*
+ * Policer (srTCM/trTCM) install surface (spec sec 5.6).
+ *
+ * The dpaa1 policer API exported from the dpaa driver
+ * (fman_policer_install() in dpaa_fman_caps.c) consumes a host-endian
+ * struct fman_policer_profile (bits/sec rates, byte bursts) that is
+ * module-private to fsl_dpa.ko. To program the FMan policer profile
+ * record (which lives in fsl_dpaa_fman.ko alongside the MURAM allocator)
+ * without a circular include, dpaa_fman_caps.c normalises its host-endian
+ * profile into the neutral descriptor below and hands it to the fman-side
+ * installer.  The neutral fields carry HOST values; the fman-side encoder
+ * does the exp/mant rate-field and 256-byte burst quantisation per
+ * LS1046A RM 8.7.6 and writes the 16-byte big-endian MURAM record (see
+ * fman_pcd_plcr.c).
+ */
+
+/**
+ * struct fman_pcd_plcr_hw_profile - one normalised policer profile (host).
+ * @trtcm:       true = two-rate trTCM (RFC 2698); false = srTCM (RFC 2697)
+ * @color_aware: true = honour the incoming frame colour (colour-aware)
+ * @cir_bps:     committed information rate, bits/sec (both modes)
+ * @cbs_bytes:   committed burst size, bytes (both modes)
+ * @pir_bps:     peak information rate, bits/sec (trTCM only; 0 for srTCM)
+ * @pbs_bytes:   peak/excess burst size, bytes (trTCM PBS / srTCM EBS)
+ *
+ * The fman-side installer encodes @cir_bps/@pir_bps into the FMan
+ * exp<<29|mant<<13 rate field and @cbs_bytes/@pbs_bytes into 256-byte
+ * burst mantissas, saturating at the silicon ceiling on overflow.
+ */
+struct fman_pcd_plcr_hw_profile {
+	bool trtcm;
+	bool color_aware;
+	u64 cir_bps;
+	u32 cbs_bytes;
+	u64 pir_bps;
+	u32 pbs_bytes;
+};
+
+/**
+ * fman_pcd_plcr_install() - program one srTCM/trTCM policer profile.
+ * @pcd:        PCD subsystem handle (fman_get_pcd(fm))
+ * @port_id:    FMan port id this profile is installed for
+ * @profile_id: caller-chosen silicon slot id (0..255)
+ * @hw:         neutral profile spec (host bps/bytes; encoded by this body)
+ *
+ * Allocates a 16-byte MURAM profile record, encodes the rate/burst/mode
+ * fields per RM 8.7.6, writes the record, and registers the profile on
+ * pcd->plcr_profiles. Re-installing on a populated (port, slot) tears the
+ * old profile down first (idempotent rebuild).
+ *
+ * Return: 0 on success; negative errno on failure.
+ */
+int fman_pcd_plcr_install(struct fman_pcd *pcd, u8 port_id, u8 profile_id,
+			  const struct fman_pcd_plcr_hw_profile *hw);
+
+/**
+ * fman_pcd_plcr_destroy() - tear down one policer profile by slot.
+ * @pcd:        PCD subsystem handle
+ * @port_id:    FMan port id (matched against the profile for safety)
+ * @profile_id: the silicon slot id to release
+ *
+ * Idempotent: a (port, slot) matching no live profile is a no-op.
+ */
+void fman_pcd_plcr_destroy(struct fman_pcd *pcd, u8 port_id, u8 profile_id);
+
 #endif /* __LINUX_FSL_FMAN_PCD_H */
