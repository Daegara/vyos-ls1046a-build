diff --git a/drivers/net/ethernet/freescale/fman/fman_pcd_plcr.c b/drivers/net/ethernet/freescale/fman/fman_pcd_plcr.c
new file mode 100644
index 0000000..3a3c90b
--- /dev/null
+++ b/drivers/net/ethernet/freescale/fman/fman_pcd_plcr.c
@@ -0,0 +1,604 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * FMan PCD Policer (RFC2698/single-rate) - three-colour-marker silicon
+ * programming via the FMPL indirect profile-access window.
+ *
+ * dpaa1 forward-port (PR5 of the PCD series closing M3-3d).  This body
+ * replaces the earlier MURAM-record encoding (which never matched the
+ * silicon) with a faithful port of the NXP SDK fm_plcr.c profile path:
+ * the policer profiles do NOT live in MURAM - they are 16-word records
+ * inside the FMan Policer (FMPL) CCSR block, staged through a single
+ * shared 16-word "profile entry" window and committed to a numbered
+ * physical profile via the Profile Action Register (PAR) GO handshake.
+ *
+ * The dpaa-side entry points (fman_policer_install / fman_policer_destroy
+ * in dpaa_fman_caps.c, fsl_dpa.ko) gate on FMAN_CAP_POLICER_TRTCM,
+ * translate their module-private host-endian struct fman_policer_profile
+ * into the neutral struct fman_pcd_plcr_hw_profile declared in
+ * <linux/fsl/fman_pcd.h>, and delegate to the two EXPORT_SYMBOL_GPL entry
+ * points below (which live here in fsl_dpaa_fman.ko, so the silicon
+ * internals never cross the module boundary - identical bridge idiom to
+ * fman_pcd_cc.c / fman_pcd_manip.c / fman_pcd_kg.c).
+ *
+ * Authoritative reference
+ * -----------------------
+ * - LS1046A Reference Manual sec 8.7 (FMan Policer, FMPL register block).
+ * - NXP SDK drivers/net/ethernet/freescale/sdk_fman .../Peripherals/FM/Pcd/
+ *   fm_plcr.{c,h} (read-only silicon-fact reference; algorithm ported,
+ *   no code copied): GetInfoRateReg(), CalcRates(), CalcFPP(),
+ *   BuildProfileRegs(), WritePar(), FM_PCD_PlcrProfileSet/Delete().
+ * - RFC 2698 (trTCM) marker semantics.
+ *
+ * FMPL block geometry (all offsets relative to the FMan CCSR base, which
+ * struct fman::base_addr maps in full - mainline fman.c reaches KeyGen at
+ * base_addr + KG_OFFSET = 0xC1000, and the Policer block is the 0x1000
+ * region immediately below it at 0xC0000):
+ *
+ *   0xC0000 + 0x08C  FMPL_PAR    profile action register (GO handshake)
+ *   0xC0000 + 0x090  FMPL_PEMODE \
+ *   0xC0000 + 0x094  FMPL_PEGNIA  |
+ *   ...               ...         |  16-word shared profile-entry window
+ *   0xC0000 + 0x0CC  FMPL_PERRPC /
+ *
+ * A write of FMPL_PAR with GO|PNUM(id)|PWSEL=0xFFFF copies the staged
+ * 16-word window into physical profile @id; the engine clears GO when the
+ * copy completes.  All FMPL registers are CCSR big-endian.
+ */
+
+#include <linux/err.h>
+#include <linux/errno.h>
+#include <linux/export.h>
+#include <linux/io.h>
+#include <linux/kernel.h>
+#include <linux/list.h>
+#include <linux/log2.h>
+#include <linux/math64.h>
+#include <linux/module.h>
+#include <linux/mutex.h>
+#include <linux/slab.h>
+#include <linux/spinlock.h>
+#include <linux/types.h>
+
+#include <linux/fsl/fman_pcd.h>
+#include "fman.h"
+#include "fman_pcd_internal.h"
+
+/* ------------------------------------------------------------------ */
+/* FMPL block geometry - RM sec 8.7 / SDK fm_plcr.h                    */
+/* ------------------------------------------------------------------ */
+
+/*
+ * Byte offset of the FMan Policer (FMPL) block within the FMan CCSR map.
+ * Cross-ref mainline fman.c: KG_OFFSET = 0x000C1000; the Policer block is
+ * the 0x1000 region immediately below KeyGen.
+ */
+#define FMAN_PLCR_BLOCK_OFFSET		0x000C0000u
+
+/* Profile Action Register (FMPL_PAR) - SDK t_FmPcdPlcrRegs::fmpl_par. */
+#define FMAN_PLCR_PAR_OFFSET		0x08Cu
+
+/*
+ * 16-word shared profile-entry window (SDK t_FmPcdPlcrProfileRegs).
+ * Offsets are relative to FMAN_PLCR_BLOCK_OFFSET.
+ */
+#define FMAN_PLCR_PE_PEMODE		0x090u	/* profile entry mode */
+#define FMAN_PLCR_PE_PEGNIA		0x094u	/* green  next-invoked-action */
+#define FMAN_PLCR_PE_PEYNIA		0x098u	/* yellow next-invoked-action */
+#define FMAN_PLCR_PE_PERNIA		0x09Cu	/* red    next-invoked-action */
+#define FMAN_PLCR_PE_PECIR		0x0A0u	/* committed information rate  */
+#define FMAN_PLCR_PE_PECBS		0x0A4u	/* committed burst size        */
+#define FMAN_PLCR_PE_PEPEPIR_EIR	0x0A8u	/* peak/excess information rate */
+#define FMAN_PLCR_PE_PEPBS_EBS		0x0ACu	/* peak/excess burst size      */
+#define FMAN_PLCR_PE_PELTS		0x0B0u	/* last timestamp              */
+#define FMAN_PLCR_PE_PECTS		0x0B4u	/* committed token status      */
+#define FMAN_PLCR_PE_PEPTS_ETS		0x0B8u	/* peak/excess token status    */
+#define FMAN_PLCR_PE_PEGPC		0x0BCu	/* green  packet counter       */
+#define FMAN_PLCR_PE_PEYPC		0x0C0u	/* yellow packet counter       */
+#define FMAN_PLCR_PE_PERPC		0x0C4u	/* red    packet counter       */
+#define FMAN_PLCR_PE_PERYPC		0x0C8u	/* recoloured yellow counter   */
+#define FMAN_PLCR_PE_PERRPC		0x0CCu	/* recoloured red counter      */
+
+/* FMPL_PAR fields - SDK fm_plcr.h FM_PCD_PLCR_PAR_*. */
+#define FMAN_PLCR_PAR_GO		0x80000000u
+#define FMAN_PLCR_PAR_R			0x40000000u	/* read (clear = write) */
+#define FMAN_PLCR_PAR_PNUM_SHIFT	16
+#define FMAN_PLCR_PAR_PWSEL_MASK	0x0000FFFFu	/* select all 16 words  */
+
+/*
+ * Per-port relative->absolute profile-mapping window (SDK
+ * t_FmPcdPlcrRegs::fmpl_pmr[63], FMPL offset 0x204, +4 per port; index =
+ * BMI hw port id - 1).  KeyGen selects a RELATIVE policer profile id in
+ * KGSE_PPC with the mode ABSOLUTE bit clear; the silicon resolves it to an
+ * absolute FMPL profile through this window (absolute = BASE + relative),
+ * but ONLY while the window VALID bit is set.  If the window is left
+ * unprogrammed the BMI rejects every frame as an uninitialised profile and
+ * drops it BEFORE metering (BUG 3a: all colour counters frozen, token
+ * bucket never moves).  BRN = log2(window size).  RM sec 8.7; SDK
+ * PlcrSetPortProfiles()/PlcrClearPortProfiles().
+ */
+#define FMAN_PLCR_PMR_OFFSET		0x204u		/* fmpl_pmr[0]         */
+#define FMAN_PLCR_PMR_V			0x80000000u	/* window valid        */
+#define FMAN_PLCR_PMR_BRN_SHIFT		16		/* log2(num profiles)  */
+
+/*
+ * FMPL_PEMODE (profile entry mode) bits - SDK fm_plcr.h
+ * FM_PCD_PLCR_PEMODE_*.  The silicon implements only pass-through,
+ * RFC2698 and RFC4115 algorithms (there is NO native RFC2697/srTCM mode);
+ * a single-rate limiter is realised as RFC2698 with CIR==PIR, CBS==PBS.
+ */
+#define FMAN_PLCR_PEMODE_PI		0x80000000u	/* profile initialised */
+#define FMAN_PLCR_PEMODE_CBLND		0x40000000u	/* colour-blind        */
+#define FMAN_PLCR_PEMODE_ALG_RFC2698	0x10000000u	/* MODE[ALG] = 01      */
+#define FMAN_PLCR_PEMODE_PKT		0x00800000u	/* packet mode (clear = byte) */
+#define FMAN_PLCR_PEMODE_FLS_L2		0x00003000u	/* frame-length = L2   */
+#define FMAN_PLCR_PEMODE_FPP_SHIFT	16
+
+/*
+ * Next-Invoked-Action (NIA) encodings - SDK fm_common.h NIA_ENG_xxx /
+ * NIA_BMI_AC_xxx.  FM_PCD_PLCR_NIA_VALID gates the action; BMI enqueue
+ * forwards the (already-FQID-stamped-by-KeyGen) frame, BMI discard drops.
+ */
+#define FMAN_PLCR_NIA_VALID		0x80000000u
+#define FMAN_PLCR_NIA_ENG_BMI		0x00500000u
+#define FMAN_PLCR_NIA_BMI_AC_ENQ	0x00000002u
+#define FMAN_PLCR_NIA_BMI_AC_DISCARD	0x000000C1u
+
+#define FMAN_PLCR_NIA_ENQUEUE	(FMAN_PLCR_NIA_VALID | FMAN_PLCR_NIA_ENG_BMI | \
+				 FMAN_PLCR_NIA_BMI_AC_ENQ)	/* 0x80500002 */
+#define FMAN_PLCR_NIA_DISCARD	(FMAN_PLCR_NIA_VALID | FMAN_PLCR_NIA_ENG_BMI | \
+				 FMAN_PLCR_NIA_BMI_AC_DISCARD)	/* 0x805000C1 */
+
+/*
+ * Timestamp-unit scale for the rate calculation.  The FMan FPM timestamp
+ * is enabled by mainline fman.c enable_time_stamp() with
+ * count1_micro_bit = FM_TIMESTAMP_1_USEC_BIT = 8, i.e. one microsecond is
+ * 2^8 = 256 timestamp ticks.  The SDK rate maths counts in tenths of a
+ * nanosecond for precision: tsuInTenthNanos = 1000 * 10 / (1 << 8) = 39.
+ */
+#define FMAN_PLCR_TSU_TENTH_NANO	39ULL
+
+/*
+ * Byte-mode rate divisor: 1e9 (nano) * 10 (tenth) * 8 (bit->byte) = 8e10.
+ * NOTE: this is the NATIVE-bits-per-second form.  The SDK takes the rate
+ * in Kbps and multiplies by 1000 inside GetInfoRateReg(); we feed bps
+ * directly and so omit that *1000, keeping the divisor at 8e10.
+ */
+#define FMAN_PLCR_BYTE_DIV		80000000000ULL
+
+/*
+ * Serialises access to the single shared FMPL profile-entry window + PAR
+ * handshake across all profiles (one FMan).  Mirrors the SDK PlcrHwLock.
+ */
+static DEFINE_SPINLOCK(plcr_hw_lock);
+
+/**
+ * struct fman_pcd_plcr_profile - bookkeeping for one installed profile.
+ * @node:        anchor on pcd->plcr_list (protected by pcd->lock)
+ * @pcd:         owning PCD subsystem (back-pointer)
+ * @port_id:     the FMan port this profile was installed for
+ * @profile_id:  physical FMPL profile slot id (0..255)
+ *
+ * The profile contents live entirely in silicon (FMPL profile @profile_id);
+ * this node exists only so fman_pcd_release() can reap profiles on unbind
+ * and so destroy() can match a (port, slot).  Definition is private to
+ * this translation unit.
+ */
+struct fman_pcd_plcr_profile {
+	struct list_head	node;
+	struct fman_pcd	*pcd;
+	u8		port_id;
+	u8		profile_id;
+};
+
+/* The 16-word staged profile image, in window order. */
+struct plcr_profile_regs {
+	u32 pemode;
+	u32 pegnia;
+	u32 peynia;
+	u32 pernia;
+	u32 pecir;
+	u32 pecbs;
+	u32 pepepir_eir;
+	u32 pepbs_ebs;
+	u32 pelts;
+	u32 pects;
+	u32 pepts_ets;
+	u32 pegpc;
+	u32 peypc;
+	u32 perpc;
+	u32 perypc;
+	u32 perrpc;
+};
+
+/* ------------------------------------------------------------------ */
+/* Rate encoder - faithful port of SDK fm_plcr.c CalcRates()          */
+/* ------------------------------------------------------------------ */
+
+/*
+ * Convert the chosen floating-point-position shift into the MODE[FPP]
+ * field value.  SDK CalcFPP(): the TS register splits into fraction
+ * (low) and integer (high); the field maps 0..15 -> 16..31 and
+ * 16..31 -> 0..15.
+ */
+static u32 plcr_calc_fpp(u32 fpp_shift)
+{
+	if (fpp_shift > 15)
+		return 15 - (0x1f - fpp_shift);
+	return 16 + fpp_shift;
+}
+
+/*
+ * Compute the integer (high 16 bits) and fraction (low 16 bits) halves of
+ * a CIR/PIR rate field for @bps at floating-point shift @fpp_shift, in
+ * byte mode.  Native-bps port of SDK GetInfoRateReg().
+ *
+ * OVERFLOW SAFETY: at high rates ((tmp << fpp_shift) << 16) overflows u64,
+ * but so does ((integer << 16) * div) by the SAME modular amount, so their
+ * unsigned (modular, well-defined in C) difference equals the true small
+ * remainder (< div < 2^37).  Do NOT add intermediate clamps here - that
+ * would break the cancellation.  See SDK GetInfoRateReg() comment.
+ */
+static void plcr_get_inforate(u64 bps, u32 fpp_shift,
+			      u64 *p_integer, u64 *p_fraction)
+{
+	u64 tmp = bps * FMAN_PLCR_TSU_TENTH_NANO;
+	u64 div = FMAN_PLCR_BYTE_DIV;
+	u64 shifted = tmp << fpp_shift;
+
+	*p_integer = div64_u64(shifted, div);
+	*p_fraction = div64_u64((shifted << 16) - ((*p_integer << 16) * div),
+				div);
+}
+
+/*
+ * Port of SDK fm_plcr.c CalcRates(): pick a single MODE[FPP] that suits
+ * both rates (calibrated on the faster of the two), then encode CIR and
+ * PIR as 16.16 fixed-point fields.  Burst sizes pass through unscaled
+ * (the FMPL CBS/PBS registers are in bytes).
+ */
+static void plcr_calc_rates(u64 cir_bps, u64 pir_bps, u32 cbs_bytes,
+			    u32 pbs_bytes, u32 *cir, u32 *cbs,
+			    u32 *pir_eir, u32 *pbs_ebs, u32 *fpp)
+{
+	u64 integer, fraction;
+	u64 faster = (cir_bps > pir_bps) ? cir_bps : pir_bps;
+	u32 temp;
+	u32 fpp_shift = 0;
+
+	/* Calibrate fpp on the faster rate at shift 0. */
+	plcr_get_inforate(faster, 0, &integer, &fraction);
+	temp = (u32)((integer << 16) & 0xFFFFFFFFULL);
+
+	if (temp != 0) {
+		/* Integer non-zero: shift unused high zeroes into fraction. */
+		while ((temp & 0x80000000u) == 0) {
+			temp <<= 1;
+			fpp_shift++;
+		}
+		/* Rate so high the TS cannot represent it: clamp at the
+		 * silicon maximum integer resolution (faithful to the SDK
+		 * error bound; our rates are <= 10G so this is defensive).
+		 */
+		if (fpp_shift > 15)
+			fpp_shift = 15;
+	} else {
+		/* Integer zero: all resolution goes to the fraction. */
+		temp = (u32)fraction;
+		if (temp == 0) {
+			fpp_shift = 31;
+		} else {
+			fpp_shift = 16;
+			while ((temp & 0x8000u) == 0) {
+				temp <<= 1;
+				fpp_shift++;
+			}
+		}
+	}
+
+	/* Re-encode both rates at the chosen shift. */
+	plcr_get_inforate(cir_bps, fpp_shift, &integer, &fraction);
+	*cir = (u32)((integer << 16) | (fraction & 0xFFFF));
+	plcr_get_inforate(pir_bps, fpp_shift, &integer, &fraction);
+	*pir_eir = (u32)((integer << 16) | (fraction & 0xFFFF));
+
+	*cbs = cbs_bytes;
+	*pbs_ebs = pbs_bytes;
+	*fpp = plcr_calc_fpp(fpp_shift);
+}
+
+/* ------------------------------------------------------------------ */
+/* Profile-image builder - port of SDK BuildProfileRegs()             */
+/* ------------------------------------------------------------------ */
+
+/*
+ * Assemble the 16-word profile image from the neutral profile.  The
+ * silicon has no RFC2697 mode, so both the caller's trTCM and single-rate
+ * requests are realised as RFC2698; the dpaa-side bridge sets
+ * cir==pir / cbs==pbs for the single-rate (tc police rate/burst) case so
+ * the yellow band is empty and over-rate frames go straight to red->drop.
+ * Byte mode, L2 frame-length selection, green/yellow -> enqueue, red ->
+ * discard.  Metering buckets start full (0xFFFFFFFF); counters start 0.
+ */
+static void plcr_build_profile(const struct fman_pcd_plcr_hw_profile *hw,
+			       struct plcr_profile_regs *r)
+{
+	u32 cir, cbs, pir_eir, pbs_ebs, fpp;
+	u32 pemode;
+
+	plcr_calc_rates(hw->cir_bps, hw->pir_bps, hw->cbs_bytes,
+			hw->pbs_bytes, &cir, &cbs, &pir_eir, &pbs_ebs, &fpp);
+
+	pemode = FMAN_PLCR_PEMODE_PI | FMAN_PLCR_PEMODE_ALG_RFC2698;
+	if (!hw->color_aware)
+		pemode |= FMAN_PLCR_PEMODE_CBLND;	/* colour-blind */
+	/* byte mode (PKT clear), L2 frame length, rollback L2 (RBFLS clear) */
+	pemode |= FMAN_PLCR_PEMODE_FLS_L2;
+	pemode |= (fpp << FMAN_PLCR_PEMODE_FPP_SHIFT);
+
+	r->pemode	= pemode;
+	r->pegnia	= FMAN_PLCR_NIA_ENQUEUE;
+	r->peynia	= FMAN_PLCR_NIA_ENQUEUE;
+	r->pernia	= FMAN_PLCR_NIA_DISCARD;
+	r->pecir	= cir;
+	r->pecbs	= cbs;
+	r->pepepir_eir	= pir_eir;
+	r->pepbs_ebs	= pbs_ebs;
+	r->pelts	= 0;
+	r->pects	= 0xFFFFFFFFu;		/* committed bucket full */
+	r->pepts_ets	= 0xFFFFFFFFu;		/* peak bucket full      */
+	r->pegpc	= 0;
+	r->peypc	= 0;
+	r->perpc	= 0;
+	r->perypc	= 0;
+	r->perrpc	= 0;
+}
+
+/* ------------------------------------------------------------------ */
+/* FMPL indirect window access - port of SDK WritePar()               */
+/* ------------------------------------------------------------------ */
+
+static void __iomem *plcr_fmpl_base(struct fman_pcd *pcd)
+{
+	return fman_pcd_get_fman(pcd)->base_addr + FMAN_PLCR_BLOCK_OFFSET;
+}
+
+/* Write @par to FMPL_PAR and spin until the engine clears GO. */
+static void plcr_write_par(void __iomem *fmpl, u32 par)
+{
+	void __iomem *par_reg = fmpl + FMAN_PLCR_PAR_OFFSET;
+
+	iowrite32be(par, par_reg);
+	while (ioread32be(par_reg) & FMAN_PLCR_PAR_GO)
+		cpu_relax();
+}
+
+/*
+ * Stage the 16-word image into the shared profile-entry window and commit
+ * it to physical profile @profile_id via the PAR GO handshake.  Holds
+ * plcr_hw_lock across the whole window-write + commit so concurrent
+ * profiles cannot corrupt the shared staging window.
+ */
+static void plcr_commit_profile(struct fman_pcd *pcd, u8 profile_id,
+				const struct plcr_profile_regs *r)
+{
+	void __iomem *fmpl = plcr_fmpl_base(pcd);
+	unsigned long flags;
+
+	spin_lock_irqsave(&plcr_hw_lock, flags);
+
+	iowrite32be(r->pemode,		fmpl + FMAN_PLCR_PE_PEMODE);
+	iowrite32be(r->pegnia,		fmpl + FMAN_PLCR_PE_PEGNIA);
+	iowrite32be(r->peynia,		fmpl + FMAN_PLCR_PE_PEYNIA);
+	iowrite32be(r->pernia,		fmpl + FMAN_PLCR_PE_PERNIA);
+	iowrite32be(r->pecir,		fmpl + FMAN_PLCR_PE_PECIR);
+	iowrite32be(r->pecbs,		fmpl + FMAN_PLCR_PE_PECBS);
+	iowrite32be(r->pepepir_eir,	fmpl + FMAN_PLCR_PE_PEPEPIR_EIR);
+	iowrite32be(r->pepbs_ebs,	fmpl + FMAN_PLCR_PE_PEPBS_EBS);
+	iowrite32be(r->pelts,		fmpl + FMAN_PLCR_PE_PELTS);
+	iowrite32be(r->pects,		fmpl + FMAN_PLCR_PE_PECTS);
+	iowrite32be(r->pepts_ets,	fmpl + FMAN_PLCR_PE_PEPTS_ETS);
+	iowrite32be(r->pegpc,		fmpl + FMAN_PLCR_PE_PEGPC);
+	iowrite32be(r->peypc,		fmpl + FMAN_PLCR_PE_PEYPC);
+	iowrite32be(r->perpc,		fmpl + FMAN_PLCR_PE_PERPC);
+	iowrite32be(r->perypc,		fmpl + FMAN_PLCR_PE_PERYPC);
+	iowrite32be(r->perrpc,		fmpl + FMAN_PLCR_PE_PERRPC);
+
+	plcr_write_par(fmpl,
+		       FMAN_PLCR_PAR_GO |
+		       ((u32)profile_id << FMAN_PLCR_PAR_PNUM_SHIFT) |
+		       FMAN_PLCR_PAR_PWSEL_MASK);
+
+	spin_unlock_irqrestore(&plcr_hw_lock, flags);
+}
+
+/*
+ * Invalidate physical profile @profile_id: stage PEMODE with the PI
+ * (profile-initialised) bit cleared and commit.  Port of SDK
+ * FM_PCD_PlcrProfileDelete(): it writes ~PI into the window PEMODE word
+ * and commits all words - the other 15 stale window words are irrelevant
+ * once PI is clear.
+ */
+static void plcr_invalidate_profile(struct fman_pcd *pcd, u8 profile_id)
+{
+	void __iomem *fmpl = plcr_fmpl_base(pcd);
+	unsigned long flags;
+
+	spin_lock_irqsave(&plcr_hw_lock, flags);
+
+	iowrite32be(~FMAN_PLCR_PEMODE_PI, fmpl + FMAN_PLCR_PE_PEMODE);
+	plcr_write_par(fmpl,
+		       FMAN_PLCR_PAR_GO |
+		       ((u32)profile_id << FMAN_PLCR_PAR_PNUM_SHIFT) |
+		       FMAN_PLCR_PAR_PWSEL_MASK);
+
+	spin_unlock_irqrestore(&plcr_hw_lock, flags);
+}
+
+/*
+ * Program the per-port FMPL profile-mapping window so the RELATIVE policer
+ * profile id KeyGen places in KGSE_PPC (ABSOLUTE bit clear) resolves to an
+ * absolute FMPL profile.  @base = absolute base profile, @num_profiles =
+ * window size (power of two; BRN = log2).  For the single per-port profile
+ * we install, base = profile_id and num = 1 (BRN = 0), so relative 0 maps to
+ * absolute profile_id.  @port_id is the BMI hw port id (1..63); the window
+ * index is port_id - 1.  Port of SDK PlcrSetPortProfiles().
+ */
+static void plcr_set_port_window(struct fman_pcd *pcd, u8 port_id,
+				 u16 base, u8 num_profiles)
+{
+	void __iomem *fmpl = plcr_fmpl_base(pcd);
+	void __iomem *pmr = fmpl + FMAN_PLCR_PMR_OFFSET + (port_id - 1) * 4;
+	u32 log2num = order_base_2(num_profiles);
+	u32 val = FMAN_PLCR_PMR_V |
+		  (log2num << FMAN_PLCR_PMR_BRN_SHIFT) | base;
+	unsigned long flags;
+
+	spin_lock_irqsave(&plcr_hw_lock, flags);
+	iowrite32be(val, pmr);
+	spin_unlock_irqrestore(&plcr_hw_lock, flags);
+}
+
+/*
+ * Close the per-port FMPL profile-mapping window (VALID bit -> 0) so the
+ * silicon stops resolving relative profile ids for this port.  Port of SDK
+ * PlcrClearPortProfiles().
+ */
+static void plcr_clear_port_window(struct fman_pcd *pcd, u8 port_id)
+{
+	void __iomem *fmpl = plcr_fmpl_base(pcd);
+	void __iomem *pmr = fmpl + FMAN_PLCR_PMR_OFFSET + (port_id - 1) * 4;
+	unsigned long flags;
+
+	spin_lock_irqsave(&plcr_hw_lock, flags);
+	iowrite32be(0, pmr);
+	spin_unlock_irqrestore(&plcr_hw_lock, flags);
+}
+
+/* Find an installed profile for (@port_id, @profile_id).  Caller holds
+ * pcd->lock.
+ */
+static struct fman_pcd_plcr_profile *
+plcr_find_locked(struct fman_pcd *pcd, u8 port_id, u8 profile_id)
+{
+	struct list_head *head = fman_pcd_get_plcr_list(pcd);
+	struct fman_pcd_plcr_profile *p;
+
+	if (!head)
+		return NULL;
+	list_for_each_entry(p, head, node)
+		if (p->port_id == port_id && p->profile_id == profile_id)
+			return p;
+	return NULL;
+}
+
+/**
+ * fman_pcd_plcr_install() - program one RFC2698/single-rate policer profile.
+ * @pcd:     the PCD subsystem (from fman_get_pcd())
+ * @port_id: the FMan port the profile is installed for
+ * @profile_id: physical FMPL profile slot id (0..255)
+ * @hw:      neutral profile spec (host bps/bytes; this body encodes them)
+ *
+ * Encodes the 16.16 CIR/PIR rate fields + byte burst sizes + PEMODE word +
+ * per-colour NIAs per RM sec 8.7, stages them into the FMPL profile-entry
+ * window and commits to physical profile @profile_id via the PAR GO
+ * handshake, then registers the profile on pcd->plcr_list so
+ * fman_pcd_release() reaps it on unbind.  Re-installing on a populated
+ * slot for this port replaces the bookkeeping entry (idempotent rebuild).
+ *
+ * Return: 0 on success; negative errno on failure.
+ *
+ * Port of SDK fm_plcr.c FM_PCD_PlcrProfileSet().
+ */
+int fman_pcd_plcr_install(struct fman_pcd *pcd, u8 port_id, u8 profile_id,
+			  const struct fman_pcd_plcr_hw_profile *hw)
+{
+	struct fman_pcd_plcr_profile *p, *old;
+	struct plcr_profile_regs regs;
+	struct mutex *pcd_lock;
+
+	if (!pcd || !hw)
+		return -EINVAL;
+
+	/* Reject a zero committed rate (the silicon would never pass a
+	 * frame); the dpaa-side bridge also screens this, belt-and-braces.
+	 */
+	if (hw->cir_bps == 0)
+		return -EINVAL;
+	/* RFC2698 requires PIR >= CIR. */
+	if (hw->trtcm && hw->pir_bps < hw->cir_bps)
+		return -ERANGE;
+
+	p = kzalloc(sizeof(*p), GFP_KERNEL);
+	if (!p)
+		return -ENOMEM;
+	INIT_LIST_HEAD(&p->node);
+	p->pcd = pcd;
+	p->port_id = port_id;
+	p->profile_id = profile_id;
+
+	/* Encode then commit the silicon profile. */
+	plcr_build_profile(hw, &regs);
+	plcr_commit_profile(pcd, profile_id, &regs);
+
+	/* Open the per-port relative->absolute profile window so the RELATIVE
+	 * id KeyGen selects (KGSE_PPC, ABSOLUTE bit clear) resolves to this
+	 * absolute profile.  base = profile_id, num = 1 (single per-port
+	 * profile).  Without this the BMI drops every frame BEFORE metering
+	 * (BUG 3a).  Mirrors SDK FmPcdPlcrAllocProfiles(port, profile_id, 1).
+	 */
+	plcr_set_port_window(pcd, port_id, profile_id, 1);
+
+	/* Publish: replace any existing bookkeeping for this (port, slot). */
+	pcd_lock = fman_pcd_get_lock(pcd);
+	mutex_lock(pcd_lock);
+	old = plcr_find_locked(pcd, port_id, profile_id);
+	if (old) {
+		list_del(&old->node);
+		kfree(old);
+	}
+	list_add_tail(&p->node, fman_pcd_get_plcr_list(pcd));
+	mutex_unlock(pcd_lock);
+
+	return 0;
+}
+EXPORT_SYMBOL_GPL(fman_pcd_plcr_install);
+
+/**
+ * fman_pcd_plcr_destroy() - tear down one policer profile by slot.
+ * @pcd:     the PCD subsystem
+ * @port_id: the FMan port (matched against the profile for safety)
+ * @profile_id: the physical FMPL profile slot id to release
+ *
+ * Idempotent: a (port, slot) matching no live profile is a no-op.
+ * Invalidates the silicon profile (clears PEMODE[PI] and commits) so the
+ * engine stops metering, then drops the bookkeeping node.
+ *
+ * Port of SDK fm_plcr.c FM_PCD_PlcrProfileDelete().
+ */
+void fman_pcd_plcr_destroy(struct fman_pcd *pcd, u8 port_id, u8 profile_id)
+{
+	struct fman_pcd_plcr_profile *p;
+	struct mutex *pcd_lock;
+
+	if (!pcd)
+		return;
+
+	pcd_lock = fman_pcd_get_lock(pcd);
+	mutex_lock(pcd_lock);
+	p = plcr_find_locked(pcd, port_id, profile_id);
+	if (p)
+		list_del(&p->node);
+	mutex_unlock(pcd_lock);
+
+	if (!p)
+		return;
+
+	/* Close the per-port profile window (VALID -> 0) so KeyGen stops
+	 * resolving the relative id, then disarm the silicon profile and free
+	 * bookkeeping.  Mirrors SDK FmPcdPlcrFreeProfiles().
+	 */
+	plcr_clear_port_window(pcd, port_id);
+	plcr_invalidate_profile(pcd, profile_id);
+	kfree(p);
+}
+EXPORT_SYMBOL_GPL(fman_pcd_plcr_destroy);
