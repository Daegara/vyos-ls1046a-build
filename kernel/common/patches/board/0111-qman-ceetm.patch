+#define REG_CEETM_UPDATE_PERIOD	1000 /* credit-update reference period (ns) */
+#define QM_SP_ENABLE_CEETM(n)	(0x80000000 >> (n))
+
+/*
+ * CEETM_CFG_PRES PRES field:
+ *   PRES = (2^22 / credit-update-reference-period) * QMan-clock-period
+ *        = ((2^22 * 10^9) / REG_CEETM_UPDATE_PERIOD) / qman_clk
+ */
+int qman_ceetm_set_prescaler(enum qm_dc_portal portal)
+{
+	u64 temp;
+	u16 pres;
+
+	if (!qm_ccsr_start)
+		return -ENODEV;
+	temp = 0x400000ULL * 100;
+	do_div(temp, REG_CEETM_UPDATE_PERIOD);
+	temp *= 10000000;
+	do_div(temp, qman_clk);
+	pres = (u16)temp;
+	qm_ccsr_out(REG_CEETM_CFG_IDX, portal);
+	qm_ccsr_out(REG_CEETM_CFG_PRES, pres);
+	return 0;
+}
+EXPORT_SYMBOL_GPL(qman_ceetm_set_prescaler);
+
+int qman_ceetm_get_prescaler(u16 *pres)
+{
+	if (!qm_ccsr_start)
+		return -ENODEV;
+	*pres = (u16)qm_ccsr_in(REG_CEETM_CFG_PRES);
+	return 0;
+}
+
+int qman_sp_enable_ceetm_mode(enum qm_dc_portal portal, u16 sub_portal)
+{
+	u32 dcp_cfg;
+
+	if (!qm_ccsr_start)
+		return -ENODEV;
+	dcp_cfg = qm_ccsr_in(REG_DCP_CFG(portal));
+	dcp_cfg |= QM_SP_ENABLE_CEETM(sub_portal);
+	qm_ccsr_out(REG_DCP_CFG(portal), dcp_cfg);
+	return 0;
+}
+EXPORT_SYMBOL_GPL(qman_sp_enable_ceetm_mode);
+
+int qman_sp_disable_ceetm_mode(enum qm_dc_portal portal, u16 sub_portal)
+{
+	u32 dcp_cfg;
+
+	if (!qm_ccsr_start)
+		return -ENODEV;
+	dcp_cfg = qm_ccsr_in(REG_DCP_CFG(portal));
+	dcp_cfg &= ~QM_SP_ENABLE_CEETM(sub_portal);
+	qm_ccsr_out(REG_DCP_CFG(portal), dcp_cfg);
+	return 0;
+}
+EXPORT_SYMBOL_GPL(qman_sp_disable_ceetm_mode);
