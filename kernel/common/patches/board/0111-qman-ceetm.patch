+
+	q.cid = cpu_to_be16(cid);
+	q.dcpid = dcpid;
+	return qman_ceetm_mc_exec(QM_CEETM_VERB_MAPPING_SHAPER_TCFC_QUERY, &q,
+				  sizeof(q), res, sizeof(*res));
+}
