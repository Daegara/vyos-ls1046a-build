+
+/*
+ * Generic CEETM management-command transport (implemented in qman.c). Issues
+ * the command body @cmd (@cmd_len bytes, written after the verb byte) on the
+ * affine software portal with verb @verb, waits for completion, validates the
+ * response verb and result code, and copies @rsp_len bytes of the response
+ * out to @rsp. Returns 0, -ETIMEDOUT or -EIO.
+ */
+int qman_ceetm_mc_exec(u8 verb, const void *cmd, size_t cmd_len,
+		       void *rsp, size_t rsp_len);
diff --git a/include/soc/fsl/qman.h b/include/soc/fsl/qman.h
index 7f7a493..10ef43e 100644
--- a/include/soc/fsl/qman.h
+++ b/include/soc/fsl/qman.h
@@ -33,6 +33,7 @@
 
 #include <linux/bitops.h>
 #include <linux/device.h>
+#include <linux/list.h>
 
 /* Hardware constants */
 #define QM_CHANNEL_SWPORTAL0 0
@@ -1256,4 +1257,521 @@ void qman_portal_get_iperiod(struct qman_portal *portal, u32 *iperiod);
  */
 int qman_portal_set_iperiod(struct qman_portal *portal, u32 iperiod);
 
+
+/* ----------------------------------------------------------------------
+ * CEETM (Customer Edge Egress Traffic Management) public API
+ *
+ * Hierarchical egress traffic management for the QorIQ DPAA1 FMan datapath:
+ * sub-portals (SP) feed logical network interfaces (LNI) feed class-queue
+ * channels; each channel hosts up to 8 strict-priority class queues (CQ), and
+ * frames are enqueued via logical frame queues (LFQ). LNIs and channels carry
+ * dual-rate (commit/excess) shapers; class congestion groups (CCG) provide
+ * tail-drop. Available only when CONFIG_FSL_QMAN_CEETM is enabled.
+ * ---------------------------------------------------------------------- */
+
+/* Direct-connect (FMan) portal index */
+enum qm_dc_portal {
+	qm_dc_portal_fman0 = 0,
+	qm_dc_portal_fman1 = 1,
+};
+
+/* Flag for the statistics accessors: also reset the counter after reading */
+#define QMAN_CEETM_FLAG_CLEAR_STATISTICS_COUNTER	0x1
+
+/* 'we_mask' bits for qman_ceetm_ccg_set(): select which CCG attrs to write */
+#define QM_CCGR_WE_MODE		0x0001	/* mode (bytes/frames) */
+#define QM_CCGR_WE_CS_THRES_IN	0x0002	/* congestion-state entry threshold */
+#define QM_CCGR_WE_TD_EN	0x0004	/* tail-drop enable */
+#define QM_CCGR_WE_CSCN_TUPD	0x0008	/* CSCN target update */
+#define QM_CCGR_WE_CSCN_EN	0x0010	/* congestion notification enable */
+#define QM_CCGR_WE_WR_EN_R	0x0020	/* WRED enable - red */
+#define QM_CCGR_WE_WR_EN_Y	0x0040	/* WRED enable - yellow */
+#define QM_CCGR_WE_WR_EN_G	0x0080	/* WRED enable - green */
+#define QM_CCGR_WE_WR_PARM_R	0x0100	/* WRED parameters - red */
+#define QM_CCGR_WE_WR_PARM_Y	0x0200	/* WRED parameters - yellow */
+#define QM_CCGR_WE_WR_PARM_G	0x0400	/* WRED parameters - green */
+#define QM_CCGR_WE_OAL		0x0800	/* overhead accounting length */
+#define QM_CCGR_WE_CS_THRES_OUT	0x1000	/* congestion-state exit threshold */
+#define QM_CCGR_WE_TD_THRES	0x2000	/* tail-drop threshold */
+#define QM_CCGR_WE_TD_MODE	0x4000	/* tail-drop mode (state/threshold) */
+#define QM_CCGR_WE_CDV		0x8000	/* cdv */
+
+/**
+ * struct qm_ceetm_rate - CEETM shaper token rate
+ * @whole: integer part of the token rate (0..2047)
+ * @fraction: fractional part in units of 1/8192 (0..8191)
+ *
+ * Represents a rate as the 11.13 fixed-point value whole + fraction/8192.
+ */
+struct qm_ceetm_rate {
+	u16 whole;
+	u16 fraction;
+};
+
+/* CEETM sub-portal */
+struct qm_ceetm_sp {
+	unsigned int idx;
+	unsigned int dcp_idx;
+	int is_claimed;
+	struct qm_ceetm_lni *lni;
+};
+
+/* CEETM logical network interface */
+struct qm_ceetm_lni {
+	unsigned int idx;
+	unsigned int dcp_idx;
+	int is_claimed;
+	struct qm_ceetm_sp *sp;
+	struct list_head channels;
+	int shaper_enable;
+	int shaper_couple;
+	int oal;
+	struct qm_ceetm_rate cr_token_rate;
+	struct qm_ceetm_rate er_token_rate;
+	u16 cr_token_bucket_limit;
+	u16 er_token_bucket_limit;
+};
+
+/* CEETM class-queue channel */
+struct qm_ceetm_channel {
+	struct list_head node;
+	unsigned int idx;
+	unsigned int lni_idx;
+	unsigned int dcp_idx;
+	struct list_head class_queues;
+	struct list_head ccgs;
+	u8 shaper_enable;
+	u8 shaper_couple;
+	struct qm_ceetm_rate cr_token_rate;
+	struct qm_ceetm_rate er_token_rate;
+	u16 cr_token_bucket_limit;
+	u16 er_token_bucket_limit;
+};
+
+/* CEETM class congestion group */
+struct qm_ceetm_ccg {
+	struct qm_ceetm_channel *parent;
+	struct list_head node;
+	unsigned int idx;
+};
+
+/* CEETM class queue */
+struct qm_ceetm_cq {
+	struct qm_ceetm_channel *parent;
+	struct qm_ceetm_ccg *ccg;
+	struct list_head node;
+	unsigned int idx;
+	int is_claimed;
+	struct list_head bound_lfqids;
+};
+
+/* CEETM logical frame queue */
+struct qm_ceetm_lfq {
+	struct qm_ceetm_channel *parent;
+	struct list_head node;
+	unsigned int idx;
+	unsigned int dctidx;
+	u64 context_a;
+	u32 context_b;
+	qman_cb_mr ern;
+};
+
+/**
+ * struct qm_ceetm_ccg_params - CEETM class congestion group parameters
+ * @mode: 0 = count bytes, 1 = count frames
+ * @td_en: enable tail-drop
+ * @td_mode: 0 = tail-drop on congestion-state, 1 = on threshold
+ * @cscn_en: enable congestion-state-change notifications (not wired in v1)
+ * @wr_en_g: enable WRED rejections, green
+ * @wr_en_y: enable WRED rejections, yellow
+ * @wr_en_r: enable WRED rejections, red
+ * @td_thres: tail-drop threshold (see qm_cgr_cs_thres_set64())
+ * @cs_thres_in: congestion-state entry threshold
+ * @cs_thres_out: congestion-state exit threshold
+ * @oal: overhead accounting length, signed per-packet "tax"
+ * @wr_parm_g: WRED parameters, green
+ * @wr_parm_y: WRED parameters, yellow
+ * @wr_parm_r: WRED parameters, red
+ */
+struct qm_ceetm_ccg_params {
+	u8 mode:1;
+	u8 td_en:1;
+	u8 td_mode:1;
+	u8 cscn_en:1;
+	u8 wr_en_g:1;
+	u8 wr_en_y:1;
+	u8 wr_en_r:1;
+	struct qm_cgr_cs_thres td_thres;
+	struct qm_cgr_cs_thres cs_thres_in;
+	struct qm_cgr_cs_thres cs_thres_out;
+	signed char oal;
+	struct qm_cgr_wr_parm wr_parm_g;
+	struct qm_cgr_wr_parm wr_parm_y;
+	struct qm_cgr_wr_parm wr_parm_r;
+};
+
+/**
+ * qman_ceetm_bps2tokenrate - convert a bit-rate to a CEETM token rate
+ * @bps: desired shaper rate in bits-per-second
+ * @token_rate: output token rate
+ * @rounding: <0 round down, >0 round up, 0 round to nearest
+ *
+ * Return: 0 on success, -EINVAL if the prescaler/QMan clock is unavailable.
+ */
+int qman_ceetm_bps2tokenrate(u64 bps, struct qm_ceetm_rate *token_rate,
+			     u16 rounding);
+
+/**
+ * qman_ceetm_tokenrate2bps - convert a CEETM token rate to a bit-rate
+ * @token_rate: input token rate
+ * @bps: output rate in bits-per-second
+ * @rounding: <0 round down, >0 round up, 0 round to nearest
+ *
+ * Return: 0 on success, -EINVAL if the prescaler/QMan clock is unavailable.
+ */
+int qman_ceetm_tokenrate2bps(const struct qm_ceetm_rate *token_rate, u64 *bps,
+			     u16 rounding);
+
+/**
+ * qman_ceetm_sp_claim - claim a CEETM sub-portal by index
+ * @sp: output sub-portal object
+ * @dcp_idx: direct-connect portal (qm_dc_portal_fman0 on LS1046A)
+ * @sp_idx: sub-portal index (0..15)
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_sp_claim(struct qm_ceetm_sp **sp, enum qm_dc_portal dcp_idx,
+			unsigned int sp_idx);
+
+/**
+ * qman_ceetm_sp_release - release a CEETM sub-portal
+ * @sp: the sub-portal to release
+ *
+ * Return: 0 on success, -EBUSY if a mapped LNI is still claimed.
+ */
+int qman_ceetm_sp_release(struct qm_ceetm_sp *sp);
+
+/**
+ * qman_ceetm_lni_claim - claim a CEETM logical network interface by index
+ * @lni: output LNI object
+ * @dcp_idx: direct-connect portal
+ * @lni_idx: LNI index (0..7)
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_lni_claim(struct qm_ceetm_lni **lni, enum qm_dc_portal dcp_idx,
+			 unsigned int lni_idx);
+
+/**
+ * qman_ceetm_lni_release - release a CEETM LNI
+ * @lni: the LNI to release
+ *
+ * Return: 0 on success, -EBUSY if channels are still attached.
+ */
+int qman_ceetm_lni_release(struct qm_ceetm_lni *lni);
+
+/**
+ * qman_ceetm_sp_set_lni - map a sub-portal to an LNI and enable CEETM mode
+ * @sp: the sub-portal
+ * @lni: the LNI to map it to
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_sp_set_lni(struct qm_ceetm_sp *sp, struct qm_ceetm_lni *lni);
+
+/**
+ * qman_ceetm_lni_enable_shaper - enable the LNI dual-rate shaper
+ * @lni: the LNI
+ * @coupled: non-zero to couple excess-rate credit to the commit bucket
+ * @oal: overhead accounting length
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_lni_enable_shaper(struct qm_ceetm_lni *lni, int coupled,
+				 int oal);
+
+/**
+ * qman_ceetm_lni_disable_shaper - disable the LNI shaper
+ * @lni: the LNI
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_lni_disable_shaper(struct qm_ceetm_lni *lni);
+
+/**
+ * qman_ceetm_lni_set_commit_rate_bps - set the LNI commit (CR) rate
+ * @lni: the LNI
+ * @bps: commit rate in bits-per-second
+ * @max_burst_size: commit token-bucket limit
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_lni_set_commit_rate_bps(struct qm_ceetm_lni *lni, u64 bps,
+				       u16 max_burst_size);
+
+/**
+ * qman_ceetm_lni_set_excess_rate_bps - set the LNI excess (ER) rate
+ * @lni: the LNI
+ * @bps: excess rate in bits-per-second
+ * @max_burst_size: excess token-bucket limit
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_lni_set_excess_rate_bps(struct qm_ceetm_lni *lni, u64 bps,
+				       u16 max_burst_size);
+
+/**
+ * qman_ceetm_channel_claim - claim a class-queue channel under an LNI
+ * @channel: output channel object
+ * @lni: the parent LNI
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_channel_claim(struct qm_ceetm_channel **channel,
+			     struct qm_ceetm_lni *lni);
+
+/**
+ * qman_ceetm_channel_release - release a class-queue channel
+ * @channel: the channel to release
+ *
+ * Return: 0 on success, -EBUSY if CQs or CCGs are still attached.
+ */
+int qman_ceetm_channel_release(struct qm_ceetm_channel *channel);
+
+/**
+ * qman_ceetm_channel_enable_shaper - enable the channel dual-rate shaper
+ * @channel: the channel
+ * @coupled: non-zero to couple excess-rate credit to the commit bucket
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_channel_enable_shaper(struct qm_ceetm_channel *channel,
+				     int coupled);
+
+/**
+ * qman_ceetm_channel_disable_shaper - disable the channel shaper
+ * @channel: the channel
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_channel_disable_shaper(struct qm_ceetm_channel *channel);
+
+/**
+ * qman_ceetm_channel_set_commit_rate_bps - set the channel commit (CR) rate
+ * @channel: the channel
+ * @bps: commit rate in bits-per-second
+ * @max_burst_size: commit token-bucket limit
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_channel_set_commit_rate_bps(struct qm_ceetm_channel *channel,
+					   u64 bps, u16 max_burst_size);
+
+/**
+ * qman_ceetm_channel_set_excess_rate_bps - set the channel excess (ER) rate
+ * @channel: the channel
+ * @bps: excess rate in bits-per-second
+ * @max_burst_size: excess token-bucket limit
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_channel_set_excess_rate_bps(struct qm_ceetm_channel *channel,
+					   u64 bps, u16 max_burst_size);
+
+/**
+ * qman_ceetm_channel_set_weight - set the uFQ weight of an unshaped channel
+ * @channel: the unshaped channel
+ * @token_limit: the weight, expressed as a CR token bucket limit (bytes)
+ *
+ * Unshaped channels compete in the LNI's unshaped fair-queuing (uFQ)
+ * algorithm using the CR token bucket limit as their weight. Must be
+ * non-zero or the channel is never scheduled. Returns -EINVAL if the
+ * channel has its shaper enabled.
+ */
+int qman_ceetm_channel_set_weight(struct qm_ceetm_channel *channel,
+				  u16 token_limit);
+
+/**
+ * qman_ceetm_channel_set_cq_cr_eligibility - set CQ commit-rate eligibility
+ * @channel: the channel
+ * @cq_level: class-queue level (0..7)
+ * @set: non-zero to make the CQ eligible for commit-rate scheduling
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_channel_set_cq_cr_eligibility(struct qm_ceetm_channel *channel,
+					     unsigned int cq_level, int set);
+
+/**
+ * qman_ceetm_channel_set_cq_er_eligibility - set CQ excess-rate eligibility
+ * @channel: the channel
+ * @cq_level: class-queue level (0..7)
+ * @set: non-zero to make the CQ eligible for excess-rate scheduling
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_channel_set_cq_er_eligibility(struct qm_ceetm_channel *channel,
+					     unsigned int cq_level, int set);
+
+/**
+ * qman_ceetm_cq_claim - claim a strict-priority class queue
+ * @cq: output class-queue object
+ * @channel: the parent channel
+ * @idx: class-queue index (0..7, strict priority)
+ * @ccg: optional class congestion group to bind, or NULL
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_cq_claim(struct qm_ceetm_cq **cq,
+			struct qm_ceetm_channel *channel, unsigned int idx,
+			struct qm_ceetm_ccg *ccg);
+
+/**
+ * qman_ceetm_cq_release - release a class queue (drains it first)
+ * @cq: the class queue to release
+ *
+ * Return: 0 on success, -EBUSY if LFQIDs are still bound.
+ */
+int qman_ceetm_cq_release(struct qm_ceetm_cq *cq);
+
+/**
+ * qman_ceetm_drain_cq - drain all frames from a class queue
+ * @cq: the class queue
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_drain_cq(struct qm_ceetm_cq *cq);
+
+/**
+ * qman_ceetm_cq_get_dequeue_statistics - read CQ dequeue counters
+ * @cq: the class queue
+ * @flags: QMAN_CEETM_FLAG_CLEAR_STATISTICS_COUNTER to clear after read
+ * @frame_count: output dequeued frame count
+ * @byte_count: output dequeued byte count
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_cq_get_dequeue_statistics(struct qm_ceetm_cq *cq, u32 flags,
+					 u64 *frame_count, u64 *byte_count);
+
+/**
+ * qman_ceetm_ccg_claim - claim a class congestion group
+ * @ccg: output CCG object
+ * @channel: the parent channel
+ * @idx: CCG index (0..15)
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_ccg_claim(struct qm_ceetm_ccg **ccg,
+			 struct qm_ceetm_channel *channel, unsigned int idx);
+
+/**
+ * qman_ceetm_ccg_release - release a class congestion group
+ * @ccg: the CCG to release
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_ccg_release(struct qm_ceetm_ccg *ccg);
+
+/**
+ * qman_ceetm_ccg_set - configure a subset of CCG attributes
+ * @ccg: the CCG
+ * @we_mask: write-enable mask of QM_CCGR_WE_* bits
+ * @params: the attribute values
+ *
+ * Return: 0 on success, -EIO on command failure.
+ */
+int qman_ceetm_ccg_set(struct qm_ceetm_ccg *ccg, u16 we_mask,
+		       const struct qm_ceetm_ccg_params *params);
+
+/**
+ * qman_ceetm_ccg_get_reject_statistics - read CCG reject counters
+ * @ccg: the CCG
+ * @flags: QMAN_CEETM_FLAG_CLEAR_STATISTICS_COUNTER to clear after read
+ * @frame_count: output rejected frame count
+ * @byte_count: output rejected byte count
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_ccg_get_reject_statistics(struct qm_ceetm_ccg *ccg, u32 flags,
+					 u64 *frame_count, u64 *byte_count);
+
+/**
+ * qman_ceetm_lfq_claim - claim a logical frame queue on a class queue
+ * @lfq: output LFQ object
+ * @cq: the class queue to attach to
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_lfq_claim(struct qm_ceetm_lfq **lfq, struct qm_ceetm_cq *cq);
+
+/**
+ * qman_ceetm_lfq_release - release a logical frame queue
+ * @lfq: the LFQ to release
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_lfq_release(struct qm_ceetm_lfq *lfq);
+
+/**
+ * qman_ceetm_lfq_set_context - program the LFQ dequeue context (DCT)
+ * @lfq: the LFQ
+ * @context_a: 64-bit dequeue context A presented to the FMan
+ * @context_b: 32-bit dequeue context B
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_lfq_set_context(struct qm_ceetm_lfq *lfq, u64 context_a,
+			       u32 context_b);
+
+/**
+ * qman_ceetm_create_fq - bind a qman_fq to an LFQ for enqueue + ERN delivery
+ * @lfq: the logical frame queue
+ * @fq: the caller-provided frame-queue object to initialise
+ *
+ * Sets @fq up as an enqueue-only handle on the LFQ and registers it in the
+ * QMan ERN lookup table so that tail-drop rejections are delivered to
+ * @lfq->ern. Must be paired with qman_ceetm_destroy_fq() on teardown.
+ *
+ * Return: 0 on success or a negative errno.
+ */
+int qman_ceetm_create_fq(struct qm_ceetm_lfq *lfq, struct qman_fq *fq);
+
+/**
+ * qman_ceetm_destroy_fq - tear down a qman_fq created by qman_ceetm_create_fq
+ * @fq: the frame-queue object
+ *
+ * Removes @fq from the ERN lookup table and frees its lookup slot. Call after
+ * qman_ceetm_lfq_release() and before freeing @fq's storage.
+ */
+void qman_ceetm_destroy_fq(struct qman_fq *fq);
+
+/* CCSR-level CEETM helpers (implemented in qman_ccsr.c) */
+
+/**
+ * qman_ceetm_set_prescaler - program the CEETM credit-update prescaler
+ * @portal: direct-connect portal
+ *
+ * Return: 0 on success, -ENODEV if the CCSR map is unavailable.
+ */
+int qman_ceetm_set_prescaler(enum qm_dc_portal portal);
+
+/**
+ * qman_sp_enable_ceetm_mode - enable CEETM mode for a sub-portal
+ * @portal: direct-connect portal
+ * @sub_portal: sub-portal index
+ *
+ * Return: 0 on success, -ENODEV if the CCSR map is unavailable.
+ */
+int qman_sp_enable_ceetm_mode(enum qm_dc_portal portal, u16 sub_portal);
+
+/**
+ * qman_sp_disable_ceetm_mode - disable CEETM mode for a sub-portal
+ * @portal: direct-connect portal
+ * @sub_portal: sub-portal index
+ *
+ * Return: 0 on success, -ENODEV if the CCSR map is unavailable.
+ */
+int qman_sp_disable_ceetm_mode(enum qm_dc_portal portal, u16 sub_portal);
+
 #endif	/* __FSL_QMAN_H */
