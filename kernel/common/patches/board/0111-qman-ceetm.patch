+/*
+ * CEETM management-command transport. CEETM management commands (verbs
+ * 0x70-0x7D) ride the existing affine-portal MC ring. This is the single
+ * entry point used by all CEETM object code in qman_ceetm.c; that file never
+ * touches portal internals directly.
+ */
+int qman_ceetm_mc_exec(u8 verb, const void *cmd, size_t cmd_len,
+		       void *rsp, size_t rsp_len)
+{
+	struct qman_portal *p;
+	union qm_mc_command *mcc;
+	union qm_mc_result *mcr;
+	unsigned long irqflags;
+	int ret = 0;
+
+	if (cmd_len > sizeof(*mcc) - 1 || rsp_len > sizeof(*mcr))
+		return -EINVAL;
+
+	p = get_affine_portal();
+	local_irq_save(irqflags);
+	mcc = qm_mc_start(&p->p);
+	/* The command body follows the verb byte (byte 0) of the MC entry */
+	if (cmd && cmd_len)
+		memcpy((u8 *)mcc + 1, cmd, cmd_len);
+	qm_mc_commit(&p->p, verb);
+	if (!qm_mc_result_timeout(&p->p, &mcr)) {
+		ret = -ETIMEDOUT;
+		goto out;
+	}
+	if ((mcr->verb & QM_MCR_VERB_MASK) != verb ||
+	    mcr->result != QM_MCR_RESULT_OK) {
+		ret = -EIO;
+		goto out;
+	}
+	if (rsp && rsp_len)
+		memcpy(rsp, mcr, rsp_len);
+out:
+	local_irq_restore(irqflags);
+	put_affine_portal();
+	return ret;
+}
+EXPORT_SYMBOL_GPL(qman_ceetm_mc_exec);
+
+/*
+ * qman_ceetm_create_fq - bind a qman_fq to a CEETM logical frame queue.
+ *
+ * ERN delivery for CEETM:
+ *   CEETM FQs have no FQD; their dequeue context lives in the DCT (set via
+ *   qman_ceetm_lfq_set_context()). The DCT context_b is the *FMan* dequeue
+ *   context, NOT the ERN routing tag. ERN routing on the software portal works
+ *   exactly like for ordinary FQs: qman_enqueue() stamps the EQCR entry tag
+ *   with fq_to_tag(fq) (== fq->idx), and a tail-drop rejection comes back as a
+ *   software ERN whose ern.tag carries that same value, which the MR handler
+ *   resolves with tag_to_fq() -> fq_table[tag]. So all that is required for
+ *   correct ERN delivery is to register @fq in fq_table at a valid fq->idx.
+ *
+ *   fq_table is indexed by fqid*2 and sized for the regular FQID range. CEETM
+ *   LFQIDs (0xF00000+) would index far past the table, so we reserve a dynamic
+ *   FQID purely to obtain an in-range, collision-free lookup slot
+ *   (fq->idx = fqid*2 + 1, the NO_MODIFY/odd slot). fq->fqid keeps the real
+ *   LFQID, which is what qm_fqid_set() programs into the enqueue ring entry.
+ */
+int qman_ceetm_create_fq(struct qm_ceetm_lfq *lfq, struct qman_fq *fq)
+{
+	u32 fqid;
+	int ret;
+
+	fq->fqid = lfq->idx;
+	fq->flags = QMAN_FQ_FLAG_NO_MODIFY;
+	fq->state = qman_fq_state_oos;
+	fq->cgr_groupid = 0;
+	if (lfq->ern)
+		fq->cb.ern = lfq->ern;
+
+	ret = qman_alloc_fqid(&fqid);
+	if (ret)
+		return ret;
+	fq->idx = fqid * 2 + 1;
+	if (WARN_ON(fq_table[fq->idx])) {
+		qman_release_fqid(fqid);
+		return -EBUSY;
+	}
+	fq_table[fq->idx] = fq;
+	return 0;
+}
+EXPORT_SYMBOL_GPL(qman_ceetm_create_fq);
+
+void qman_ceetm_destroy_fq(struct qman_fq *fq)
+{
+	u32 fqid = fq->idx >> 1;
+
+	fq_table[fq->idx] = NULL;
+	/* clear the table slot before releasing the fqid (see qman_destroy_fq) */
+	smp_wmb();
+	qman_release_fqid(fqid);
+	fq->idx = 0;
+}
+EXPORT_SYMBOL_GPL(qman_ceetm_destroy_fq);
+
