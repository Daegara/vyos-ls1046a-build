+			 unsigned int lni_idx)
+{
+	struct qm_ceetm_lni *p;
+	int ret;
+
+	if (dcp_idx != qm_dc_portal_fman0)
+		return -EINVAL;
+
+	ret = ceetm_bitmap_claim(ceetm_lni_map, CEETM_NR_LNIS, lni_idx);
+	if (ret) {
+		pr_err("CEETM: LNI %u not available\n", lni_idx);
+		return ret;
