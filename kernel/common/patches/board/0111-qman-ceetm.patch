+/* ----------------------------------------------------------------------
+ * CEETM (Customer Edge Egress Traffic Management) - internal definitions
+ *
+ * Management-command verbs, wire-format command/response structures and the
+ * generic transport helper used by qman_ceetm.c. These are private to the
+ * driver; the public CEETM object API lives in <soc/fsl/qman.h>.
+ *
+ * The SDK originals (NXP fsl_qman.h) used big/little-endian #ifdef bitfield
+ * pairs; here every multi-byte field is an explicit __beN value and every
+ * sub-32-bit packed field (lfqid:24, crtcr:24, frm_cnt:40, byte_cnt:48, ...)
+ * is a raw big-endian byte array, so the wire layout is byte-exact and
+ * endian-portable without compiler bitfield-ordering assumptions.
+ * ---------------------------------------------------------------------- */
+
+/* See "1.5.9.7 CEETM Management Commands" */
+#define QM_CEETM_VERB_LFQMT_CONFIG			0x70
+#define QM_CEETM_VERB_LFQMT_QUERY			0x71
+#define QM_CEETM_VERB_CQ_CONFIG				0x72
+#define QM_CEETM_VERB_CQ_QUERY				0x73
+#define QM_CEETM_VERB_DCT_CONFIG			0x74
+#define QM_CEETM_VERB_DCT_QUERY				0x75
+#define QM_CEETM_VERB_CLASS_SCHEDULER_CONFIG		0x76
+#define QM_CEETM_VERB_CLASS_SCHEDULER_QUERY		0x77
+#define QM_CEETM_VERB_MAPPING_SHAPER_TCFC_CONFIG	0x78
+#define QM_CEETM_VERB_MAPPING_SHAPER_TCFC_QUERY		0x79
+#define QM_CEETM_VERB_CCGR_CONFIG			0x7A
+#define QM_CEETM_VERB_CCGR_QUERY			0x7B
+#define QM_CEETM_VERB_CQ_PEEK_POP_XFDRREAD		0x7C
+#define QM_CEETM_VERB_STATISTICS_QUERY_WRITE		0x7D
+
+/* mapping/shaper/tcfc command-id selectors (top bits of 'cid') */
+#define CEETM_COMMAND_CHANNEL_MAPPING	(0 << 12)
+#define CEETM_COMMAND_SP_MAPPING	(1 << 12)
+#define CEETM_COMMAND_CHANNEL_SHAPER	(2 << 12)
+#define CEETM_COMMAND_LNI_SHAPER	(3 << 12)
+#define CEETM_COMMAND_TCFC		(4 << 12)
+
+/* ccgr command-id selector (top bits of 'ccgrid') */
+#define CEETM_CCGR_CM_CONFIGURE		(0 << 14)
+
+/* channel/sp mapping control byte */
+#define CEETM_MAP_SHAPED	0x80
+#define CEETM_MAP_LNI_ID_MASK	0x07
+
+/* shaper control byte: cpl(bit7), oal(bits4-0) */
+#define CEETM_SHAPER_CPL	0x80
+#define CEETM_SHAPER_OAL_MASK	0x1f
+
+/* ccgr cm_config control byte */
+#define CEETM_CCGR_CTL_MODE	0x01
+#define CEETM_CCGR_CTL_CSCN_EN	0x02
+#define CEETM_CCGR_CTL_TD_MODE	0x04
+#define CEETM_CCGR_CTL_TD_EN	0x08
+#define CEETM_CCGR_CTL_WR_EN_R	0x10
+#define CEETM_CCGR_CTL_WR_EN_Y	0x20
+#define CEETM_CCGR_CTL_WR_EN_G	0x40
+
+/* class-scheduler eligibility-mask bit for CQ 'n' */
+#define CQ_ELIGIBILITY_SET(n)	(1 << (7 - (n)))
+
+/* statistics_query_write command types */
+#define CEETM_QUERY_DEQUEUE_STATISTICS		0x00
+#define CEETM_QUERY_DEQUEUE_CLEAR_STATISTICS	0x01
+#define CEETM_QUERY_REJECT_STATISTICS		0x03
+#define CEETM_QUERY_REJECT_CLEAR_STATISTICS	0x04
+
+/*
+ * CEETM management-command bodies. These describe bytes 1..63 of the 64-byte
+ * MC command entry (byte 0 is the verb, written by the transport helper), so
+ * each is exactly 63 bytes.
+ */
+struct qm_mcc_ceetm_lfqmt_config {
+	u8 __reserved1[4];
+	u8 lfqid[3];		/* 24-bit big-endian */
+	u8 __reserved2[2];
+	__be16 cqid;
+	u8 __reserved3[2];
+	__be16 dctidx;
+	u8 __reserved4[48];
+} __packed;
+
+struct qm_mcc_ceetm_lfqmt_query {
+	u8 __reserved1[4];
+	u8 lfqid[3];
+	u8 __reserved2[56];
+} __packed;
+
+struct qm_mcc_ceetm_cq_config {
+	u8 __reserved1;
+	__be16 cqid;
+	u8 dcpid;
+	u8 __reserved2;
+	__be16 ccgid;
+	u8 __reserved3[56];
+} __packed;
+
+struct qm_mcc_ceetm_dct_config {
+	u8 __reserved1;
+	__be16 dctidx;
+	u8 dcpid;
+	u8 __reserved2[15];
+	__be32 context_b;
+	__be64 context_a;
+	u8 __reserved3[32];
