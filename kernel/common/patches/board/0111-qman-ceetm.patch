+
+struct qm_mcc_ceetm_class_scheduler_config {
+	u8 __reserved1;
+	__be16 cqcid;
+	u8 dcpid;
+	u8 __reserved2[6];
+	u8 gpc;			/* gpc_combine_flag(0x40)|prio_b(0x38)|prio_a(0x07) */
+	__be16 crem;
+	__be16 erem;
