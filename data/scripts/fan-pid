#!/usr/bin/env python3
"""
fan-pid — PID-based EMC2305 fan controller for the LS1046A Mono Gateway DK.

Replaces the stock `fancontrol` linear-curve daemon with a multi-zone PID loop
that drives the EMC2305 PWM from the *hottest* of the SoC's five thermal zones
(ddr, serdes, fman, cluster, sec) plus an EMA filter on the fan tachometer.

Why PID instead of fancontrol's linear ramp?
  - smoother PWM trajectory  -> lower acoustic noise band crossings (~80 PWM)
  - longer fan-bearing life   -> fewer step changes
  - per-zone setpoints        -> SerDes/FMan/SEC get their own dT and target
  - explicit safety ladder    -> hard MAXPWM at any zone >= ZONE.crit_temp,
                                  hard FAULT log if any zone reaches 100 C

Why a single Python file?
  - same idiom as the existing fancontrol-setup.sh / sfp-check / ask-conntrack-fix
  - no extra runtime deps (Python 3 + sysfs already shipped in VyOS)
  - one systemd unit, one config block at the top, no dotfiles

Hardware refs (LS1046A RM, AGENTS.md):
  EMC2305 at i2c-7 addr 0x2e (hwmon by name, NOT by number — index drifts)
  Cortex-A72 cluster T_J,throttle = 95 C, T_J,max = 105 C
  Stock DC-axial fan kick-start floor = PWM 39 (1044 RPM); PWM 38 stalls.
    Daemon enforces PWM_MIN_RUN=40 with 1-PWM margin → 1020 RPM at idle.
    The chip itself honors arbitrary 0..255 values via /dev/i2c — the floor
    is the FAN's, not the silicon's. (Earlier "EMC2305 quantizes at 51"
    lore was actually a kernel 6.18 sysfs driver bug; see the
    EMC2305_I2C_ADDR comment block.)
  Mono Gateway has hardware inverter on TX_DISABLE (irrelevant here, noted only
    so future GPIO-related fan-fault designs don't repeat the misdiagnosis logged
    in qdrant under "SFP+ misdiagnosis log").

Algorithm summary:
  Every TICK seconds:
    1. Read all 5 thermal zones.  If any is unreadable, retain previous value
       (sysfs reads under thermal-poll contention can transiently fail).
    2. For each zone, compute error = T - setpoint.  Run a per-zone PI
       controller: PWM_i = clamp(MIN_PWM, MAX_PWM, PWM_floor + Kp*err + Ki*sum_err).
       Anti-windup: clamp the integral term to +/- (MAX_PWM - PWM_floor) / Ki.
    3. Final PWM = max( PWM_i for all zones ).  This is the protective max-policy:
       any zone individually demanding more cooling wins.
    4. Hard ceiling: if ANY zone >= crit_temp, force PWM = MAX_PWM.  Anti-windup
       reset on all zones to prevent overshoot when temps drop again.
    5. Hard fault: if ANY zone >= 100 C, syslog at LOG_CRIT and force PWM = 255
       (silicon damage threshold).  Continue running.
    6. EMA-smooth the final PWM (alpha = EMA_ALPHA) before writing to sysfs to
       avoid sub-tick jitter ringing the fan around the audible 80-PWM band.
    7. Write final PWM if it changed by >= PWM_DEADBAND.  Reduces sysfs traffic
       and EMC2305 register churn.
    8. Log every LOG_INTERVAL seconds: per-zone temp, per-zone PWM, final PWM,
       fan RPM.  At LOG_LEVEL=DEBUG, log every tick.

Tuning rationale (Kp / Ki / setpoints) — see code constants below.

ExecStart contract: runs in foreground, writes stderr to journald.  SIGTERM
clean-shutdown: leaves PWM at MAX_PWM (255) so a daemon crash doesn't silently
suffocate the SoC.  Use `systemctl stop fan-pid` only when you intend to stop
managing the fan; it will go to full speed.
"""
from __future__ import annotations

import errno
import fcntl
import os
import re
import signal
import sys
import syslog
import time
from dataclasses import dataclass, field
from typing import Optional


# ---------- Tuning constants -----------------------------------------------------
# Per-zone controller parameters.  Setpoints picked from LS1046A RM and AGENTS.md
# field experience:
#   ddr (commercial-grade DDR4):      derate above 85 C, conservative target 65
#   serdes (10G PCS, hot under load): T_J,max 105, target 70 with extra headroom
#   fman (microcode RAM hot-spot):    T_J,max 105, target 70 (FMan is the hottest
#                                      die area when forwarding @ 10 Gbps)
#   cluster (A72 quad):               throttle 95, target 65 to leave 30 C burst headroom
#   sec (CAAM JR):                    T_J,max 105, target 65 under sustained IPsec
#
# Setpoint = "the temperature we want this zone to hold under steady-state load".
# Crit_temp = "if exceeded, force MAX_PWM regardless of PI state" (5 C below the
#             throttle/derate point so we still have margin for transient spikes).
#
# Kp and Ki are PWM-units per degree-C error.  Tuned for the EMC2305 + small
# DC-axial fan time constant (fan: ~3 s rise from MIN to MAX duty; SoC zones:
# 2 s for serdes/fman, 5 s for cluster/sec, ~30 s for ddr).
#
# Why per-zone Kp/Ki instead of one shared loop?
#   - Different time constants need different gains.  A single Ki tuned for ddr
#     (slow) would cause cluster (fast) to oscillate.  A single Ki tuned for
#     cluster would windup before ddr ever moved.
#   - Per-zone integrals also allow each zone to "settle into" its own quiet
#     PWM without dragging the others along.
@dataclass
class Zone:
    name: str            # /sys/class/thermal/thermal_zone*/type string
    setpoint: float      # target temp (C)
    crit_temp: float     # if T >= crit, force MAX_PWM
    kp: float            # proportional gain (PWM per C)
    ki: float            # integral gain (PWM per (C * tick))
    # runtime state
    last_temp: float = 0.0
    integral: float = 0.0
    last_pwm: float = 0.0


ZONES = [
    Zone("ddr-thermal",     setpoint=65.0, crit_temp=80.0, kp=4.0,  ki=0.20),
    Zone("serdes-thermal",  setpoint=70.0, crit_temp=85.0, kp=6.0,  ki=0.30),
    Zone("fman-thermal",    setpoint=70.0, crit_temp=87.0, kp=6.0,  ki=0.30),
    Zone("cluster-thermal", setpoint=65.0, crit_temp=85.0, kp=5.0,  ki=0.25),
    Zone("sec-thermal",     setpoint=65.0, crit_temp=85.0, kp=5.0,  ki=0.25),
]
# Aliases tolerated for thermal_zone "type" string differences across kernels.
# (mainline 6.18 uses "ddr-thermal"/"cluster-thermal", SDK 6.6 uses
#  "core_cluster" instead of "cluster-thermal".  Add as encountered.)
ZONE_ALIASES = {
    "cluster-thermal": ("core_cluster", "cluster_thermal"),
    "ddr-thermal":     ("ddr_thermal",),
    "fman-thermal":    ("fman_thermal",),
    "serdes-thermal":  ("serdes_thermal",),
    "sec-thermal":     ("sec_thermal",),
}

PWM_FLOOR    = 0     # PWM applied when all zones at/below setpoint
PWM_MIN_RUN  = 40    # Kick-start floor — empirically measured 2026-05-11
                     # on Mono Gateway DK with stock DC-axial fan: from a
                     # stopped state, PWM=39 is the lowest value that
                     # spins the fan up (1044 RPM); PWM=38 stays stalled.
                     # PWM=40 spins to 1020 RPM with 1-PWM margin against
                     # the kick-start knee. The previous lore that "the
                     # EMC2305 quantizes PWM at 51" was actually a kernel
                     # 6.18 sysfs driver bug — see the EMC2305_I2C_ADDR
                     # comment block — and was wrong about the silicon.
                     # The chip honors arbitrary 0..255 values when written
                     # over /dev/i2c. The stall floor is the FAN's, not the
                     # chip's. If you swap the fan to a different model,
                     # rerun the kick-start sweep and update this constant.
PWM_MAX      = 255   # full speed
PWM_DEADBAND = 3     # don't write to sysfs for changes smaller than this
EMA_ALPHA    = 0.4   # 0 = no smoothing, 1 = no history; 0.4 ~= 1.5 tick lag

TICK_SECONDS = 2.0   # control loop period
LOG_INTERVAL = 30.0  # seconds between INFO log lines (use DEBUG for every tick)

EMC2305_HWMON_NAME = "emc2305"
PWM_FILE  = "pwm1"
FAN_FILE  = "fan1_input"

# Direct-i2c bypass for the broken kernel emc2305 sysfs PWM path.
#
# Symptom (verified on kernel 6.18.28-vyos hwmon3 / i2c-7 0x2e on
# 2026-05-11): writing N to /sys/class/hwmon/hwmonN/pwm1 returns
# success and read-back returns N for ~1 second, then the sysfs read
# spontaneously reverts to 255, the chip's actual duty register
# (0x30) stays at 0xFF, and the fan stays at MAX RPM. The kernel
# emc2305 driver in 6.18 silently drops sub-MAX writes — the chip
# itself is in direct-PWM mode (FAN_CONFIG1 bit7=0, FSC disabled),
# so writing the duty register over /dev/i2c-7 with I2C_SLAVE_FORCE
# works perfectly: writing 51 to register 0x30 immediately drops
# fan RPM from ~8700 to ~1700. Therefore fan-pid bypasses sysfs
# entirely for PWM writes and goes straight to the chip via
# /dev/i2c-<bus> + I2C_SLAVE_FORCE.
#
# Tach reads are kept on the sysfs path because hwmon's
# fan1_input/fan2_input numbers are correct (and bypass would
# require us to reimplement the multi-byte tach-to-RPM conversion
# the kernel already does for free).
#
# Required: i2c-dev module loaded so /dev/i2c-* exists. The
# `lm-sensors` apt package would normally install
# /etc/modules-load.d/i2c-dev.conf; we don't ship lm-sensors, so
# `i2c-dev` is loaded explicitly via `modprobe` in this daemon
# (defensive — already auto-loads on most distros from the i2c-tools
# udev rule).
EMC2305_I2C_ADDR = 0x2e          # SMBus 7-bit address on i2c-7
EMC2305_FAN1_DUTY_REG = 0x30     # bit7..0 = direct PWM duty 0..255
EMC2305_FAN2_DUTY_REG = 0x40
I2C_SLAVE_FORCE = 0x0706         # ioctl: claim addr even if kernel driver bound

HARD_FAULT_TEMP = 100.0  # at/above this any zone triggers a CRIT log

# Boot whistle: audible attention-getter chirp played once at daemon startup
# so the operator can confirm the box has reached usable runtime state without
# needing a serial console or network to be up. Six pulses of (low, high,
# low, high…) at ~3 Hz make a recognisable "wheeeeu-wheeeeu" pattern that
# is distinct from any organic fan modulation under load.
# Mirrors the legacy boot-complete-notify.sh behavior (which has been
# absorbed into this daemon — single PWM owner, no race over /sys/.../pwm1).
WHISTLE_PULSES   = 6
WHISTLE_LOW_PWM  = 130   # ~50 % duty — soft tone
WHISTLE_HIGH_PWM = 255   # full speed — loud tone
WHISTLE_HALF_S   = 0.3   # seconds per half-cycle (low or high)


# ---------- sysfs helpers --------------------------------------------------------
def find_emc2305_pwm() -> tuple[str, str]:
    """Locate EMC2305 hwmon by name (numbers drift across boots).

    Returns (pwm_path, fan_input_path) both absolute.  pwm_path is kept
    only for legacy callers / introspection — actual PWM writes go via
    /dev/i2c (find_emc2305_i2c() below) because the kernel emc2305 sysfs
    PWM interface is broken on 6.18 (silently drops sub-MAX writes).
    Raises RuntimeError if EMC2305 not present (board not Mono Gateway DK,
    or i2c bus is broken).
    """
    for entry in sorted(os.listdir("/sys/class/hwmon")):
        if not entry.startswith("hwmon"):
            continue
        name_path = f"/sys/class/hwmon/{entry}/name"
        try:
            with open(name_path) as f:
                if f.read().strip() == EMC2305_HWMON_NAME:
                    pwm  = f"/sys/class/hwmon/{entry}/{PWM_FILE}"
                    fan  = f"/sys/class/hwmon/{entry}/{FAN_FILE}"
                    if not os.path.exists(pwm):
                        raise RuntimeError(f"{pwm} missing — wrong EMC2305 channel?")
                    return pwm, fan
        except OSError:
            continue
    raise RuntimeError("EMC2305 hwmon not found (no entry named 'emc2305')")


def find_emc2305_i2c() -> int:
    """Open /dev/i2c-<bus> for the EMC2305 and claim 0x2e with I2C_SLAVE_FORCE.

    Walks /sys/bus/i2c/devices/ for an entry of the form '<bus>-002e' bound to
    the emc2305 driver, opens the corresponding /dev/i2c-<bus> char device,
    and issues the I2C_SLAVE_FORCE ioctl so we can talk to the chip even
    though the kernel emc2305 driver also has it claimed (the FORCE variant
    of I2C_SLAVE permits this; the unforced variant returns EBUSY).

    Returns an open i2c bus fd. Caller must os.close() it on shutdown.
    Raises RuntimeError if no EMC2305 is bound to the i2c subsystem
    (would only happen on a board that lacks the chip).
    """
    rx = re.compile(r"^(\d+)-002e$")
    for entry in sorted(os.listdir("/sys/bus/i2c/devices")):
        m = rx.match(entry)
        if not m:
            continue
        bus = int(m.group(1))
        # Confirm it's actually an emc2305 (could be another chip at 0x2e
        # on a different board); read the symlinked driver name.
        drv = f"/sys/bus/i2c/devices/{entry}/driver"
        if os.path.islink(drv):
            target = os.path.basename(os.readlink(drv))
            if target != "emc2305":
                continue
        dev = f"/dev/i2c-{bus}"
        if not os.path.exists(dev):
            # i2c-dev module not loaded — best-effort modprobe.
            try:
                os.system("modprobe i2c-dev >/dev/null 2>&1")
            except Exception:
                pass
        if not os.path.exists(dev):
            raise RuntimeError(f"{dev} missing (i2c-dev module not loaded?)")
        fd = os.open(dev, os.O_RDWR)
        try:
            fcntl.ioctl(fd, I2C_SLAVE_FORCE, EMC2305_I2C_ADDR)
        except OSError:
            os.close(fd)
            raise
        return fd
    raise RuntimeError("No EMC2305 found on any i2c bus (no <bus>-002e entry under /sys/bus/i2c/devices)")


def i2c_write_pwm(i2c_fd: int, value: int) -> None:
    """Write `value` (0..255) to EMC2305 fan1 duty register 0x30.

    SMBus byte-data write: send two bytes (register, value). The kernel
    i2c char-dev does the SMBus-vs-i2c framing for us when called via
    plain os.write because the EMC2305 register protocol is "register
    address byte, then data byte" — identical to what os.write delivers.

    Errors are logged but NOT raised (a transient i2c NACK shouldn't kill
    the controller; we'll retry next tick).
    """
    try:
        os.write(i2c_fd, bytes([EMC2305_FAN1_DUTY_REG, value & 0xFF]))
    except OSError as e:
        syslog.syslog(syslog.LOG_WARNING, f"fan-pid: i2c write failed: {e}")


def find_thermal_zones() -> dict[str, str]:
    """Map zone canonical name -> /sys/class/thermal/thermal_zoneN/temp path.

    Honors ZONE_ALIASES so the same daemon binary works on mainline and SDK
    kernels without conditional code.  Missing zones are OK (logged once at
    startup) — the PI loop simply won't include them in max().
    """
    found: dict[str, str] = {}
    for entry in sorted(os.listdir("/sys/class/thermal")):
        if not entry.startswith("thermal_zone"):
            continue
        type_path = f"/sys/class/thermal/{entry}/type"
        temp_path = f"/sys/class/thermal/{entry}/temp"
        if not (os.path.exists(type_path) and os.path.exists(temp_path)):
            continue
        try:
            with open(type_path) as f:
                t = f.read().strip()
        except OSError:
            continue
        # Canonicalize against ZONES + ZONE_ALIASES.
        for z in ZONES:
            if t == z.name or t in ZONE_ALIASES.get(z.name, ()):
                found[z.name] = temp_path
                break
    return found


def read_temp(path: str) -> Optional[float]:
    """Read /sys/class/thermal/.../temp (millidegC) -> degC float, or None."""
    try:
        with open(path) as f:
            return int(f.read().strip()) / 1000.0
    except (OSError, ValueError):
        return None


def write_pwm(path: str, value: int) -> None:
    """Legacy sysfs-PWM write — KEPT FOR REFERENCE ONLY.

    DO NOT CALL FROM THE CONTROL LOOP. The kernel emc2305 driver in 6.18
    silently drops sub-MAX writes via this path (sysfs reports success,
    register 0x30 stays 0xFF, fan stays at MAX). Use i2c_write_pwm() with
    the fd returned by find_emc2305_i2c() instead.

    This stub is left so introspection / unit tests can still target the
    sysfs path if anyone wants to demonstrate the bug.
    """
    try:
        with open(path, "w") as f:
            f.write(str(value))
    except OSError as e:
        syslog.syslog(syslog.LOG_WARNING,
                      f"fan-pid: pwm write failed: {e}")


def read_fan_rpm(path: str) -> Optional[int]:
    try:
        with open(path) as f:
            return int(f.read().strip())
    except (OSError, ValueError):
        return None

def play_startup_whistle(i2c_fd: int) -> None:
    """One-shot audible boot-complete chirp: WHISTLE_PULSES * (low, high) pairs.

    Absorbed from the legacy /usr/local/bin/boot-complete-notify.sh so there is
    a single owner of the EMC2305 duty register (the systemd ordering between
    fan-pid and boot-complete-notify previously raced — fan-pid would step
    on the first pulse and the operator heard a half-chirp instead of the
    full pattern).

    Goes via the direct-i2c path for the same reason the control loop does:
    the kernel sysfs PWM interface on 6.18 silently drops sub-MAX writes, so
    a sysfs-driven whistle would only ever produce the HIGH (255) pulses
    audibly with no audible LOW transition (the LOW phase would silently
    stay at 255).

    Best-effort: any i2c write failure is logged but does not abort daemon
    startup.  Total runtime ~ WHISTLE_PULSES * 2 * WHISTLE_HALF_S = ~3.6 s with
    defaults; this delays entry into the control loop, which is acceptable
    because steady-state thermal response time is dominated by the SoC's own
    ~30 s thermal mass, not the first few PWM ticks.
    """
    try:
        for _ in range(WHISTLE_PULSES):
            i2c_write_pwm(i2c_fd, WHISTLE_LOW_PWM)
            time.sleep(WHISTLE_HALF_S)
            i2c_write_pwm(i2c_fd, WHISTLE_HIGH_PWM)
            time.sleep(WHISTLE_HALF_S)
    except Exception as e:
        syslog.syslog(syslog.LOG_WARNING, f"fan-pid: startup whistle failed: {e!r}")
    syslog.syslog(syslog.LOG_INFO, "fan-pid: startup whistle complete — entering control loop")


# ---------- Controller ----------------------------------------------------------
class Controller:
    """One PI controller per zone, output combined via max()."""

    def __init__(self, i2c_fd: int, fan_path: str, zone_paths: dict[str, str]):
        self.i2c_fd    = i2c_fd
        self.fan_path  = fan_path
        self.zone_paths = zone_paths
        self.last_written_pwm = -1   # force first write
        # Initialize EMA at MIN_RUN, not 0. Otherwise the first tick produces
        # alpha*max_pwm_zone + (1-alpha)*0 = 0.4*40 = 16, which is well below
        # the kick-start floor and stalls the fan from rest. Once stalled the
        # PI controller can't recover until temps climb high enough that the
        # EMA-smoothed output crosses 39 again, by which time the SoC has
        # been baking for many ticks.
        self.smoothed_pwm = float(PWM_MIN_RUN)
        self.last_log_t = 0.0

    def integral_clamp(self, z: Zone) -> float:
        """Anti-windup: cap |integral| so it can saturate the actuator but no more."""
        if z.ki <= 0:
            return 0.0
        # Max useful integral = (PWM_MAX - PWM_FLOOR) / Ki.
        # We allow +/- that magnitude.  Clamp tightens further for very-low-Ki
        # zones (which already track via Kp).
        return (PWM_MAX - PWM_FLOOR) / z.ki

    def step(self) -> tuple[int, dict[str, float], dict[str, float]]:
        """One control tick.  Returns (final_pwm, zone_temps, zone_pwms)."""
        zone_temps: dict[str, float] = {}
        zone_pwms:  dict[str, float] = {}
        any_critical = False
        any_fault    = False
        max_pwm_zone = float(PWM_FLOOR)

        for z in ZONES:
            path = self.zone_paths.get(z.name)
            if path is None:
                continue
            t = read_temp(path)
            if t is None:
                # transient read failure — reuse last good temp so PI doesn't
                # zero-out integral and overshoot when reads recover
                t = z.last_temp
            else:
                z.last_temp = t
            zone_temps[z.name] = t

            if t >= HARD_FAULT_TEMP:
                any_fault = True
            if t >= z.crit_temp:
                any_critical = True

            err = t - z.setpoint
            # PI step.  Note we integrate even when output is saturated, but the
            # clamp below prevents windup beyond useful range.
            z.integral += err
            ic = self.integral_clamp(z)
            if z.integral >  ic: z.integral =  ic
            if z.integral < -ic: z.integral = -ic

            pwm_i = PWM_FLOOR + z.kp * err + z.ki * z.integral
            # Always enforce PWM_MIN_RUN (=40): the stock DC-axial fan
            # kick-start floor was empirically measured at PWM 39 (1044 RPM)
            # on 2026-05-11; PWM 38 stays stalled. The chip itself honors
            # arbitrary values via /dev/i2c — the limit is the fan's, not
            # the silicon's. Anything below 40 risks a stalled fan and a
            # dead spot in the cooling response, so the PI math is clamped
            # here rather than producing physically-meaningless sub-stall
            # demand. To run the fan slower, replace it with a smaller one
            # and re-measure the kick-start knee (see the PWM_MIN_RUN
            # docstring).
            if pwm_i < PWM_MIN_RUN:
                pwm_i = PWM_MIN_RUN
            pwm_i = max(0.0, min(float(PWM_MAX), pwm_i))
            z.last_pwm = pwm_i
            zone_pwms[z.name] = pwm_i
            if pwm_i > max_pwm_zone:
                max_pwm_zone = pwm_i

        # Safety overrides bypass smoothing — we want them to take effect THIS tick.
        if any_critical or any_fault:
            target = float(PWM_MAX)
            # Reset integrals: when temp comes back down we don't want the
            # accumulated 30-second saturation pushing PWM to MAX for another
            # 30 s.  This is a hard reset, not a graceful decay, because the
            # safety-override case is a thermal emergency.
            for z in ZONES:
                z.integral = 0.0
            self.smoothed_pwm = target
            if any_fault:
                hottest = max(zone_temps.items(), key=lambda kv: kv[1], default=("?", 0))
                syslog.syslog(syslog.LOG_CRIT,
                              f"fan-pid: HARD FAULT zone={hottest[0]} temp={hottest[1]:.1f}C "
                              f">= {HARD_FAULT_TEMP}C — silicon damage threshold; PWM forced to MAX")
        else:
            # EMA smoothing on the final actuator command
            self.smoothed_pwm = (EMA_ALPHA * max_pwm_zone
                                 + (1.0 - EMA_ALPHA) * self.smoothed_pwm)
            # Enforce MIN_RUN AFTER smoothing too. The per-zone floor is
            # applied before max(), but EMA blending with a previous low
            # value can still drag the output below MIN_RUN on a downward
            # transition. The fan kick-start floor is a hardware limit —
            # any output below it physically stalls the fan, no matter how
            # the math arrived there.
            if self.smoothed_pwm < PWM_MIN_RUN:
                self.smoothed_pwm = float(PWM_MIN_RUN)
            target = self.smoothed_pwm

        out = int(round(target))
        # Deadband: avoid i2c writes for noise-level changes.  Always write
        # when crossing 0 (fan stop) or PWM_MAX (full).
        force = (out == 0 or out == PWM_MAX)
        if force or self.last_written_pwm < 0 or abs(out - self.last_written_pwm) >= PWM_DEADBAND:
            i2c_write_pwm(self.i2c_fd, out)
            self.last_written_pwm = out

        return out, zone_temps, zone_pwms

    def maybe_log(self, now: float, final_pwm: int,
                  zt: dict[str, float], zp: dict[str, float]) -> None:
        if now - self.last_log_t < LOG_INTERVAL:
            return
        self.last_log_t = now
        rpm = read_fan_rpm(self.fan_path)
        rpm_str = f"{rpm}rpm" if rpm is not None else "?rpm"
        zt_str = " ".join(f"{n.split('-')[0]}={t:.1f}" for n, t in zt.items())
        zp_str = " ".join(f"{n.split('-')[0]}={p:.0f}" for n, p in zp.items())
        syslog.syslog(syslog.LOG_INFO,
                      f"fan-pid: pwm={final_pwm}/{PWM_MAX} {rpm_str} | T[{zt_str}] | demand[{zp_str}]")


# ---------- Main loop -----------------------------------------------------------
_running = True


def _on_sigterm(_sig, _frame):
    global _running
    _running = False


def main() -> int:
    syslog.openlog("fan-pid", syslog.LOG_PID, syslog.LOG_DAEMON)

    # Board gate — only run on LS1046A.  Same idiom as fancontrol-setup.
    try:
        with open("/proc/device-tree/compatible", "rb") as f:
            compat = f.read().split(b"\0")
    except OSError:
        compat = []
    if not any(b"fsl,ls1046a" in c for c in compat):
        syslog.syslog(syslog.LOG_INFO, "fan-pid: not LS1046A, exiting")
        return 0

    try:
        pwm_path, fan_path = find_emc2305_pwm()
    except RuntimeError as e:
        syslog.syslog(syslog.LOG_ERR, f"fan-pid: {e} — failing to MAX_PWM if possible, exit 1")
        return 1
    syslog.syslog(syslog.LOG_INFO, f"fan-pid: hwmon pwm path {pwm_path} (introspection only), fan tach at {fan_path}")

    # Open raw i2c bypass (kernel sysfs PWM interface is broken on 6.18 — see
    # the EMC2305_I2C_ADDR comment block at top). All PWM writes from here on
    # go via i2c_write_pwm(i2c_fd, value).
    try:
        i2c_fd = find_emc2305_i2c()
    except (RuntimeError, OSError) as e:
        syslog.syslog(syslog.LOG_ERR, f"fan-pid: i2c open failed: {e!r} — exit 1")
        return 1
    syslog.syslog(syslog.LOG_INFO, f"fan-pid: i2c bus claimed at addr 0x{EMC2305_I2C_ADDR:02x}")

    zone_paths = find_thermal_zones()
    if not zone_paths:
        syslog.syslog(syslog.LOG_ERR, "fan-pid: no usable thermal_zone* found — exiting")
        # Defensive: leave fan at full so the SoC isn't suffocated by a stuck low PWM.
        i2c_write_pwm(i2c_fd, PWM_MAX)
        os.close(i2c_fd)
        return 1
    missing = [z.name for z in ZONES if z.name not in zone_paths]
    if missing:
        syslog.syslog(syslog.LOG_WARNING,
                      f"fan-pid: thermal zones missing (will skip): {','.join(missing)}")
    syslog.syslog(syslog.LOG_INFO,
                  f"fan-pid: controlling {len(zone_paths)} zones: {','.join(zone_paths)}")

    play_startup_whistle(i2c_fd)

    signal.signal(signal.SIGTERM, _on_sigterm)
    signal.signal(signal.SIGINT,  _on_sigterm)

    ctrl = Controller(i2c_fd, fan_path, zone_paths)
    next_tick = time.monotonic()
    try:
        while _running:
            now = time.monotonic()
            if now < next_tick:
                time.sleep(min(TICK_SECONDS, next_tick - now))
                continue
            next_tick = now + TICK_SECONDS
            try:
                final, zt, zp = ctrl.step()
                ctrl.maybe_log(now, final, zt, zp)
            except Exception as e:  # belt-and-braces: never crash on a tick
                syslog.syslog(syslog.LOG_ERR, f"fan-pid: tick failed: {e!r}")
    finally:
        # Defensive shutdown: hand control back to the BIOS/firmware default by
        # writing MAX_PWM.  If a maintainer restarts the daemon under load they
        # don't want a stale low PWM throttling the SoC during the gap.
        try:
            i2c_write_pwm(i2c_fd, PWM_MAX)
            syslog.syslog(syslog.LOG_INFO, "fan-pid: shutdown — left PWM at MAX as failsafe")
        except Exception:
            pass
        try:
            os.close(i2c_fd)
        except Exception:
            pass
    return 0


if __name__ == "__main__":
    sys.exit(main())