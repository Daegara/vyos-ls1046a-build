diff --git a/src/op_mode/image_installer.py b/src/op_mode/image_installer.py
index 68db05f..dbc3685 100755
--- a/src/op_mode/image_installer.py
+++ b/src/op_mode/image_installer.py
@@ -1092,6 +1092,31 @@ def install_image() -> None:
         # copy saved encrypted config volume
         copy_previous_encrypted_config(f'{DIR_DST_ROOT}/luks', image_name)
 
+        # U-Boot boards: write vyos.env DIRECTLY to eMMC mount as belt-and-
+        # suspenders (grub.set_default hook above also writes it, but we
+        # must guarantee it exists for first boot).
+        try:
+            vyos_env = Path(f'{DIR_DST_ROOT}/boot/vyos.env')
+            vyos_env.write_text(f'vyos_image={image_name}\n')
+        except Exception:
+            pass
+
+        # U-Boot boards: one-time bootloader env setup (fw_setenv).
+        # Pass --root so the script operates on the eMMC mount, not /.
+        # Errors are non-fatal — user can set up U-Boot manually.
+        postinstall = Path('/usr/local/bin/vyos-postinstall')
+        if postinstall.exists():
+            print('Configuring U-Boot for automatic eMMC boot...')
+            try:
+                rc = run(f'{postinstall} --root {DIR_DST_ROOT} {image_name}')
+                if rc == 0:
+                    print('U-Boot configuration complete.')
+                else:
+                    print('WARNING: U-Boot configuration returned errors (non-fatal).')
+                    print('  You may need to set up U-Boot manually — see INSTALL.md.')
+            except Exception:
+                pass
+
         if is_raid_install(install_target):
             write_dir: str = f'{DIR_DST_ROOT}/boot/{image_name}/rw'
             raid.update_default(write_dir)
