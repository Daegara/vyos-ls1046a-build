                 )
         return False
 
+    def set_vlan_strip(self, state):
+        """
+        Enable hardware VLAN tag stripping on receive. State can be either
+        True or False. On the NXP LS1046A this drives the DPAA1 FMan Header
+        Manipulation offload via the dpaa_set_features() .ndo_set_features
+        bridge (NETIF_F_HW_VLAN_CTAG_RX).
+        Example:
+        >>> from vyos.ifconfig import EthernetIf
+        >>> i = EthernetIf('eth0')
+        >>> i.set_vlan_strip(True)
+        """
+        if not isinstance(state, bool):
+            raise ValueError('Value out of range')
+
+        enabled, fixed = self.ethtool.get_rx_vlan_offload()
+        if enabled != state:
+            if not fixed:
+                return self.set_interface('rxvlan', 'on' if state else 'off')
+            else:
+                print(
+                    'Adapter does not support changing rx-vlan-offload settings!'
+                )
+        return False
+
     def set_rps(self, state):
         if not isinstance(state, bool):
             raise ValueError('Value out of range')
@@ -571,6 +600,9 @@ def update(self, config):
