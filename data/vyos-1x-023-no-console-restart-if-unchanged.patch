+# LS1046A: tracks whether any serial-getty drop-in file was actually
+# modified during generate(). apply() uses this to decide whether to call
+# restart_login_consoles().
+#
+# Background: the original generate() unconditionally os.unlink()'d every
+# serial-getty*.service file in /run/systemd/system, then re-rendered
+# them. On a serial-console-only board with `console=ttyS0` in the kernel
+# cmdline, the unit-file disappearance, combined with the subsequent
+# `systemctl daemon-reload` issued elsewhere in the vyos-router pipeline,
+# makes systemd GC the running serial-getty@ttyS0 instance and emit an
+# explicit Stop job (MESSAGE_ID=de5b426a..., JOB_TYPE=stop, _PID=1
+# _COMM=systemd). Restart=always does NOT recover from explicit stops
+# (systemd.service(5)), so the console stays dead until a much later
+# commit-phase restart_login_consoles() brings it back up — 21+ s on
+# LS1046A. The fix: never touch a drop-in unless its rendered replacement
+# is genuinely different. systemd then sees no unit-file disappearance
+# during daemon-reload and emits no GC stop job.
+_serial_getty_files_changed: bool = False
+
+def _read_file_bytes(path: str) -> bytes:
+    try:
+        with open(path, 'rb') as f:
+            return f.read()
+    except OSError:
+        return b''
+
+def _write_if_changed(path: str, content: str) -> bool:
+    """Write content to path only if the on-disk bytes differ. Returns True
+    if a write occurred, False if the file was already byte-identical.
+    The parent directory is created if missing. Uses temp-file + rename
+    so systemd never sees a partial/empty file during a concurrent
+    daemon-reload."""
+    new_bytes = content.encode('utf-8')
+    if os.path.isfile(path) and _read_file_bytes(path) == new_bytes:
+        return False
+    os.makedirs(os.path.dirname(path), exist_ok=True)
+    tmp_path = path + '.tmp'
+    with open(tmp_path, 'wb') as f:
+        f.write(new_bytes)
+    os.rename(tmp_path, path)
+    return True
+
