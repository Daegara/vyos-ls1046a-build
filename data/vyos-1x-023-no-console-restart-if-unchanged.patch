+# LS1046A: snapshot of rendered serial-getty@*.service drop-ins captured in
+# generate() (pre-unlink and post-render). apply() uses this to skip
+# restart_login_consoles() when nothing changed, because systemctl restart
+# kills the agetty (Stop) and there is a window before the fresh agetty
+# attaches where the serial console swallows keystrokes from a connected
+# operator. With Restart=always agetty does NOT recover from an explicit
+# Stop, by systemd design (see systemd.service(5)).
+_serial_getty_snapshot_pre: dict = {}
+_serial_getty_snapshot_post: dict = {}
+
+def _snapshot_serial_getty_renders(base_dir: str) -> dict:
+    """Return {filename: sha256-hex} for every serial-getty@*.service file
+    currently present under base_dir. Missing directory yields {}."""
+    out: dict = {}
+    if not os.path.isdir(base_dir):
+        return out
+    for entry in os.listdir(base_dir):
+        if 'serial-getty' not in entry:
+            continue
+        path = os.path.join(base_dir, entry)
+        if not os.path.isfile(path):
+            continue
+        try:
+            with open(path, 'rb') as f:
+                out[entry] = hashlib.sha256(f.read()).hexdigest()
+        except OSError:
+            # Treat unreadable file as "changed" by recording a sentinel
+            out[entry] = 'unreadable'
+    return out
+
