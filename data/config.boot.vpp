interfaces {
    ethernet eth0 {
        address dhcp
        description "MGMT (left RJ45)"
    }
    ethernet eth1 {
        description "VPP data (center RJ45)"
        mtu 1500
    }
    ethernet eth2 {
        description "VPP data (right RJ45)"
        mtu 1500
    }
    ethernet eth3 {
        description "VPP data (left SFP+)"
        mtu 1500
    }
    ethernet eth4 {
        description "VPP data (right SFP+)"
        mtu 1500
    }
    loopback lo {
    }
}
service {
    ssh {
    }
}
system {
    config-management {
        commit-revisions 100
    }
    host-name vyos
    login {
        user vyos {
            authentication {
                encrypted-password "$6$rounds=656000$ypOI6W4mMxT1AEUs$dwrNWa2uPRkwNnFWdsQg9Lr0zRBujQisD6zmS0rAAH2qSjoCbvi84uEGdMLC5H6W60kQSeZu2KhFmguvYK7HJ0"
                public-keys "vanityssh@vyos" {
                    key "AAAAC3NzaC1lZDI1NTE5AAAAIBTFXhL3cM7V4TqClTrl2AEI80Jcv6Fuyimm++VyOS++"
                    type "ssh-ed25519"
                }
            }
        }
    }
    ntp {
        allow-client {
            address "127.0.0.0/8"
            address "169.254.0.0/16"
            address "10.0.0.0/8"
            address "172.16.0.0/12"
            address "192.168.0.0/16"
            address "::1/128"
            address "fe80::/10"
            address "fc00::/7"
        }
        server time.apple.com {
        }
        server time.cloudflare.com {
        }
        server time.google.com {
        }
    }
    option {
        kernel {
            memory {
                hugepage-count 512
                hugepage-size 2M
            }
        }
        performance network-latency
        reboot-on-panic
        reboot-on-upgrade-failure 5
        time-format 24-hour
    }
    syslog {
        global {
            facility all {
                level info
            }
            facility local7 {
                level debug
            }
        }
    }
    update-check {
        auto-check
        url https://raw.githubusercontent.com/mihakralj/vyos-ls1046a-build/refs/heads/main/version-default.json
    }
    watchdog {
        reboot-timeout 60
        shutdown-timeout 60
    }
}
vpp {
    settings {
        allow-unsupported-nics
        interface eth1 {
        }
        interface eth2 {
        }
        interface eth3 {
        }
        interface eth4 {
        }
        poll-sleep-usec 100
        resource-allocation {
            cpu-cores 1
            memory {
                main-heap-size 256M
            }
        }
    }
}
