diff --git a/python/vyos/ifconfig/ethernet.py b/python/vyos/ifconfig/ethernet.py
index 02d4b76..2a87c79 100644
--- a/python/vyos/ifconfig/ethernet.py
+++ b/python/vyos/ifconfig/ethernet.py
@@ -364,6 +364,60 @@ def set_vlan_strip(self, state):
                 )
         return False
 
+    def set_ingress_policer(self, config):
+        """
+        Install or remove a hardware ingress rate policer. On the NXP LS1046A
+        this drives the DPAA1 FMan Policer via the dpaa_setup_tc() matchall
+        .ndo_setup_tc bridge. Supplying only 'bandwidth' installs a
+        single-rate (srTCM) policer; additionally supplying 'peak-bandwidth'
+        installs a two-rate (trTCM) policer.
+
+        'config' is the per-interface configuration dictionary. The policer is
+        attached as a matchall filter (pref 50) on the classic 'ffff: ingress'
+        qdisc so it coexists with any mirror/redirect filter on the same qdisc.
+        This must be called AFTER the base-class mirror/redirect setup, which
+        may tear the ingress qdisc down and rebuild it.
+        Example:
+        >>> from vyos.ifconfig import EthernetIf
+        >>> i = EthernetIf('eth0')
+        >>> i.set_ingress_policer({'ingress_policer': {'bandwidth': '1gbit'}})
+        """
+        ifname = self.ifname
+        pref = '50'
+
+        # Always remove our own filter first so the call is idempotent and a
+        # deleted policer leaves no stale hardware profile behind.
+        self._popen(f'tc filter del dev {ifname} parent ffff: pref {pref} 2>/dev/null')
+
+        policer = config.get('ingress_policer')
+        if not policer:
+            return None
+
+        rate = policer.get('bandwidth')
+        if not rate:
+            return None
+
+        # Ensure the ingress qdisc exists (shared with mirror/redirect). Adding
+        # an already-present qdisc fails harmlessly - errors are ignored.
+        self._popen(f'tc qdisc add dev {ifname} handle ffff: ingress 2>/dev/null')
+
+        burst = policer.get('burst', '15k')
+        peak = policer.get('peak_bandwidth')
+
+        cmd = (
+            f'tc filter add dev {ifname} parent ffff: pref {pref} '
+            f'matchall skip_sw action police rate {rate} burst {burst}'
+        )
+        if peak:
+            mtu = read_file(f'/sys/class/net/{ifname}/mtu')
+            cmd += f' peakrate {peak} mtu {mtu}'
+        cmd += ' conform-exceed drop/pipe'
+
+        _, err = self._popen(cmd)
+        if err:
+            print('tc filter for ingress-policer failed')
+        return None
+
     def set_rps(self, state):
         if not isinstance(state, bool):
             raise ValueError('Value out of range')
@@ -636,5 +690,10 @@ def update(self, config):
         # call base class last
         super().update(config)
 
+        # Hardware ingress policer (DPAA1 FMan Policer offload). Must run after
+        # super().update() so the mirror/redirect ingress qdisc teardown/rebuild
+        # has already happened - our matchall filter is added last and survives.
+        self.set_ingress_policer(config)
+
         # enable/disable EAPoL (Extensible Authentication Protocol over Local Area Network)
         self.set_eapol()
diff --git a/src/conf_mode/interfaces_ethernet.py b/src/conf_mode/interfaces_ethernet.py
index 10b778e..02a9523 100755
--- a/src/conf_mode/interfaces_ethernet.py
+++ b/src/conf_mode/interfaces_ethernet.py
@@ -376,6 +376,24 @@ def verify_vpp_remove_vif(ethernet: dict):
     for vlan in vlan_names:
         verify_vpp_remove_interface(vlan, vpp_config)
 
+def verify_ingress_policer(ethernet):
+    """
+    Verify the hardware ingress-policer configuration. 'bandwidth' (the
+    committed information rate) is mandatory; 'peak-bandwidth' is optional and
+    upgrades the policer from single-rate (srTCM) to two-rate (trTCM). On the
+    NXP LS1046A this is offloaded to the DPAA1 FMan Policer.
+    """
+    policer = ethernet.get('ingress_policer')
+    if not policer:
+        return None
+
+    if 'bandwidth' not in policer:
+        raise ConfigError(
+            'ingress-policer requires "bandwidth" (committed information rate) '
+            'to be set'
+        )
+    return None
+
 def verify(ethernet):
     verify_flowtable(ethernet)
     verify_vpp_remove_vif(ethernet)
@@ -387,6 +405,7 @@ def verify(ethernet):
     verify_interface_exists(ethernet, ifname, state_required=True)
     verify_eapol(ethernet)
     verify_mirror_redirect(ethernet)
+    verify_ingress_policer(ethernet)
     # No need to check speed and duplex keys as both have default values
     ethtool = Ethtool(ifname)
     verify_speed_duplex(ethernet, ethtool)
