 <!--NOTE: In soft parser code, pppoe table base is calculated and added as ccbase +0x30 -->
 <!-- this pppoe relay table is allocated dynamically by FMC while pushing tables from cdx_pcd.xml -->
 <!-- If any new table gets added ccbase value of ppoe relay table should be checked and updated accordingly -->
<netpcd>
<!--
  ASK PCD hash tables (DDR-backed EHASH allocation, ask40+ kernel +
  fmlib B2 ABI extension + fmc B4 parser/emitter).

  external="yes" routes FM_PCD_HashTableSet() through ExternalHashTableSet
  (DDR allocation) instead of the MURAM-bound default allocator,
  eliminating the previous Chain-2-A MURAM exhaustion (fm_cc.c:4842
  AllocStatsObjs / :7751 Unexpected NULL Pointer for ~16K stats objects
  in the 384 KiB FMan internal MURAM).

  Hash bucket count constraint: ExternalHashTableSet (fm_ehash.c:925)
  requires (hashResMask + 1) to be a power of 2, ≤ 32768. The mask
  attribute on <hashtable> is emitted verbatim into htNode.hashResMask,
  so it MUST be one of: 0x1, 0x3, 0x7, 0xf, 0x1f, 0x3f, 0x7f, 0xff,
  0x1ff, 0x3ff, 0x7ff, 0xfff, 0x1fff, 0x3fff, 0x7fff. Previous
  MURAM-era values (0x1ff0, 0xff0, 0xf0) violated this and caused
  fm_ehash.c:925 "unsupported hash mask value" once EHASH dispatch
  went live in ask40.

  Current sizing: mask=0xff (256 buckets) × 16 tables ≈ 4096 buckets in
  DDR — trivial vs the previous MURAM ceiling. max=8 keeps prefilled
  entries small; CMM populates the working set dynamically via FCI.

  Iteration history (kept for archival reference):
    - max=512, mask=0x1ff0  : MURAM exhaustion at AllocStatsObjs
    - max=128, mask=0xff0   : MURAM exhaustion at AllocStatsObjs
    - max=32,  mask=0xf0    : MURAM exhaustion at MatchTableSet
    - max=8,   mask=0xf0    : MURAM exhaustion at MatchTableSet
    - max=8,   mask=0xf0 + external/aging (ask40) : EHASH dispatch
                              works but rejects mask (not 2^N - 1)
    - max=8,   mask=0xff + external/aging (current) : DDR allocation
                              succeeds, ample headroom.
-->
<classification name="cdx_udp4_cc" max="8" masks="yes" shared="true" external="yes" aging="yes" table_type="IPV4_UDP_TABLE">
  <key>
     <hashtable mask="0xff" hashshift="0" keysize="14"/>
  </key>
</classification>

