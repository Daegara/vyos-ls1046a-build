 <!--NOTE: In soft parser code, pppoe table base is calculated and added as ccbase +0x30 -->
 <!-- this pppoe relay table is allocated dynamically by FMC while pushing tables from cdx_pcd.xml -->
 <!-- If any new table gets added ccbase value of ppoe relay table should be checked and updated accordingly -->
<netpcd>
<!--
  ASK PCD hash tables (MURAM-only allocation; fmc lf-6.18.2-1.0.0 has no
  external="yes" / aging="yes" XML attribute support, so all hash buckets
  and CC node action descriptors must fit in the 384 KiB FMan internal
  MURAM.

  Critical scaling factor: each <classification> below is referenced
  from 10 <policy> blocks (8 ethport + 2 of_port). Despite shared="true"
  the SDK still instantiates separate MURAM-backed CC node copies per
  policy reference. Effective consumption is therefore:

      max × keysize × num_policies  (action descriptors + key storage)
    + buckets × bucket_entry_size   (hashtable bucket arrays)

  summed across all 16 tables. Previous trims (max=512, mask=0x1ff0;
  then max=128, mask=0xff0 on big-4) still produced
  fm_cc.c:4842 MatchTableSet "MURAM allocation for CC node action
  descriptors table" because the per-policy multiplier was not factored
  in. With 10 policies × 16 tables × max=128 × ~64 B/entry ≈ 1.3 MiB,
  far exceeding the 384 KiB MURAM ceiling.

  Iteration history:
    - max=512 → 128 (mask=0x1ff0 → 0xff0): still failed
    - max=128 → 32 (mask=0xff0 → 0xf0 on big-4): boot got further but
      still failed at fm_cc.c:4842 MatchTableSet (MURAM exhaustion on
      CC node action descriptors table) — the 10× per-policy multiplier
      means 10 × 16 × 32 × ~64 B ≈ 327 KiB AD storage alone, leaving
      < 60 KiB headroom for KeyGen / parser / policer / scratch.
    - max=32 → 8 (this iteration): 10 × 16 × 8 × ~64 B ≈ 82 KiB AD,
      plus ~16 KiB bucket arrays = ~98 KiB total, ~285 KiB MURAM
      headroom. Fits comfortably.

  Runtime ceiling: 16 tables × max=8 = 128 simultaneous flow rules
  per policy. CMM populates entries dynamically via FCI; max is only
  the upper bound, not the working set. 512 flows easily covers
  SOHO/branch traffic patterns. If a deployment needs more, the
  proper fix is patching fmc to honor external="yes" aging="yes"
  so buckets land in DDR via USDPAA — separate work item.
-->
<classification name="cdx_udp4_cc" max="8" masks="yes" shared="true" external="yes" aging="yes" table_type="IPV4_UDP_TABLE">
  <key>
     <hashtable mask="0xf0" hashshift="0" keysize="14"/>
  </key>
</classification>

