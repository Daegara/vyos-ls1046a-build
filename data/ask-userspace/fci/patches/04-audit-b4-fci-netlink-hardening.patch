--- a/fci.c
+++ b/fci.c
@@ -430,6 +430,12 @@
 	}
 
 	nlh = nlmsg_put(skb, 0, 0, 0, len + FCI_MSG_HDR_SIZE, 0);
+	if (!nlh) {
+		this_fci->stats.rx_msg_err++;
+		kfree_skb(skb);
+		rc = -EMSGSIZE;
+		goto err;
+	}
 
 	fci_msg = nlmsg_data(nlh);
 
@@ -462,6 +468,12 @@
 
 	FCI_PRINTK(FCI_INBOUND, "FCI: %s\n", __func__);
 
+	/* B4 F-01: validate nlmsg header before dereferencing payload. */
+	if (skb->len < NLMSG_HDRLEN || !NLMSG_OK(nlh, skb->len)) {
+		this_fci->stats.rx_msg_err++;
+		return;
+	}
+
 	/* extract fci message from skb */
 	fci_msg = nlmsg_data(nlh);
 
@@ -473,6 +485,11 @@
 	if (nskb)
 	{
 		rep = nlmsg_put(nskb, NETLINK_CB(skb).portid, nlh->nlmsg_seq, 0, 0, 0);
+		if (!rep) {
+			this_fci->stats.rx_msg_err++;
+			kfree_skb(nskb);
+			return;
+		}
 
 		fci_rep = nlmsg_data(rep);
 
@@ -652,9 +669,17 @@
 
 	/* Create /proc/fci entry */
 #if LINUX_VERSION_CODE > KERNEL_VERSION(3,10,0)
-	proc_create("fci", 0, NULL, &fci_proc_fops);
+	if (!proc_create("fci", 0, NULL, &fci_proc_fops)) {
+		printk(KERN_ERR "FCI: failed to create /proc/fci\n");
+		fci_exit();
+		return -ENOMEM;
+	}
 #else
-	create_proc_read_entry("fci", 0, 0, fci_proc_info, NULL);
+	if (!create_proc_read_entry("fci", 0, 0, fci_proc_info, NULL)) {
+		printk(KERN_ERR "FCI: failed to create /proc/fci\n");
+		fci_exit();
+		return -ENOMEM;
+	}
 #endif
 
 	return 0;
