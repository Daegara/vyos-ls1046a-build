#!/usr/bin/env bash
# dpaa1-check — verify DPAA1 networking elements on the LS1046A Mono Gateway DK
#
# Usage:   dpaa1-check
#
# Verifies:
#   - DT nodes for FMan, QMan, BMan
#   - FMan drivers loaded (fsl_fman, fsl_dpaa_mac, fsl_dpa)
#   - Jumbo frame config (fsl_fm_max_frm)
#   - FMan PHY drivers (mxl-gpy for RJ45, rollball/DAC for SFP+)
#   - Network interfaces (eth0-eth4) existence and MTU
#   - AF_XDP queues mapping (queue_index fix)
#
# Exit codes:
#   0 — all elements healthy
#   1 — failure detected
#   2 — not LS1046A

set -u
export PATH=/usr/sbin:/usr/bin:/sbin:/bin:$PATH

# ---------------------------------------------------------------------------
# Colour escapes (TTY only)
# ---------------------------------------------------------------------------
if [ -t 1 ] && [ "${TERM:-dumb}" != "dumb" ]; then
    C_RST=$'\033[0m'
    C_BOLD=$'\033[1m'
    C_DIM=$'\033[2m'
    C_GREEN=$'\033[1;32m'
    C_YELLOW=$'\033[1;33m'
    C_RED=$'\033[1;31m'
    C_BLUE=$'\033[1;34m'
else
    C_RST='' C_BOLD='' C_DIM='' C_GREEN='' C_YELLOW='' C_RED='' C_BLUE=''
fi

ok()    { printf "  [%sOK%s]   %s\n"   "$C_GREEN"  "$C_RST" "$*"; }
warn()  { printf "  [%sWARN%s] %s\n"   "$C_YELLOW" "$C_RST" "$*"; }
fail()  { printf "  [%sFAIL%s] %s\n"   "$C_RED"    "$C_RST" "$*"; }
skip()  { printf "  [%sSKIP%s] %s\n"   "$C_BLUE"   "$C_RST" "$*"; }
note()  { printf "         %s%s%s\n"   "$C_DIM"    "$*"     "$C_RST"; }
hdr()   { printf "\n%s%s%s\n"          "$C_BOLD"   "$*"     "$C_RST"; }

EXIT=0
mark_fail() { EXIT=1; }

# ---------------------------------------------------------------------------
# Board gate
# ---------------------------------------------------------------------------
if [ ! -f /proc/device-tree/compatible ] \
   || ! tr '\0' '\n' < /proc/device-tree/compatible | grep -q 'fsl,ls1046a'; then
    echo "dpaa1-check: not LS1046A — nothing to report" >&2
    exit 2
fi

printf "%sdpaa1-check%s — LS1046A DPAA1 networking status\n" "$C_BOLD" "$C_RST"

# ---------------------------------------------------------------------------
# 1. SoC controller presence (devicetree)
# ---------------------------------------------------------------------------
hdr "1) DPAA1 controllers (devicetree)"

for block in fman@1a00000 qman@1880000 bman@1890000; do
    dt_node="/proc/device-tree/soc/${block}"
    if [ -d "$dt_node" ]; then
        compat=$(tr '\0' ' ' < "$dt_node/compatible" 2>/dev/null | sed 's/ *$//')
        ok "DT node $block present"
        note "compatible = \"$compat\""
    else
        fail "no $dt_node — $block not in DT"
        mark_fail
    fi
done

# ---------------------------------------------------------------------------
# 2. Driver / module posture
# ---------------------------------------------------------------------------
hdr "2) DPAA1 kernel drivers"

DPAA_DRVS=(fsl-fman fsl_dpaa_mac fsl_dpa qman_ccsr bman_ccsr)
for drv in "${DPAA_DRVS[@]}"; do
    if [ -d "/sys/bus/platform/drivers/${drv}" ]; then
        ok "${drv} present (platform driver)"
    else
        fail "${drv} NOT loaded — DPAA1 unavailable"
        mark_fail
    fi
done

# Check Maxlinear PHY driver
if [ -d "/sys/bus/mdio_bus/drivers/Maxlinear Ethernet GPY115C" ]; then
    ok "Maxlinear GPY115C PHY driver present"
else
    warn "Maxlinear PHY driver NOT found — RJ45 ports may fail SGMII negotiation"
fi

# ---------------------------------------------------------------------------
# 3. FMan configuration
# ---------------------------------------------------------------------------
hdr "3) FMan Configuration"

if grep -q 'fsl_dpaa_fman.fsl_fm_max_frm=9600' /proc/cmdline; then
    ok "fsl_dpaa_fman.fsl_fm_max_frm=9600 found in bootargs (Jumbo frames enabled)"
else
    warn "fsl_fm_max_frm=9600 not found in bootargs (Jumbo frames disabled)"
fi

# ---------------------------------------------------------------------------
# 4. Network Interfaces
# ---------------------------------------------------------------------------
hdr "4) Network Interfaces (eth0-eth4)"

for i in {0..4}; do
    iface="eth${i}"
    if [ -d "/sys/class/net/${iface}" ]; then
        operstate=$(cat "/sys/class/net/${iface}/operstate" 2>/dev/null || echo "?")
        mtu=$(cat "/sys/class/net/${iface}/mtu" 2>/dev/null || echo "?")
        if [ "$operstate" = "up" ]; then
            ok "${iface} is UP (MTU=${mtu})"
        elif [ "$operstate" = "down" ]; then
            note "${iface} is down (MTU=${mtu})"
        else
            note "${iface} operstate=${operstate} (MTU=${mtu})"
        fi
        
        # Determine port type based on iface
        if [ "$i" -ge 3 ]; then
            if [ "$mtu" -gt 3290 ]; then
                warn "SFP+ port ${iface} MTU=${mtu} exceeds AF_XDP safe limit (3290)"
            fi
        fi
    else
        fail "interface ${iface} missing"
        mark_fail
    fi
done

# ---------------------------------------------------------------------------
# 5. AF_XDP & ZC Status
# ---------------------------------------------------------------------------
hdr "5) AF_XDP Zero-Copy Status"

if [ -x /usr/local/bin/xsk-zc-check ]; then
    note "Calling xsk-zc-check..."
    /usr/local/bin/xsk-zc-check | while IFS= read -r line; do
        note "  $line"
    done
else
    skip "xsk-zc-check script not found"
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
hdr "Summary"
if [ "$EXIT" = "0" ]; then
    ok "DPAA1 healthy"
else
    fail "DPAA1 check FAILED — see entries above"
fi

exit "$EXIT"