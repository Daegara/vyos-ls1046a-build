#!/usr/bin/env bash
# ask-check — health check for the ASK hardware-offload dataplane on the
# LS1046A Mono Gateway DK.
#
# Usage:   ask-check          (re-run with sudo for symbol/debugfs depth)
#
# ============================================================================
# WHAT THIS TESTS
# ============================================================================
# ASK is the FMan-silicon hardware-offload dataplane: the operator turns it
# on per-port, and from then on the FMan classifies, forwards, NATs, and
# IPsec-terminates matching flows entirely in hardware, leaving the CPU idle.
# When ASK is OFF the board runs the mainline kernel dataplane (RSS to kernel
# RX queues); the VPP/AF_XDP overlay is a separate dataplane reported by
# xsk-zc-check, not here.
#
# This script walks the ASK datapath bottom-up, from the silicon programming
# layer to the operator CLI, in the order ASK brings itself up, and reports
# whether each capability is present and healthy. It is a production probe:
# every section describes a capability the finished ASK dataplane MUST have,
# so a component that is missing, stubbed, or broken is a [FAIL]. The script
# returns success only when the whole ASK chain is operational; until ASK is
# complete it is expected to fail on the not-yet-implemented pieces, and each
# failure names exactly which capability is absent.
#
# The chain, in bring-up order:
#
#   1. Dataplane posture          which dataplane owns the ports right now
#   2. FMan PCD subsystem         the silicon programming layer (KeyGen / CC /
#                                 Header-Manip / Policer) + its MURAM budget
#   3. Reversible mode switch     turning ASK on/off must be register-exact and
#                                 leak-free, verified by snapshot, never reboot
#   4. Hardware classification    the external-hash / FE engine that gives a
#                                 classified frame a terminal disposition
#   5. Hardware forwarding        L3 next-hop rewrite (strip/insert L2, TTL,
#                                 checksum) applied inline in the FMan
#   6. Control-plane module       ask.ko: the genl family + flow table + the
#                                 engage/disengage entry point
#   7. Hardware IPsec offload     CAAM job rings + descriptor sharing + the
#                                 ESP packet-mode offload bind on FMan netdevs
#   8. Operator CLI               'set system offload ask' + the validator that
#                                 keeps ASK and VPP mutually exclusive
#   9. dmesg integrity            no error/stall/leak lines from the datapath
#
# Tags:
#   [OK]    capability present and healthy
#   [WARN]  present but degraded — investigate
#   [FAIL]  capability missing or broken — ASK is not operational here
#   [SKIP]  cannot test in this environment (not LS1046A, no privilege, or a
#           probing tool is absent) — NOT a verdict on ASK itself
#
# Exit codes:
#   0  the ASK dataplane is fully operational
#   1  at least one capability is missing or broken
#   2  not an LS1046A board

set -u

# ---------------------------------------------------------------------------
# Colour escapes (TTY only). Same convention as caam-check / fan-check.
# ---------------------------------------------------------------------------
if [ -t 1 ] && [ "${TERM:-dumb}" != "dumb" ]; then
    C_RST=$'\033[0m'
    C_BOLD=$'\033[1m'
    C_DIM=$'\033[2m'
    C_GREEN=$'\033[1;32m'
    C_YELLOW=$'\033[1;33m'
    C_RED=$'\033[1;31m'
    C_BLUE=$'\033[1;34m'
else
    C_RST='' C_BOLD='' C_DIM='' C_GREEN='' C_YELLOW='' C_RED='' C_BLUE=''
fi

ok()    { printf "  [%sOK%s]   %s\n" "$C_GREEN"  "$C_RST" "$*"; }
warn()  { printf "  [%sWARN%s] %s\n" "$C_YELLOW" "$C_RST" "$*"; }
fail()  { printf "  [%sFAIL%s] %s\n" "$C_RED"    "$C_RST" "$*"; }
skip()  { printf "  [%sSKIP%s] %s\n" "$C_BLUE"   "$C_RST" "$*"; }
note()  { printf "         %s%s%s\n" "$C_DIM"    "$*"     "$C_RST"; }
hdr()   { printf "\n%s%s%s\n"        "$C_BOLD"   "$*"     "$C_RST"; }

EXIT=0
N_OK=0 N_WARN=0 N_FAIL=0 N_SKIP=0

record_ok()   { ok   "$@"; N_OK=$((N_OK+1));     }
record_warn() { warn "$@"; N_WARN=$((N_WARN+1)); }
record_fail() { fail "$@"; N_FAIL=$((N_FAIL+1)); EXIT=1; }
record_skip() { skip "$@"; N_SKIP=$((N_SKIP+1)); }

# ---------------------------------------------------------------------------
# Board gate
# ---------------------------------------------------------------------------
if [ ! -f /proc/device-tree/compatible ] \
   || ! tr '\0' '\n' < /proc/device-tree/compatible | grep -q 'fsl,ls1046a'; then
    echo "ask-check: not LS1046A — nothing to report" >&2
    exit 2
fi

# ---------------------------------------------------------------------------
# Header
# ---------------------------------------------------------------------------
hostname_str=$(hostname 2>/dev/null || echo "?")
kernel_str=$(uname -r 2>/dev/null || echo "?")
printf "%sask-check%s  host=%s  kernel=%s  %s\n" \
    "$C_BOLD" "$C_RST" "$hostname_str" "$kernel_str" "$(date -u +'%Y-%m-%dT%H:%M:%SZ')"
if [ "$(id -u)" -ne 0 ]; then
    note "running unprivileged — symbol/debugfs probes will SKIP; re-run with sudo for full depth"
fi

# ---------------------------------------------------------------------------
# Cached state
# ---------------------------------------------------------------------------
DMESG=$(dmesg 2>/dev/null || true)
LSMOD=$(lsmod 2>/dev/null || true)
KALLSYMS=""
if [ -r /proc/kallsyms ]; then
    KALLSYMS=$(cat /proc/kallsyms 2>/dev/null || true)
    if [ "$(id -u)" -ne 0 ] && ! echo "$KALLSYMS" | awk '{print $3}' | grep -q .; then
        KALLSYMS=""
    fi
fi

has_sym()   { [ -n "$KALLSYMS" ] && echo "$KALLSYMS" | awk '{print $3}' | grep -qx "$1"; }
has_mod()   { echo "$LSMOD" | awk '{print $1}' | grep -qx "$1"; }
dmesg_has() { echo "$DMESG" | grep -qE "$1"; }

# Probe a debugfs node's existence with root/non-root awareness.
# Returns: 0 present, 1 absent, 2 indeterminate (no privilege to stat).
dbg_state() {
    local p="$1"
    if [ -e "$p" ]; then return 0; fi
    if [ "$(id -u)" -ne 0 ] && [ ! -r /sys/kernel/debug ]; then return 2; fi
    return 1
}

# Discover FMan/DPAA netdevs once.
DPAA_NETDEVS=()
for dev in /sys/class/net/*/device/of_node; do
    [ -L "$dev" ] || continue
    target=$(readlink -f "$dev" 2>/dev/null || true)
    case "$target" in
        */fman*|*/ethernet@*) DPAA_NETDEVS+=("$(basename "$(dirname "$(dirname "$dev")")")") ;;
    esac
done

PCD_DBGFS="/sys/kernel/debug/fman_pcd"

# ===========================================================================
# 1. Dataplane posture — which dataplane owns the ports right now
# ===========================================================================
hdr "1) Dataplane posture"

if [ "${#DPAA_NETDEVS[@]}" -gt 0 ]; then
    record_ok "${#DPAA_NETDEVS[@]} FMan/DPAA netdev(s) present: ${DPAA_NETDEVS[*]}"
else
    record_fail "no DPAA/FMan netdevs — the DPAA1 stack did not initialise"
    note "fsl_dpa creates eth0..ethN under fsl_dpaa_mac parents"
fi

# ASK and VPP are mutually exclusive: a running VPP means the ports are owned
# by the AF_XDP overlay, not by ASK.
if pgrep -x vpp_main >/dev/null 2>&1 || pgrep -x vpp >/dev/null 2>&1; then
    record_warn "VPP is running — ports are owned by the AF_XDP overlay, not ASK"
    note "ASK and VPP are mutually exclusive; use xsk-zc-check for the VPP path"
else
    note "no VPP process — ASK may own the ports"
fi

# Is hardware offload currently engaged on any port?
last_xition=$(echo "$DMESG" | grep -E 'ask hw: offload (EN|DIS)' | tail -1)
if echo "$last_xition" | grep -q ENGAGED; then
    record_ok "hardware offload currently ENGAGED on an FMan port"
    note "$last_xition"
else
    note "hardware offload not currently engaged (ASK is opt-in per port)"
fi

# ===========================================================================
# 2. FMan PCD subsystem — the silicon programming layer
# ===========================================================================
hdr "2) FMan PCD subsystem (KeyGen / Classify / Header-Manip / Policer)"

if [ ! -d /sys/kernel/debug ]; then
    record_skip "debugfs not mounted — mount -t debugfs none /sys/kernel/debug to probe PCD"
elif [ "$(id -u)" -ne 0 ] && [ ! -r /sys/kernel/debug ]; then
    record_skip "/sys/kernel/debug is mode 0700 — re-run with sudo to probe the PCD surface"
elif [ -d "$PCD_DBGFS" ]; then
    record_ok "PCD subsystem present at $PCD_DBGFS"
    instances=$(find "$PCD_DBGFS" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
    if [ "$instances" -eq 0 ]; then
        record_fail "$PCD_DBGFS has no per-FMan instance — the PCD subsystem never initialised"
    else
        note "$instances FMan PCD instance(s)"
    fi
    # MURAM budget — the on-chip memory the PCD programs flows into. Exhaustion
    # is the classic offload failure (allocations start returning -ENOMEM), so a
    # zero-free budget is fatal, and a large 'used' while offload is OFF means a
    # previous disable did not release its allocations (a reversibility leak).
    budget_file=$(find "$PCD_DBGFS" -mindepth 2 -maxdepth 2 -name muram_budget -type f 2>/dev/null | head -1)
    if [ -n "$budget_file" ] && [ -r "$budget_file" ]; then
        budget_str=$(tr '\n' ' ' < "$budget_file" 2>/dev/null | sed 's/  */ /g; s/ *$//')
        used_bytes=$(echo "$budget_str" | grep -oE 'used[= ]+[0-9]+' | head -1 | grep -oE '[0-9]+')
        free_bytes=$(echo "$budget_str" | grep -oE 'free[= ]+[0-9]+' | head -1 | grep -oE '[0-9]+')
        if [ -n "$free_bytes" ] && [ "$free_bytes" -gt 0 ] 2>/dev/null; then
            record_ok "MURAM budget healthy (free=${free_bytes}B used=${used_bytes:-?}B)"
            note "$budget_str"
            if ! echo "$last_xition" | grep -q ENGAGED \
               && [ -n "${used_bytes:-}" ] && [ "$used_bytes" -gt 4096 ] 2>/dev/null; then
                record_warn "MURAM used=${used_bytes}B while offload is OFF — possible leaked teardown"
                note "pcd-snapshot diff vs the boot baseline is the authoritative check"
            fi
        else
            record_fail "MURAM budget exhausted (free=0) — no room to program offloaded flows"
            note "$budget_str"
        fi
    else
        record_fail "$PCD_DBGFS present but no readable muram_budget node"
    fi
else
    record_fail "FMan PCD subsystem absent — $PCD_DBGFS missing"
    note "needs CONFIG_FSL_FMAN_PCD=y"
fi

# The four PCD engines must each export their programming API. Symbol names are
# the kernel-internal API ask.ko calls to program the silicon.
if [ -z "$KALLSYMS" ]; then
    record_skip "kallsyms unreadable — cannot probe PCD engine APIs (re-run with sudo)"
else
    pcd_engines=(
        "KeyGen (flow distribution):fman_pcd_kg_scheme_create fman_pcd_kg_port_attach_cc fman_pcd_kg_port_attach_policer"
        "Coarse Classification:fman_pcd_cc_static_install fman_cc_tree_install fman_pcd_cc_static_get_base"
        "Header Manipulation:fman_pcd_hm_install fman_hm_node_install fman_hm_nexthop_get"
        "Policer:fman_policer_install fman_pcd_plcr_install fman_policer_caps_supported"
        "Port primitives:fman_port_set_cc_base fman_port_set_rx_bpool fman_pcd_port_ensure_params_page"
    )
    for grp in "${pcd_engines[@]}"; do
        gname="${grp%%:*}"; gsyms="${grp#*:}"
        missing=""
        for s in $gsyms; do has_sym "$s" || missing="$missing $s"; done
        if [ -z "$missing" ]; then
            record_ok "PCD engine: $gname"
        else
            record_fail "PCD engine incomplete — $gname missing:$missing"
        fi
    done
fi

# ===========================================================================
# 3. Reversible mode switch — turning ASK on/off must not require a reboot
# ===========================================================================
hdr "3) Reversible offload mode switch"

# The coarse engage/disengage entry point ask.ko (and the operator CLI) call to
# move a port between the kernel dataplane and the ASK dataplane.
if [ -z "$KALLSYMS" ]; then
    record_skip "kallsyms unreadable — cannot confirm the offload engage/disengage API"
elif has_sym fman_pcd_offload_engage && has_sym fman_pcd_offload_disengage; then
    record_ok "offload engage/disengage API present (fman_pcd_offload_engage/_disengage)"
else
    record_fail "offload engage/disengage API missing — ASK cannot be turned on/off at runtime"
fi

# The snapshot verifier proves a disable returns the silicon to a register-exact
# copy of the offload-off state (the reversibility contract). Without it there is
# no way to certify that disabling ASK left no residue.
if command -v pcd-snapshot >/dev/null 2>&1; then
    record_ok "pcd-snapshot reversibility verifier installed"
    note "capture the offload-off baseline at boot; diff after every disable — must match"
else
    record_fail "pcd-snapshot not installed — offload reversibility cannot be verified"
fi

# ===========================================================================
# 4. Hardware classification — the engine that dispositions a classified frame
# ===========================================================================
hdr "4) Hardware classification engine (external-hash / FE)"

# The external-hash + flow-entry engine is what gives a classified frame its
# terminal hardware disposition (forward, NAT, drop) instead of falling back to
# software. Its DDR/MURAM structures are exposed as read-only inspector nodes;
# all of them must be present for hardware classification to work, and the
# engine must actually disposition frames — proven by an engaged port carrying
# traffic without it reappearing in the kernel's software path.
if [ ! -d /sys/kernel/debug ] || { [ "$(id -u)" -ne 0 ] && [ ! -r /sys/kernel/debug ]; }; then
    record_skip "debugfs unreadable — re-run with sudo to inspect the classification engine"
else
    inst_dir=$(find "$PCD_DBGFS" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | head -1)
    if [ -z "$inst_dir" ]; then
        record_fail "no PCD instance — cannot locate the classification engine"
    else
        # Inspector nodes for the engine's structures: object pool, per-port
        # support, the shared FE singletons, the external-hash table, the
        # per-flow entries, the classifier->FE root link, and the flow store.
        fe_present=0 fe_total=0 fe_missing=""
        for node in fe_pool fe_port fe_singletons fe_ehash fe_enq fe_enter fe_flow; do
            fe_total=$((fe_total+1))
            if [ -e "$inst_dir/$node" ]; then
                fe_present=$((fe_present+1))
            else
                fe_missing="$fe_missing $node"
            fi
        done
        if [ "$fe_present" -eq "$fe_total" ]; then
            record_ok "classification engine structures present ($fe_total/$fe_total)"
        elif [ "$fe_present" -gt 0 ]; then
            record_fail "classification engine incomplete ($fe_present/$fe_total) — missing:$fe_missing"
        else
            record_fail "classification engine absent — hardware classify is not built in"
        fi

        # The classifier-to-FE root link must be armed for a classified frame to
        # actually reach the engine. The inspector reports whether it is wired.
        if [ -r "$inst_dir/fe_enter" ]; then
            if grep -qiE 'armed|root.*0x[1-9a-f]|enter.*[1-9]' "$inst_dir/fe_enter" 2>/dev/null; then
                record_ok "classifier->FE root link armed"
            else
                record_fail "classifier->FE root link not armed — classified frames have no disposition"
                note "this is the gate to a working ASK datapath; until it is armed no flow offloads"
            fi
        fi
    fi
fi

# ===========================================================================
# 5. Hardware forwarding — inline L3 next-hop rewrite
# ===========================================================================
hdr "5) Hardware forwarding (L3 next-hop rewrite)"

if [ -z "$KALLSYMS" ]; then
    record_skip "kallsyms unreadable — cannot probe the forwarding op-set"
else
    if has_sym fman_hm_nexthop_get && has_sym fman_hm_nexthop_put; then
        record_ok "next-hop rewrite cache present (de-dups L2 rewrite per adjacency)"
    else
        record_fail "next-hop rewrite cache missing — per-flow rewrite would exhaust MURAM"
    fi
    if has_sym dpaa_get_rx_fman_port && has_sym dpaa_get_tx_fqid; then
        record_ok "netdev->hardware-id resolvers present (maps a route to its FMan port/FQ)"
    else
        record_fail "netdev->hardware-id resolvers missing — ask.ko cannot target a forward"
    fi
fi

# ===========================================================================
# 6. Control-plane module — ask.ko
# ===========================================================================
hdr "6) Control-plane module (ask.ko)"

if [ -d /sys/module/ask ]; then
    record_ok "ask.ko loaded"
    [ -r /sys/module/ask/version ]    && note "version    = $(cat /sys/module/ask/version 2>/dev/null)"
    [ -r /sys/module/ask/srcversion ] && note "srcversion = $(cat /sys/module/ask/srcversion 2>/dev/null)"
    [ -r /sys/module/ask/refcnt ]     && note "refcnt     = $(cat /sys/module/ask/refcnt 2>/dev/null)"
else
    kver=$(uname -r)
    if find "/lib/modules/$kver" -name 'ask.ko*' 2>/dev/null | grep -q .; then
        record_fail "ask.ko installed but not loaded — try: modprobe ask"
        [ -f /etc/modules-load.d/ask.conf ] || note "missing /etc/modules-load.d/ask.conf auto-load drop-in"
    else
        record_fail "ask.ko not installed — the ASK control plane is absent"
    fi
fi

# The generic-netlink family is the control-plane RPC surface (flow table query,
# events). It must be registered for any management tooling to reach ASK.
if command -v genl >/dev/null 2>&1; then
    if [ "$(id -u)" -ne 0 ]; then
        record_skip "genl ctrl list requires root — re-run with sudo to probe the 'ask' genl family"
    else
        ask_id=$(genl ctrl list 2>/dev/null | awk '/^Name: ask$/ { getline; if ($1=="ID:") { print $2; exit } }')
        if [ -n "$ask_id" ]; then
            record_ok "'ask' generic-netlink family registered (id $ask_id)"
        else
            record_fail "'ask' generic-netlink family not registered — control plane unreachable"
        fi
    fi
else
    record_skip "iproute2 'genl' not installed — cannot probe the genl family"
fi

# The flow table — the live set of offloaded flows — must be inspectable.
ASK_DBGFS="/sys/kernel/debug/ask"
dbg_state "$ASK_DBGFS"; rc=$?
if [ "$rc" -eq 0 ]; then
    record_ok "ask.ko debugfs interface present at $ASK_DBGFS"
    [ -e "$ASK_DBGFS/offload" ] \
        && note "offload control node present (engage/disengage a port)" \
        || record_fail "offload control node missing — cannot drive the mode switch from ask.ko"
elif [ "$rc" -eq 2 ]; then
    record_skip "$ASK_DBGFS not statable unprivileged — re-run with sudo"
elif [ -d /sys/module/ask ]; then
    record_fail "ask.ko loaded but $ASK_DBGFS absent — debugfs interface not built"
fi

# L2 switchdev offload (bridged flows in hardware).
if [ -d /sys/module/ask_bridge ]; then
    record_ok "ask_bridge.ko loaded (L2 switchdev offload)"
else
    record_fail "ask_bridge.ko not loaded — bridged/L2 flows will not offload"
fi

# ===========================================================================
# 7. Hardware IPsec offload (ESP packet-mode via CAAM)
# ===========================================================================
hdr "7) Hardware IPsec offload (ESP via CAAM)"

# CAAM (the SEC crypto block) must be healthy and share descriptors with the
# FMan-initiated dequeue path, and each FMan netdev must advertise ESP offload.
if command -v caam-check >/dev/null 2>&1; then
    if caam-check >/dev/null 2>&1; then
        record_ok "CAAM healthy (Job Rings / RNG / kernel crypto) — see caam-check for detail"
    else
        record_fail "CAAM unhealthy — run 'caam-check'; IPsec offload is impossible without it"
    fi
elif [ -d /sys/bus/platform/drivers/caam_jr ]; then
    jrs=$(find /sys/bus/platform/drivers/caam_jr -maxdepth 1 -type l \
          ! -name bind ! -name unbind ! -name uevent ! -name module 2>/dev/null | wc -l)
    [ "$jrs" -gt 0 ] && record_ok "$jrs CAAM Job Ring(s) bound" \
                     || record_fail "no CAAM Job Rings bound — IPsec offload impossible"
else
    record_fail "caam_jr driver absent — no hardware crypto"
fi

# Descriptor-sharing hook so FMan-dequeued frames reach SEC without the CPU.
if [ -n "$KALLSYMS" ]; then
    has_sym caam_qi_ext_consumer_register \
        && record_ok "CAAM descriptor-sharing API present (FMan->SEC offload hook)" \
        || record_fail "CAAM descriptor-sharing API missing — ASK cannot offload IPsec to SEC"
fi

# ESP packet-mode offload advertised on the FMan netdevs.
if [ "${#DPAA_NETDEVS[@]}" -gt 0 ] && command -v ethtool >/dev/null 2>&1; then
    iface="${DPAA_NETDEVS[0]}"
    esp_off=$(ethtool -k "$iface" 2>/dev/null | awk -F: '/^esp-hw-offload/ {gsub(/ /,"",$2); print $2}')
    case "$esp_off" in
        on|"on[fixed]") record_ok "$iface advertises ESP hardware offload (esp-hw-offload=$esp_off)" ;;
        *)              record_fail "$iface does not advertise ESP hardware offload (esp-hw-offload=${esp_off:-absent})" ;;
    esac
else
    record_skip "no DPAA netdevs or ethtool — cannot probe ESP offload advertisement"
fi

# ===========================================================================
# 8. Operator CLI — 'set system offload ask'
# ===========================================================================
hdr "8) Operator CLI ('set system offload ask')"

# The ASK enable/per-port CLI, and the validator that keeps ASK and VPP from
# both claiming a port. Probe specifically for the 'ask' leaf so the unrelated
# stock 'system offload classify' subtree does not false-positive.
if [ -d /opt/vyatta/share/vyatta-cfg/templates/system/offload/ask ] \
   || find /usr/libexec/vyos/conf_mode -maxdepth 1 -name 'system_offload*ask*' 2>/dev/null | grep -q . \
   || (command -v cli-shell-api >/dev/null 2>&1 && cli-shell-api existsActive system offload ask 2>/dev/null); then
    record_ok "'set system offload ask' CLI present"
    note "the validator must keep ASK and VPP mutually exclusive on any port"
else
    record_fail "'set system offload ask' CLI absent — operator cannot enable ASK"
    note "('system offload classify' is a different, unrelated feature)"
fi

# ===========================================================================
# 9. dmesg integrity
# ===========================================================================
hdr "9) dmesg integrity (datapath errors / stalls / leaks)"

ASK_DMESG=$(echo "$DMESG" | grep -iE 'ask hw:|ask:|ask_bridge|fman_pcd|fman.*fe[-_]|caam_qi_ext|offload (EN|DIS)' || true)
if [ -z "$ASK_DMESG" ]; then
    record_warn "no ASK-related lines in dmesg (ring buffer may have wrapped)"
else
    errs=$(echo "$ASK_DMESG" \
        | grep -iE 'error|failed|cannot|unable|refused|denied|invalid|-ENOMEM|EOPNOTSUPP|stall|park|drift|leak' \
        | grep -ivE 'refusing to load.*ucode' || true)
    if [ -z "$errs" ]; then
        record_ok "no error-class lines in the ASK dmesg trail ($(echo "$ASK_DMESG" | wc -l) line(s))"
    else
        record_fail "$(echo "$errs" | wc -l) error-class line(s) in the ASK dmesg trail:"
        echo "$errs" | head -8 | while IFS= read -r l; do note "$l"; done
    fi
    echo "$ASK_DMESG" | grep -iE 'registered|MURAM|ucode|engaged|disengaged' \
        | head -6 | while IFS= read -r l; do note "$l"; done
fi

# ===========================================================================
# Summary
# ===========================================================================
hdr "Summary"

total=$((N_OK + N_WARN + N_FAIL + N_SKIP))
printf "  %3d/%3d %sOK%s  " "$N_OK" "$total" "$C_GREEN" "$C_RST"
printf "%3d %sWARN%s  "     "$N_WARN" "$C_YELLOW" "$C_RST"
printf "%3d %sFAIL%s  "     "$N_FAIL" "$C_RED"    "$C_RST"
printf "%3d %sSKIP%s\n"     "$N_SKIP" "$C_BLUE"   "$C_RST"
echo
note "FAIL = a capability the ASK dataplane requires is missing or broken here"
note "SKIP = could not be tested in this environment (privilege / tool / board)"

if [ "$EXIT" = "0" ]; then
    ok "ASK hardware-offload dataplane is OPERATIONAL"
else
    fail "ASK hardware-offload dataplane is NOT operational ($N_FAIL capability gap(s))"
fi

exit "$EXIT"
