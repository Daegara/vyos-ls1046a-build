#!/usr/bin/env bash
# ask-check — exercise the full ASK2 fast-path chain on the LS1046A
# Mono Gateway DK.
#
# Usage:   ask-check
#
# ASK2 (modern rewrite, specs/ask2-rewrite-spec.md v1.1) is a stack of
# four in-tree kernel patches plus one out-of-tree kernel module plus a
# userspace daemon plus a CLI plus a per-VyOS-config glue layer. This
# script probes every layer from silicon up to operator surface, in the
# same order ASK2 brings itself up at boot:
#
#   1. Flavor / kernel posture
#   2. In-tree patches landed (0001 caam-qi-share, 0002 dpaa-eth-flow-block,
#      0003 fman-host-command-api, 0004 fman-pcd-subsystem)
#   3. ask.ko (genl_family "ask", debugfs, rhashtable, flow_block_cb)
#   4. ask_bridge.ko (switchdev notifier)
#   5. FMan PCD subsystem (MURAM budget, KeyGen/CC/Manip/Plcr/Replic/Prs APIs)
#   6. CAAM QI sharing (descriptor share API exposed for ask.ko)
#   7. dpaa-eth flow_block (NETIF_F_HW_TC on FMan netdevs)
#   8. xfrm offload (ESP packet-mode bind on FMan netdevs)
#   9. askd userspace daemon (sd_notify, /run/askd.sock, Varlink)
#  10. ask-cli operator tool
#  11. nf_flow_table HW-offload round trip (nft 'flags offload' acceptance)
#  12. dmesg integrity (no fman_pcd / ask_* / caam_qi errors)
#
# As of 2026-05-14 the ASK2 PR stack is mid-flight (per
# plans/ASK2-IMPLEMENTATION.md): PR1–PR14h have landed (kernel-side
# scaffolding, genl skeleton, flow_block_cb stubs, all PCD prep/body
# patches, CAAM/DPAA/FMan kernel patches, MURAM budget probe), but the
# end-to-end wire-up PR14g is split into 5 sub-PRs landing sequentially
# and gates PR15–PR21 (askd, ask-cli, VyOS CLI integration, xfrm
# offload, remaining flow types). Tests covering not-yet-landed
# milestones are written here on purpose — they fail today and will
# pass as the work proceeds. Each failure points to the PR row that
# would deliver it.
#
# Tags:
#   [OK]    — component is present and healthy
#   [WARN]  — present but degraded or running stub
#   [FAIL]  — component is expected at this milestone and is missing
#   [SKIP]  — out of scope (wrong flavor, kernel cmdline, or board)
#   [TODO]  — feature gated on a PR not yet landed; expected to fail
#
# Exit codes:
#   0  — ASK2 fast path is fully healthy (all [OK], no [FAIL])
#   1  — at least one [FAIL]: a milestone the current PR stack should
#        deliver did not deliver it
#   2  — not an LS1046A board (sysfs paths absent)
#   3  — FLAVOR != ask (no point running this test)

set -u

# ---------------------------------------------------------------------------
# Colour escapes (TTY only). Same convention as caam-check / fan-check.
# ---------------------------------------------------------------------------
if [ -t 1 ] && [ "${TERM:-dumb}" != "dumb" ]; then
    C_RST=$'\033[0m'
    C_BOLD=$'\033[1m'
    C_DIM=$'\033[2m'
    C_GREEN=$'\033[1;32m'
    C_YELLOW=$'\033[1;33m'
    C_RED=$'\033[1;31m'
    C_BLUE=$'\033[1;34m'
    C_MAGENTA=$'\033[1;35m'
else
    C_RST='' C_BOLD='' C_DIM='' C_GREEN='' C_YELLOW='' C_RED='' C_BLUE='' C_MAGENTA=''
fi

ok()    { printf "  [%sOK%s]   %s\n"   "$C_GREEN"   "$C_RST" "$*"; }
warn()  { printf "  [%sWARN%s] %s\n"   "$C_YELLOW"  "$C_RST" "$*"; }
fail()  { printf "  [%sFAIL%s] %s\n"   "$C_RED"     "$C_RST" "$*"; }
skip()  { printf "  [%sSKIP%s] %s\n"   "$C_BLUE"    "$C_RST" "$*"; }
todo()  { printf "  [%sTODO%s] %s\n"   "$C_MAGENTA" "$C_RST" "$*"; }
note()  { printf "         %s%s%s\n"   "$C_DIM"    "$*"     "$C_RST"; }
hdr()   { printf "\n%s%s%s\n"          "$C_BOLD"   "$*"     "$C_RST"; }

EXIT=0
N_OK=0 N_WARN=0 N_FAIL=0 N_SKIP=0 N_TODO=0

# Wrap result emitters so we can count.
record_ok()   { ok   "$@"; N_OK=$((N_OK+1));   }
record_warn() { warn "$@"; N_WARN=$((N_WARN+1)); }
record_fail() { fail "$@"; N_FAIL=$((N_FAIL+1)); EXIT=1; }
record_skip() { skip "$@"; N_SKIP=$((N_SKIP+1)); }
record_todo() { todo "$@"; N_TODO=$((N_TODO+1)); }

# ---------------------------------------------------------------------------
# Board gate
# ---------------------------------------------------------------------------
if [ ! -f /proc/device-tree/compatible ] \
   || ! tr '\0' '\n' < /proc/device-tree/compatible | grep -q 'fsl,ls1046a'; then
    echo "ask-check: not LS1046A — nothing to report" >&2
    exit 2
fi

# ---------------------------------------------------------------------------
# Header
# ---------------------------------------------------------------------------
hostname_str=$(hostname 2>/dev/null || echo "?")
kernel_str=$(uname -r 2>/dev/null || echo "?")
printf "%sask-check%s  host=%s  kernel=%s  %s\n" \
    "$C_BOLD" "$C_RST" "$hostname_str" "$kernel_str" "$(date -u +'%Y-%m-%dT%H:%M:%SZ')"
note "spec: specs/ask2-rewrite-spec.md v1.1  |  plan: plans/ASK2-IMPLEMENTATION.md"

# ---------------------------------------------------------------------------
# Cached state
# ---------------------------------------------------------------------------
DMESG=$(dmesg 2>/dev/null || true)
LSMOD=$(lsmod 2>/dev/null || true)
KALLSYMS=""
# Reading /proc/kallsyms unprivileged returns zeros for symbol addresses
# but the names are still visible — enough for presence detection.
if [ -r /proc/kallsyms ]; then
    KALLSYMS=$(cat /proc/kallsyms 2>/dev/null || true)
fi

has_sym()    { [ -n "$KALLSYMS" ] && echo "$KALLSYMS" | awk '{print $3}' | grep -qx "$1"; }
has_mod()    { echo "$LSMOD" | awk '{print $1}' | grep -qx "$1"; }
dmesg_has()  { echo "$DMESG" | grep -qE "$1"; }

# Reference manual: 4 in-tree patches + 1 OOT module + userspace.
note "ASK2 stack: 4 in-tree patches + ask.ko/ask_bridge.ko + askd + ask-cli"

# ---------------------------------------------------------------------------
# 1. In-tree patches landed (kernel-side scaffolding from PR10–PR14h)
# ---------------------------------------------------------------------------
hdr "1) In-tree kernel patches landed"

# --- Patch 0001 caam-qi-share-descriptors (PR10) ---
# Exposes caam_qi_ext_consumer_register/release so ask.ko can share AEAD
# descriptors with FMan-initiated dequeues. Symbol exported GPL.
if has_sym caam_qi_ext_consumer_register; then
    record_ok "0001-caam-qi-share-descriptors.patch (caam_qi_ext_consumer_register exported)"
elif [ -n "$KALLSYMS" ]; then
    record_fail "0001-caam-qi-share patch missing — caam_qi_ext_consumer_register absent from kallsyms"
    note "PR10 expected this; verify caam_qi.ko built-in or autoloaded"
else
    record_warn "/proc/kallsyms unreadable — cannot probe for caam_qi_ext_consumer_register"
    note "re-run with CAP_SYSLOG (sudo ask-check) for symbol-level checks"
fi

# --- Patch 0002 dpaa-eth-flow-block (PR11) ---
# Registers flow_block_cb on dpaa_eth netdevs so nf_flow_table can offload.
# Exposed via NETIF_F_HW_TC feature bit on the netdev + setup_tc op.
DPAA_NETDEVS=()
for dev in /sys/class/net/*/device/of_node; do
    [ -L "$dev" ] || continue
    target=$(readlink -f "$dev" 2>/dev/null || true)
    case "$target" in
        */fman*|*/ethernet@*) DPAA_NETDEVS+=("$(basename "$(dirname "$(dirname "$dev")")")") ;;
    esac
done
if [ "${#DPAA_NETDEVS[@]}" -gt 0 ]; then
    record_ok "${#DPAA_NETDEVS[@]} FMan/DPAA netdev(s) present: ${DPAA_NETDEVS[*]}"
    # Pick the first DPAA netdev and probe its hw-tc-offload feature.
    probe="${DPAA_NETDEVS[0]}"
    if command -v ethtool >/dev/null 2>&1; then
        tc_off=$(ethtool -k "$probe" 2>/dev/null | awk -F: '/hw-tc-offload/ {gsub(/ /,"",$2); print $2}')
        case "$tc_off" in
            on)           record_ok "0002-dpaa-eth-flow-block.patch ($probe hw-tc-offload=on)" ;;
            off)          record_warn "0002 patch present but $probe hw-tc-offload=off (enable with ethtool -K $probe hw-tc-offload on)" ;;
            "on[fixed]")  record_ok "0002 patch landed and locked on ($probe hw-tc-offload=on [fixed])" ;;
            "off[fixed]") record_fail "0002 patch missing — $probe hw-tc-offload=off [fixed]" ;;
            *)            record_warn "0002 status indeterminate — ethtool -k $probe hw-tc-offload reports '$tc_off'" ;;
        esac
    else
        record_skip "ethtool not installed — cannot probe hw-tc-offload on $probe"
    fi
else
    record_fail "no DPAA/FMan netdevs found — DPAA1 stack did not initialise"
    note "AGENTS.md: 'fsl_dpa' driver creates eth0..ethN under fsl_dpaa_mac parents"
fi

# --- Patch 0003 fman-host-command-api (PR12) ---
# Exposes fmd_host_cmd() as a kernel-internal API used by ask.ko.
if has_sym fmd_host_cmd; then
    record_ok "0003-fman-host-command-api.patch (fmd_host_cmd exported)"
elif [ -n "$KALLSYMS" ]; then
    record_warn "0003 patch landed per PR12 but fmd_host_cmd not exported — possibly EXPORT_SYMBOL_GPL only and module not loaded yet"
    note "stock QEF 210.10.1 ucode does not use this opcode-dispatch path; this is future infrastructure"
else
    record_skip "/proc/kallsyms unreadable — cannot probe for fmd_host_cmd"
fi

# --- Patch 0004 fman-pcd-subsystem (PR14a-f) ---
# Modern PCD reimplementation: KeyGen, CC, Manip, Plcr, Replic, Prs.
# Surfaces:
#   - /sys/kernel/debug/fman_pcd/muram_budget                  (PR14a)
#   - exported symbols fman_pcd_keygen_*  (PR14b body)
#   - exported symbols fman_pcd_cc_*       (PR14c body)
#   - exported symbols fman_pcd_manip_*    (PR14d body)
#   - exported symbols fman_pcd_plcr_*     (PR14e body)
#   - exported symbols fman_pcd_replic_*   (PR14f body)
#   - fman_pcd_from_of_node                (PR14g-prep)
PCD_DBGFS="/sys/kernel/debug/fman_pcd"
if [ -d "$PCD_DBGFS" ]; then
    record_ok "0004 PCD debugfs root present at $PCD_DBGFS"
    if [ -r "$PCD_DBGFS/muram_budget" ]; then
        budget_str=$(cat "$PCD_DBGFS/muram_budget" 2>/dev/null | tr '\n' ' ' | sed 's/ *$//')
        free_bytes=$(echo "$budget_str" | grep -oE 'free=[0-9]+' | head -1 | cut -d= -f2)
        if [ -n "$free_bytes" ] && [ "$free_bytes" -gt 0 ] 2>/dev/null; then
            record_ok "muram_budget free=${free_bytes} bytes"
            note "$budget_str"
        else
            record_warn "muram_budget present but free=0 — silicon may be wedged or budget too tight"
            note "PR14h reduced FMAN_PCD_MURAM_RESERVED_BYTES — confirm RESERVED < total"
        fi
    else
        record_warn "$PCD_DBGFS exists but muram_budget unreadable (mount debugfs as root)"
    fi
else
    if [ ! -d /sys/kernel/debug ]; then
        record_skip "debugfs not mounted — mount -t debugfs none /sys/kernel/debug to probe PCD"
    else
        record_fail "0004-fman-pcd-subsystem.patch missing — $PCD_DBGFS absent"
        note "PR14a was expected to create this — check kernel config CONFIG_FSL_FMAN_PCD=y"
    fi
fi

# Per-component PCD exported symbols (each gates one sub-PR).
# Symbol names match the actual landed exports (see __ksymtab_* in System.map).
for sym_pr in \
    "fman_pcd_kg_scheme_create:14b" \
    "fman_pcd_cc_node_create:14c" \
    "fman_pcd_manip_create:14d" \
    "fman_pcd_plcr_profile_create:14e" \
    "fman_pcd_replic_group_create:14f" \
    "fman_pcd_from_of_node:14g-prep" ; do
    sym="${sym_pr%:*}"
    pr="${sym_pr#*:}"
    if has_sym "$sym"; then
        record_ok "PR${pr} symbol present: $sym"
    elif [ -z "$KALLSYMS" ]; then
        : # already warned once
    else
        record_fail "PR${pr} symbol missing: $sym"
    fi
done

# ---------------------------------------------------------------------------
# 2. ask.ko — the OOT module
# ---------------------------------------------------------------------------
hdr "2) ask.ko (out-of-tree kernel module)"

if [ -d /sys/module/ask ]; then
    record_ok "/sys/module/ask present"
    if [ -r /sys/module/ask/version ]; then
        note "version = $(cat /sys/module/ask/version 2>/dev/null)"
    fi
    if [ -r /sys/module/ask/refcnt ]; then
        note "refcnt = $(cat /sys/module/ask/refcnt 2>/dev/null)"
    fi
    if [ -r /sys/module/ask/srcversion ]; then
        note "srcversion = $(cat /sys/module/ask/srcversion 2>/dev/null)"
    fi
else
    record_fail "ask.ko not loaded — /sys/module/ask absent"
    note "PR1 module skeleton landed; PR14g end-to-end wire-up gates production load"
    note "try: modprobe ask  (will fail with EOPNOTSUPP if PR14g not landed)"
fi

# Module parameters (Section 3.2). Whichever module params are exposed
# should at minimum cover debugfs depth and stats interval.
if [ -d /sys/module/ask/parameters ]; then
    pcount=$(ls /sys/module/ask/parameters 2>/dev/null | wc -l)
    note "$pcount module parameter(s) exposed"
fi

# genl_family registered (Section 7.1).
if command -v genl >/dev/null 2>&1; then
    if genl ctrl-list 2>/dev/null | grep -qw 'ask'; then
        family_id=$(genl ctrl-list 2>/dev/null | awk '/ Name: ask/ {print "found"; exit}')
        record_ok "genl_family 'ask' registered"
    else
        record_fail "genl_family 'ask' not registered (PR5 GET_INFO should give this)"
    fi
elif command -v ynl >/dev/null 2>&1; then
    # Modern probe path
    if ynl --family ask --do get-info 2>/dev/null | grep -qE 'ucode|version'; then
        record_ok "genl_family 'ask' responds to GET_INFO via ynl"
    else
        record_fail "genl_family 'ask' present but GET_INFO not responding"
    fi
else
    record_skip "neither 'genl' (iproute2) nor 'ynl' installed — cannot probe genl family"
fi

# Multicast groups (Section 7.1).
if [ -r /proc/net/netlink ]; then
    # Each multicast group registration shows up as a kernel listener on
    # the GENERIC netlink family (proto 16).
    nl_listeners=$(awk '$2 == "16"' /proc/net/netlink 2>/dev/null | wc -l)
    note "/proc/net/netlink: $nl_listeners GENERIC-netlink listener(s)"
fi

# debugfs surfaces (Section 3.2 ask_debugfs.c).
ASK_DBGFS="/sys/kernel/debug/ask"
if [ -d "$ASK_DBGFS" ]; then
    record_ok "ask.ko debugfs root present at $ASK_DBGFS"
    for f in flow_table muram stats events; do
        if [ -e "$ASK_DBGFS/$f" ]; then
            ok "  $ASK_DBGFS/$f"
        else
            warn "  $ASK_DBGFS/$f missing (subset of ask_debugfs.c not yet wired)"
        fi
    done
else
    if [ -d /sys/kernel/debug ] && [ -d /sys/module/ask ]; then
        record_warn "ask.ko loaded but $ASK_DBGFS absent — CONFIG_ASK_DEBUG=n in build?"
    elif [ ! -d /sys/kernel/debug ]; then
        record_skip "debugfs not mounted — cannot inspect $ASK_DBGFS"
    fi
fi

# kunit tests (PR4 harness, PR9 ≥ 80% coverage).
KUNIT_DIR="/sys/kernel/debug/kunit"
if [ -d "$KUNIT_DIR" ]; then
    ask_kunit=$(find "$KUNIT_DIR" -maxdepth 2 -name 'results' 2>/dev/null | xargs -r grep -l ask 2>/dev/null | head -1)
    if [ -n "$ask_kunit" ]; then
        if grep -q '^ok' "$ask_kunit" 2>/dev/null && ! grep -q '^not ok' "$ask_kunit" 2>/dev/null; then
            record_ok "kunit ask suite: all passing"
        else
            record_warn "kunit ask suite present but contains 'not ok' lines"
            grep -E '^(not |)ok' "$ask_kunit" 2>/dev/null | head -5 | while IFS= read -r l; do note "$l"; done
        fi
    else
        note "kunit harness present but no ask suite results — load kunit_ask module or rerun KUNIT_ALL_TESTS=y"
    fi
fi

# ---------------------------------------------------------------------------
# 3. ask_bridge.ko — switchdev notifier for L2 fast path
# ---------------------------------------------------------------------------
hdr "3) ask_bridge.ko (switchdev notifier)"

if [ -d /sys/module/ask_bridge ]; then
    record_ok "/sys/module/ask_bridge present"
elif [ -d /sys/module/ask ]; then
    record_todo "ask_bridge.ko not loaded — PR15 (M3 remaining flow types) gated on PR14g"
    note "L2 bridge fast-path is part of milestone M3, not M1"
else
    record_skip "ask.ko itself not loaded — ask_bridge depends on it"
fi

# ---------------------------------------------------------------------------
# 4. CAAM crypto / IPsec offload prerequisites
# ---------------------------------------------------------------------------
hdr "4) CAAM prerequisites (delegated to caam-check)"

if command -v caam-check >/dev/null 2>&1; then
    if caam-check >/dev/null 2>&1; then
        record_ok "caam-check passed — CAAM Job Rings, RNG, kernel crypto all healthy"
    else
        record_warn "caam-check reports CAAM problems — run 'caam-check' directly for details"
        note "ASK2 IPsec offload (PR16) requires caam_qi.ko healthy"
    fi
else
    # Inline minimum check: JR driver bound to at least one device.
    if [ -d /sys/bus/platform/drivers/caam_jr ]; then
        jrs=$(find /sys/bus/platform/drivers/caam_jr -maxdepth 1 -type l \
              ! -name bind ! -name unbind ! -name uevent ! -name module 2>/dev/null | wc -l)
        if [ "$jrs" -gt 0 ]; then
            record_ok "$jrs CAAM Job Ring(s) bound"
        else
            record_fail "no CAAM Job Rings bound — IPsec offload impossible"
        fi
    else
        record_fail "caam_jr driver absent"
    fi
fi

# ---------------------------------------------------------------------------
# 5. xfrm packet-mode offload (PR16)
# ---------------------------------------------------------------------------
hdr "5) xfrm packet-mode offload (ESP)"

# Each FMan netdev should expose xdo_dev_state_add when ask.ko has
# registered xfrmdev_ops on it. Check via NETIF_F_HW_ESP feature bit.
if [ "${#DPAA_NETDEVS[@]}" -gt 0 ] && command -v ethtool >/dev/null 2>&1; then
    iface="${DPAA_NETDEVS[0]}"
    esp_off=$(ethtool -k "$iface" 2>/dev/null | awk -F: '/^esp-hw-offload/ {gsub(/ /,"",$2); print $2}')
    case "$esp_off" in
        on|"on[fixed]")   record_ok "$iface esp-hw-offload=on" ;;
        off)              record_todo "$iface esp-hw-offload=off — PR16 (ask_xfrm.c) gated on PR14g" ;;
        "off[fixed]")     record_todo "$iface esp-hw-offload=off [fixed] — xfrmdev_ops not yet registered" ;;
        *)                record_todo "esp-hw-offload feature not exposed — milestone M4 not started" ;;
    esac
else
    record_skip "no DPAA netdevs or ethtool — cannot probe xfrm offload state"
fi

# ---------------------------------------------------------------------------
# 6. askd userspace daemon (PR17 — gated on PR14g)
# ---------------------------------------------------------------------------
hdr "6) askd daemon (userspace promotion engine)"

if [ -x /usr/bin/askd ] || [ -x /usr/local/bin/askd ]; then
    record_ok "askd binary installed"
    # Service status
    if systemctl --quiet is-active askd.service 2>/dev/null; then
        record_ok "askd.service is active (running)"
        # Type=notify means sd_notify(READY=1) was received.
        sd_status=$(systemctl show -p Status askd.service 2>/dev/null | cut -d= -f2-)
        [ -n "$sd_status" ] && note "Status = $sd_status"
    elif systemctl list-unit-files 2>/dev/null | grep -qE '^askd\.service'; then
        record_warn "askd.service unit installed but not active"
        note "try: systemctl start askd  (or check 'systemctl status askd' for errors)"
    else
        record_warn "askd binary installed but no askd.service unit — packaging incomplete"
    fi

    # Varlink / control socket
    if [ -S /run/askd.sock ]; then
        record_ok "/run/askd.sock varlink socket present"
        if command -v varlinkctl >/dev/null 2>&1; then
            if varlinkctl info /run/askd.sock 2>/dev/null | grep -q 'io\.askd'; then
                record_ok "varlink io.askd.* interface responds"
            else
                record_warn "/run/askd.sock present but varlink info returned no io.askd interface"
            fi
        else
            note "install systemd's varlinkctl to probe the Varlink interface directly"
        fi
    else
        record_warn "no /run/askd.sock — daemon may have failed to bind"
    fi
else
    record_todo "askd binary not installed — PR17 (M5.1 askd sd-event + libmnl) gated on PR14g"
    note "spec §6: askd is the userspace promotion engine; without it nothing pushes flows"
fi

# ---------------------------------------------------------------------------
# 7. ask-cli operator tool (PR18 — gated on PR14g)
# ---------------------------------------------------------------------------
hdr "7) ask-cli operator tool"

if command -v ask-cli >/dev/null 2>&1; then
    record_ok "ask-cli installed at $(command -v ask-cli)"
    # Smoke: 'ask-cli muram' should print MURAM budget without error.
    if out=$(ask-cli muram 2>/dev/null); then
        record_ok "ask-cli muram responded"
        echo "$out" | head -3 | while IFS= read -r line; do note "$line"; done
    else
        record_warn "ask-cli installed but 'ask-cli muram' failed (askd unreachable?)"
    fi
else
    record_todo "ask-cli not installed — PR18 (M5.2 Python Varlink client) gated on PR14g"
fi

# ---------------------------------------------------------------------------
# 8. VyOS CLI integration (PR19 — gated on PR14g)
# ---------------------------------------------------------------------------
hdr "8) VyOS CLI integration ('set system ask ...')"

# The VyOS interface definition would live under
# /opt/vyatta/share/vyatta-cfg/templates/system/ask/ or equivalent
# interface-definitions XML in /usr/libexec/vyos/conf_mode/system_ask.py.
if [ -d /opt/vyatta/share/vyatta-cfg/templates/system/ask ] \
   || [ -f /usr/libexec/vyos/conf_mode/system_ask.py ] \
   || find /usr/share/vyos -maxdepth 3 -name 'system_ask*' 2>/dev/null | grep -q .; then
    record_ok "VyOS 'system ask' templates / conf_mode glue present"
else
    record_todo "no VyOS 'set system ask' CLI surface yet — PR19 (M5.3) gated on PR14g"
    note "spec §11: target syntax 'set system ask flow-offload enable / ipsec-offload enable'"
fi

# ---------------------------------------------------------------------------
# 9. nf_flow_table HW-offload acceptance smoke test (Section 4, §13.7)
# ---------------------------------------------------------------------------
hdr "9) nf_flow_table HW-offload smoke test"

# This is the spec §13.7 acceptance gate. We don't push real traffic — we
# only check that nftables accepts a flow table with 'flags offload' on a
# DPAA netdev without -EOPNOTSUPP. Adding the flowtable is non-destructive
# if we delete it immediately; we use a unique table name to avoid clashing.
if [ "${#DPAA_NETDEVS[@]}" -eq 0 ]; then
    record_skip "no DPAA netdevs — nft offload test inapplicable"
elif ! command -v nft >/dev/null 2>&1; then
    record_skip "nft not installed — cannot test flow_block acceptance"
elif [ "$(id -u)" -ne 0 ]; then
    record_skip "not root — nft offload test requires CAP_NET_ADMIN (try: sudo ask-check)"
else
    iface="${DPAA_NETDEVS[0]}"
    test_tbl="ask_check_probe_$$"
    nft_script="add table inet $test_tbl
add flowtable inet $test_tbl ft { hook ingress priority 0; devices = { $iface }; flags offload; }
delete table inet $test_tbl"
    err=$(printf '%s\n' "$nft_script" | nft -f - 2>&1)
    rc=$?
    if [ "$rc" -eq 0 ]; then
        record_ok "nft flowtable with 'flags offload' on $iface accepted (flow_block_cb wired)"
    else
        case "$err" in
            *EOPNOTSUPP*|*"Operation not supported"*)
                record_todo "nft 'flags offload' returns EOPNOTSUPP on $iface — PR14g end-to-end wire-up missing"
                note "$err"
                ;;
            *)
                record_fail "nft flowtable smoke test failed: $err"
                ;;
        esac
        # Always try to clean up if the add half-landed.
        nft delete table inet "$test_tbl" 2>/dev/null || true
    fi
fi

# ---------------------------------------------------------------------------
# 10. dmesg integrity
# ---------------------------------------------------------------------------
hdr "10) dmesg integrity (ask / fman_pcd / caam_qi)"

ASK_DMESG=$(echo "$DMESG" | grep -iE 'ask\b|ask_bridge|fman_pcd|caam_qi_share|caam_qi_ext' || true)
if [ -z "$ASK_DMESG" ]; then
    record_warn "no ASK-related lines in dmesg (ring buffer may have wrapped)"
else
    # Count error-level lines (no easy way without dmesg -l err, but we
    # can filter on common error strings).
    errs=$(echo "$ASK_DMESG" | grep -iE 'error|failed|warn|cannot|unable|refused|denied|invalid|EOPNOTSUPP' | grep -ivE 'refusing to load.*ucode' || true)
    if [ -z "$errs" ]; then
        record_ok "no error-class lines in ASK dmesg trail ($(echo "$ASK_DMESG" | wc -l) line(s) total)"
    else
        record_warn "$(echo "$errs" | wc -l) error-class line(s) in ASK dmesg trail:"
        echo "$errs" | head -8 | while IFS= read -r l; do note "$l"; done
    fi
    # Surface the banner / probe lines explicitly.
    echo "$ASK_DMESG" | grep -E 'module loaded|probe|registered|MURAM budget|ucode' | head -6 | \
        while IFS= read -r l; do note "$l"; done
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
hdr "Summary"

total=$((N_OK + N_WARN + N_FAIL + N_SKIP + N_TODO))
printf "  %3d / %3d %sOK%s   "   "$N_OK"   "$total" "$C_GREEN"   "$C_RST"
printf "%3d %sWARN%s   "          "$N_WARN"         "$C_YELLOW"  "$C_RST"
printf "%3d %sFAIL%s   "          "$N_FAIL"         "$C_RED"     "$C_RST"
printf "%3d %sSKIP%s   "          "$N_SKIP"         "$C_BLUE"    "$C_RST"
printf "%3d %sTODO%s\n"           "$N_TODO"         "$C_MAGENTA" "$C_RST"
echo
note "TODO = feature gated on a PR that has not landed yet (see plans/ASK2-IMPLEMENTATION.md)"
note "FAIL = something this milestone's PR set should deliver and didn't"
note "WARN = present but degraded; investigate but not a regression"

if [ "$EXIT" = "0" ] && [ "$N_TODO" -eq 0 ]; then
    ok "ASK2 fast path FULLY OPERATIONAL"
elif [ "$EXIT" = "0" ]; then
    ok "ASK2 fast path operational at the current milestone ($N_TODO TODO remaining)"
else
    fail "ASK2 chain has $N_FAIL regression(s) at the current milestone"
fi

exit "$EXIT"
