diff --git a/src/fm_lib.c b/src/fm_lib.c
index 907d5d4..305dcee 100644
--- a/src/fm_lib.c
+++ b/src/fm_lib.c
@@ -42,6 +42,7 @@
 #include <termios.h>
 #include <sys/ioctl.h>
 #include <stdbool.h>
+#include <stddef.h>     /* offsetof, for ASK B1 ABI bracketed-memcpy */
 
 #include "fm_ext.h"
 #include "fm_pcd_ext.h"
@@ -678,7 +679,53 @@ t_Handle FM_PCD_KgSchemeSet (t_Handle h_FmPcd, t_FmPcdKgSchemeParams *p_Scheme)
 
     _fml_dbg("Calling...\n");
 
-    memcpy(&params, p_Scheme, sizeof(t_FmPcdKgSchemeParams));
+    /* ASK B1 (F01) v2: 3-segment realignment copy.
+     *
+     * Userspace t_FmPcdKgSchemeParams (with ASK `bool shared` ext at offset 16)
+     * vs kernel ioc_fm_pcd_kg_scheme_params_t. Layout:
+     *
+     *           offset    userspace              kernel
+     *               0     bool modify            bool modify
+     *               8     union id               union scm_id
+     *              16     bool shared (ASK)      bool always_direct
+     *              17     bool alwaysDirect      <padding>
+     *              24     netEnvParams.*         net_env_params.*    (8-byte aligned)
+     *
+     * v1 of this fix copied [0..16) head and tail [17..) -> [16..) which
+     * realigned alwaysDirect correctly but shifted netEnvParams.h_NetEnv
+     * (offset 24 on userspace) to kernel offset 23 — pointer misaligned by
+     * one byte. Reproduced as SIGSEGV inside FM_PCD_KgSchemeSet at +0x54
+     * with the corruption fingerprint x2=0x20000aaaaf...
+     *
+     * v2: copy in three segments so 8-byte-aligned fields stay aligned:
+     *   1. [0..16)  head — same on both sides
+     *   2. byte at  userspace 17 -> kernel 16  (alwaysDirect / always_direct)
+     *   3. [24..end) aligned tail starting at netEnvParams / net_env_params
+     */
+    _Static_assert(offsetof(ioc_fm_pcd_kg_scheme_params_t, scm_id) ==
+                       offsetof(t_FmPcdKgSchemeParams, id),
+                   "ASK B1: id/scm_id offset mismatch fmlib vs kernel UAPI");
+    _Static_assert(offsetof(ioc_fm_pcd_kg_scheme_params_t, net_env_params) ==
+                       offsetof(t_FmPcdKgSchemeParams, netEnvParams),
+                   "ASK B1 v2: netEnvParams offset mismatch fmlib vs kernel UAPI");
+    {
+        const size_t head_sz      = offsetof(t_FmPcdKgSchemeParams, shared);
+        const size_t fml_aligned  = offsetof(t_FmPcdKgSchemeParams, netEnvParams);
+        const size_t ioc_aligned  = offsetof(ioc_fm_pcd_kg_scheme_params_t, net_env_params);
+        const size_t ioc_total    = sizeof(ioc_fm_pcd_kg_scheme_params_t);
+        const size_t fml_total    = sizeof(t_FmPcdKgSchemeParams);
+        const size_t aligned_tail = ((ioc_total - ioc_aligned) <
+                                     (fml_total - fml_aligned)) ?
+                                    (ioc_total - ioc_aligned) :
+                                    (fml_total - fml_aligned);
+        memset(&params, 0, sizeof(params));
+        memcpy(&params, p_Scheme, head_sz);
+        ((char*)&params)[offsetof(ioc_fm_pcd_kg_scheme_params_t, always_direct)] =
+            ((const char*)p_Scheme)[offsetof(t_FmPcdKgSchemeParams, alwaysDirect)];
+        memcpy((char*)&params + ioc_aligned,
+               (const char*)p_Scheme + fml_aligned,
+               aligned_tail);
+    }
     params.id = NULL;
 
     if (params.modify)
@@ -1245,7 +1292,30 @@ t_Handle FM_PCD_HashTableSet(t_Handle h_FmPcd, t_FmPcdHashTableParams *p_Param)
 
     _fml_dbg("Calling...\n");
 
-    memcpy(&params, p_Param, sizeof(t_FmPcdHashTableParams));
+    /* ASK B1 (F02) v2: defensive memset+min(sizes) copy. Post-B2 (which
+     * extended the userspace t_FmPcdHashTableParams with agingSupport,
+     * externalHash, externalHashParams to mirror the kernel UAPI), the
+     * field offsets 0..79 are layout-identical between userspace
+     * t_FmPcdHashTableParams (80 B) and kernel
+     * ioc_fm_pcd_hash_table_params_t (88 B). The kernel struct is 8 B
+     * longer because it carries a trailing `void *id` output field that
+     * userspace does not need (the `params.id = NULL` line below is the
+     * canonical zero-init for that slot). min(sizes) = 80 -> we copy the
+     * common prefix and the post-memset zero-init keeps `id` clean.
+     *
+     * NOTE: pre-B2 history. Before B2 the comment claimed "kernel has
+     * none [of the ASK ext fields]" which was wrong — the kernel had
+     * MORE fields (aging_support, external_hash, external_hash_params)
+     * than userspace, in slots that userspace had no symbol to write
+     * into, so fmc could not opt the kernel into ask40's EHASH dispatch.
+     * B2 closed that gap. */
+    {
+        const size_t copy_sz =
+            sizeof(params) < sizeof(t_FmPcdHashTableParams) ?
+            sizeof(params) : sizeof(t_FmPcdHashTableParams);
+        memset(&params, 0, sizeof(params));
+        memcpy(&params, p_Param, copy_sz);
+    }
     params.id = NULL;
 
     if (params.cc_next_engine_params_for_miss.next_engine == e_IOC_FM_PCD_CC &&
