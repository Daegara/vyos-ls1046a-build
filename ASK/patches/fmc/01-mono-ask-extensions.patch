     for (unsigned int i = 0; i < 10; i++)
         classification->frameLength.push_back(i+1);
@@ -578,6 +583,19 @@ CPCDReader::parseClassification( CClassification* classification, xmlNodePtr pNo
         classification->shared = true;
     }
 
+    /* ASK B4: external="yes" routes hash table allocation through EHASH
+     * (DDR-backed via ExternalHashTableSet) instead of MURAM, fixing the
+     * Chain-2-A MURAM exhaustion (fm_cc.c:4842 AllocStatsObjs / :7751
+     * Unexpected NULL Pointer). aging="yes" enables hash entry aging.
+     * table_type names the en_exthash_type enum value (see fm_eh_types.h). */
+    if ( getAttr( pNode, "external" ) == "true" || getAttr( pNode, "external" ) == "yes" ) {
+        classification->externalHash = true;
+    }
+    if ( getAttr( pNode, "aging" ) == "true" || getAttr( pNode, "aging" ) == "yes" ) {
+        classification->agingSupport = true;
+    }
+    classification->tableType = getAttr( pNode, "table_type" );
